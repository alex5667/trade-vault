+      ML_COMMIT_POLICY_COMMIT_STREAM: ${ML_COMMIT_POLICY_COMMIT_STREAM:-stream:ml:recommendation_commit_requests}
+      ML_COMMIT_POLICY_RESULTS_STREAM: ${ML_COMMIT_POLICY_RESULTS_STREAM:-stream:ml:commit_policy_results}
+      ML_COMMIT_POLICY_AUDIT_STREAM: ${ML_COMMIT_POLICY_AUDIT_STREAM:-stream:ml:recommendation_audit}
+      ML_COMMIT_POLICY_GLOBAL_KEY: ${ML_COMMIT_POLICY_GLOBAL_KEY:-cfg:ml:commit_policy:global}
+      ML_COMMIT_POLICY_ACTION_PREFIX: ${ML_COMMIT_POLICY_ACTION_PREFIX:-cfg:ml:commit_policy:action:}
+      ML_COMMIT_POLICY_STATE_PREFIX: ${ML_COMMIT_POLICY_STATE_PREFIX:-state:ml:commit_policy:}
+    ports:
+      - "9858:9858"
+    restart: unless-stopped
+
+  scanner-ml-recommendation-commit-executor-v1:
+    build:
+      context: ..
+      dockerfile: python-worker/Dockerfile.gpu
+    command: python -m orderflow_services.ml_recommendation_commit_executor_v1
+    environment:
+      REDIS_URL: ${REDIS_URL:-redis://redis-worker-1:6379/0}
+      ML_RECOMMENDATION_COMMIT_EXECUTOR_METRICS_PORT: "9859"
+      ML_RECOMMENDATION_COMMIT_EXECUTOR_INPUT_STREAM: ${ML_RECOMMENDATION_COMMIT_EXECUTOR_INPUT_STREAM:-stream:ml:recommendation_commit_requests}
+      ML_RECOMMENDATION_COMMIT_EXECUTOR_RESULT_STREAM: ${ML_RECOMMENDATION_COMMIT_EXECUTOR_RESULT_STREAM:-stream:ml:recommendation_apply_results}
+      ML_RECOMMENDATION_COMMIT_EXECUTOR_ROLLBACK_INPUT_STREAM: ${ML_RECOMMENDATION_COMMIT_EXECUTOR_ROLLBACK_INPUT_STREAM:-stream:ml:recommendation_rollback_requests}
+      ML_RECOMMENDATION_COMMIT_EXECUTOR_ROLLBACK_STREAM: ${ML_RECOMMENDATION_COMMIT_EXECUTOR_ROLLBACK_STREAM:-stream:ml:recommendation_rollback_journal}
+      ML_RECOMMENDATION_COMMIT_EXECUTOR_AUDIT_STREAM: ${ML_RECOMMENDATION_COMMIT_EXECUTOR_AUDIT_STREAM:-stream:ml:recommendation_audit}
+    ports:
+      - "9859:9859"
+    restart: unless-stopped
+
