@@ -0,0 +1,36 @@
+from orderflow_services.operator_routing_incident_route_rca_results_persister_v2_19 import (
+    output_hash_for_result,
+)
+from orderflow_services.operator_routing_incident_route_rca_quality_scorer_v2_19 import (
+    compute_quality_score,
+)
+from orderflow_services.operator_routing_incident_route_rca_feedback_loop_v2_19 import (
+    usefulness_score,
+)
+
+
+def test_output_hash_is_stable():
+    row = {
+        "incident_id": "route-inc-42",
+        "provider": "vertex",
+        "model_name": "gemini-2.5-flash-lite",
+        "prompt_version": "routing_incident_route_rca_v1",
+        "policy_version": "policy_v1",
+        "result_json": '{"summary":"ok","findings":[],"recommendations":[]}',
+    }
+    assert output_hash_for_result(row) == output_hash_for_result(dict(row))
+
+
+def test_compute_quality_score_rewards_summary_findings_and_recommendations():
+    result = {
+        "summary": "incident explained",
+        "findings": [{"evidence": ["a", "b"]}, {"evidence": ["c"]}],
+        "recommendations": [{"action": "open_incident"}],
+    }
+    score = compute_quality_score(result)
+    assert 0.4 <= score <= 1.0
+
+
+def test_usefulness_mapping():
+    assert usefulness_score("VERY_USEFUL") == 1.0
+    assert usefulness_score("USEFUL") == 0.75
+    assert usefulness_score("NOT_USEFUL") == 0.0
