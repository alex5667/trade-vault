+                """
+                INSERT INTO llm_operator_routing_incident_route_rca_feedback (
+                    incident_id,
+                    ts_ms,
+                    reviewer,
+                    decision,
+                    usefulness_score,
+                    note
+                ) VALUES (
+                    %(incident_id)s,
+                    %(ts_ms)s,
+                    %(reviewer)s,
+                    %(decision)s,
+                    %(usefulness_score)s,
+                    %(note)s
+                )
+                """,
+                {
+                    "incident_id": row.get("incident_id", ""),
+                    "ts_ms": int(row.get("ts_ms", now_ms())),
+                    "reviewer": row.get("reviewer", ""),
+                    "decision": row.get("decision", ""),
+                    "usefulness_score": usefulness,
+                    "note": row.get("note", ""),
+                },
+            )
+            cur.execute(
+                """
+                UPDATE llm_operator_routing_incident_route_rca_results
+                SET usefulness_score = COALESCE((
+                    SELECT AVG(f.usefulness_score)
+                    FROM llm_operator_routing_incident_route_rca_feedback f
+                    WHERE f.incident_id = %(incident_id)s
+                ), usefulness_score)
+                WHERE incident_id = %(incident_id)s
+                """,
+                {"incident_id": row.get("incident_id", "")},
+            )
+            conn.commit()
+
+
+async def main() -> None:  # pragma: no cover
+    if redis is None:
+        raise RuntimeError("redis.asyncio is required")
+    start_http_server(PORT)
+    if UP:
+        UP.set(1)
+    r = redis.from_url(os.getenv("REDIS_URL", "redis://localhost:6379/0"))
+    await ensure_group(r, INPUT_STREAM, GROUP)
+    db_url = os.getenv("DATABASE_URL", "")
+    while True:
+        rows = await r.xreadgroup(GROUP, CONSUMER, {INPUT_STREAM: ">"}, count=32, block=5000)
+        if not rows:
+            continue
+        for _stream, messages in rows:
+            for msg_id, payload in messages:
+                started = time.perf_counter()
+                status = "ok"
+                try:
+                    row = as_dict(payload)
+                    score = usefulness_score(row.get("decision", ""))
+                    await persist_if_configured(db_url, row, score)
+                    summary_payload = {
+                        "schema_version": 1,
+                        "incident_id": row.get("incident_id", ""),
+                        "reviewer": row.get("reviewer", ""),
+                        "decision": row.get("decision", ""),
+                        "usefulness_score": str(score),
+                        "ts_ms": str(now_ms()),
+                    }
+                    await r.xadd(SUMMARY_STREAM, summary_payload, maxlen=MAXLEN, approximate=True)
+                    await r.hset(
+                        LAST_HASH,
+                        mapping={
+                            "incident_id": row.get("incident_id", ""),
+                            "decision": row.get("decision", ""),
+                            "usefulness_score": str(score),
+                            "ts_ms": str(now_ms()),
+                        },
+                    )
+                    await r.xack(INPUT_STREAM, GROUP, msg_id)
+                    if LAST_RUN_TS:
+                        LAST_RUN_TS.set(time.time())
+                except Exception:
+                    status = "error"
+                    await r.xack(INPUT_STREAM, GROUP, msg_id)
+                finally:
+                    if RUNS:
+                        RUNS.labels(status=status).inc()
+                    if LAT:
+                        LAT.observe(max(time.perf_counter() - started, 0.0))
+
+
+if __name__ == "__main__":  # pragma: no cover
+    import asyncio
+    asyncio.run(main())
