+BEGIN;
+
+CREATE TABLE IF NOT EXISTS llm_operator_routing_incident_route_rca_results (
+    id                bigserial PRIMARY KEY,
+    incident_id       text NOT NULL,
+    ts_ms             bigint NOT NULL,
+    provider          text NOT NULL,
+    model_name        text NOT NULL,
+    prompt_version    text NOT NULL,
+    policy_version    text NOT NULL,
+    output_hash       text NOT NULL,
+    quality_score     double precision,
+    usefulness_score  double precision,
+    result_json       jsonb NOT NULL,
+    UNIQUE(incident_id, output_hash)
+);
+
+CREATE INDEX IF NOT EXISTS idx_llm_operator_routing_incident_route_rca_results_incident_id
+    ON llm_operator_routing_incident_route_rca_results(incident_id);
+
+CREATE INDEX IF NOT EXISTS idx_llm_operator_routing_incident_route_rca_results_ts_ms
+    ON llm_operator_routing_incident_route_rca_results(ts_ms DESC);
+
+CREATE TABLE IF NOT EXISTS llm_operator_routing_incident_route_rca_quality (
+    id               bigserial PRIMARY KEY,
+    incident_id      text NOT NULL,
+    ts_ms            bigint NOT NULL,
+    output_hash      text NOT NULL,
+    quality_score    double precision NOT NULL,
+    quality_json     jsonb NOT NULL
+);
+
+CREATE TABLE IF NOT EXISTS llm_operator_routing_incident_route_rca_feedback (
+    id                bigserial PRIMARY KEY,
+    incident_id       text NOT NULL,
+    ts_ms             bigint NOT NULL,
+    reviewer          text NOT NULL,
+    decision          text NOT NULL,
+    usefulness_score  double precision NOT NULL,
+    note              text
+);
+
+COMMIT;
