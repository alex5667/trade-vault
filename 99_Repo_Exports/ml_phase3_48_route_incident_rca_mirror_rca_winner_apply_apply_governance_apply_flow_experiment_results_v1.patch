+                )
+            cur.execute(
+                """
+                INSERT INTO llm_route_incident_rca_mirror_rca_winner_apply_apply_governance_apply_flow_experiment_winner_decisions (
+                    ts_ms, decision, reason_code, winner_arm, decision_json
+                ) VALUES (
