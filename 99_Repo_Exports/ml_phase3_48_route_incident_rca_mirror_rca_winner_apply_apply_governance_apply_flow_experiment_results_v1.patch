+                    "ts_ms": now_ms(),
+                    "decision": decision["decision"],
+                    "reason_code": decision["reason_code"],
+                    "winner_arm": decision["winner_arm"],
+                    "decision_json": json.dumps({"scorecards": scorecards, "decision": decision}),
+                },
+            )
+            conn.commit()
+
