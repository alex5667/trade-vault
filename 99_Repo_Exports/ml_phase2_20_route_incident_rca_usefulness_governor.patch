index 0000000..5555555
--- /dev/null
+++ b/orderflow_services/tests/test_operator_routing_incident_route_rca_usefulness_governor_v2_20.py
@@ -0,0 +1,39 @@
+from orderflow_services.operator_routing_incident_route_rca_usefulness_governor_v2_20 import (
+    action_key,
+    build_decision_row,
+    decision_for,
+    provider_key,
+    weighted_score,
+)
+
+
+def test_weighted_score_prefers_usefulness():
+    score = weighted_score(quality_avg=0.5, usefulness_avg=1.0)
+    assert round(score, 6) == round(0.4 * 0.5 + 0.6 * 1.0, 6)
+
+
+def test_decision_for_respects_thresholds():
