+++ /mnt/data/stage/python-worker/core/ok_fields.py	2026-02-21 07:46:42.040082006 +0000
@@ -0,0 +1,227 @@
+from __future__ import annotations
+
+import json
+from typing import Any, Dict, Optional, Tuple
+
+
+def _to_str(v: Any) -> str:
+    if v is None:
+        return ""
+    if isinstance(v, (bytes, bytearray)):
+        try:
+            return v.decode("utf-8", errors="replace")
+        except Exception:
+            return str(v)
+    return str(v)
+
+
+def _int01(v: Any, default: int = 0) -> int:
+    """Best-effort convert to 0/1. Accepts bool/int/float/str/bytes."""
+    try:
+        if v is None:
+            return int(default)
+        if isinstance(v, bool):
+            return 1 if v else 0
+        if isinstance(v, (bytes, bytearray)):
+            v = _to_str(v)
+        if isinstance(v, (int, float)):
+            return 1 if int(v) != 0 else 0
+        s = str(v).strip().lower()
+        if s in ("1", "true", "yes", "y", "on", "ok", "pass", "allow", "allowed"):
+            return 1
+        if s in ("0", "false", "no", "n", "off", "fail", "deny", "denied"):
+            return 0
+        # Numeric string?
+        return 1 if int(float(s)) != 0 else 0
+    except Exception:
+        return int(default)
+
+
+def _try_json(v: Any) -> Optional[Any]:
+    if v is None:
+        return None
+    if isinstance(v, (bytes, bytearray)):
+        v = _to_str(v)
+    if not isinstance(v, str):
+        return None
+    s = v.strip()
+    if not s:
+        return None
+    if s[0] not in ("{", "["):
+        return None
+    try:
+        return json.loads(s)
+    except Exception:
+        return None
+
+
+def _row_get(row: Dict[str, Any], key: str) -> Any:
+    """Dict get that is tolerant to bytes keys and case differences."""
+    if key in row:
+        return row.get(key)
+    lk = key.lower()
+    for k, v in row.items():
+        try:
+            ks = k.decode("utf-8", errors="replace") if isinstance(k, (bytes, bytearray)) else str(k)
+        except Exception:
+            ks = str(k)
+        if ks == key or ks.lower() == lk:
+            return v
+    return None
+
+
+def _payload_dict(row: Dict[str, Any]) -> Optional[Dict[str, Any]]:
+    for k in ("payload", "data", "json", "decision", "decision_json", "event", "evidence"):
+        v = _row_get(row, k)
+        obj = _try_json(v)
+        if isinstance(obj, dict):
+            return obj
+    return None
+
+
+def parse_ok_fields_ex(row: Dict[str, Any]) -> Tuple[int, int, int, Dict[str, str]]:
+    """Parse ok / ok_soft / ok_rule from a stream row.
+
+    Returns: (ok, ok_soft, ok_rule, meta)
+      meta contains sources for each field: ok_src, ok_soft_src, ok_rule_src, payload_decoded.
+    """
+    meta: Dict[str, str] = {"ok_src": "", "ok_soft_src": "", "ok_rule_src": "", "payload_decoded": "0"}
+
+    # 1) Direct fields (preferred)
+    ok_v = _row_get(row, "ok")
+    if ok_v is not None:
+        ok = _int01(ok_v, 0)
+        meta["ok_src"] = "row.ok"
+    else:
+        ok = 0
+
+    ok_soft_v = _row_get(row, "ok_soft")
+    if ok_soft_v is not None:
+        ok_soft = _int01(ok_soft_v, 0)
+        meta["ok_soft_src"] = "row.ok_soft"
+    else:
+        ok_soft = 0
+
+    ok_rule_v = _row_get(row, "ok_rule")
+    if ok_rule_v is not None:
+        ok_rule = _int01(ok_rule_v, 0)
+        meta["ok_rule_src"] = "row.ok_rule"
+    else:
+        ok_rule = -1  # unknown for now
+
+    # 2) Aliases (row)
+    if meta["ok_src"] == "":
+        for alias in ("ok_final", "allow", "decision_ok", "rule_ok", "ok_strict"):
+            v = _row_get(row, alias)
+            if v is not None:
+                ok = _int01(v, 0)
+                meta["ok_src"] = f"row.{alias}"
+                break
+
+    if meta["ok_soft_src"] == "":
+        for alias in ("soft_ok", "okSoft", "soft_fail", "is_soft"):
+            v = _row_get(row, alias)
+            if v is not None:
+                ok_soft = _int01(v, 0)
+                meta["ok_soft_src"] = f"row.{alias}"
+                break
+
+    if meta["ok_rule_src"] == "":
+        for alias in ("rule_ok", "ok_strict", "heur_ok", "ok_heur"):
+            v = _row_get(row, alias)
+            if v is not None:
+                ok_rule = _int01(v, 0)
+                meta["ok_rule_src"] = f"row.{alias}"
+                break
+
+    # 3) Payload JSON
+    payload = _payload_dict(row)
+    if isinstance(payload, dict):
+        meta["payload_decoded"] = "1"
+
+        if meta["ok_src"] == "":
+            for k in ("ok", "ok_final", "allow", "decision_ok"):
+                if k in payload:
+                    ok = _int01(payload.get(k), 0)
+                    meta["ok_src"] = f"payload.{k}"
+                    break
+
+        if meta["ok_soft_src"] == "":
+            for k in ("ok_soft", "soft_ok", "okSoft", "soft_fail", "is_soft"):
+                if k in payload:
+                    ok_soft = _int01(payload.get(k), 0)
+                    meta["ok_soft_src"] = f"payload.{k}"
+                    break
+
+        if meta["ok_rule_src"] == "":
+            for k in ("ok_rule", "rule_ok", "ok_strict", "heur_ok", "ok_heur"):
+                if k in payload:
+                    ok_rule = _int01(payload.get(k), 0)
+                    meta["ok_rule_src"] = f"payload.{k}"
+                    break
+
+        # Some producers place nested dicts
+        if meta["ok_src"] == "" and isinstance(payload.get("decision"), dict):
+            d = payload["decision"]
+            for k in ("ok", "allow", "ok_final"):
+                if k in d:
+                    ok = _int01(d.get(k), 0)
+                    meta["ok_src"] = f"payload.decision.{k}"
+                    break
+
+    # 4) Fallback: if ok missing but ok_rule known -> use ok_rule as ok (keeps ok_rate meaningful)
+    if meta["ok_src"] == "":
+        if ok_rule in (0, 1):
+            ok = int(ok_rule)
+            meta["ok_src"] = "fallback.ok_rule"
+        else:
+            ok = 0
+            meta["ok_src"] = "missing"
+
+    if meta["ok_soft_src"] == "":
+        meta["ok_soft_src"] = "missing"
+
+    if meta["ok_rule_src"] == "":
+        if ok_rule in (0, 1):
+            meta["ok_rule_src"] = "inferred"
+        else:
+            # infer from ok if nothing else
+            ok_rule = int(ok)
+            meta["ok_rule_src"] = "fallback.ok"
+    if ok_rule not in (0, 1):
+        ok_rule = int(ok)
+
+    return int(ok), int(ok_soft), int(ok_rule), meta
+
+
+def parse_ok_fields(row: Dict[str, Any]) -> Tuple[int, int]:
+    ok, ok_soft, _ok_rule, _meta = parse_ok_fields_ex(row)
+    return ok, ok_soft
+
+
+def derive_ok_fields_from_ofc(ofc: Any, evidence: Optional[Dict[str, Any]] = None) -> Tuple[int, int, int, str]:
+    """Derive (ok, ok_soft, ok_rule, ok_src) from OFConfirm-like object + evidence dict.
+
+    Motivation: in some branches OFConfirm exposes ok_rule/allow but not ok, which made ok_rate always 0.
+    """
+    e = evidence if isinstance(evidence, dict) else {}
+    if not e:
+        try:
+            ev = getattr(ofc, "evidence", None)
+            if isinstance(ev, dict):
+                e = ev
+        except Exception:
+            e = {}
+
+    # ok_soft
+    ok_soft_v = e.get("ok_soft", None)
+    if ok_soft_v is not None:
+        ok_soft = _int01(ok_soft_v, 0)
+    else:
+        v = getattr(ofc, "ok_soft", None)
+        ok_soft = _int01(v, 0)
+
+    # ok_rule (heuristic)
+    v = getattr(ofc, "ok_rule", None)
+    if v is not None:
+        ok_rule = _int01(v, 0)
+    elif "ok_rule" in e:
+        ok_rule = _int01(e.get("ok_rule"), 0)
+    elif "rule_ok" in e:
+        ok_rule = _int01(e.get("rule_ok"), 0)
+    else:
+        ok_rule = -1
+
+    # ok (final)
+    ok_src = "missing"
+    v = getattr(ofc, "ok", None)
+    if v is not None:
+        ok = _int01(v, 0)
+        ok_src = "ofc.ok"
+    else:
+        v = getattr(ofc, "allow", None)
+        if v is not None:
+            ok = _int01(v, 0)
+            ok_src = "ofc.allow"
+        elif "ok" in e:
+            ok = _int01(e.get("ok"), 0)
+            ok_src = "evidence.ok"
+        else:
+            ok = -1
+
+    # fallback
+    if ok not in (0, 1):
+        if ok_rule in (0, 1):
+            ok = int(ok_rule)
+            ok_src = "fallback.ok_rule"
+        else:
+            ok = 0
+            ok_src = "fallback.0"
+
+    if ok_rule not in (0, 1):
+        ok_rule = int(ok)
+
+    return int(ok), int(ok_soft), int(ok_rule), str(ok_src)
