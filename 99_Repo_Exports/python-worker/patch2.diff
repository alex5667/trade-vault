--- /mnt/data/orig_stage/python-worker/tests/test_ok_fields.py	1970-01-01 00:00:00.000000000 +0000
+++ /mnt/data/stage/python-worker/tests/test_ok_fields.py	2026-02-21 07:53:17.346779678 +0000
@@ -0,0 +1,38 @@
+import json
+
+from core.ok_fields import parse_ok_fields_ex, derive_ok_fields_from_ofc
+
+
+def test_parse_ok_fields_ex_direct_and_bytes():
+    row = {b"ok": b"1", b"ok_soft": b"0", b"ok_rule": b"1"}
+    ok, ok_soft, ok_rule, meta = parse_ok_fields_ex(row)
+    assert (ok, ok_soft, ok_rule) == (1, 0, 1)
+    assert meta["ok_src"] == "row.ok"
+
+
+def test_parse_ok_fields_ex_payload_ok_rule_fallback():
+    row = {"payload": json.dumps({"ok_rule": 1, "ok_soft": 0})}
+    ok, ok_soft, ok_rule, meta = parse_ok_fields_ex(row)
+    assert (ok, ok_soft, ok_rule) == (1, 0, 1)
+    assert meta["ok_src"] == "fallback.ok_rule"
+
+
+def test_derive_ok_fields_from_ofc_prefers_ok_over_ok_rule():
+    class Dummy:
+        ok = 1
+        ok_rule = 0
+        allow = False
+        ok_soft = 0
+
+    ok, ok_soft, ok_rule, ok_src = derive_ok_fields_from_ofc(Dummy(), {})
+    assert (ok, ok_soft, ok_rule) == (1, 0, 1)
+    assert ok_src == "ofc.ok"
