[Unit]
Description=Trade latency-contract deploy-lint exporter
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/default/trade-latency-sensitive-jobs-staging
Environment=PYTHONUNBUFFERED=1
ExecStart=/bin/bash -lc 'cd "${TRADE_REPO_ROOT:?}" && ./orderflow_services/deploy/systemd/run_trade_latency_contract_deploy_lint_exporter_v1.sh'
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
