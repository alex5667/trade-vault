# Tick Gate Aggregator (Step 22)

REDIS_URL=redis://redis-worker-1:6379/0

# Stream to tail (published by Step 19 wrapper)
TICK_GATE_REDIS_STREAM=ops:tick_quality_gate

# Consumer group settings (XREADGROUP)
TICK_GATE_AGG_GROUP=tick_gate_agg
TICK_GATE_AGG_START_ID=$

# Exporter port
TICK_GATE_METRICS_PORT=9112

# Label limiting to prevent Prometheus cardinality explosions
TICK_GATE_REASON_LABEL_MODE=collapse
TICK_GATE_REASON_ALLOWLIST=skew,unknown_side,process_p99,e2e_p99,ts_now,ts_stream

TICK_GATE_SYMBOL_LABEL_MODE=collapse
TICK_GATE_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT
