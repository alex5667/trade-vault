# Redis
REDIS_URL=redis://redis-worker-1:6379/0

# Tick gate metrics endpoint
TICK_GATE_METRICS_URL=http://localhost:8000/metrics
TICK_GATE_WINDOW_S=60
# Optional symbol gate (leave empty for global gate)
# TICK_GATE_SYMBOL=BTCUSDT

# Auto-apply block keys
AUTO_APPLY_BLOCK_PREFIX=cfg:suggestions:entry_policy:auto_apply_block

# Anti-flap
AUTO_APPLY_BLOCK_MIN_HOLD_S=300
AUTO_APPLY_UNBLOCK_PASS_STREAK=3
AUTO_APPLY_BLOCK_REASON_PIN_S=600

# How to handle INSUFFICIENT_DATA from gate: fail_open | fail_closed
AUTO_APPLY_BLOCKER_INSUFF_MODE=fail_open

# Block TTL in Redis (should be > hold time)
AUTO_APPLY_BLOCK_TTL_S=900

# Daemon loop interval
AUTO_APPLY_BLOCKER_INTERVAL_S=30

# Publish audit events
AUTO_APPLY_TICK_GATE_PUBLISH_REDIS=1
AUTO_APPLY_TICK_GATE_STREAM=ops:auto_apply_tick_gate
AUTO_APPLY_TICK_GATE_STREAM_MAXLEN=20000
