# Example environment for Tick-Quality Gated Ramp (Step 20)
#
# Place this file somewhere readable by your runner (systemd/cron/docker),
# then export or load it before running the gated command.
#
# Required (metrics endpoint for the python-worker that exports /metrics)
TICK_GATE_METRICS_URL=http://localhost:8000/metrics

# Gate window (seconds) - tool scrapes /metrics twice over this window
TICK_GATE_WINDOW_S=60

# Fail mode: fail_open | fail_closed
TICK_GATE_FAIL_MODE=fail_open

# Optional Redis publish (best-effort)
REDIS_URL=redis://redis-worker-1:6379/0
TICK_GATE_PUBLISH_REDIS=1
TICK_GATE_REDIS_STREAM=ops:tick_quality_gate

# Thresholds (override as needed)
TICK_GATE_PROCESS_P99_MS=25
TICK_GATE_E2E_P99_MS=5000
TICK_GATE_UNKNOWN_SIDE_EMA=0.10
TICK_GATE_TS_NOW_EMA=0.05
TICK_GATE_TS_STREAM_ID_EMA=0.20
TICK_GATE_SKEW_EMA_MS=30000
TICK_GATE_AGE_EMA_MS=30000

# Optional: restrict to one symbol (otherwise checks global + per-symbol where present)
#TICK_GATE_SYMBOL=BTCUSDT

# Command to run (cron wrapper uses this; systemd units embed command directly)
#TICK_GATE_COMMAND="python -m tools.nightly_meta_enforce_ramp_bundle"
