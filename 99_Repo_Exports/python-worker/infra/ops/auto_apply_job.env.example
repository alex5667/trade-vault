# Auto-apply job (Step 28) - environment example

# Redis for block keys + ops audit stream
REDIS_URL=redis://redis-worker-1:6379/0

# Required: actual apply runner command
# Example (replace with your real apply runner):
AUTO_APPLY_CMD=python -m tools.nightly_meta_enforce_ramp_bundle

# Optional: working directory for command
AUTO_APPLY_WORKDIR=/home/alex/front/trade/scanner_infra/python-worker

# Optional: timeout for apply runner
AUTO_APPLY_TIMEOUT_S=600

# Where to log attempts (best-effort)
AUTO_APPLY_OPS_STREAM=ops:auto_apply_runs

# Block keys namespace (must match Step 25/26 blocker)
AUTO_APPLY_BLOCK_PREFIX=cfg:suggestions:entry_policy:auto_apply_block

# If Redis/guard fails:
# - fail_open: run apply anyway (default)
# - fail_closed: skip apply (exit 21)
AUTO_APPLY_FAIL_MODE=fail_open
