# Auto-apply Tick Gate Exporter

REDIS_URL=redis://redis-worker-1:6379/0

# Key prefix used by blocker (Step25/26)
AUTO_APPLY_BLOCK_PREFIX=cfg:suggestions:entry_policy:auto_apply_block

# Exporter config
AUTO_APPLY_EXPORTER_PORT=9115
AUTO_APPLY_EXPORTER_POLL_S=5

# Reason label control to avoid high-cardinality
# collapse: unknown reasons -> __other__
# allow: allow reasons but still collapses if allowlist provided
# skip: no reason labeling (single series)
AUTO_APPLY_REASON_LABEL_MODE=collapse
AUTO_APPLY_REASON_ALLOWLIST=unknown_side,skew,process_p99,e2e_p99,ts_now,ts_stream,fail,pass
