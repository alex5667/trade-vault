[Unit]
Description=Auto-Apply Job (gated by tick-gate block)
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/home/alex/front/trade/scanner_infra/python-worker
EnvironmentFile=/etc/default/auto-apply-job
ExecStart=/usr/bin/python3 -m tools.auto_apply_job_entrypoint
Nice=5

# Hard safety: do not restart loops for a oneshot
Restart=no

[Install]
WantedBy=multi-user.target
