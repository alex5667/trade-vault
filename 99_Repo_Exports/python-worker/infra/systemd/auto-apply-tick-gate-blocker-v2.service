[Unit]
Description=Auto-Apply Tick Gate Blocker v2 (anti-flap)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=-/etc/default/auto-apply-tick-gate-blocker-v2
WorkingDirectory=/home/alex/front/trade/scanner_infra/python-worker
ExecStart=/usr/bin/python3 -m tools.auto_apply_tick_gate_blocker_v2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
