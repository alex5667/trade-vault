[Unit]
Description=Trade OF nightly engine-regress (baseline inputs/output)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=/etc/trade/of_reports.env
WorkingDirectory=/home/alex/front/trade/scanner_infra/python-worker
ExecStart=/usr/bin/python3 -m tools.nightly_regress_engine_replay
StandardOutput=journal
StandardError=journal

