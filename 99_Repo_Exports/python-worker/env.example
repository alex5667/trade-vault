# ============================================================================
# Python Worker - Environment Variables (Recommended Configuration)
# ============================================================================
# Скопируйте этот файл в .env и адаптируйте под ваши нужды
# ============================================================================

# ----------------------------------------------------------------------------
# REDIS CONNECTIONS
# ----------------------------------------------------------------------------
REDIS_URL=redis://redis-worker-1:6379/0
REDIS_TICKS_URL=redis://redis-ticks:6379/0
REDIS_SIGNALS_URL=redis://redis-worker-1:6379/0
TRADES_CLOSED_STREAM_NAME=trades:closed
TRADES_CLOSED_STREAM_MAXLEN=50000

# ----------------------------------------------------------------------------
# BASE ORDERFLOW HANDLER - RECOMMENDED DEFAULTS
# ----------------------------------------------------------------------------

# === 1. СТРОГИЙ BREAKOUT ПО OBI ===
# Требует подтверждения OBI для breakout сигналов (рекомендуется)
BREAKOUT_REQUIRE_OBI=true

# === 2. OBI SUSTAINED КАК "УСТОЙЧИВОСТЬ" ===
# Проверяет не только среднее, но и долю устойчивых наблюдений
OBI_SUSTAINED_USE_FRACTION=true
OBI_SUSTAINED_MIN_SAMPLES=3
OBI_SUSTAINED_MIN_FRACTION=0.6

# === 3. ПОРОГИ Z-SCORE ПО ТИПАМ СИГНАЛОВ ===
# Раздельные пороги для разных типов сигналов
BREAKOUT_Z_THRESHOLD=3.0
ABSORPTION_Z_THRESHOLD=3.0
EXTREME_Z_MULT=1.6
# MAIN_Z_THRESHOLD - вычисляется автоматически как min(breakout_z, absorption_z, delta_z)

# === 4. ABSORPTION CONTROLS ===
# Требовать weak_progress для absorption
ABSORPTION_REQUIRE_WEAK_PROGRESS=true

# === 5. ABSORPTION MICRO-PROXY (для crypto) ===
# Использовать микроструктурный proxy для absorption
# Работает только если есть is_buyer_maker в тиках
ABSORPTION_USE_MICRO_PROXY=true
ABSORPTION_MICRO_ADVERSE_MIN=0.60
ABSORPTION_MICRO_REALIZED_EMA_MAX=-0.50

# ----------------------------------------------------------------------------
# ДОПОЛНИТЕЛЬНЫЕ ПАРАМЕТРЫ
# ----------------------------------------------------------------------------

# === BREAKOUT CONTROLS ===
BREAKOUT_MIN_DIST_ATR=0.0
LEVEL_SIGNAL_COOLDOWN_MS=15000

# === OBI SETTINGS ===
OBI_MAX_STALE_MS=2500

# === DELTA BUCKETING ===
DELTA_BUCKET_MS=1000
DELTA_BUCKET_MAX_ZERO_FILL=3

# === TICK PROCESSING ===
MAX_TICK_LAG_MS=5000

# === SIGNAL OUTBOX ===
USE_SIGNAL_OUTBOX=true
SIGNAL_DEDUP_TTL_MS=60000

# === GPU ACCELERATION ===
GPU_ENABLED=true

# === LOGGING ===
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# ATR SELECTOR & SANITY (DIFF A)
# ----------------------------------------------------------------------------
# --- ATR sanity (light) ---
ATR_SANITY_ENABLE=1
ATR_MAX_AGE_MS=900000
ATR_BPS_MIN_SANITY=2
ATR_BPS_MAX_SANITY=800

# --- ATR selector (TF + source) ---
ATR_SELECTOR_ENABLE=0
ATR_SELECTOR_PERIOD_SEC=300
ATR_SELECTOR_TFS=1m,5m,15m
ATR_SELECTOR_MAX_AGE_MS=900000
ATR_SELECTOR_HOLD_DOWN_MS=1800000
ATR_SELECTOR_SWITCH_MARGIN=0.05
ATR_SELECTOR_PRICE_KEY_PREFIX=cfg:last_px:

# --- ATR sanity (full) ---
ATR_JUMP_MAX_REL=0.8
ATR_JUMP_WINDOW_SEC=3600
ATR_SWITCH_WINDOW_SEC=3600
ATR_REPORT_TOP_N=15
ATR_SANITY_WINDOW=120
ATR_LAST_GOOD_TTL_MS=1800000
ATR_META_REFRESH_MS=10000

# --- Sets used by reporters (TTL in seconds) ---
ATR_JUMP_SYMBOLS_SET_TTL_SEC=86400
ATR_SWITCH_SYMBOLS_SET_TTL_SEC=86400

# --- Keys written by selector ---
ATR_SEL_META_KEY_PREFIX=cfg:atr_sel_meta:
ATR_SEL_TF_KEY_PREFIX=cfg:atr_tf:
ATR_SEL_SRC_KEY_PREFIX=cfg:atr_src:

# ----------------------------------------------------------------------------
# CVD CONSISTENCY & QUARANTINE (DIFF B)
# ----------------------------------------------------------------------------
CVD_QUARANTINE_ENABLE=0
CVD_JUMP_ABS_QTY=5000
# Preferred (USD/notional) thresholding for two-baseline detection
CVD_JUMP_ABS_USD=2000000
CVD_JUMP_REL_K=8.0
CVD_JUMP_WINDOW_MS=180000
CVD_JUMP_K_EVENTS=2
CVD_QUARANTINE_TTL_MS=900000
# Robust scale (median abs delta USD) refresh control
CVD_MEDIAN_WINDOW=120
CVD_MED_RECALC_EVERY=50
# Out-of-order protection (event-time)
CVD_OOO_MAX_LAG_MS=2000

# When set, treat incoming ticks with these keys as "expected reset" (skip jump trigger on that tick)
# Example: "reset,cvd_reset,reset_flag"
CVD_EXPECTED_RESET_KEYS=reset,cvd_reset,reset_flag

# ----------------------------------------------------------------------------
# MICROBAR STREAM SPLIT (DIFF C)
# ----------------------------------------------------------------------------
MICROBAR_SPLIT_STREAMS_ENABLE=0
MICROBAR_SPLIT_DUAL_WRITE=1
MICROBAR_LEGACY_STREAM=events:microbar_closed
MICROBAR_PER_SYMBOL_PREFIX=events:microbar_closed:
MICROBAR_MAJORS_STREAM=events:microbar_closed:majors
MICROBAR_SYMBOLS_SET=events:microbar_closed:symbols
MICROBAR_LEGACY_MAXLEN=200000
MICROBAR_PER_SYMBOL_MAXLEN=50000
MICROBAR_SYMBOLS_SET_TTL_SEC=86400
MICROBAR_MAJORS=BTCUSDT,ETHUSDT

# ----------------------------------------------------------------------------
# COST-AWARE LCB (DIFF D) - Step 2: Cost-aware LCB with Hysteresis
# ----------------------------------------------------------------------------
# Enable cost-aware LCB in winner suggester/evaluator
LCB_COST_AWARE_ENABLE=0

# Confidence for LCB (z): 1.28 ~ 80%, 1.64 ~ 95%
LCB_Z=1.28

# Minimum trades per arm to be eligible
LCB_MIN_N=40

# Minimum acceptable LCB floor (in R units)
LCB_FLOOR_R=0.00

# Winner hysteresis: require margin and consecutive windows
LCB_MIN_DELTA_LCB=0.05
LCB_CONFIRM_WINDOWS=2

# How far back suggester looks (hours)
LCB_LOOKBACK_HOURS=24

# Cost model toggles
# If your total_pnl already includes fees (net), keep FEES_ALREADY_NET=1 and do not subtract fees twice.
LCB_FEES_ALREADY_NET=1
# If you store pnl_gross labels AND want evaluator to subtract fees_usd, set SUBTRACT_FEES=1 and FEES_ALREADY_NET=0.
LCB_SUBTRACT_FEES=0

# Optional: cap slippage bps (safety)
LCB_SLIPPAGE_BPS_CAP=250

# Winner state TTL in Redis (seconds, default 7 days)
LCB_WINNER_STATE_TTL_SEC=604800

# ----------------------------------------------------------------------------
# ML: PURGED CV FOR TB LABELS (DIFF E)
# ----------------------------------------------------------------------------
ML_PURGED_CV_ENABLE=1
ML_PURGED_CV_EMBARGO_MS=60000

# ----------------------------------------------------------------------------
# OFI IMPACT PROXY FOR SLIPPAGE (DIFF F)
# ----------------------------------------------------------------------------
SLIP_OFI_K=0.0

# ----------------------------------------------------------------------------
# REPORTS (Telegram) - Health Reporter для ATR/CVD/Streams
# ----------------------------------------------------------------------------
REPORTS_ENABLE=0
REPORTS_PERIOD_SEC=3600
REPORTS_TOP_N=10
REPORTS_SPIKE_COOLDOWN_SEC=600

# Redis для reporter (defaults to REDIS_URL если не задан)
REPORTS_REDIS_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----------------------------------------------------------------------------
# Observability: Prometheus metrics + SRE alert worker
# ----------------------------------------------------------------------------
# --- Prometheus-style metrics exporter (no external deps) ---
METRICS_ENABLE=1
METRICS_BIND=0.0.0.0
METRICS_PORT=9109
METRICS_REDIS_URL=
METRICS_MAX_SYMBOLS=200
METRICS_TFS_MAP=1m:1,5m:2,15m:3,1h:4
METRICS_COUNTER_TTL_SEC=604800

# --- Alerts worker (Telegram) ---
ALERTS_ENABLE=1
ALERTS_INTERVAL_SEC=60
ALERTS_COOLDOWN_SEC=600

# Thresholds
ALERT_ATR_BAD_PCT=30
ALERT_CVD_QUAR_PCT=30
ALERT_STREAM_MIN_XLEN=500
ALERT_ATR_SWITCH_COUNT=10
ALERT_CVD_JUMP_COUNT=10
ALERT_LCB_WINNER_CHANGES=10

# Last price TTL for ATR selector
LAST_PX_TTL_SEC=600

# Per-signal quality keys (записываются strategy, читаются reporter)
REPORT_KEYS_TTL_SEC=7200
ATR_BAD_SYMBOLS_SET=cfg:atr_bad:symbols
CVD_Q_SYMBOLS_SET=cfg:cvd_quarantine:symbols

# Streams health
REPORT_STREAMS_ENABLE=1
REPORT_STREAMS_MIN_XLEN=200
REPORT_STREAMS_MAX_SCAN=200

# ATR health
REPORT_ATR_ENABLE=1

# CVD quarantine health
REPORT_CVD_ENABLE=1

# Spike thresholds
REPORT_SPIKE_ATR_BAD=20
REPORT_SPIKE_CVD_Q=20

# ----------------------------------------------------------------------------
# NEWS PIPELINE CONFIGURATION
# ----------------------------------------------------------------------------
# Путь к модулю с тегами (news_pipeline/tags.py)
NEWS_TAGS_MODULE=news_pipeline.tags

# Пороги силы новости для grade 0-4 (strength thresholds)
NEWS_GRADE_THRESHOLDS=0.25,0.45,0.65,0.85

# Горизонт по grade в секундах (1h, 6h, 12h, 24h, 72h)
NEWS_HORIZON_BY_GRADE=3600,21600,43200,86400,259200

# Оверрайды горизонта по типам новостей (секунды)
NEWS_HORIZON_MACRO_SEC=21600
NEWS_HORIZON_INCIDENT_SEC=259200
NEWS_HORIZON_EXCHANGE_SEC=86400
NEWS_HORIZON_EARNINGS_SEC=86400
NEWS_HORIZON_REG_SEC=86400
NEWS_HORIZON_ETF_SEC=86400
NEWS_HORIZON_GEO_SEC=172800
NEWS_HORIZON_RISK_OFF_SEC=43200
NEWS_HORIZON_RISK_ON_SEC=21600

# Безопасные границы горизонта
NEWS_HORIZON_MIN_SEC=1800
NEWS_HORIZON_MAX_SEC=604800

# Дефолт confidence если analyzer не предоставляет
NEWS_DEFAULT_CONFIDENCE=0.5

# ----------------------------------------------------------------------------
# КОНФИГУРАЦИИ ПО ИНСТРУМЕНТАМ
# ----------------------------------------------------------------------------

# === BTCUSDT (Crypto высокочастотный) ===
BTCUSDT_DELTA_Z_THRESHOLD=2.7
BTCUSDT_OBI_THRESHOLD=0.35
BTCUSDT_WEAK_PROGRESS_ATR=0.15
BTCUSDT_MIN_SIGNAL_INTERVAL_SEC=60

# Специфичные пороги для BTCUSDT
#BTCUSDT_BREAKOUT_Z_THRESHOLD=3.2
#BTCUSDT_ABSORPTION_Z_THRESHOLD=2.5
#BTCUSDT_EXTREME_Z_MULT=2.0
#BTCUSDT_OBI_SUSTAINED_MIN_SAMPLES=5
#BTCUSDT_OBI_SUSTAINED_MIN_FRACTION=0.7

# === ETHUSDT (Crypto высокочастотный) ===
ETHUSDT_DELTA_Z_THRESHOLD=2.5
ETHUSDT_OBI_THRESHOLD=0.4
ETHUSDT_WEAK_PROGRESS_ATR=0.15
ETHUSDT_MIN_SIGNAL_INTERVAL_SEC=60

# === XAUUSD (Commodities) ===
XAUUSD_DELTA_Z_THRESHOLD=3.0
XAUUSD_OBI_THRESHOLD=0.5
XAUUSD_WEAK_PROGRESS_ATR=0.10
XAUUSD_MIN_SIGNAL_INTERVAL_SEC=120

# Специфичные пороги для XAUUSD
#XAUUSD_ABSORPTION_Z_THRESHOLD=2.8
#XAUUSD_OBI_SUSTAINED_MIN_SAMPLES=2
#XAUUSD_OBI_SUSTAINED_MIN_FRACTION=0.5
#XAUUSD_ABSORPTION_USE_MICRO_PROXY=false

# ----------------------------------------------------------------------------
# ПРИМЕРЫ ПРОФИЛЕЙ
# ----------------------------------------------------------------------------

# === ПРОФИЛЬ: КОНСЕРВАТИВНЫЙ (меньше сигналов, выше качество) ===
#BREAKOUT_Z_THRESHOLD=3.5
#ABSORPTION_Z_THRESHOLD=3.5
#OBI_SUSTAINED_MIN_FRACTION=0.7
#ABSORPTION_REQUIRE_WEAK_PROGRESS=true

# === ПРОФИЛЬ: АГРЕССИВНЫЙ (больше сигналов, ниже качество) ===
#BREAKOUT_Z_THRESHOLD=2.5
#ABSORPTION_Z_THRESHOLD=2.5
#OBI_SUSTAINED_MIN_FRACTION=0.5
#ABSORPTION_REQUIRE_WEAK_PROGRESS=false

# === ПРОФИЛЬ: CRYPTO СПЕЦИФИЧНЫЙ ===
#BREAKOUT_Z_THRESHOLD=3.2
#ABSORPTION_Z_THRESHOLD=2.5
#EXTREME_Z_MULT=2.0
#OBI_SUSTAINED_MIN_SAMPLES=5
#OBI_SUSTAINED_MIN_FRACTION=0.7
#ABSORPTION_USE_MICRO_PROXY=true
#ABSORPTION_MICRO_ADVERSE_MIN=0.65
#DELTA_BUCKET_MS=1000

# ----------------------------------------------------------------------------
# ЗАМЕТКИ
# ----------------------------------------------------------------------------
# 1. Начните с минимальной конфигурации (только BREAKOUT_REQUIRE_OBI и OBI_SUSTAINED_*)
# 2. Протестируйте на исторических данных
# 3. Постепенно добавляйте параметры
# 4. Мониторьте метрики в Grafana
# 5. Проводите A/B тесты перед production
#
# Документация:
# - handlers/RECOMMENDED_CONFIG.md - полное руководство
# - handlers/CONFIG_CHEATSHEET.md - быстрая шпаргалка
# - handlers/OBI_SUSTAINED_IMPROVEMENTS.md - детали OBI sustained
# - handlers/PER_SIGNAL_Z_THRESHOLDS.md - детали Z-порогов
# ============================================================================

