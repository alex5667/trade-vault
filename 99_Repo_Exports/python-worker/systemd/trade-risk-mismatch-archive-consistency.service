[Unit]
Description=trade risk mismatch archive consistency checker (P5X operator hardening)
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/trade
EnvironmentFile=-/etc/default/trade-operator-hardening
ExecStart=/usr/bin/python3 /opt/trade/scripts/check_risk_mismatch_summary_archive_consistency.py
