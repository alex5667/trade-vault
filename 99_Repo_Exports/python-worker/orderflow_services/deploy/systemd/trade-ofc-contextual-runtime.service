[Unit]
Description=Trade OFC contextual runtime with overlay-aware auto-reloader
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Restart=always
RestartSec=5
EnvironmentFile=/etc/default/trade-latency-sensitive-jobs-staging
ExecStart=/bin/bash -lc 'cd "${TRADE_REPO_ROOT:?}" && ./python-worker/orderflow_services/deploy/systemd/run_trade_ofc_contextual_runtime_v1.sh'
KillMode=control-group
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
