[Unit]
Description=Trade OFC contextual exporter
After=network-online.target docker.service
Wants=network-online.target
Requires=docker.service

[Service]
Type=simple
EnvironmentFile=/etc/default/trade-latency-sensitive-jobs-staging
Environment=PYTHONUNBUFFERED=1
ExecStart=/bin/bash -lc 'cd "${TRADE_REPO_ROOT:?}" && ./python-worker/orderflow_services/deploy/systemd/run_trade_ofc_contextual_exporter_v1.sh'
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
