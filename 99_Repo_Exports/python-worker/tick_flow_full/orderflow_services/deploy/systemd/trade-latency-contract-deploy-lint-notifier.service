[Unit]
Description=Trade latency-contract deploy-lint notifier
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=/etc/default/trade-latency-sensitive-jobs-staging
Environment=PYTHONUNBUFFERED=1
ExecStart=/bin/bash -lc 'cd "${TRADE_REPO_ROOT:?}" && ./orderflow_services/deploy/systemd/run_trade_latency_contract_deploy_lint_notifier_v1.sh'

[Install]
WantedBy=multi-user.target
