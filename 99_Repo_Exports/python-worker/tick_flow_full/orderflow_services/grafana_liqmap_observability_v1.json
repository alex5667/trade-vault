{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 60000},
              {"color": "red", "value": 180000}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "expr": "max by (symbol, window) (liqmap_snapshot_age_ms{symbol=~\"$symbol\", window=~\"$window\"})",
          "legendFormat": "{{symbol}}/{{window}}",
          "refId": "A"
        }
      ],
      "title": "LiqMap snapshot age (ms)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 10}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 9},
      "id": 2,
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "expr": "sum by (symbol, window, where) (increase(liqmap_parse_errors_total{symbol=~\"$symbol\", window=~\"$window\"}[5m]))",
          "legendFormat": "{{symbol}}/{{window}}/{{where}}",
          "refId": "A"
        }
      ],
      "title": "LiqMap parse/compute errors (5m increase)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["orderflow", "liqmap"],
  "templating": {
    "list": [
      {
        "current": {"selected": true, "text": "All", "value": ".*"},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "definition": "label_values(liqmap_snapshot_age_ms, symbol)",
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "name": "symbol",
        "options": [],
        "query": {"query": "label_values(liqmap_snapshot_age_ms, symbol)", "refId": "StandardVariableQuery"},
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "type": "query"
      },
      {
        "current": {"selected": true, "text": "All", "value": ".*"},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "definition": "label_values(liqmap_snapshot_age_ms, window)",
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "name": "window",
        "options": [],
        "query": {"query": "label_values(liqmap_snapshot_age_ms, window)", "refId": "StandardVariableQuery"},
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "utc",
  "title": "LiqMap Observability (v1)",
  "uid": "liqmap_obsv_v1",
