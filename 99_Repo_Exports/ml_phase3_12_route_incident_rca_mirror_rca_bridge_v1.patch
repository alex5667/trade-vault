+++ b/orderflow_services/prometheus_alerts_ml_phase3_12_route_incident_rca_mirror_rca_bridge_v1.yml
@@ -0,0 +1,31 @@
+groups:
+  - name: ml_phase3_12_route_incident_rca_mirror_rca_bridge_v1
+    rules:
+      - alert: MLRouteIncidentRCAMirrorRCABridgeStale
+        expr: time() - ml_route_incident_rca_mirror_rca_bridge_last_run_ts_seconds > 1800
+        for: 10m
+        labels: { severity: warning }
+        annotations:
+          summary: "route incident RCA mirror RCA bridge is stale"
+
+      - alert: MLRouteIncidentRCAMirrorRCABridgeErrors
+        expr: increase(ml_route_incident_rca_mirror_rca_bridge_runs_total{status="error"}[30m]) > 0
+        for: 5m
