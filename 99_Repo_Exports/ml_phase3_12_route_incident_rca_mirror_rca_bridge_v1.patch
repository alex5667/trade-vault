+      ML_ROUTE_INCIDENT_RCA_MIRROR_RCA_BRIDGE_MODE: ${ML_ROUTE_INCIDENT_RCA_MIRROR_RCA_BRIDGE_MODE:-AUTO}
+      ML_ROUTE_INCIDENT_RCA_MIRROR_RCA_BRIDGE_REQUIRE_VERTEX_DEGRADED_FOR_LOCAL: ${ML_ROUTE_INCIDENT_RCA_MIRROR_RCA_BRIDGE_REQUIRE_VERTEX_DEGRADED_FOR_LOCAL:-1}
+      ML_ROUTE_INCIDENT_RCA_MIRROR_RCA_BRIDGE_MAX_BUNDLE_BYTES: ${ML_ROUTE_INCIDENT_RCA_MIRROR_RCA_BRIDGE_MAX_BUNDLE_BYTES:-131072}
+      ML_ROUTE_INCIDENT_RCA_MIRROR_RCA_BRIDGE_MAX_PROMPT_CHARS: ${ML_ROUTE_INCIDENT_RCA_MIRROR_RCA_BRIDGE_MAX_PROMPT_CHARS:-12000}
+      ML_ROUTE_INCIDENT_RCA_MIRROR_VERTEX_RCA_STREAM: ${ML_ROUTE_INCIDENT_RCA_MIRROR_VERTEX_RCA_STREAM:-stream:ml:route_incident_rca_mirror_vertex_rca_requests}
+      ML_LOCAL_FALLBACK_REQUESTS_STREAM: ${ML_LOCAL_FALLBACK_REQUESTS_STREAM:-stream:ml:local_fallback_requests}
+      ML_ROUTE_INCIDENT_RCA_MIRROR_INCIDENT_BUNDLES_STREAM: ${ML_ROUTE_INCIDENT_RCA_MIRROR_INCIDENT_BUNDLES_STREAM:-stream:ml:route_incident_rca_mirror_incident_bundles}
+      ML_ROUTE_INCIDENT_RCA_MIRROR_RCA_BRIDGE_VERTEX_HEALTH_HASH: ${ML_ROUTE_INCIDENT_RCA_MIRROR_RCA_BRIDGE_VERTEX_HEALTH_HASH:-metrics:ml:vertex_health:last}
