@@ -0,0 +1,57 @@
+from orderflow_services.operator_routing_incident_rca_route_incident_bundle_builder_v2_17 import (
+    build_bundle,
+    primary_reason_codes,
+    severity_from_reason_codes,
+    summarize_route_diff,
+)
+
+
+def test_summarize_route_diff_detects_changes():
+    before = {
+        "provider": "vertex",
+        "model_name": "gemini-2.5-flash-lite",
+        "prompt_version": "v1",
+        "policy_version": "policy_v1",
+    }
+    after = {
+        "provider": "vertex",
+        "model_name": "gemini-2.5-flash",
+        "prompt_version": "v2",
+        "policy_version": "policy_v1",
+    }
+    diff = summarize_route_diff(before, after)
+    assert diff["model_name"]["before"] == "gemini-2.5-flash-lite"
+    assert diff["model_name"]["after"] == "gemini-2.5-flash"
+    assert diff["prompt_version"]["after"] == "v2"
+
+
+def test_primary_reason_codes_and_severity():
+    sections = {
+        "verify_results": [{"verification_reason_code": "USEFULNESS_DROP"}],
+        "slo_rollups": [{"reason_codes_json": '["ROUTE_MTTR_SLO_BREACH","ROUTE_SUCCESS_RATE_LOW"]'}],
+    }
+    reasons = primary_reason_codes(sections)
+    assert "ROUTE_MTTR_SLO_BREACH" in reasons
+    assert severity_from_reason_codes(reasons) == "critical"
+
+
+def test_build_bundle_contains_timeline_and_hash():
+    request_row = {"experiment_id": "exp-1", "ts_ms": "1000"}
+    sections = {
+        "apply_results": [{"baseline_route_json": '{"provider":"vertex","model_name":"gemini-2.5-flash-lite","prompt_version":"v1"}',
+                           "target_route_json": '{"provider":"vertex","model_name":"gemini-2.5-flash","prompt_version":"v2"}',
+                           "ts_ms": "1010"}],
+        "verify_results": [{"current_route_json": '{"provider":"vertex","model_name":"gemini-2.5-flash","prompt_version":"v2"}',
+                            "verification_reason_code": "USEFULNESS_DROP",
+                            "verification_status": "ROLLBACK_REQUIRED",
+                            "ts_ms": "1020"}],
+        "rollback_requests": [],
+        "rollback_results": [],
+        "rollback_journal": [],
+        "retry_requests": [],
+        "slo_rollups": [],
+        "escalations": [],
+        "audit": [],
+    }
+    bundle = build_bundle("exp-1", request_row, sections)
+    assert bundle["incident_id"] == "exp-1"
+    assert bundle["timeline_json"]
+    assert bundle["bundle_hash"]
