+import sys
+import types
+
+# Minimal stubs so we can import the module without optional runtime deps.
+redis_mod = types.ModuleType("redis")
+redis_asyncio_mod = types.ModuleType("redis.asyncio")
+setattr(redis_mod, "asyncio", redis_asyncio_mod)
+sys.modules.setdefault("redis", redis_mod)
+sys.modules.setdefault("redis.asyncio", redis_asyncio_mod)
+
+prom_mod = types.ModuleType("prometheus_client")
+class _DummyMetric:
+    def __init__(self, *a, **k):
+        pass
+    def labels(self, *a, **k):
+        return self
+    def inc(self, *a, **k):
+        return None
+    def set(self, *a, **k):
+        return None
+prom_mod.Counter = _DummyMetric
+prom_mod.Gauge = _DummyMetric
+prom_mod.start_http_server = lambda *a, **k: None
+sys.modules.setdefault("prometheus_client", prom_mod)
+
+core_mod = types.ModuleType("core")
+core_rsc = types.ModuleType("core.redis_stream_consumer")
+class _DummyHelper:
+    def __init__(self, *a, **k):
+        pass
+core_rsc.AsyncRedisStreamHelper = _DummyHelper
+sys.modules.setdefault("core", core_mod)
+sys.modules.setdefault("core.redis_stream_consumer", core_rsc)
+
+from services.orderflow.tools.trade_close_joiner_worker_v5 import _enrich_calib_fields
+
+
+def test_enrich_calib_fields_prefers_close_payload_then_signal_payload_then_decision():
+    out = {}
+    close_payload = {
+        "paper_only": 1,
+        "signal_payload": {
+            "calib": 1,
+            "calib_kind": "cont_ctx_window",
+            "candidate_window_ms": 180000,
+            "baseline_window_ms": 120000,
+            "entry_reason": "rescued_cont_ctx_window",
+        },
+    }
+    decision = {
+        "parent_signal_id": "sig-parent",
+        "cont_ctx_age_ms": 111000,
+    }
+
+    _enrich_calib_fields(out, close_payload, decision)
+
+    assert out["paper_only"] == 1
+    assert out["calib"] == 1
+    assert out["calib_kind"] == "cont_ctx_window"
+    assert out["candidate_window_ms"] == 180000
+    assert out["baseline_window_ms"] == 120000
+    assert out["entry_reason"] == "rescued_cont_ctx_window"
+    assert out["parent_signal_id"] == "sig-parent"
+    assert out["cont_ctx_age_ms"] == 111000
+
+
+def test_enrich_calib_fields_close_payload_overrides_signal_payload():
+    out = {}
+    close_payload = {
+        "candidate_window_ms": 150000,
+        "signal_payload": {
+            "candidate_window_ms": 180000,
+            "calib": 1,
+        },
+    }
+    decision = {"candidate_window_ms": 210000}
+
+    _enrich_calib_fields(out, close_payload, decision)
+
+    assert out["candidate_window_ms"] == 150000
+    assert out["calib"] == 1
