+def _signal_payload_dict(d: Dict[str, Any]) -> Dict[str, Any]:
+    sp = d.get("signal_payload")
+    if isinstance(sp, dict):
+        return sp
+    if isinstance(sp, str) and sp:
+        obj = _loads_json(sp)
+        return obj if isinstance(obj, dict) else {}
+    return {}
+
+
+def _copy_if_present(dst: Dict[str, Any], src: Dict[str, Any], key: str, *alt_keys: str) -> None:
+    v = _pick(src, key, *alt_keys)
+    if v is not None:
+        dst[key] = v
+
+
+def _enrich_calib_fields(out: Dict[str, Any], close_payload: Dict[str, Any], decision: Dict[str, Any]) -> None:
+    """Propagate shadow/paper calibrator fields into trades:closed.
+
+    Priority: close payload -> signal_payload -> decision.
+    This keeps the stream contract flat for calibrators/exporters while staying fail-open.
+    """
+    sp = _signal_payload_dict(close_payload)
+
+    def pickv(key: str, *alts: str):
+        v = _pick(close_payload, key, *alts)
+        if v is not None:
+            return v
+        v = _pick(sp, key, *alts)
+        if v is not None:
+            return v
+        return _pick(decision, key, *alts)
+
+    for key, alts in (
+        ("paper_only", tuple()),
+        ("shadow_only", tuple()),
+        ("is_virtual", tuple()),
+        ("calib", tuple()),
+        ("calib_kind", tuple()),
+        ("calib_run_id", tuple()),
+        ("candidate_window_ms", tuple()),
+        ("baseline_window_ms", tuple()),
+        ("cont_ctx_age_ms", tuple()),
+        ("entry_reason", tuple()),
+        ("parent_signal_id", tuple()),
+    ):
+        v = pickv(key, *alts)
+        if v is not None:
+            out[key] = v
+
+    # Normalize flags to 0/1 where possible.
+    for key in ("paper_only", "shadow_only", "is_virtual", "calib"):
+        if key in out:
+            try:
+                out[key] = int(out[key] or 0)
+            except Exception:
+                out[key] = 1 if bool(out[key]) else 0
+
+
