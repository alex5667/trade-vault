[Unit]
Description=ExecHealth ACL policy apply with rollout preflight guard
After=network-online.target docker.service
Wants=network-online.target
Requires=docker.service

[Service]
Type=oneshot
EnvironmentFile=-/etc/default/exec-health-freeze-acl-policy-apply
WorkingDirectory=/opt/scanner_infra
ExecStart=/opt/scanner_infra/orderflow_services/deploy/systemd/run-exec-health-freeze-acl-policy-apply-v1.sh
Nice=10
TimeoutStartSec=1800

[Install]
WantedBy=multi-user.target
