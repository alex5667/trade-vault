+services:
+  scanner-route-incident-rca-mirror-governor-v3-7:
+    build: { context: ., dockerfile: python-worker/Dockerfile.gpu }
+    command: ["python", "-m", "orderflow_services.route_incident_rca_mirror_governor_v3_7"]
+    restart: unless-stopped
+    environment:
+      REDIS_URL: ${REDIS_URL:-redis://redis-worker-1:6379/0}
+      DATABASE_URL: ${DATABASE_URL:-}
+      ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_PORT: ${ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_PORT:-9923}
+      ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_RUN_EVERY_SEC: ${ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_RUN_EVERY_SEC:-300}
+      ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_WINDOW_MIN: ${ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_WINDOW_MIN:-1440}
+      ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_LOOKBACK_COUNT: ${ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_LOOKBACK_COUNT:-500}
+      ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_ADVISORY_ONLY: ${ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_ADVISORY_ONLY:-1}
+      ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_EXECUTOR_MODE: ${ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_EXECUTOR_MODE:-DRY_RUN}
+      ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_MIN_SAMPLE: ${ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_MIN_SAMPLE:-20}
+      ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_MAX_MISMATCH_RATE: ${ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_MAX_MISMATCH_RATE:-0.00}
+      ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_MAX_DRIFT_RATE: ${ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_MAX_DRIFT_RATE:-0.20}
+      ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_MIN_MATCH_RATE: ${ML_ROUTE_INCIDENT_RCA_MIRROR_GOVERNOR_MIN_MATCH_RATE:-0.70}
