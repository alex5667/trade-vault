# MT5 Bridge Environment Configuration
# Copy this file to mt5-bridge.env and fill in your values

# MT5 Account Credentials (REQUIRED)
# For RoboForex Demo Account (from project documentation)
MT5_LOGIN=12345678
MT5_PASSWORD=demo_password
MT5_SERVER=RoboForex-Demo

# Redis Connection (OPTIONAL - defaults to redis-worker-1)
REDIS_DSN=redis://redis-worker-1:6379/0

# Symbol Mapping (OPTIONAL - JSON string)
# Maps scanner_infra symbols to MT5 symbol names
# RoboForex typically uses .m suffix for metals
MT5_SYMBOL_MAP='{"XAUUSD": "XAUUSD.m", "BTCUSDT": "BTCUSDT.m", "EURUSD": "EURUSD.", "GBPUSD": "GBPUSD."}'

# Performance Tuning (OPTIONAL)
POLL_BLOCK_MS=500
POLL_COUNT=20
STEP_INTERVAL=0.2

# Logging (OPTIONAL)
LOG_LEVEL=INFO
