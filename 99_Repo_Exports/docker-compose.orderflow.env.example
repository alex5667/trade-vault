# ============================================================================
# Docker Compose - OrderFlow Handler Environment Variables
# ============================================================================
# Этот файл содержит рекомендуемые environment variables для python-worker
# сервисов в docker-compose.yml
#
# Использование:
# 1. Добавьте эти переменные в секцию environment вашего python-worker сервиса
# 2. Или создайте .env файл и используйте env_file в docker-compose
# ============================================================================

# ----------------------------------------------------------------------------
# БАЗОВАЯ КОНФИГУРАЦИЯ (рекомендуется для всех)
# ----------------------------------------------------------------------------

# === 1. СТРОГИЙ BREAKOUT ПО OBI ===
BREAKOUT_REQUIRE_OBI=true

# === 2. OBI SUSTAINED КАК "УСТОЙЧИВОСТЬ" ===
OBI_SUSTAINED_USE_FRACTION=true
OBI_SUSTAINED_MIN_SAMPLES=3
OBI_SUSTAINED_MIN_FRACTION=0.6

# === 3. ПОРОГИ Z-SCORE ПО ТИПАМ СИГНАЛОВ ===
BREAKOUT_Z_THRESHOLD=3.0
ABSORPTION_Z_THRESHOLD=3.0
EXTREME_Z_MULT=1.6

# === 4. ABSORPTION CONTROLS ===
ABSORPTION_REQUIRE_WEAK_PROGRESS=true

# === 5. ABSORPTION MICRO-PROXY (для crypto) ===
ABSORPTION_USE_MICRO_PROXY=true
ABSORPTION_MICRO_ADVERSE_MIN=0.60
ABSORPTION_MICRO_REALIZED_EMA_MAX=-0.50

# ----------------------------------------------------------------------------
# ДОПОЛНИТЕЛЬНЫЕ ПАРАМЕТРЫ
# ----------------------------------------------------------------------------
BREAKOUT_MIN_DIST_ATR=0.0
LEVEL_SIGNAL_COOLDOWN_MS=15000
OBI_MAX_STALE_MS=2500
DELTA_BUCKET_MS=1000
DELTA_BUCKET_MAX_ZERO_FILL=3
MAX_TICK_LAG_MS=5000

# ----------------------------------------------------------------------------
# DECISION TRACE SYSTEM (рекомендуется включить для диагностики)
# ----------------------------------------------------------------------------
DECISION_TRACE_ENABLE=1
DECISION_TRACE_MAX_EVENTS=200
DECISION_TRACE_DIAG_STREAM=stream:signals:diagnostics
SIGNAL_DIAGNOSTICS_STREAM=stream:signals:diagnostics
DECISION_TRACE_SIDECAR_UPDATE_ON_SUCCESS=0
DECISION_TRACE_LOG_SAMPLE_RATE=0.02
DECISION_TRACE_SUMMARY_MAXLEN=240
DECISION_TRACE_SIDECAR_MAX_BYTES=120000
RUNTIME_REFRESH_EVERY_SEC=10

# ----------------------------------------------------------------------------
# DETERMINISM & REPLAY (Round 9)
# ----------------------------------------------------------------------------
PUBLISH_OF_INPUTS=1
OF_INPUTS_STREAM=signals:of:inputs
PUBLISH_OF_CONFIRM=1
OF_CONFIRM_STREAM=signals:of:confirm

# ----------------------------------------------------------------------------
# SUPERVISOR CONFIGURATION
# ----------------------------------------------------------------------------
CRYPTO_OF_SUPERVISOR=true
CRYPTO_OF_SUPERVISOR_INTERVAL_SEC=5
CRYPTO_OF_SUPERVISOR_MAX_RESTARTS=10
CRYPTO_OF_SUPERVISOR_WINDOW_SEC=300

# ----------------------------------------------------------------------------
# ПРИМЕР ИСПОЛЬЗОВАНИЯ В docker-compose.yml
# ----------------------------------------------------------------------------
#
# services:
#   python-worker-btcusdt:
#     build: ./python-worker
#     environment:
#       # Redis connections
#       - REDIS_URL=redis://scanner-redis:6379/0
#       - REDIS_TICKS_URL=redis://redis-ticks:6379/0
#       
#       # BaseOrderFlowHandler - рекомендуемые значения
#       - BREAKOUT_REQUIRE_OBI=true
#       - OBI_SUSTAINED_USE_FRACTION=true
#       - OBI_SUSTAINED_MIN_SAMPLES=3
#       - OBI_SUSTAINED_MIN_FRACTION=0.6
#       - BREAKOUT_Z_THRESHOLD=3.0
#       - ABSORPTION_Z_THRESHOLD=3.0
#       - EXTREME_Z_MULT=1.6
#       - ABSORPTION_REQUIRE_WEAK_PROGRESS=true
#       - ABSORPTION_USE_MICRO_PROXY=true
#       - ABSORPTION_MICRO_ADVERSE_MIN=0.60
#       - ABSORPTION_MICRO_REALIZED_EMA_MAX=-0.50
#       
#       # Instrument specific
#       - BTCUSDT_DELTA_Z_THRESHOLD=2.7
#       - BTCUSDT_OBI_THRESHOLD=0.35
#       - BTCUSDT_WEAK_PROGRESS_ATR=0.15
#
# ----------------------------------------------------------------------------
# ИЛИ ИСПОЛЬЗОВАНИЕ env_file
# ----------------------------------------------------------------------------
#
# services:
#   python-worker-btcusdt:
#     build: ./python-worker
#     env_file:
#       - ./python-worker/env.example
#     environment:
#       # Переопределить специфичные для контейнера
#       - SYMBOL=BTCUSDT
#
# ============================================================================

