    {
      "title": "Adverse RD / Cancel-to-Trade / Taker Imbalance",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        { "expr": "max(trade_adverse_rd_bad_share)", "legendFormat": "Adverse RD Bad" },
