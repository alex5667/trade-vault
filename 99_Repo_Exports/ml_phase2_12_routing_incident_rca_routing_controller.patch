+BEGIN;
+
+CREATE TABLE IF NOT EXISTS llm_operator_routing_incident_rca_routing_decisions (
+    id                        bigserial PRIMARY KEY,
+    route_change_id           text NOT NULL,
+    ts_ms                     bigint NOT NULL,
+    task_type                 text,
+    compact_hash              text,
+    input_provider            text,
+    input_model_name          text,
+    input_prompt_version      text,
+    input_policy_version      text,
+    route_decision            text NOT NULL,
+    effective_provider        text NOT NULL,
+    effective_model_name      text NOT NULL,
+    effective_prompt_version  text NOT NULL,
+    effective_policy_version  text NOT NULL,
+    routing_mode              text NOT NULL,
+    committed                 boolean NOT NULL DEFAULT false,
+    suppress_reasons_json     jsonb,
+    provider_policy_decision  text,
+    promote_signals_n         integer
+);
+
+CREATE INDEX IF NOT EXISTS idx_llm_operator_routing_incident_rca_routing_decisions_route_change_id
+    ON llm_operator_routing_incident_rca_routing_decisions(route_change_id);
+
+CREATE INDEX IF NOT EXISTS idx_llm_operator_routing_incident_rca_routing_decisions_ts_ms
+    ON llm_operator_routing_incident_rca_routing_decisions(ts_ms DESC);
+
+COMMIT;
