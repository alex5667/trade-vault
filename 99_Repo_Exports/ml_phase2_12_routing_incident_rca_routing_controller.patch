+      ML_OPERATOR_ROUTING_INCIDENT_RCA_DEFAULT_MODEL: ${ML_OPERATOR_ROUTING_INCIDENT_RCA_DEFAULT_MODEL:-gemini-2.5-flash-lite}
+      ML_OPERATOR_ROUTING_INCIDENT_RCA_DEFAULT_PROMPT_VERSION: ${ML_OPERATOR_ROUTING_INCIDENT_RCA_DEFAULT_PROMPT_VERSION:-routing_incident_rca_v1}
