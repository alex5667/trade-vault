+groups:
+  - name: ml_phase2_integration_freeze_v1
+    rules:
+      - alert: MLPhase2IntegrationFreezeStale
+        expr: time() - ml_phase2_integration_freeze_last_run_ts_seconds > 1800
+        for: 10m
+        labels: { severity: warning }
+        annotations:
+          summary: "phase2 integration freeze auditor is stale"
+
+      - alert: MLPhase2IntegrationFreezeNoGo
+        expr: ml_phase2_integration_freeze_failed_checks > 0
+        for: 5m
+        labels: { severity: critical }
+        annotations:
+          summary: "phase2 integration freeze produced NO_GO"
+
+      - alert: MLPhase2IntegrationFreezeWarn
+        expr: ml_phase2_integration_freeze_warn_checks > 0
+        for: 15m
+        labels: { severity: warning }
+        annotations:
+          summary: "phase2 integration freeze produced WARN checks"
