+from orderflow_services.phase2_integration_freeze_auditor_v2_if1 import (
+    age_ms_from_ts,
+    parse_ts_ms,
+    summarize_decision,
+)
+
+
+def test_parse_ts_ms_handles_invalid_values():
+    assert parse_ts_ms("1000") == 1000
+    assert parse_ts_ms(None) == 0
+    assert parse_ts_ms("bad") == 0
+
+
+def test_age_ms_from_ts_is_bounded():
+    assert age_ms_from_ts(1000, 2000) == 1000
+    assert age_ms_from_ts(0, 2000) >= 10**12
+
+
+def test_summarize_decision():
+    assert summarize_decision(0, 0) == "GO"
+    assert summarize_decision(0, 2) == "WARN"
+    assert summarize_decision(1, 0) == "NO_GO"
