+def _decode(fields: Dict[Any, Any]) -> Dict[str, str]:
+    out: Dict[str, str] = {}
+    for k, v in fields.items():
+        kk = k.decode() if isinstance(k, (bytes, bytearray)) else str(k)
+        vv = v.decode() if isinstance(v, (bytes, bytearray)) else str(v)
