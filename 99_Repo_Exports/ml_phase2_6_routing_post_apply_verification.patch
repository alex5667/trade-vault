+        ts_ms=int(float(d.get("ts_ms", "0") or 0)),
+        rollback_type=d.get("rollback_type", "ROUTE_DEFAULT_ROLLBACK"),
+        baseline_route_json=d.get("baseline_route_json", "{}"),
+        applied_route_json=d.get("applied_route_json", "{}"),
