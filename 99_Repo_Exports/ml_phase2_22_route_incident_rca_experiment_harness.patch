new file mode 100644
index 0000000..5555555
--- /dev/null
+++ b/orderflow_services/tests/test_operator_routing_incident_route_rca_experiment_harness_v2_22.py
@@ -0,0 +1,39 @@
+from orderflow_services.operator_routing_incident_route_rca_experiment_router_v2_22 import (
+    choose_arm,
+)
+from orderflow_services.operator_routing_incident_route_rca_experiment_winner_selector_v2_22 import (
+    arm_score,
+)
+
+
+def test_choose_arm_is_deterministic():
+    a = choose_arm("inc-123", "exp-a", 0.5)
+    b = choose_arm("inc-123", "exp-a", 0.5)
+    assert a == b
+    assert a in {"control", "challenger"}
+
+
+def test_choose_arm_respects_extreme_shares():
+    assert choose_arm("inc-1", "exp-a", 1.0) == "control"
+    assert choose_arm("inc-1", "exp-a", 0.0) == "challenger"
+
+
+def test_arm_score_weights_usefulness_higher():
+    score = arm_score(quality_avg=0.5, usefulness_avg=1.0)
+    assert round(score, 6) == round(0.4 * 0.5 + 0.6 * 1.0, 6)
