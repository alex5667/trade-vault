+BEGIN;
+
+CREATE TABLE IF NOT EXISTS llm_operator_routing_incident_route_rca_exposure_logs (
+    id                bigserial PRIMARY KEY,
+    incident_id       text NOT NULL,
+    experiment_id     text NOT NULL,
+    experiment_arm    text NOT NULL,
+    provider          text NOT NULL,
+    model_name        text NOT NULL,
+    prompt_version    text NOT NULL,
+    policy_version    text NOT NULL,
+    ts_ms             bigint NOT NULL
+);
+
+CREATE INDEX IF NOT EXISTS idx_llm_operator_routing_incident_route_rca_exposure_logs_exp_ts
+    ON llm_operator_routing_incident_route_rca_exposure_logs(experiment_id, ts_ms DESC);
+
+CREATE TABLE IF NOT EXISTS llm_operator_routing_incident_route_rca_experiment_winner_decisions (
+    id                bigserial PRIMARY KEY,
+    experiment_id     text NOT NULL,
+    ts_ms             bigint NOT NULL,
+    decision          text NOT NULL,
+    winner            text NOT NULL,
+    uplift            double precision NOT NULL,
+    control_json      jsonb NOT NULL,
+    challenger_json   jsonb NOT NULL
+);
+
+CREATE INDEX IF NOT EXISTS idx_llm_operator_routing_incident_route_rca_experiment_winner_decisions_exp_ts
+    ON llm_operator_routing_incident_route_rca_experiment_winner_decisions(experiment_id, ts_ms DESC);
+
+COMMIT;
