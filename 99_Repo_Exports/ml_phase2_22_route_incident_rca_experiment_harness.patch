+from __future__ import annotations
+
+import hashlib
+import json
+import os
+import time
+from typing import Any, Dict, Tuple
+
+try:  # pragma: no cover
+    import redis.asyncio as redis
+except Exception:  # pragma: no cover
+    redis = None
+
+try:  # pragma: no cover
+    from prometheus_client import Counter, Gauge, Histogram, start_http_server
+except Exception:  # pragma: no cover
+    Counter = Gauge = Histogram = None
+    def start_http_server(*args: Any, **kwargs: Any) -> None:
+        return None
+
+
+APP_NAME = "operator_routing_incident_route_rca_experiment_router_v2_22"
+INPUT_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_EXPERIMENT_INPUT_STREAM",
+    "stream:ml:operator_routing_incident_rca_route_rca_requests_routed",
+)
+OUTPUT_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_EXPERIMENT_OUTPUT_STREAM",
+    "stream:ml:operator_routing_incident_route_rca_requests_experimented",
+)
+EXPOSURES_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_EXPOSURES_STREAM",
+    "stream:ml:operator_routing_incident_route_rca_exposures",
+)
+AUDIT_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_EXPERIMENT_AUDIT_STREAM",
+    "stream:ml:operator_routing_incident_route_rca_experiment_audit",
+)
+GROUP = os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_EXPERIMENT_GROUP", APP_NAME)
+CONSUMER = os.getenv("HOSTNAME", APP_NAME)
+PORT = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_EXPERIMENT_PORT", "9907"))
+MAXLEN = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_EXPERIMENT_MAXLEN", "20000"))
+
+EXPERIMENT_ENABLE = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_EXPERIMENT_ENABLE", "1"))
+EXPERIMENT_ID = os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_EXPERIMENT_ID", "route_incident_rca_ab_v1")
+CONTROL_SHARE = float(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_CONTROL_SHARE", "0.5"))
+
+CONTROL_PROVIDER = os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_CONTROL_PROVIDER", "vertex")
+CONTROL_MODEL = os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_CONTROL_MODEL", "gemini-2.5-flash-lite")
+CONTROL_PROMPT_VERSION = os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_CONTROL_PROMPT_VERSION", "routing_incident_route_rca_v1")
+CONTROL_POLICY_VERSION = os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_CONTROL_POLICY_VERSION", "policy_v1")
+
+CHALLENGER_PROVIDER = os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_CHALLENGER_PROVIDER", "vertex")
+CHALLENGER_MODEL = os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_CHALLENGER_MODEL", "gemini-2.5-flash")
+CHALLENGER_PROMPT_VERSION = os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_CHALLENGER_PROMPT_VERSION", "routing_incident_route_rca_v2")
+CHALLENGER_POLICY_VERSION = os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_CHALLENGER_POLICY_VERSION", "policy_v1")
+
+
+def _counter(name: str, doc: str, labels: Tuple[str, ...] = ()) -> Any:
+    return Counter(name, doc, labels) if Counter else None
+
+
+def _gauge(name: str, doc: str, labels: Tuple[str, ...] = ()) -> Any:
+    return Gauge(name, doc, labels) if Gauge else None
+
+
+def _hist(name: str, doc: str, labels: Tuple[str, ...] = ()) -> Any:
+    return Histogram(name, doc, labels) if Histogram else None
+
+
+RUNS = _counter(
+    "ml_operator_routing_incident_route_rca_experiment_runs_total",
+    "Route-incident RCA experiment router runs",
+    ("status", "arm"),
+)
+LAT = _hist(
+    "ml_operator_routing_incident_route_rca_experiment_latency_seconds",
+    "Route-incident RCA experiment router latency seconds",
+)
+UP = _gauge(
+    "ml_operator_routing_incident_route_rca_experiment_up",
+    "Route-incident RCA experiment router up",
+)
+LAST_RUN_TS = _gauge(
+    "ml_operator_routing_incident_route_rca_experiment_last_run_ts_seconds",
+    "Route-incident RCA experiment router last run timestamp",
+)
+EXPOSURES = _counter(
+    "ml_operator_routing_incident_route_rca_exposures_total",
+    "Route-incident RCA experiment exposures",
+    ("experiment_id", "arm"),
+)
+
+
+def now_ms() -> int:
+    return int(time.time() * 1000)
+
+
+def as_dict(fields: Dict[Any, Any]) -> Dict[str, Any]:
+    out: Dict[str, Any] = {}
+    for k, v in fields.items():
+        kk = k.decode() if isinstance(k, (bytes, bytearray)) else str(k)
+        if isinstance(v, (bytes, bytearray)):
+            try:
+                out[kk] = v.decode()
+            except Exception:
+                out[kk] = v.hex()
+        else:
+            out[kk] = v
+    return out
+
+
+def _hash01(s: str) -> float:
+    h = hashlib.sha256(s.encode("utf-8")).digest()
+    x = int.from_bytes(h[:8], "big", signed=False)
+    return (x % 10_000_000) / 10_000_000.0
+
+
+def choose_arm(incident_id: str, experiment_id: str, control_share: float) -> str:
+    if control_share <= 0.0:
+        return "challenger"
+    if control_share >= 1.0:
+        return "control"
+    return "control" if _hash01(f"{experiment_id}:{incident_id}") < control_share else "challenger"
+
+
+def route_for_arm(arm: str) -> Dict[str, str]:
+    if arm == "challenger":
+        return {
+            "provider": CHALLENGER_PROVIDER,
+            "model_name": CHALLENGER_MODEL,
+            "prompt_version": CHALLENGER_PROMPT_VERSION,
+            "policy_version": CHALLENGER_POLICY_VERSION,
+        }
+    return {
+        "provider": CONTROL_PROVIDER,
+        "model_name": CONTROL_MODEL,
+        "prompt_version": CONTROL_PROMPT_VERSION,
+        "policy_version": CONTROL_POLICY_VERSION,
+    }
+
+
+def stable_json(obj: Any) -> str:
+    return json.dumps(obj, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
+
+
+async def ensure_group(client: Any, stream_key: str, group: str) -> None:
+    try:
+        await client.xgroup_create(stream_key, group, id="$", mkstream=True)
+    except Exception:
+        return
+
+
+async def main() -> None:  # pragma: no cover
+    if redis is None:
+        raise RuntimeError("redis.asyncio is required")
+    start_http_server(PORT)
+    if UP:
+        UP.set(1)
+    r = redis.from_url(os.getenv("REDIS_URL", "redis://localhost:6379/0"))
+    await ensure_group(r, INPUT_STREAM, GROUP)
+    while True:
+        rows = await r.xreadgroup(GROUP, CONSUMER, {INPUT_STREAM: ">"}, count=32, block=5000)
+        if not rows:
+            continue
+        for _stream, messages in rows:
+            for msg_id, payload in messages:
+                started = time.perf_counter()
+                status = "ok"
+                arm = "control"
+                try:
+                    row = as_dict(payload)
+                    incident_id = row.get("incident_id", "") or row.get("request_id", "")
+                    if not incident_id:
+                        raise ValueError("missing incident_id")
+                    if EXPERIMENT_ENABLE != 1:
+                        arm = "control"
+                    else:
+                        arm = choose_arm(incident_id, EXPERIMENT_ID, CONTROL_SHARE)
+                    chosen = route_for_arm(arm)
+                    routed = {
+                        "schema_version": 1,
+                        "incident_id": incident_id,
+                        "task_type": row.get("task_type", ""),
+                        "payload_json": row.get("payload_json", "{}"),
+                        "compact_hash": row.get("compact_hash", ""),
+                        "severity": row.get("severity", "info"),
+                        "experiment_id": EXPERIMENT_ID,
+                        "experiment_arm": arm,
+                        "provider": chosen["provider"],
+                        "model_name": chosen["model_name"],
+                        "prompt_version": chosen["prompt_version"],
+                        "policy_version": chosen["policy_version"],
+                        "ts_ms": str(now_ms()),
+                    }
+                    await r.xadd(OUTPUT_STREAM, routed, maxlen=MAXLEN, approximate=True)
+                    await r.xadd(
+                        EXPOSURES_STREAM,
+                        {
+                            "schema_version": 1,
+                            "incident_id": incident_id,
+                            "experiment_id": EXPERIMENT_ID,
+                            "experiment_arm": arm,
+                            "provider": chosen["provider"],
+                            "model_name": chosen["model_name"],
+                            "prompt_version": chosen["prompt_version"],
+                            "policy_version": chosen["policy_version"],
+                            "ts_ms": str(now_ms()),
+                        },
+                        maxlen=MAXLEN,
+                        approximate=True,
+                    )
+                    await r.xadd(
+                        AUDIT_STREAM,
+                        {
+                            "event_type": "ROUTE_INCIDENT_RCA_EXPERIMENT_ROUTED",
+                            "incident_id": incident_id,
+                            "experiment_id": EXPERIMENT_ID,
+                            "experiment_arm": arm,
+                            "provider": chosen["provider"],
+                            "model_name": chosen["model_name"],
+                            "prompt_version": chosen["prompt_version"],
+                            "policy_version": chosen["policy_version"],
+                            "ts_ms": str(now_ms()),
+                        },
+                        maxlen=MAXLEN,
+                        approximate=True,
+                    )
+                    await r.xack(INPUT_STREAM, GROUP, msg_id)
+                    if LAST_RUN_TS:
+                        LAST_RUN_TS.set(time.time())
+                    if EXPOSURES:
+                        EXPOSURES.labels(experiment_id=EXPERIMENT_ID, arm=arm).inc()
+                except Exception as exc:
+                    status = "error"
+                    await r.xadd(
+                        AUDIT_STREAM,
+                        {
+                            "event_type": "ROUTE_INCIDENT_RCA_EXPERIMENT_ROUTER_FAILED",
+                            "error": str(exc),
+                            "ts_ms": str(now_ms()),
+                        },
+                        maxlen=MAXLEN,
+                        approximate=True,
+                    )
+                    await r.xack(INPUT_STREAM, GROUP, msg_id)
+                finally:
+                    if RUNS:
+                        RUNS.labels(status=status, arm=arm).inc()
+                    if LAT:
+                        LAT.observe(max(time.perf_counter() - started, 0.0))
+
+
+if __name__ == "__main__":  # pragma: no cover
+    import asyncio
+    asyncio.run(main())
