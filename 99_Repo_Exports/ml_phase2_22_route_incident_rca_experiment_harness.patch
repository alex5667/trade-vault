+from __future__ import annotations
+
+import json
+import os
+import time
+from collections import defaultdict
+from typing import Any, Dict, List, Tuple
+
+try:  # pragma: no cover
+    import redis.asyncio as redis
+except Exception:  # pragma: no cover
+    redis = None
+
+try:  # pragma: no cover
+    from prometheus_client import Counter, Gauge, Histogram, start_http_server
+except Exception:  # pragma: no cover
+    Counter = Gauge = Histogram = None
+    def start_http_server(*args: Any, **kwargs: Any) -> None:
+        return None
+
+
+APP_NAME = "operator_routing_incident_route_rca_experiment_winner_selector_v2_22"
+EXPOSURES_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_EXPOSURES_STREAM",
+    "stream:ml:operator_routing_incident_route_rca_exposures",
+)
+RESULTS_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_RESULTS_STREAM",
+    "stream:ml:operator_routing_incident_rca_route_rca_results",
+)
+FEEDBACK_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_FEEDBACK_SUMMARY_STREAM",
+    "stream:ml:operator_routing_incident_rca_route_rca_feedback_summary",
+)
+WINNER_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_WINNER_DECISIONS_STREAM",
+    "stream:ml:operator_routing_incident_route_rca_experiment_winner_decisions",
+)
+AUDIT_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_EXPERIMENT_AUDIT_STREAM",
+    "stream:ml:operator_routing_incident_route_rca_experiment_audit",
+)
+STATE_PREFIX = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_WINNER_STATE_PREFIX",
+    "cfg:ml:operator_routing_incident_route_rca_experiment:winner:",
+)
+PORT = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_WINNER_SELECTOR_PORT", "9908"))
+WINDOW_MIN = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_EXPERIMENT_WINDOW_MIN", "1440"))
+MIN_SAMPLE = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_EXPERIMENT_MIN_SAMPLE", "8"))
+MAXLEN = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_WINNER_SELECTOR_MAXLEN", "20000"))
+EXPERIMENT_ID = os.getenv("ML_OPERATOR_ROUTING_INCIDENT_ROUTE_RCA_EXPERIMENT_ID", "route_incident_rca_ab_v1")
+
+
+def _counter(name: str, doc: str, labels: Tuple[str, ...] = ()) -> Any:
+    return Counter(name, doc, labels) if Counter else None
+
+
+def _gauge(name: str, doc: str, labels: Tuple[str, ...] = ()) -> Any:
+    return Gauge(name, doc, labels) if Gauge else None
+
+
+def _hist(name: str, doc: str, labels: Tuple[str, ...] = ()) -> Any:
+    return Histogram(name, doc, labels) if Histogram else None
+
+
+RUNS = _counter(
+    "ml_operator_routing_incident_route_rca_experiment_winner_runs_total",
+    "Route-incident RCA experiment winner runs",
+    ("decision",),
+)
+LAT = _hist(
+    "ml_operator_routing_incident_route_rca_experiment_winner_latency_seconds",
+    "Route-incident RCA experiment winner latency seconds",
+)
+UP = _gauge(
+    "ml_operator_routing_incident_route_rca_experiment_winner_up",
+    "Route-incident RCA experiment winner selector up",
+)
+LAST_RUN_TS = _gauge(
+    "ml_operator_routing_incident_route_rca_experiment_winner_last_run_ts_seconds",
+    "Route-incident RCA experiment winner selector last run timestamp",
+)
+
+
+def now_ms() -> int:
+    return int(time.time() * 1000)
+
+
+def as_dict(fields: Dict[Any, Any]) -> Dict[str, Any]:
+    out: Dict[str, Any] = {}
+    for k, v in fields.items():
+        kk = k.decode() if isinstance(k, (bytes, bytearray)) else str(k)
+        if isinstance(v, (bytes, bytearray)):
+            try:
+                out[kk] = v.decode()
+            except Exception:
+                out[kk] = v.hex()
+        else:
+            out[kk] = v
+    return out
+
+
+def stable_json(obj: Any) -> str:
+    return json.dumps(obj, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
+
+
+async def xr_recent(client: Any, stream_key: str, limit: int) -> List[Dict[str, Any]]:
+    try:
+        rows = await client.xrevrange(stream_key, count=limit)
+    except Exception:
+        return []
+    out: List[Dict[str, Any]] = []
+    for entry_id, payload in rows:
+        row = as_dict(payload)
+        row["_stream_id"] = entry_id.decode() if isinstance(entry_id, (bytes, bytearray)) else str(entry_id)
+        out.append(row)
+    return out
+
+
+def arm_score(quality_avg: float, usefulness_avg: float) -> float:
+    return round(0.4 * quality_avg + 0.6 * usefulness_avg, 6)
+
+
+async def main() -> None:  # pragma: no cover
+    if redis is None:
+        raise RuntimeError("redis.asyncio is required")
+    start_http_server(PORT)
+    if UP:
+        UP.set(1)
+    r = redis.from_url(os.getenv("REDIS_URL", "redis://localhost:6379/0"))
+    lookback = max(MIN_SAMPLE * 50, 200)
+
+    while True:
+        started = time.perf_counter()
+        decision = "HOLD"
+        try:
+            exposures = await xr_recent(r, EXPOSURES_STREAM, lookback)
+            results = await xr_recent(r, RESULTS_STREAM, lookback)
+            feedback = await xr_recent(r, FEEDBACK_STREAM, lookback)
+
+            exposure_by_incident: Dict[str, Dict[str, Any]] = {}
+            for row in exposures:
+                if row.get("experiment_id") != EXPERIMENT_ID:
+                    continue
+                incident_id = row.get("incident_id", "")
+                if not incident_id:
+                    continue
+                exposure_by_incident[incident_id] = row
+
+            arm_quality = defaultdict(list)
+            for row in results:
+                incident_id = row.get("incident_id", "")
+                exp = exposure_by_incident.get(incident_id)
+                if not exp:
+                    continue
+                arm = exp.get("experiment_arm", "")
+                try:
+                    payload = json.loads(row.get("result_json", "{}"))
+                    findings = payload.get("findings", []) or []
+                    recos = payload.get("recommendations", []) or []
+                    summary = 1.0 if str(payload.get("summary", "")).strip() else 0.0
+                    quality = min(1.0, 0.2 * summary + 0.15 * len(findings) + 0.1 * len(recos))
+                except Exception:
+                    quality = 0.5
+                arm_quality[arm].append(float(quality))
+
+            arm_usefulness = defaultdict(list)
+            for row in feedback:
+                incident_id = row.get("incident_id", "")
+                exp = exposure_by_incident.get(incident_id)
+                if not exp:
+                    continue
+                arm = exp.get("experiment_arm", "")
+                try:
+                    usefulness = float(row.get("usefulness_score", "0.5"))
+                except Exception:
+                    usefulness = 0.5
+                arm_usefulness[arm].append(usefulness)
+
+            def summarize_arm(arm: str) -> Dict[str, Any]:
+                q = arm_quality.get(arm, [])
+                u = arm_usefulness.get(arm, [])
+                sample_n = min(len(q) if q else 0, len(u) if u else 0) if q and u else max(len(q), len(u))
+                quality_avg = sum(q) / len(q) if q else 0.0
+                usefulness_avg = sum(u) / len(u) if u else 0.0
+                return {
+                    "sample_n": sample_n,
+                    "quality_avg": round(quality_avg, 6),
+                    "usefulness_avg": round(usefulness_avg, 6),
+                    "score": arm_score(quality_avg, usefulness_avg),
+                }
+
+            control = summarize_arm("control")
+            challenger = summarize_arm("challenger")
+
+            if control["sample_n"] < MIN_SAMPLE or challenger["sample_n"] < MIN_SAMPLE:
+                decision = "HOLD"
+                winner = "none"
+                uplift = 0.0
+            else:
+                uplift = round(challenger["score"] - control["score"], 6)
+                if uplift > 0.0:
+                    decision = "PROMOTE_CHALLENGER"
+                    winner = "challenger"
+                elif uplift < 0.0:
+                    decision = "KEEP_CONTROL"
+                    winner = "control"
+                else:
+                    decision = "HOLD"
+                    winner = "none"
+
+            payload = {
+                "schema_version": 1,
+                "experiment_id": EXPERIMENT_ID,
+                "decision": decision,
+                "winner": winner,
+                "control_json": stable_json(control),
+                "challenger_json": stable_json(challenger),
+                "uplift": str(uplift),
+                "ts_ms": str(now_ms()),
+            }
+            await r.xadd(WINNER_STREAM, payload, maxlen=MAXLEN, approximate=True)
+            await r.xadd(
+                AUDIT_STREAM,
+                {
+                    "event_type": "ROUTE_INCIDENT_RCA_EXPERIMENT_WINNER_DECIDED",
+                    "experiment_id": EXPERIMENT_ID,
+                    "decision": decision,
+                    "winner": winner,
+                    "uplift": str(uplift),
+                    "ts_ms": str(now_ms()),
+                },
+                maxlen=MAXLEN,
+                approximate=True,
+            )
+            await r.hset(
+                f"{STATE_PREFIX}{EXPERIMENT_ID}",
+                mapping={
+                    "decision": decision,
+                    "winner": winner,
+                    "uplift": str(uplift),
+                    "control_json": stable_json(control),
+                    "challenger_json": stable_json(challenger),
+                    "ts_ms": str(now_ms()),
+                },
+            )
+
+            if LAST_RUN_TS:
+                LAST_RUN_TS.set(time.time())
+        except Exception as exc:
+            decision = "ERROR"
+            await r.xadd(
+                AUDIT_STREAM,
+                {
+                    "event_type": "ROUTE_INCIDENT_RCA_EXPERIMENT_WINNER_FAILED",
+                    "experiment_id": EXPERIMENT_ID,
+                    "error": str(exc),
+                    "ts_ms": str(now_ms()),
+                },
+                maxlen=MAXLEN,
+                approximate=True,
+            )
+        finally:
+            if RUNS:
+                RUNS.labels(decision=decision).inc()
+            if LAT:
+                LAT.observe(max(time.perf_counter() - started, 0.0))
+            time.sleep(max(WINDOW_MIN, 5) * 60)
+
+
+if __name__ == "__main__":  # pragma: no cover
+    main()
