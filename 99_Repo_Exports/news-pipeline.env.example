# News Pipeline Environment Variables Example
# Copy this file to news-pipeline.env and customize the values

# Redis Configuration
REDIS_URL=redis://redis-worker-1:6379/0

# News RSS Sources (comma-separated URLs)
# Add your preferred RSS feeds here
NEWS_RSS_URLS=https://feeds.bbci.co.uk/news/rss.xml,https://rss.cnn.com/rss/edition.rss,https://feeds.reuters.com/reuters/topNews

# Stream Names
NEWS_RAW_STREAM=news:raw
NEWS_ANALYSIS_STREAM=news:analysis
CALENDAR_EVENTS_STREAM=calendar:events

# DLQ Streams
NEWS_RAW_DLQ=news:raw:dlq
NEWS_ANALYSIS_DLQ=news:analysis:dlq
CALENDAR_EVENTS_DLQ=calendar:events:dlq

# Consumer Groups
NEWS_ANALYZER_GROUP=news-analyzer
NEWS_FEATURE_GROUP=news-feature-store
CALENDAR_FEATURE_GROUP=calendar-feature-store

# TTL Settings (seconds)
NEWS_DEDUPE_TTL_SEC=172800
NEWS_ANALYSIS_TTL_SEC=604800
NEWS_AGG_TTL_SEC=7200
CALENDAR_EVENT_TTL_SEC=604800
CALENDAR_AGG_TTL_SEC=21600

# Processing Settings
NEWS_RISK_HALF_LIFE_SEC=1800
NEWS_STREAM_MAXLEN=100000
NEWS_DEBUG_SAMPLE_RATE=0.01

# Leader Lock
NEWS_INGESTOR_LEADER_KEY=news:ingestor:leader
NEWS_INGESTOR_LEADER_TTL_SEC=8

# Poll Intervals
NEWS_POLL_SEC=10

# Logging
LOG_LEVEL=INFO

# LLM Configuration (Gemini)
# IMPORTANT: Set your actual Gemini API key here
GEMINI_API_KEY=your_actual_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# LLM Fallback — DeepSeek-v3.2 via Nvidia Integrate API
NVIDIA_DEEPSEEK_API_KEY=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
NVIDIA_DEEPSEEK_MODEL=deepseek-ai/deepseek-v3.2

# News Sources Configuration JSON
# This defines which news providers are enabled and their settings
NEWS_SOURCES_JSON={"providers":["rss","cryptopanic","fmp","newsapi"],"cryptopanic":{"enabled":true,"currencies":["BTC","ETH","SOL","BNB"],"filter":"important","kind":"news","region":"en"},"fmp":{"enabled":true,"tickers":["SPY","QQQ","DIA","IWM","AAPL","MSFT","NVDA","TSLA","COIN","MSTR"],"economic":{"countries":["US","EU"],"importance":["High","Medium"]}},"newsapi":{"enabled":true,"q":"(bitcoin OR ethereum OR crypto OR binance OR coinbase) OR (FOMC OR Fed OR ECB OR CPI OR NFP OR rates) OR (S&P 500 OR Nasdaq OR earnings)","language":"en"},"rss":{"enabled":true,"urls":["https://www.ecb.europa.eu/rss/press.html"]}}

# API Keys for news providers (leave empty to disable)
CRYPTOPANIC_AUTH_TOKEN=your_cryptopanic_api_key_here
FMP_API_KEY=your_fmp_api_key_here
NEWSAPI_KEY=your_newsapi_key_here

# Leader-lock settings
NEWS_INGESTOR_LEADER_KEY=news:ingestor:leader
NEWS_INGESTOR_LEADER_TTL_SEC=30
NEWS_INGESTOR_STALE_TAKEOVER_MS=180000
NEWS_INGESTOR_STANDBY_POLL_SEC=2.0

# Standby Ingestor Configuration
STANDBY_INGESTOR_ENABLE=1
NEWS_INGESTOR_LEADER_KEY=news:ingestor:leader
NEWS_INGESTOR_LEADER_TTL_MS=8000

# Hostnames (for consumer identification - will be set by containers)
HOSTNAME=news-service-1
