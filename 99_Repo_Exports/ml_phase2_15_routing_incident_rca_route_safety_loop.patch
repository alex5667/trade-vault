+                    status = "error"
+                    await r.xadd(
+                        AUDIT_STREAM,
+                        {
+                            "event_type": "ROUTING_INCIDENT_RCA_ROUTE_ROLLBACK_FAILED",
+                            "error": str(exc),
+                            "mode": MODE,
+                            "ts_ms": str(now_ms()),
+                        },
+                        maxlen=MAXLEN,
+                        approximate=True,
+                    )
+                    await r.xack(INPUT_STREAM, GROUP, msg_id)
+                finally:
+                    if RUNS:
+                        RUNS.labels(status=status, mode=MODE).inc()
+                    if LAT:
+                        LAT.observe(max(time.perf_counter() - started, 0.0))
+
+
+if __name__ == "__main__":  # pragma: no cover
+    import asyncio
+    asyncio.run(main())
