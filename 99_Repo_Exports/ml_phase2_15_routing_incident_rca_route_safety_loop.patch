+    "Routing-incident RCA routing verifier last run timestamp",
+)
+
+
+def now_ms() -> int:
+    return int(time.time() * 1000)
+
+
+def as_dict(fields: Dict[Any, Any]) -> Dict[str, Any]:
+    out: Dict[str, Any] = {}
+    for k, v in fields.items():
+        kk = k.decode() if isinstance(k, (bytes, bytearray)) else str(k)
+        if isinstance(v, (bytes, bytearray)):
+            try:
+                out[kk] = v.decode()
+            except Exception:
+                out[kk] = v.hex()
+        else:
+            out[kk] = v
+    return out
+
+
+def stable_json(obj: Any) -> str:
+    return json.dumps(obj, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
+
+
+def maybe_json(value: Any, default: Any = None) -> Any:
+    if value is None:
+        return default
+    if isinstance(value, (dict, list)):
+        return value
+    try:
+        return json.loads(value)
+    except Exception:
+        return default
+
+
+def safe_int(value: Any, default: int = 0) -> int:
+    try:
+        return int(float(value))
+    except Exception:
+        return default
+
+
+def safe_float(value: Any, default: float = 0.0) -> float:
+    try:
+        return float(value)
+    except Exception:
+        return default
+
+
+def evaluate_verification(
+    apply_row: Dict[str, Any],
+    current_route: Dict[str, Any],
+    feedback_snapshot: Dict[str, Any],
+    now_ts_ms: int,
+) -> Dict[str, Any]:
+    baseline = maybe_json(apply_row.get("baseline_route_json"), {}) or {}
+    target = maybe_json(apply_row.get("target_route_json"), {}) or {}
+    route_match = (
+        current_route.get("provider") == target.get("provider")
+        and current_route.get("model_name") == target.get("model_name")
+        and current_route.get("prompt_version") == target.get("prompt_version")
+        and current_route.get("policy_version") == target.get("policy_version")
+    )
+    feedback_ts_ms = safe_int(feedback_snapshot.get("ts_ms"), 0)
+    staleness_ms = max(0, now_ts_ms - feedback_ts_ms) if feedback_ts_ms > 0 else 10**12
+    usefulness = safe_float(feedback_snapshot.get("usefulness_score"), 0.5)
+    exposure_n = safe_int(feedback_snapshot.get("exposure_n"), 0)
+
+    out = {
+        "verification_status": "PASS",
+        "verification_reason_code": "OK",
+        "baseline_route_json": stable_json(baseline),
+        "target_route_json": stable_json(target),
+        "current_route_json": stable_json(current_route),
+        "feedback_snapshot_json": stable_json(feedback_snapshot),
+        "usefulness_score": usefulness,
+        "feedback_staleness_ms": staleness_ms,
+        "exposure_n": exposure_n,
+    }
+    if exposure_n < MIN_EXPOSURE:
+        out["verification_status"] = "INCONCLUSIVE"
+        out["verification_reason_code"] = "LOW_EXPOSURE"
+        return out
+    if not route_match:
+        out["verification_status"] = "ROLLBACK_REQUIRED"
+        out["verification_reason_code"] = "ROUTE_MISMATCH"
+        return out
+    if staleness_ms > MAX_FEEDBACK_STALENESS_MS:
+        out["verification_status"] = "ROLLBACK_REQUIRED"
+        out["verification_reason_code"] = "FEEDBACK_STALE"
+        return out
+    if usefulness < MIN_USEFULNESS:
+        out["verification_status"] = "ROLLBACK_REQUIRED"
+        out["verification_reason_code"] = "USEFULNESS_DROP"
+        return out
+    return out
+
+
+async def ensure_group(client: Any, stream_key: str, group: str) -> None:
+    try:
+        await client.xgroup_create(stream_key, group, id="$", mkstream=True)
+    except Exception:
+        return
+
+
+async def persist_if_configured(db_url: str, apply_row: Dict[str, Any], verification: Dict[str, Any]) -> None:
+    if not db_url or psycopg is None:
+        return
+    with psycopg.connect(db_url) as conn:  # pragma: no cover
+        with conn.cursor() as cur:
+            cur.execute(
+                """
+                INSERT INTO llm_operator_routing_incident_rca_route_apply_verifications (
+                    experiment_id,
+                    ts_ms,
+                    status,
+                    reason_code,
+                    usefulness_score,
+                    exposure_n,
+                    baseline_route_json,
+                    target_route_json,
+                    current_route_json,
+                    feedback_snapshot_json
+                ) VALUES (
+                    %(experiment_id)s,
+                    %(ts_ms)s,
+                    %(status)s,
+                    %(reason_code)s,
+                    %(usefulness_score)s,
+                    %(exposure_n)s,
+                    %(baseline_route_json)s,
+                    %(target_route_json)s,
+                    %(current_route_json)s,
+                    %(feedback_snapshot_json)s
+                )
+                """,
+                {
+                    "experiment_id": apply_row.get("experiment_id", ""),
+                    "ts_ms": now_ms(),
+                    "status": verification["verification_status"],
+                    "reason_code": verification["verification_reason_code"],
+                    "usefulness_score": verification["usefulness_score"],
+                    "exposure_n": verification["exposure_n"],
+                    "baseline_route_json": verification["baseline_route_json"],
+                    "target_route_json": verification["target_route_json"],
+                    "current_route_json": verification["current_route_json"],
+                    "feedback_snapshot_json": verification["feedback_snapshot_json"],
+                },
+            )
+            conn.commit()
+
+
+async def main() -> None:  # pragma: no cover
+    if redis is None:
+        raise RuntimeError("redis.asyncio is required")
+    start_http_server(PORT)
+    if UP:
+        UP.set(1)
+    r = redis.from_url(os.getenv("REDIS_URL", "redis://localhost:6379/0"))
+    await ensure_group(r, INPUT_STREAM, GROUP)
+    db_url = os.getenv("DATABASE_URL", "")
+    while True:
+        rows = await r.xreadgroup(GROUP, CONSUMER, {INPUT_STREAM: ">"}, count=32, block=5000)
+        if not rows:
+            continue
+        for _stream, messages in rows:
+            for msg_id, payload in messages:
+                started = time.perf_counter()
+                status = "ok"
+                decision_label = "PASS"
+                try:
+                    apply_row = as_dict(payload)
+                    current_route = as_dict(await r.hgetall(STATE_KEY))
+                    feedback_snapshot = as_dict(await r.hgetall(FEEDBACK_LAST_HASH))
+                    verification = evaluate_verification(apply_row, current_route, feedback_snapshot, now_ms())
+                    decision_label = verification["verification_status"]
+
+                    result_payload = {
+                        "schema_version": 1,
+                        "experiment_id": apply_row.get("experiment_id", ""),
+                        "decision": apply_row.get("decision", ""),
+                        "winner": apply_row.get("winner", ""),
+                        "uplift": apply_row.get("uplift", "0"),
+                        "verification_status": verification["verification_status"],
+                        "verification_reason_code": verification["verification_reason_code"],
+                        "usefulness_score": str(verification["usefulness_score"]),
+                        "exposure_n": str(verification["exposure_n"]),
+                        "baseline_route_json": verification["baseline_route_json"],
+                        "target_route_json": verification["target_route_json"],
+                        "current_route_json": verification["current_route_json"],
+                        "feedback_snapshot_json": verification["feedback_snapshot_json"],
+                        "ts_ms": str(now_ms()),
+                    }
+                    await persist_if_configured(db_url, apply_row, verification)
+                    await r.xadd(VERIFY_RESULTS_STREAM, result_payload, maxlen=MAXLEN, approximate=True)
+                    await r.xadd(
+                        AUDIT_STREAM,
+                        {
+                            "event_type": "ROUTING_INCIDENT_RCA_ROUTE_APPLY_VERIFIED",
+                            "experiment_id": apply_row.get("experiment_id", ""),
+                            "verification_status": verification["verification_status"],
+                            "verification_reason_code": verification["verification_reason_code"],
+                            "ts_ms": str(now_ms()),
+                        },
+                        maxlen=MAXLEN,
+                        approximate=True,
+                    )
+                    if verification["verification_status"] == "ROLLBACK_REQUIRED":
+                        await r.xadd(
+                            ROLLBACK_REQUESTS_STREAM,
+                            {
+                                "schema_version": 1,
+                                "experiment_id": apply_row.get("experiment_id", ""),
+                                "reason_code": verification["verification_reason_code"],
+                                "baseline_route_json": verification["baseline_route_json"],
+                                "target_route_json": verification["target_route_json"],
+                                "ts_ms": str(now_ms()),
+                            },
+                            maxlen=MAXLEN,
+                            approximate=True,
+                        )
+                    await r.xack(INPUT_STREAM, GROUP, msg_id)
+                    if LAST_RUN_TS:
+                        LAST_RUN_TS.set(time.time())
+                except Exception as exc:
+                    status = "error"
+                    await r.xadd(
+                        AUDIT_STREAM,
+                        {
+                            "event_type": "ROUTING_INCIDENT_RCA_ROUTE_APPLY_VERIFY_FAILED",
+                            "error": str(exc),
+                            "ts_ms": str(now_ms()),
+                        },
+                        maxlen=MAXLEN,
+                        approximate=True,
+                    )
+                    await r.xack(INPUT_STREAM, GROUP, msg_id)
+                finally:
+                    if RUNS:
+                        RUNS.labels(status=status, decision=decision_label).inc()
+                    if LAT:
+                        LAT.observe(max(time.perf_counter() - started, 0.0))
+
+
+if __name__ == "__main__":  # pragma: no cover
+    import asyncio
+    asyncio.run(main())
