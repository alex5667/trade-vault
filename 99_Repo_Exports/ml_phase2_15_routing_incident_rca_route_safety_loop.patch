--- /dev/null
+++ b/orderflow_services/tests/test_operator_routing_incident_rca_route_safety_v2_15.py
@@ -0,0 +1,53 @@
+from orderflow_services.operator_routing_incident_rca_routing_post_apply_verifier_v2_15 import (
+    evaluate_verification,
+)
+
+
+def test_evaluate_verification_low_exposure_is_inconclusive():
+    apply_row = {
+        "baseline_route_json": '{"provider":"vertex","model_name":"gemini-2.5-flash-lite","prompt_version":"v1","policy_version":"policy_v1"}',
+        "target_route_json": '{"provider":"vertex","model_name":"gemini-2.5-flash","prompt_version":"v2","policy_version":"policy_v1"}',
+    }
+    current_route = {
+        "provider": "vertex",
+        "model_name": "gemini-2.5-flash",
+        "prompt_version": "v2",
+        "policy_version": "policy_v1",
+    }
+    feedback = {"usefulness_score": "0.8", "exposure_n": "1", "ts_ms": "1000"}
+    out = evaluate_verification(apply_row, current_route, feedback, 2000)
+    assert out["verification_status"] == "INCONCLUSIVE"
+    assert out["verification_reason_code"] == "LOW_EXPOSURE"
+
+
+def test_evaluate_verification_requires_rollback_on_usefulness_drop():
+    apply_row = {
+        "baseline_route_json": '{"provider":"vertex","model_name":"gemini-2.5-flash-lite","prompt_version":"v1","policy_version":"policy_v1"}',
+        "target_route_json": '{"provider":"vertex","model_name":"gemini-2.5-flash","prompt_version":"v2","policy_version":"policy_v1"}',
+    }
+    current_route = {
+        "provider": "vertex",
+        "model_name": "gemini-2.5-flash",
+        "prompt_version": "v2",
+        "policy_version": "policy_v1",
+    }
+    feedback = {"usefulness_score": "0.2", "exposure_n": "5", "ts_ms": "1500"}
+    out = evaluate_verification(apply_row, current_route, feedback, 2000)
+    assert out["verification_status"] == "ROLLBACK_REQUIRED"
+    assert out["verification_reason_code"] == "USEFULNESS_DROP"
+