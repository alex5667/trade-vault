# P3.3 autonomy environment variables
# Copy relevant vars to your main .env or service EnvironmentFile

# Enable autonomy trigger on warning-level health status (0 to disable)
EXEC_AUTONOMY_TRIGGER_ON_WARNING=1

# Enable retention-guard quarantine policy (0 to disable)
EXEC_RETENTION_GUARD_QUARANTINE_ENABLE=1

# Path to execution health JSON report
EXECUTION_HEALTH_REPORT_PATH=/var/lib/trade-runbook/reports/latest_execution_health.json

# Prometheus textfile path for rebuild report metrics (empty = disabled)
EXEC_REBUILD_TEXTFILE_PATH=/var/lib/node_exporter/textfile/trade_execution_rebuild.prom

# Prometheus textfile path for healthcheck metrics (empty = disabled)
EXEC_HEALTHCHECK_TEXTFILE_PATH=/var/lib/node_exporter/textfile/trade_execution_health.prom

# Directory where JSON reports are published for runbook server
RUNBOOK_REPORT_DIR=/var/lib/trade-runbook/reports

# Execution journal retention days (informational; used by retention guard)
EXECUTION_RETENTION_DAYS=14
