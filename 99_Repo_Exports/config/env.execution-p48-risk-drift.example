# P4.8: Environment variables for risk drift ledger and unified dashboard.
# Copy relevant vars into your .env file.

# Enable SQL ledger sink (RiskDriftSqlSink) for repeated risk mismatch quarantine events.
TRADE_RISK_DRIFT_LEDGER_ENABLE=1

# Enable Redis quarantine for SIDs with repeated mismatches (default off for safety).
RISK_CONSISTENCY_QUARANTINE_ON_REPEATED=1

# Minimum mismatch count per SID to trigger quarantine.
RISK_CONSISTENCY_REPEAT_THRESHOLD=3

# node_exporter textfile output path for risk consistency Prometheus metrics.
RISK_CONSISTENCY_TEXTFILE_PATH=/var/lib/node_exporter/textfile_collector/risk_consistency.prom

# Refresh intervals (seconds) for P4.8 timer containers.
RISK_SUMMARY_REFRESH_INTERVAL_SEC=600
RISK_MISMATCH_REFRESH_INTERVAL_SEC=900
OPERATOR_SCORE_REFRESH_INTERVAL_SEC=900

# Grafana base URL for unified dashboard deep-links in alertmanager templates.
GRAFANA_BASE_URL=http://grafana:3000
