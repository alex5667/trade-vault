
# P4.4/P4.5: Risk audit SQL sink and canary report configuration.
# Copy relevant vars into your environment or .env file.

# Enable SQL audit sink for risk decisions (fail-open: publish path is not blocked by SQL outages)
TRADE_RISK_SQL_AUDIT_ENABLE=1

# Postgres DSN for risk audit tables (risk_decisions, risk_snapshot).
# Can share the same DB as EXECUTION_JOURNAL_DSN — uses separate tables.
RISK_AUDIT_SQL_DSN=postgresql://trade:trade@postgres:5432/trade

# Canary report: how many hours back to look at risk_decisions (default 24h)
RISK_CANARY_LOOKBACK_HOURS=24

# Canary report: output path (served by runbook server at /api/risk-canary/latest)
RISK_CANARY_REPORT_PATH=/var/lib/trade-runbook/reports/latest_risk_engine_canary.json
