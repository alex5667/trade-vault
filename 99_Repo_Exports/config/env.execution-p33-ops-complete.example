# P3.3-ops-complete environment variables
# Copy relevant values to .env or docker-compose service environment sections

# Report directory for runbook server /api/rebuild/latest and /api/health/latest
RUNBOOK_REPORT_DIR=/var/lib/trade-runbook/reports

# How many checkpoint keys to scan when checking retention guard drift
# (used by execution_healthcheck.py and scrub_replay_checkpoints.py)
EXEC_REPLAY_RETENTION_GUARD_SAMPLE_LIMIT=2000

# How many checkpoint keys the scrubber will process per run
EXEC_REPLAY_CHECKPOINT_SCRUB_SAMPLE_LIMIT=5000

# Path for node-exporter textfile collector (optional Prometheus scraping)
EXEC_HEALTHCHECK_TEXTFILE_PATH=/var/lib/node_exporter/textfile_collector/trade_execution.prom

# DSN for writing QuarantineLedger events (can share EXECUTION_JOURNAL_DSN)
# EXECUTION_QUARANTINE_LEDGER_DSN=postgresql://user:pass@postgres:5432/scanner
