# P6 runbook/ops settings
# Copy relevant variables into your .env or export before running compose

# TCP port for the trade-runbook-server container (default: 18080)
RUNBOOK_SERVER_PORT=18080

# Directory where execution health JSON reports are written by the healthcheck script
RUNBOOK_REPORT_DIR=./var/runbook-reports

# Consistency checker thresholds
# Number of orders:exec stream entries to scan per check run
# Increase if you have many historical SIDs (active sessions > 1 day)
EXEC_CONSISTENCY_STREAM_COUNT=50000
# Exit code 2 if >= this many critical mismatches
EXEC_CONSISTENCY_CRITICAL_THRESHOLD=1
# Exit code 1 if >= this many warning mismatches
EXEC_CONSISTENCY_WARNING_THRESHOLD=10

# orders:exec stream max length (0 = unlimited). Prevents unbounded Redis memory growth.
# Approximate trimming is used (redis XADD ... MAXLEN ~ N). Recommended: 500000
EXEC_STREAM_MAXLEN=50000

# User-stream freshness: age threshold in ms before reporting "stale" (default: 2 min)
USER_STREAM_STALE_MS=120000

# Redis key prefix for execution state snapshots
ORDERS_STATE_KEY_PREFIX=orders:state:

# Redis stream name for execution facts
EXEC_STREAM=orders:exec

# Redis user-stream cache key prefix
USER_STREAM_CACHE_PREFIX=orders:user_stream:

# PostgreSQL DSN for the execution journal – REQUIRED for consistency checks
# EXECUTION_JOURNAL_DSN=postgresql://user:pass@host:5432/dbname

# Alertmanager webhook receiver URLs (replace with real values)
ALERT_ROUTER_DEFAULT_URL=http://alert-router.default.svc.cluster.local/default
ALERT_ROUTER_CRITICAL_URL=http://alert-router.default.svc.cluster.local/critical
ALERT_ROUTER_OPS_URL=http://alert-router.default.svc.cluster.local/ops
ALERT_ROUTER_RISK_URL=http://alert-router.default.svc.cluster.local/risk
