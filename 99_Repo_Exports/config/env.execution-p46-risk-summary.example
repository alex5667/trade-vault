
# P4.6 Risk Summary environment variables example.
# Copy to .env or /etc/default/trade-risk-engine and fill in real values.

# Enable SQL audit logging in the risk engine
TRADE_RISK_SQL_AUDIT_ENABLE=1

# PostgreSQL DSN for risk_decisions and risk_snapshot tables
RISK_AUDIT_SQL_DSN=postgresql://trade:trade@postgres:5432/trade

# Lookback window for risk engine canary score computation (hours)
RISK_CANARY_LOOKBACK_HOURS=24

# Output path for canary report (served by runbook server at /api/risk-canary/latest)
RISK_CANARY_REPORT_PATH=/var/lib/trade-runbook/reports/latest_risk_engine_canary.json

# Output path for aggregated risk decision summary (served at /api/risk-summary/latest)
RISK_DECISION_SUMMARY_REPORT_PATH=/var/lib/trade-runbook/reports/latest_risk_decision_summary.json

# Max rows to check in the signal ↔ snapshot consistency check
RISK_CONSISTENCY_LIMIT=250

# Alertmanager base URL for Silence deep-links in alert notifications
ALERTMANAGER_EXTERNAL_URL=http://alertmanager:9093

# Runbook server base URL (used in Alertmanager templates)
RUNBOOK_BASE_URL=http://trade-runbook-server:18080
