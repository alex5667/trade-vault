# P7 consistency repair / quarantine ENV vars
# Copy relevant lines to your .env or trade-execution.env

# Minimum mismatch severity to quarantine a sid (critical | warning)
EXEC_QUARANTINE_MIN_SEVERITY=critical

# Redis key prefix for quarantined state copies
ORDERS_QUARANTINE_PREFIX=orders:quarantine:state:

# Node exporter textfile collector path for execution healthcheck
# Leave empty to disable textfile export (the JSON report is always written)
EXEC_HEALTHCHECK_TEXTFILE_PATH=/var/lib/node_exporter/textfile_collector/trade_execution_health.prom

# Repair tooling – how many stream entries to scan for state reconstruction
# Increase if you have many historical SIDs (active sessions > 1 day)
EXEC_CONSISTENCY_STREAM_COUNT=50000

# orders:exec stream max length (0 = unlimited). Prevents unbounded Redis memory growth.
EXEC_STREAM_MAXLEN=50000

# Stale threshold for user-stream freshness (ms)
USER_STREAM_STALE_MS=120000
