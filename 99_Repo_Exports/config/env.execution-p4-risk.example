# P4 risk engine safe defaults
# Copy relevant lines to your .env or the docker-compose environment block.
# All values are conservative production baselines and can be tuned per-tier.

# ── Global kill switch ────────────────────────────────────────────────────────
RISK_KILL_SWITCH=0
RISK_KILL_SWITCH_FORCE_FLATTEN=1

# ── Global portfolio limits ───────────────────────────────────────────────────
RISK_MAX_DAILY_LOSS_PCT=2.0
RISK_MAX_TOTAL_EXPOSURE_RATIO=2.25
RISK_MAX_CLUSTER_EXPOSURE_RATIO=1.15
RISK_INFRA_DEGRADED_MULTIPLIER=0.50
RISK_HIGH_VOL_MULTIPLIER=0.65

# ── Global spread / slippage caps ────────────────────────────────────────────
RISK_SOFT_SPREAD_BPS_CAP=10.0
RISK_HARD_SPREAD_BPS_CAP=25.0
RISK_MIN_STOP_DISTANCE_BPS=8.0
RISK_VOLATILITY_STOP_WEIGHT=0.50

# ── Tier symbol lists ─────────────────────────────────────────────────────────
RISK_TIER_A_SYMBOLS=BTCUSDT,ETHUSDT
RISK_TIER_B_SYMBOLS=SOLUSDT,XRPUSDT,BNBUSDT,ADAUSDT,DOGEUSDT,LTCUSDT,BCHUSDT,AVAXUSDT,LINKUSDT

# ── Tier A (BTC / ETH — deep liquid) ─────────────────────────────────────────
RISK_TIER_A_MAX_LEVERAGE=10
RISK_TIER_A_MIN_CONFIDENCE=0.55
RISK_TIER_A_MAKER_ALLOWED=1
RISK_TIER_A_SLIPPAGE_BPS_CAP=12
RISK_TIER_A_WATCHDOG_TIMEOUT_MS=4000
RISK_TIER_A_MAX_SYMBOL_EXPOSURE_RATIO=0.70
RISK_TIER_A_MAX_CONCURRENT_POSITIONS=3
RISK_TIER_A_BASE_RISK_PCT=0.75

# ── Tier B (major alts) ───────────────────────────────────────────────────────
RISK_TIER_B_MAX_LEVERAGE=5
RISK_TIER_B_MIN_CONFIDENCE=0.60
RISK_TIER_B_MAKER_ALLOWED=1
RISK_TIER_B_SLIPPAGE_BPS_CAP=18
RISK_TIER_B_WATCHDOG_TIMEOUT_MS=3500
RISK_TIER_B_MAX_SYMBOL_EXPOSURE_RATIO=0.45
RISK_TIER_B_MAX_CONCURRENT_POSITIONS=2
RISK_TIER_B_BASE_RISK_PCT=0.45

# ── Tier C (memes / thin books / noisy alts) ──────────────────────────────────
RISK_TIER_C_MAX_LEVERAGE=3
RISK_TIER_C_MIN_CONFIDENCE=0.68
RISK_TIER_C_MAKER_ALLOWED=0
RISK_TIER_C_SLIPPAGE_BPS_CAP=10
RISK_TIER_C_WATCHDOG_TIMEOUT_MS=2500
RISK_TIER_C_MAX_SYMBOL_EXPOSURE_RATIO=0.20
RISK_TIER_C_MAX_CONCURRENT_POSITIONS=1
RISK_TIER_C_BASE_RISK_PCT=0.25
