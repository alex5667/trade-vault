# P5X Operator Hardening ENV example
# Copy to .env or merge into existing ENV configuration

# Alertmanager base URL for auto-silence API calls
ALERTMANAGER_EXTERNAL_URL=http://alertmanager:9093

# Auto-silence: 1=dry-run (safe default), 0=live posting to Alertmanager
RISK_DRIFT_AUTOSILENCE_DRY_RUN=1

# Auto-silence thresholds (24h window)
RISK_DRIFT_AUTOSILENCE_QUARANTINE_THRESHOLD=10
RISK_DRIFT_AUTOSILENCE_MISMATCH_RATE_THRESHOLD=0.20

# Duration of the silence created in Alertmanager (seconds)
RISK_DRIFT_AUTOSILENCE_DURATION_SEC=3600

# Where to write the auto-silence decision report JSON
RISK_DRIFT_AUTOSILENCE_REPORT_PATH=/var/lib/trade-runbook/reports/latest_risk_drift_autosilence.json

# Prometheus textfile-collector paths (empty = disabled)
RISK_MISMATCH_ARCHIVE_CONSISTENCY_TEXTFILE_PATH=/var/lib/node_exporter/textfile_collector/risk_mismatch_archive_consistency.prom
RISK_MISMATCH_RETENTION_TEXTFILE_PATH=/var/lib/node_exporter/textfile_collector/risk_mismatch_retention.prom
