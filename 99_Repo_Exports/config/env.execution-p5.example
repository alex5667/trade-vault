# Execution rollout flags
EXEC_ALGO_CANONICAL_V2=1
EXEC_RECONCILE_ENABLE=1
EXEC_USER_STREAM_ENABLE=1
EXEC_MAKER_TP_ENABLE=1
EXEC_JOURNAL_SQL_ENABLE=1
EXEC_FORCE_SAFETY_FIRST=0
EXEC_DEGRADED_MODE_FORCE_SAFETY_FIRST=1
EXEC_DEGRADED_MODE_DISABLE_MAKER=1

# User stream / reconcile
USER_STREAM_STREAM=orders:user_stream
USER_STREAM_CACHE_PREFIX=orders:user_stream:
USER_STREAM_CACHE_TTL_SEC=900
BINANCE_RECV_WINDOW_MS=3000
BINANCE_TIME_SYNC_INTERVAL_MS=30000
MAX_CLOCK_DRIFT_MS=250

# Protection / watchdog
PROTECTION_ARM_TIMEOUT_MS=2500
TP_LIMIT_WATCHDOG_ENABLE=1
TP_LIMIT_WATCHDOG_TIMEOUT_MS=4000

# SQL execution journal
EXECUTION_JOURNAL_DSN=postgresql://postgres:postgres@postgres:5432/trade

# Pre-publish DQ / risk rollout
TRADE_DQ_HARD_VETO_ENABLE=1
TRADE_RISK_ENGINE_V2_ENABLE=1
PORTFOLIO_RISK_HARD_VETO=1

# Portfolio risk limits
RISK_MAX_DAILY_LOSS_PCT=2.0
RISK_MAX_TOTAL_EXPOSURE_RATIO=2.5
RISK_MAX_SYMBOL_EXPOSURE_RATIO=0.75
RISK_MAX_CLUSTER_EXPOSURE_RATIO=1.25
RISK_TIER_A_MAX_LEVERAGE=10
RISK_TIER_B_MAX_LEVERAGE=5
RISK_TIER_C_MAX_LEVERAGE=3

# Redis DQ thresholds
REDIS_DQ_QUEUE_LAG_HARD_MS=2500
REDIS_DQ_TICK_STALE_HARD_MS=2500
REDIS_DQ_BOOK_STALE_HARD_MS=2500
REDIS_DQ_TIMEOUT_EVENTS_HARD=5
REDIS_DQ_XACK_FAIL_HARD=2
