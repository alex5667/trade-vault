{
  "dashboard": {
    "title": "EV Gate Metrics",
    "tags": ["ev-gate", "trading", "signals"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "EV Gate Veto Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(ev_gate_veto_count{reason=\"VETO_EV_COST\"}[5m]) / rate(ev_gate_evaluate_total[5m])",
            "legendFormat": "{{kind}} - {{symbol}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percentunit", "label": "Veto Rate"},
          {"format": "short"}
        ]
      },
      {
        "id": 2,
        "title": "P(hit TP1) Distribution",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "ev_gate_p_hit_tp1",
            "legendFormat": "{{kind}} - {{symbol}} - {{regime}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percentunit", "label": "Probability", "min": 0, "max": 1},
          {"format": "short"}
        ]
      },
      {
        "id": 3,
        "title": "EV (bps) at Veto",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "ev_gate_ev_bps_veto",
            "legendFormat": "{{kind}} - {{symbol}}",
            "refId": "A"
          }
        ],
        "dataFormat": "timeseries",
        "yBucketBound": "auto"
      },
      {
        "id": 4,
        "title": "EV Stats Sample Count",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "ev_stats_sample_count",
            "legendFormat": "{{kind}} - {{symbol}} - {{regime}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Trades"},
          {"format": "short"}
        ]
      },
      {
        "id": 5,
        "title": "Veto Reasons Breakdown",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "sum by (reason) (increase(ev_gate_veto_count[1h]))",
            "legendFormat": "{{reason}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 6,
        "title": "EV Gate Evaluation Latency",
        "type": "graph",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(ev_gate_evaluate_duration_ms_bucket[5m]))",
            "legendFormat": "p95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.99, rate(ev_gate_evaluate_duration_ms_bucket[5m]))",
            "legendFormat": "p99",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "ms", "label": "Latency"},
          {"format": "short"}
        ]
      },
      {
        "id": 7,
        "title": "EV Stats Age (hours)",
        "type": "stat",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16},
        "targets": [
          {
            "expr": "ev_stats_age_hours",
            "legendFormat": "{{kind}} - {{symbol}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 24, "color": "yellow"},
                {"value": 48, "color": "red"}
              ]
            }
          }
        }
      }
    ],
    "refresh": "30s",
    "time": {"from": "now-6h", "to": "now"},
    "timepicker": {
      "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h"]
    }
  }
}
