+BEGIN;
+
+CREATE TABLE IF NOT EXISTS llm_operator_routing_incident_rca_governor_decisions (
+    id                  bigserial PRIMARY KEY,
+    ts_ms               bigint NOT NULL,
+    scope_type          text NOT NULL,
+    scope_key           text NOT NULL,
+    decision            text NOT NULL,
+    sample_n            integer NOT NULL,
+    quality_avg         double precision NOT NULL,
+    usefulness_avg      double precision NOT NULL,
+    weighted_score      double precision NOT NULL,
+    recommendation_n    integer NOT NULL,
+    advisory_only       integer NOT NULL,
+    decision_json       jsonb NOT NULL
+);
+
+CREATE INDEX IF NOT EXISTS idx_llm_operator_routing_incident_rca_governor_decisions_ts_ms
+    ON llm_operator_routing_incident_rca_governor_decisions(ts_ms DESC);
+
+CREATE INDEX IF NOT EXISTS idx_llm_operator_routing_incident_rca_governor_decisions_scope
+    ON llm_operator_routing_incident_rca_governor_decisions(scope_type, scope_key);
+
+CREATE TABLE IF NOT EXISTS llm_operator_routing_incident_rca_governor_policy_versions (
+    id               bigserial PRIMARY KEY,
+    ts_ms            bigint NOT NULL,
+    scope_type       text NOT NULL,
+    scope_key        text NOT NULL,
+    decision         text NOT NULL,
+    weighted_score   double precision NOT NULL,
+    sample_n         integer NOT NULL,
+    policy_json      jsonb NOT NULL
+);
+
+COMMIT;
