+from orderflow_services.operator_routing_incident_rca_usefulness_governor_v2_11 import (
+    Aggregate,
+    action_scope_key,
+    aggregate_action_patterns,
+    aggregate_provider_prompts,
+    decision_for_score,
+    provider_scope_key,
+)
+
+
+class DummyRow:
+    def __init__(self, provider, model_name, prompt_version, policy_version, quality_score, usefulness_score, result_json):
+        self.provider = provider
+        self.model_name = model_name
+        self.prompt_version = prompt_version
+        self.policy_version = policy_version
+        self.quality_score = quality_score
+        self.usefulness_score = usefulness_score
+        self.result_json = result_json
+
+
+def test_aggregate_weighted_score_prefers_usefulness():
+    agg = Aggregate()
+    agg.add(quality=0.90, usefulness=0.10, recommendation_n=1)
+    score = agg.weighted_score
+    assert round(score, 4) == round((0.4 * 0.90) + (0.6 * 0.10), 4)
+
+
+def test_decision_for_score_respects_min_sample():
+    assert decision_for_score(0.8, 3) == "HOLD"
+
+
+def test_scope_key_helpers():
+    assert action_scope_key("open_incident", "routing_incident_rca_v1", "policy_v1") == \
+        "open_incident:routing_incident_rca_v1:policy_v1"
+    assert provider_scope_key("vertex", "gemini-2.5-flash-lite", "routing_incident_rca_v1") == \
+        "vertex:gemini-2.5-flash-lite:routing_incident_rca_v1"
+
+
+def test_aggregate_action_patterns_and_provider_prompts():
+    rows = [
+        DummyRow(
+            provider="vertex",
+            model_name="gemini-2.5-flash-lite",
+            prompt_version="routing_incident_rca_v1",
+            policy_version="policy_v1",
+            quality_score=0.80,
+            usefulness_score=0.75,
+            result_json={"recommendations": [{"action": "open_incident"}, {"action": "draft_postmortem"}]},
+        ),
+        DummyRow(
+            provider="vertex",
+            model_name="gemini-2.5-flash-lite",
+            prompt_version="routing_incident_rca_v1",
+            policy_version="policy_v1",
+            quality_score=0.70,
+            usefulness_score=1.00,
+            result_json={"recommendations": [{"action": "open_incident"}]},
+        ),
+    ]
+    action_aggs = aggregate_action_patterns(rows)
+    provider_aggs = aggregate_provider_prompts(rows)
+    assert "open_incident:routing_incident_rca_v1:policy_v1" in action_aggs
+    assert "vertex:gemini-2.5-flash-lite:routing_incident_rca_v1" in provider_aggs
+    assert action_aggs["open_incident:routing_incident_rca_v1:policy_v1"].sample_n == 2
+