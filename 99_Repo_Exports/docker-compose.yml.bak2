services:
  redis:
    image: redis:7-alpine
    container_name: redis
    ports:
      - 0.0.0.0:6379:6379
    volumes:
      - redis-data:/data
      - ./redis-external-access.conf:/usr/local/etc/redis/redis.conf
    command: redis-server /usr/local/etc/redis/redis.conf --save "" --appendonly yes
    networks:
      - scanner-network
    healthcheck:
      test:
        - CMD
        - sh
        - -c
        - redis-cli -h localhost -p 6379 ping | grep -q PONG && redis-cli -h localhost
          -p 6379 SET __healthcheck__ test && redis-cli -h localhost -p 6379 GET __healthcheck__
          | grep -q test && redis-cli -h localhost -p 6379 DEL __healthcheck__
      interval: 10s
      timeout: 10s
      retries: 10
      start_period: 120s
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 16G
          cpus: '4.0'
        reservations:
          memory: 4G
    ulimits:
      nofile:
        soft: 65536
        hard: 65536
      memlock:
        soft: -1
        hard: -1
    shm_size: 2gb
    sysctls:
      net.core.somaxconn: 65535
  redis-worker-1:
    image: redis:7-alpine
    container_name: redis-worker-1
    expose:
      - '6379'
    volumes:
      - redis-worker-1-data:/data
      - ./redis-worker-stable.conf:/usr/local/etc/redis/redis.conf
    command: redis-server /usr/local/etc/redis/redis.conf
    networks:
      scanner-network:
        aliases:
          - redis-worker-1
          - scanner-redis-worker-1
    depends_on:
      redis:
        condition: service_healthy
    healthcheck:
      test:
        - CMD
        - redis-cli
        - ping
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 20s
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 3G
          cpus: '2.0'
        reservations:
          memory: 1G
    ulimits:
      nofile:
        soft: 65536
        hard: 65536
    shm_size: 512mb
    sysctls:
      net.core.somaxconn: 4096
  redis-worker-1b:
    image: redis:7-alpine
    container_name: redis-worker-1b
    expose:
      - '6379'
    volumes:
      - redis-worker-1b-data:/data
      - ./redis-worker-stable.conf:/usr/local/etc/redis/redis.conf
    command: redis-server /usr/local/etc/redis/redis.conf
    networks:
      scanner-network:
        aliases:
          - redis-worker-1b
    depends_on:
      redis:
        condition: service_healthy
    healthcheck:
      test:
        - CMD
        - redis-cli
        - ping
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 20s
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 3G
          cpus: '2.0'
        reservations:
          memory: 1G
    ulimits:
      nofile:
        soft: 65536
        hard: 65536
    shm_size: 512mb
    sysctls:
      net.core.somaxconn: 4096
  redis-worker-2:
