      start_period: 720s
  go-worker-3month:
    build:
      context: ./go-worker
      dockerfile: Dockerfile
    container_name: scanner-go-worker-3month
    environment:
      - REDIS_HOST=redis-worker-1
      - REDIS_PORT=6379
      - REDIS_DB=0
      - REDIS_POOL_SIZE=150
      - REDIS_MIN_IDLE_CONNS=15
      - REDIS_MAX_RETRIES=5
      - REDIS_RETRY_MIN_BACKOFF=100ms
      - REDIS_RETRY_MAX_BACKOFF=3s
      - REDIS_DIAL_TIMEOUT=10s
      - REDIS_READ_TIMEOUT=30s
      - REDIS_WRITE_TIMEOUT=30s
      - REDIS_POOL_TIMEOUT=10s
      - BINANCE_WS_TIMEFRAME=kline_3M
      - REDIS_CANDLES_HOST=redis-worker-1
      - REDIS_CANDLES_PORT=6379
      - REDIS_CANDLES_HOST_2=redis-worker-2
      - REDIS_CANDLES_PORT_2=6379
      - REDIS_TICKS_HOST=redis-ticks
      - REDIS_TICKS_PORT=6379
      - PROMETHEUS_PORT=2120
      - BINANCE_MAX_PAIRS_TO_FETCH=150
      - BINANCE_MIN_SYMBOLS_REQUIRED=150
      - BINANCE_MAX_PAIRS_TO_ADD=300
      - BINANCE_MIN_TRADES_24H=1000
    depends_on:
      redis:
        condition: service_healthy
      redis-worker-1:
        condition: service_healthy
      redis-worker-2:
        condition: service_healthy
    networks:
      - scanner-network
    restart: unless-stopped
    command:
      - sh
      - -c
      - sleep 750 && ./main
    deploy:
      resources:
        limits:
          memory: 400M
          cpus: '0.25'
        reservations:
          memory: 128M
    dns:
      - 8.8.8.8
      - 8.8.4.4
    ulimits:
      nofile:
        soft: 65536
        hard: 65536
    volumes:
      - ./logs:/app/logs
    healthcheck:
      test:
        - CMD
