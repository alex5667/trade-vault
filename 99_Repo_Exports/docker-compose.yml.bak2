  redis-ticks:
    image: redis:7-alpine
    container_name: redis-ticks
    expose:
      - '6379'
    volumes:
      - redis-ticks-data:/data
      - ./redis-ticks.conf:/usr/local/etc/redis/redis.conf
    command:
      'redis-server /usr/local/etc/redis/redis.conf --maxmemory 16gb --maxmemory-policy
      allkeys-lru

      '
    networks:
      scanner-network:
        aliases:
          - redis-ticks
    depends_on:
      redis:
        condition: service_healthy
    healthcheck:
      test:
        - CMD
        - sh
        - -c
        - redis-cli ping | grep -q PONG && redis-cli SET __healthcheck__ test && redis-cli
          GET __healthcheck__ | grep -q test && redis-cli DEL __healthcheck__
      interval: 10s
      timeout: 10s
      retries: 10
      start_period: 60s
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 16G
          cpus: '3.0'
        reservations:
          memory: 2G
    ulimits:
      nofile:
        soft: 65536
        hard: 65536
    shm_size: 1gb
    sysctls:
      net.core.somaxconn: 8192
  go-worker-1m:
    build:
      context: ./go-worker
      dockerfile: Dockerfile
    container_name: scanner-go-worker-1m
    environment:
      - REDIS_HOST=redis-worker-1
      - REDIS_PORT=6379
      - REDIS_DB=0
      - REDIS_POOL_SIZE=150
      - REDIS_MIN_IDLE_CONNS=15
      - REDIS_MAX_RETRIES=5
      - REDIS_RETRY_MIN_BACKOFF=100ms
      - REDIS_RETRY_MAX_BACKOFF=3s
      - REDIS_DIAL_TIMEOUT=10s
      - REDIS_READ_TIMEOUT=30s
      - REDIS_WRITE_TIMEOUT=30s
      - REDIS_POOL_TIMEOUT=10s
      - BINANCE_WS_TIMEFRAME=kline_1m
      - REDIS_CANDLES_HOST=redis-worker-1
      - REDIS_CANDLES_PORT=6379
      - REDIS_CANDLES_HOST_2=redis-worker-2
      - REDIS_CANDLES_PORT_2=6379
      - REDIS_TICKS_HOST=redis-ticks
      - REDIS_TICKS_PORT=6379
      - PROMETHEUS_PORT=2112
      - BINANCE_MAX_PAIRS_TO_FETCH=150
      - BINANCE_MIN_SYMBOLS_REQUIRED=150
      - BINANCE_MAX_PAIRS_TO_ADD=300
      - BINANCE_MIN_TRADES_24H=1000
    depends_on:
      redis:
        condition: service_healthy
      redis-worker-1:
        condition: service_healthy
      redis-worker-2:
        condition: service_healthy
    networks:
      - scanner-network
    restart: unless-stopped
    command:
      - sh
      - -c
      - sleep 30 && ./main
    deploy:
      resources:
        limits:
          memory: 1.5G
          cpus: '1.5'
        reservations:
          memory: 384M
    dns:
      - 8.8.8.8
      - 8.8.4.4
    ulimits:
      nofile:
        soft: 65536
        hard: 65536
    volumes:
      - ./logs:/app/logs
    healthcheck:
      test:
        - CMD
        - wget
        - --no-verbose
        - --tries=1
        - --spider
        - http://localhost:2112/metrics
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
