      - REDIS_TICKS_URL=redis://redis-ticks:6379/0
      - ATR_SOURCE=redis
      - ATR_TF=1m
      - CRYPTO_OF_REFRESH_SEC=30
      - CRYPTO_OF_LOG_LEVEL=DEBUG
      - ORDERS_QUEUE=orders:queue
      - CRYPTO_NOTIFY_STREAM=notify:telegram
      - CRYPTO_NOTIFY_REDIS_URL=redis://redis-worker-1:6379/0
      - CRYPTO_RAW_STREAM=signals:crypto:raw
      - ATR_REDIS_URL=redis://redis-worker-1:6379/0
      - CRYPTO_NOTIFY_SIGNAL_EVERY_N=10
      - CRYPTO_SIGNAL_MIN_CONF=80
      - DISABLE_CONFIDENCE_FILTER=false
      # Signal Scoring Configuration
      - MIN_SIGNAL_CONFIDENCE=80
      - MIN_SIGNAL_CONFIDENCE__XAUUSD=20
      - GOLDEN_PATTERN_MIN_CONFIDENCE=90
      - SIGNAL_METRIC_WEIGHT__DELTA_SPIKE_Z=1.0
      - SIGNAL_METRIC_WEIGHT__OBI=0.7
      - SIGNAL_METRIC_WEIGHT__WEAK_PROGRESS=0.5
      - SIGNAL_METRIC_WEIGHT__ATR_QUANTILE=0.3
      - SIGNAL_PATTERN_WEIGHT__BREAKOUT_R1=1.2
      - SIGNAL_PATTERN_WEIGHT__FADE_PDH=1.1
      - SIGNAL_PATTERN_WEIGHT__FADE_HTF_OB=1.3
      - SIGNAL_PATTERN_MIN_CONF__BREAKOUT_R1=85
      - SIGNAL_PATTERN_MIN_CONF__FADE_PDH=80
      - SIGNAL_PATTERN_MIN_CONF__FADE_HTF_OB=88
      - TP1_SHIFT_MULT=1.4
      - PYTHONPATH=/app
      - ACCOUNT_DEPOSIT_USD=100
      - ACCOUNT_LEVERAGE=100
      - RISK_PERCENT=5.0
      - CRYPTO_COMMISSION_RATE=0.0004
      - TRAILING_TP1_OFFSET_ATR=0.6
      - TRAILING_AFTER_TP1_SOURCES=CryptoOrderFlow
      - TRAILING_TP1_OFFSET_ATR_CRYPTOORDERFLOW=0.5
      - TRAILING_TP1_OFFSET_ATR_ETHUSDT=0.45
      - STREAM_MSG_MAX_RETRIES=3
      - STREAM_CLAIM_INTERVAL_MS=5000
      - STREAM_CLAIM_MIN_IDLE_MS=15000
      - STREAM_CLAIM_COUNT=50
      - ORDERFLOW_DLQ_STREAM=stream:dlq:orderflow
      - DELTA_BUCKET_MS=1000
      - OBI_MAX_STALE_MS=2500
      - TRAIL_Z_THRESHOLD=4.5
      - FORCE_TRAIL_AFTER_TP1=true
      - LEVEL_SIGNAL_COOLDOWN_MS=15000
      - BREAKOUT_MIN_DIST_ATR=0.0
      - USE_SIGNAL_OUTBOX=true
      - SIGNAL_OUTBOX_STREAM=stream:signals:outbox
      - SIGNAL_OUTBOX_MAXLEN=200000
      - SIGNAL_DEDUP_GRANULARITY=minute
      - SIGNAL_DEDUP_TTL_MS=90000
      - OUTBOX_GROUP=signals-outbox-group
      - OUTBOX_CONSUMER=outbox-dispatcher
      - OUTBOX_MAX_RETRIES=5
      - OUTBOX_DLQ_STREAM=stream:dlq:signal_outbox
      - OUTBOX_CLAIM_INTERVAL_MS=5000
      - OUTBOX_CLAIM_MIN_IDLE_MS=15000
      - OUTBOX_CLAIM_COUNT=100
      - OUTBOX_SENT_TTL_SEC=172800
      - CRYPTO_DEFAULT_DAILY_RANGE_PCT=0.04
      - CRYPTO_OBI_SPIKE_THR=0.7
      - GPU_ENABLED=true
      - NVIDIA_VISIBLE_DEVICES=all
      - NVIDIA_DRIVER_CAPABILITIES=compute,utility
      - ENABLE_L3_PROXY=true
      - L3_TAKER_RATE_EMA_ALPHA=0.12
      - L3_EPS=1e-9
      - L2_K_SMALL=5
      - L2_K_LARGE=20
      - L2_WALL_MULT=3.0
      - L2_WALL_MAX_DIST_BPS=15.0
      - L2_BATCH_MIN=3
      - ROBUST_Z_BACKEND=auto
      - ROBUST_Z_GPU_MIN_N=2048
      - OBI_SUSTAINED_USE_FRACTION=true
      - OBI_SUSTAINED_MIN_SAMPLES=3
      - OBI_SUSTAINED_MIN_FRACTION=0.6
      - BREAKOUT_REQUIRE_OBI=true
      - BREAKOUT_REQUIRE_OBI20=true
      - BREAKOUT_MIN_MICROPRICE_SHIFT_BPS=0.2
      - BREAKOUT_WALL_MAX_DIST_BPS=10.0
      - BREAKOUT_MIN_DEPLETION_SCORE=0.05
      - BREAKOUT_MAX_REFILL_SCORE=0.05
      - BREAKOUT_MAX_IMPACT_PROXY=0.35
      - ABSORPTION_MIN_REFILL_SCORE=0.05
      - ABSORPTION_WALL_MAX_DIST_BPS=12.0
      - ABSORPTION_USE_L3_FILTERS=true
      - ABSORPTION_L3_MIN_TAKER_RATE=0.0
      - EXTREME_USE_L3_FILTERS=true
      - EXTREME_L3_MAX_CANCEL_TO_TRADE=6.0
      - EXTREME_L3_MIN_TAKER_RATE=0.0
      - BTC_DELTA_Z_THRESHOLD=2.0
      - BTC_OBI_THRESHOLD=0.35
      - BTC_MIN_SIGNAL_INTERVAL=20
      - BTC_STOP_MODE=ATR
      - BTC_STOP_ATR_MULT=0.8
      - BTC_TP_RR=1,1.5,2.5
      - ETH_DELTA_Z_THRESHOLD=2.0
    depends_on:
      redis:
        condition: service_healthy
      redis-ticks:
        condition: service_healthy
    networks:
      - scanner-network
    volumes:
      - ./logs:/app/logs
    restart: on-failure:5
    deploy:
      resources:
        limits:
          memory: 512M
          cpus: '0.5'
        reservations:
          memory: 128M
    command:
      - sh
      - -c
      - sleep 40 && python services/crypto_orderflow_service.py
