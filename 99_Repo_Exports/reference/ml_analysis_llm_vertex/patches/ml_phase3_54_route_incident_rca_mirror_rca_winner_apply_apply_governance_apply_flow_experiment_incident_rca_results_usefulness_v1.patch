+    if not db_url or psycopg is None:
+        return
+    with psycopg.connect(db_url) as conn:  # pragma: no cover
+        with conn.cursor() as cur:
+            cur.execute(
+                """
+                INSERT INTO llm_route_incident_rca_mirror_rca_winner_apply_apply_governance_apply_flow_experiment_incident_rca_usefulness_rollups (
+                    ts_ms, window_min,
+                    vertex_n, vertex_avg_quality, vertex_avg_usefulness, vertex_accepted_rate,
+                    local_n, local_avg_quality, local_avg_usefulness, local_accepted_rate,
+                    rollup_json
+                ) VALUES (
+                    %(ts_ms)s, %(window_min)s,
