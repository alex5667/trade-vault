+from __future__ import annotations
+
+import asyncio
+import json
+import os
+import time
+from typing import Any, Dict, Tuple
+
+try:  # pragma: no cover
+    import redis.asyncio as redis
+except Exception:  # pragma: no cover
+    redis = None
+
+try:  # pragma: no cover
+    import psycopg
+except Exception:  # pragma: no cover
+    psycopg = None
+
+try:  # pragma: no cover
