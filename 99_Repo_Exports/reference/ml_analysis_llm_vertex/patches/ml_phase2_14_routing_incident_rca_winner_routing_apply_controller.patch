+def test_evaluate_apply_blocks_on_min_sample():
+    winner_row = {
+        "decision": "PROMOTE_CHALLENGER",
+        "winner": "challenger",
+        "uplift": "0.10",
+        "control_json": '{"sample_n": 4}',
+        "challenger_json": '{"sample_n": 4}',
+    }
+    current_route = {"last_applied_ts_ms": "0"}
+    policy = {
+        "kill_switch": 0,
+        "commit_enabled": 1,
+        "executor_mode": "DRY_RUN",
+        "cooldown_sec": 100,
+        "min_sample": 8,
+        "min_uplift": 0.05,
+    }
+    out = evaluate_apply(winner_row, current_route, policy, 1, 100000)
+    assert out["status"] == "HOLD"
+    assert out["reason_code"] == "MIN_SAMPLE_NOT_MET"
+
+
+def test_evaluate_apply_ready_in_dry_run():
+    winner_row = {
+        "decision": "PROMOTE_CHALLENGER",
+        "winner": "challenger",
+        "uplift": "0.10",
