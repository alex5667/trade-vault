+    current_route = {"last_applied_ts_ms": "0"}
+    policy = {
+        "kill_switch": 0,
+        "commit_enabled": 1,
+        "executor_mode": "COMMIT",
+        "cooldown_sec": 100,
+        "min_sample": 8,
+        "min_uplift": 0.05,
+    }
+    out = evaluate_apply(winner_row, current_route, policy, 1, 100000)
+    assert out["status"] == "APPLY_CANDIDATE"
+    assert out["executor_mode"] == "DRY_RUN"
+    assert "gemini-2.5-flash" in out["route_json"]
