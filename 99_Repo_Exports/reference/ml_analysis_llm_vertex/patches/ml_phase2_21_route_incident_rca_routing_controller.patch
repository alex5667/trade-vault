+BEGIN;
+
+CREATE TABLE IF NOT EXISTS llm_operator_routing_incident_route_rca_routing_decisions (
+    id              bigserial PRIMARY KEY,
+    incident_id     text NOT NULL,
+    ts_ms           bigint NOT NULL,
+    provider        text NOT NULL,
+    model_name      text NOT NULL,
+    prompt_version  text NOT NULL,
+    policy_version  text NOT NULL,
+    route_source    text NOT NULL,
+    meta_json       jsonb NOT NULL
+);
+
+CREATE INDEX IF NOT EXISTS idx_llm_operator_routing_incident_route_rca_routing_decisions_incident_id
+    ON llm_operator_routing_incident_route_rca_routing_decisions(incident_id);
+
+CREATE INDEX IF NOT EXISTS idx_llm_operator_routing_incident_route_rca_routing_decisions_ts_ms
+    ON llm_operator_routing_incident_route_rca_routing_decisions(ts_ms DESC);
+
+COMMIT;
