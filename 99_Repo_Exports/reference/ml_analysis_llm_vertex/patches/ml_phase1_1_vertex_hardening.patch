+            try:
+                cfg = genai_types.GenerateContentConfig(
+                    temperature=0.1,
+                    max_output_tokens=int(os.getenv("VERTEX_TRIAGE_MAX_OUTPUT_TOKENS", "1500") or 1500),
+                    response_mime_type="application/json",
+                )
+                resp = self._client.models.generate_content(
+                    model=self._model,
+                    contents=prompt,
