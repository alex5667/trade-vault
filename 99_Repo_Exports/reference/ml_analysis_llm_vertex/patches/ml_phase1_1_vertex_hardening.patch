+        self._model = os.getenv("VERTEX_TRIAGE_MODEL", "gemini-2.5-flash-lite")
+        self._timeout_ms = int(os.getenv("VERTEX_TIMEOUT_MS", "45000") or 45000)
+        self._max_retries = int(os.getenv("VERTEX_RETRY_MAX", "5") or 5)
