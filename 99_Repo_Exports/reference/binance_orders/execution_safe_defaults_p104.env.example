# deploy/execution_safe_defaults_p104.env.example
#
# P1.2.2 HA-safe execution projection worker — reference env overlay.
# Copy this file to your ops/ directory and override values as needed.
# All vars documented below with safe production defaults.
EXEC_SINGLE_ACTIVE_POSITION_PER_SYMBOL=0
EXEC_SINGLE_ACTIVE_POSITION_RELEASE_ON_TERMINAL=1
EXEC_SINGLE_ACTIVE_POSITION_STALE_TIMEOUT_MS=900000
ORDERS_ACTIVE_SYMBOL_KEY_PREFIX=orders:active_symbol_sid:

# ---------------------------------------------------------------------------
# P1.2.1: Core projection worker settings
# ---------------------------------------------------------------------------

# Redis URL for the execution journal and derived state
REDIS_URL=redis://redis-worker-1:6379/0

# Primary journal stream (executor appends here)
EXEC_STREAM=orders:exec

# Derived state key prefix  orders:state:{sid}
ORDERS_STATE_KEY_PREFIX=orders:state:

# TTL for derived state entries (86400 = 24h)
ORDERS_STATE_TTL_SEC=86400

# Disable inline materialisation on executor hot-path (journal-first mode)
EXEC_INLINE_STATE_PROJECTION=0

# Global cursor key tracking last projected stream ID
EXEC_PROJECTION_CURSOR_KEY=orders:exec:projection:cursor

# Events consumed per run_once() call
EXEC_PROJECTION_BATCH_SIZE=500

# Sleep between idle batches (ms)
EXEC_PROJECTION_IDLE_SLEEP_MS=500

# Optional PostgreSQL DSN for journal sink (leave empty to skip DB writes)
EXECUTION_JOURNAL_DSN=

# ---------------------------------------------------------------------------
# P1.2.2: HA Leader Lease + Fencing Token
# ---------------------------------------------------------------------------

# Set 1 to enable leader election (recommended for production multi-replica).
# Set 0 for single-node / development.
EXEC_PROJECTION_LEASE_ENABLE=1

# Redis key that holds the current leader's worker ID (SET NX PX)
EXEC_PROJECTION_LEASE_KEY=orders:exec:projection:leader

# Lease TTL in milliseconds (5000ms = 5s; must be > renew interval)
EXEC_PROJECTION_LEASE_TTL_MS=5000

# Renewal interval in ms — background thread extends TTL before expiry
EXEC_PROJECTION_LEASE_RENEW_INTERVAL_MS=2000

# This worker's unique identity (defaults to hostname if empty)
EXEC_PROJECTION_WORKER_ID=

# Monotonic fencing counter key (INCR on each successful lease acquisition)
EXEC_PROJECTION_FENCE_KEY=orders:exec:projection:fence

# How many idle cycles to wait before retrying lease acquisition on standby
EXEC_PROJECTION_LEASE_RETRY_IDLES=10

# ---------------------------------------------------------------------------
# P1.2.2: Health HTTP server
# ---------------------------------------------------------------------------

# Port for /healthz, /readyz, /api/execution-projection/health
EXEC_PROJECTION_HEALTH_PORT=8090

# Lag threshold for readyz: 503 if lag_ms > this value (or not leader)
EXEC_PROJECTION_LAG_READYZ_MAX_MS=30000

# ---------------------------------------------------------------------------
# P1.2.3: Execution bootstrap gate knobs
# ---------------------------------------------------------------------------

EXEC_BOOTSTRAP_REQUIRE_READY=1
EXEC_BOOTSTRAP_REQUIRE_PROJECTION_READY=1
EXEC_BOOTSTRAP_REQUIRE_USER_STREAM_READY=1
EXEC_BOOTSTRAP_TIMEOUT_MS=120000
EXEC_BOOTSTRAP_POLL_MS=500
EXEC_BOOTSTRAP_USER_STREAM_GRACE_MS=45000
EXEC_BOOTSTRAP_HEALTH_PORT=8787

# ---------------------------------------------------------------------------
# P1.2.4: Persisted bootstrap block state (incident + runbook API)
# ---------------------------------------------------------------------------

# Redis key for the latest bootstrap status snapshot (TTL = BLOCK_TTL_SEC)
EXEC_BOOTSTRAP_STATUS_KEY=orders:execution:bootstrap:status

# Redis key for the latest persisted block incident (inspectable via API)
EXEC_BOOTSTRAP_LAST_BLOCK_KEY=orders:execution:bootstrap:last_block

# TTL in seconds for both keys (86400 = 24h)
EXEC_BOOTSTRAP_BLOCK_TTL_SEC=86400
