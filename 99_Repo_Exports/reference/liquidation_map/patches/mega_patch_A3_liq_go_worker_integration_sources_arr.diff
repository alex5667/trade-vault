@@ -0,0 +1,43 @@
+package liquidation
+
+import "testing"
+
+func TestParseBybitAllLiquidation(t *testing.T) {
+	raw := []byte(`{"topic":"allLiquidation.BTCUSDT","ts":1710000000100,"data":[
+		{"time":1710000000100,"side":"Buy","symbol":"BTCUSDT","size":"0.05","price":"49999.5"},
+		{"time":1710000000200,"side":"Sell","symbol":"BTCUSDT","size":"0.07","price":"50010"}
+	]}`)
+	evs, err := ParseBybitAllLiquidation(raw, 1710000000999)
+	if err != nil {
+		t.Fatalf("unexpected err: %v", err)
+	}
+	if len(evs) != 2 {
+		t.Fatalf("expected 2 events, got %d", len(evs))
+	}
+	if evs[0].Venue != "bybit_linear" {
+		t.Fatalf("bad venue: %q", evs[0].Venue)
+	}
+	if evs[0].OrderSide != "BUY" {
+		t.Fatalf("expected order_side=BUY, got %q", evs[0].OrderSide)
+	}
+	if evs[0].LiqSide != "long" {
+		t.Fatalf("expected liq_side=long, got %q", evs[0].LiqSide)
+	}
+	if evs[1].OrderSide != "SELL" {
+		t.Fatalf("expected order_side=SELL, got %q", evs[1].OrderSide)
+	}
+	if evs[1].LiqSide != "short" {
+		t.Fatalf("expected liq_side=short, got %q", evs[1].LiqSide)
+	}
+}
+
+func TestParseBybitAllLiquidation_IgnoresNonDataMessages(t *testing.T) {
+	raw := []byte(`{"op":"pong"}`)
+	evs, err := ParseBybitAllLiquidation(raw, 0)
+	if err != nil {
+		t.Fatalf("unexpected err: %v", err)
+	}
+	if len(evs) != 0 {
+		t.Fatalf("expected 0 events, got %d", len(evs))
+	}
+}
