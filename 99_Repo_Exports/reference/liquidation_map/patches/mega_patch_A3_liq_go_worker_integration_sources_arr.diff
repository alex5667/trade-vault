new file mode 100644
index 0000000..40c223a
--- /dev/null
+++ b/internal/liquidation/errors.go
@@ -0,0 +1,40 @@
+package liquidation
+
+import "fmt"
+
+// ReasonError позволяет прокинуть в контроллер структурированную причину quarantine/drop.
+// Используйте ReasonError для ошибок валидации/нормализации (missing_symbol, bad_decimal, unknown_side и т.д.).
+//
+// Для ошибок JSON unmarshal и сетевых ошибок ReasonError обычно не требуется — их можно учитывать как parse_error.
+type ReasonError struct {
+	reason string
+	err    error
+}
+
+func (e ReasonError) Error() string {
+	if e.err == nil {
+		return e.reason
+	}
+	return fmt.Sprintf("%s: %v", e.reason, e.err)
+}
+
+func (e ReasonError) Unwrap() error { return e.err }
+
+func (e ReasonError) Reason() string { return e.reason }
+
+func wrapReason(reason string, err error) error {
+	return ReasonError{reason: reason, err: err}
+}
+
+func parseReason(err error) string {
+	if err == nil {
+		return ""
+	}
+	type rr interface{ Reason() string }
+	if r, ok := err.(rr); ok {
+		if v := r.Reason(); v != "" {
+			return v
+		}
+	}
+	return "parse_error"
+}
diff --git a/internal/liquidation/normalize.go b/internal/liquidation/normalize.go
new file mode 100644
index 0000000..41e6688
--- /dev/null
+++ b/internal/liquidation/normalize.go
@@ -0,0 +1,51 @@
+package liquidation
+
+import (
+	"errors"
+	"strings"
+)
+
+// normalizeSymbol приводит символ к UPPERCASE и проверяет, что он не пустой.
+func normalizeSymbol(sym string) (string, error) {
+	s := strings.ToUpper(strings.TrimSpace(sym))
+	if s == "" {
+		return "", wrapReason("missing_symbol", errors.New("missing symbol"))
+	}
+	return s, nil
+}
+
+// inferLiqSideFromOrderSide применяет единое правило интерпретации для liquidation streams.
+//
+// Для Binance forceOrder:
+//   SELL — закрывает LONG (liq_side=long)
+//   BUY  — закрывает SHORT (liq_side=short)
+//
+// Для Bybit allLiquidation:
+//   Buy  => long liquidation
+//   Sell => short liquidation
+//
+// Мы приводим order_side к BUY|SELL и возвращаем liq_side long|short.
+func inferLiqSideFromOrderSide(orderSide string) (string, error) {
+	s := strings.ToUpper(strings.TrimSpace(orderSide))
+	switch s {
+	case "SELL":
+		return "long", nil
+	case "BUY":
+		return "short", nil
+	default:
+		return "", wrapReason("unknown_side", errors.New("unknown side"))
+	}
+}
+
+// normalizeBybitSide приводит "Buy"/"Sell" к order_side=BUY|SELL + liq_side.
+func normalizeBybitSide(rawSide string) (orderSide string, liqSide string, err error) {
+	s := strings.ToLower(strings.TrimSpace(rawSide))
+	switch s {
+	case "buy":
+		return "BUY", "long", nil
+	case "sell":
+		return "SELL", "short", nil
+	default:
+		return "", "", wrapReason("unknown_side", errors.New("unknown side"))
+	}
+}
diff --git a/internal/liquidation/publisher.go b/internal/liquidation/publisher.go
new file mode 100644
index 0000000..6592bff
--- /dev/null
+++ b/internal/liquidation/publisher.go
@@ -0,0 +1,130 @@
+package liquidation
+
+import (
+	"context"
+	"math/rand"
+	"sync"
+	"time"
+
+	goredis "github.com/go-redis/redis/v8"
+
+	"go-worker/internal/redis"
+)
+
+// Publisher — тонкая обвязка над BatchStreamPublisher.
+//
+// Задачи:
+//   - единый DTO контракт (LiqEventV1 -> Redis values)
+//   - sampling raw/quarantine
+//   - best-effort публикация (fail-open)
+//
+// Потоки:
+//   - основной stream: cfg.Stream
+//   - quarantine stream: cfg.QuarantineStream
+//
+// Quarantine и raw в основном потоке семплируются, чтобы не раздувать Redis/сеть.
+type Publisher struct {
+	cfg Config
+
+	main *redis.BatchStreamPublisher
+	q    *redis.BatchStreamPublisher
+
+	rngMu sync.Mutex
+	rng   *rand.Rand
+}
+
+func NewPublisher(rdb *goredis.Client, cfg Config) *Publisher {
+	main := redis.NewBatchStreamPublisher(rdb, cfg.Stream, cfg.StreamMaxLen, cfg.BatchSize, cfg.FlushInterval)
+	var q *redis.BatchStreamPublisher
+	if cfg.DQ.EnableQuarantine {
+		// quarantine держим короче (чтобы не забивать Redis).
+		q = redis.NewBatchStreamPublisher(rdb, cfg.QuarantineStream, 50_000, 200, 50*time.Millisecond)
+	}
+	return &Publisher{
+		cfg:  cfg,
+		main: main,
+		q:    q,
+		rng:  rand.New(rand.NewSource(time.Now().UnixNano())),
+	}
+}
+
+func (p *Publisher) Start(ctx context.Context) {
+	p.main.Start(ctx)
+	if p.q != nil {
+		p.q.Start(ctx)
+	}
+}
+
+func (p *Publisher) shouldSample(prob float64) bool {
+	if prob <= 0 {
+		return false
+	}
+	if prob >= 1 {
+		return true
+	}
+	p.rngMu.Lock()
+	v := p.rng.Float64()
+	p.rngMu.Unlock()
+	return v < prob
+}
+
+// Publish пишет нормализованное событие в основной stream.
+// Возвращает false, если внутренний буфер переполнен.
+func (p *Publisher) Publish(ev LiqEventV1, raw []byte) bool {
+	values := ev.ToRedisValues()
+	if p.shouldSample(p.cfg.RawSampleRate) {
+		if s := truncateRaw(raw, p.cfg.RawMaxBytes); s != "" {
+			values["raw"] = s
+		}
+	}
+	return p.main.Enqueue(values)
+}
+
+// QuarantineEvent публикует событие в quarantine stream (семплируемо).
+func (p *Publisher) QuarantineEvent(ev LiqEventV1, raw []byte, reason string) {
+	if p.q == nil {
+		return
+	}
+	if !p.shouldSample(p.cfg.QuarantineSampleRate) {
+		return
+	}
+	values := ev.ToRedisValues()
+	values["reason"] = reason
+	if s := truncateRaw(raw, p.cfg.RawMaxBytes); s != "" {
+		values["raw"] = s
+	}
+	_ = p.q.Enqueue(values)
+}
+
+// QuarantineRaw публикует минимальный DTO, когда парсинг целиком не удался.
+func (p *Publisher) QuarantineRaw(venue string, raw []byte, nowMs int64, reason string) {
+	if p.q == nil {
+		return
+	}
+	if !p.shouldSample(p.cfg.QuarantineSampleRate) {
+		return
+	}
+	values := map[string]interface{}{
+		"ts_event_ms":  int64(0),
+		"ts_ingest_ms": nowMs,
+		"venue":        venue,
+		"symbol":       "",
+		"order_side":   "",
+		"liq_side":     "",
+		"price":        "",
+		"qty":          "",
+		"notional_usd": "",
+		"reason":       reason,
+	}
+	if s := truncateRaw(raw, p.cfg.RawMaxBytes); s != "" {
+		values["raw"] = s
+	}
+	_ = p.q.Enqueue(values)
+}
+
+func (p *Publisher) Close(timeout time.Duration) {
+	_ = p.main.Close(timeout)
+	if p.q != nil {
+		_ = p.q.Close(timeout)
+	}
+}
