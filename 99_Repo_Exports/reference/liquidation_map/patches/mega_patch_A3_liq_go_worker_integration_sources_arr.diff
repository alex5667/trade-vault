diff --git a/internal/liquidation/binance_forceorder.go b/internal/liquidation/binance_forceorder.go
new file mode 100644
index 0000000..65e669d
--- /dev/null
+++ b/internal/liquidation/binance_forceorder.go
@@ -0,0 +1,130 @@
+package liquidation
+
+import (
+	"bytes"
+	"encoding/json"
+	"errors"
+	"strings"
+)
+
+// Binance USDT-M Liquidation Order Stream.
+//
+// Два формата:
+//   1) <symbol>@forceOrder      — одиночное событие (object)
+//   2) !forceOrder@arr          — all-market stream (array of objects)
+//
+// Документы Binance описывают одинаковую структуру элемента "o".
+// Важно: именно all-market stream позволяет не упереться в лимит multiplex streams.
+//
+// Мы нормализуем в LiqEventV1.
+
+type binanceForceOrderMsg struct {
+	EventType string `json:"e"`
+	EventTime int64  `json:"E"`
+	Order     struct {
+		Symbol      string `json:"s"`
+		Side        string `json:"S"` // BUY / SELL
+		OrderStatus string `json:"X"` // FILLED / ...
+		Price       string `json:"p"` // order price (может быть 0)
+		AvgPrice    string `json:"ap"`
+		OrigQty     string `json:"q"`
+		FilledQty   string `json:"z"`
+		TradeTime   int64  `json:"T"` // event ts
+	} `json:"o"`
+}
+
+// ParseBinanceForceOrderMessage парсит payload из Binance liquidation stream.
+// Поддерживает как object (single), так и array (all-market).
+func ParseBinanceForceOrderMessage(raw []byte, nowMs int64) ([]LiqEventV1, error) {
+	r := bytes.TrimSpace(raw)
+	if len(r) == 0 {
+		return nil, wrapReason("empty_payload", errors.New("empty payload"))
+	}
+	// array format (!forceOrder@arr)
+	if r[0] == '[' {
+		var msgs []binanceForceOrderMsg
+		if err := json.Unmarshal(r, &msgs); err != nil {
+			return nil, err
+		}
+		out := make([]LiqEventV1, 0, len(msgs))
+		for i := range msgs {
+			ev, err := forceOrderMsgToEvent(msgs[i], nowMs)
+			if err != nil {
+				// best-effort: пропускаем плохой элемент, но не роняем весь батч.
+				continue
+			}
+			out = append(out, ev)
+		}
+		return out, nil
+	}
+
+	// single object format
+	var msg binanceForceOrderMsg
+	if err := json.Unmarshal(r, &msg); err != nil {
+		return nil, err
+	}
+	ev, err := forceOrderMsgToEvent(msg, nowMs)
+	if err != nil {
+		return nil, err
+	}
+	return []LiqEventV1{ev}, nil
+}
+
+// ParseBinanceForceOrder — legacy helper для <symbol>@forceOrder (single object).
+func ParseBinanceForceOrder(raw []byte, nowMs int64) (LiqEventV1, error) {
+	evs, err := ParseBinanceForceOrderMessage(raw, nowMs)
+	if err != nil {
+		return LiqEventV1{}, err
+	}
+	if len(evs) == 0 {
+		return LiqEventV1{}, wrapReason("empty_payload", errors.New("no events"))
+	}
+	return evs[0], nil
+}
+
+func forceOrderMsgToEvent(msg binanceForceOrderMsg, nowMs int64) (LiqEventV1, error) {
+	symbol, err := normalizeSymbol(msg.Order.Symbol)
+	if err != nil {
+		return LiqEventV1{}, err
+	}
+	orderSide := strings.ToUpper(strings.TrimSpace(msg.Order.Side))
+	liqSide, err := inferLiqSideFromOrderSide(orderSide)
+	if err != nil {
+		return LiqEventV1{}, err
+	}
+	// Binance: price может быть 0, поэтому берём ap (avg price) если доступно.
+	price := strings.TrimSpace(msg.Order.AvgPrice)
+	if price == "" || price == "0" {
+		price = strings.TrimSpace(msg.Order.Price)
+	}
+	qty := strings.TrimSpace(msg.Order.FilledQty)
+	if qty == "" || qty == "0" {
+		qty = strings.TrimSpace(msg.Order.OrigQty)
+	}
+	if !isPositiveDecimalString(price) {
+		return LiqEventV1{}, wrapReason("bad_price", errors.New("bad price"))
+	}
+	if !isPositiveDecimalString(qty) {
+		return LiqEventV1{}, wrapReason("bad_qty", errors.New("bad qty"))
+	}
+	notional, err := mulDecimalStrings(price, qty)
+	if err != nil {
+		return LiqEventV1{}, wrapReason("bad_notional", err)
+	}
+	ts := msg.Order.TradeTime
+	if ts <= 0 {
+		ts = msg.EventTime
+	}
+	return LiqEventV1{
+		TsEventMs:   ts,
+		TsIngestMs:  nowMs,
+		Venue:       "binance_usdtm",
+		Symbol:      symbol,
+		OrderSide:   orderSide,
+		LiqSide:     liqSide,
+		Price:       price,
+		Qty:         qty,
+		NotionalUsd: notional,
+		Status:      strings.TrimSpace(msg.Order.OrderStatus),
+	}, nil
+}
diff --git a/internal/liquidation/binance_forceorder_test.go b/internal/liquidation/binance_forceorder_test.go
new file mode 100644
index 0000000..2bd7f6f
--- /dev/null
+++ b/internal/liquidation/binance_forceorder_test.go
@@ -0,0 +1,60 @@
+package liquidation
+
+import "testing"
+
+func TestParseBinanceForceOrder_Single(t *testing.T) {
+	// Минимальный пример, приближенный к реальному payload (часть полей опущена).
+	raw := []byte(`{"e":"forceOrder","E":1710000000123,"o":{"s":"BTCUSDT","S":"SELL","X":"FILLED","p":"50000","ap":"50010","q":"0.10","z":"0.08","T":1710000000456}}`)
+	ev, err := ParseBinanceForceOrder(raw, 1710000000999)
+	if err != nil {
+		t.Fatalf("unexpected err: %v", err)
+	}
+	if ev.Venue != "binance_usdtm" {
+		t.Fatalf("bad venue: %q", ev.Venue)
+	}
+	if ev.Symbol != "BTCUSDT" {
+		t.Fatalf("bad symbol: %q", ev.Symbol)
+	}
+	if ev.OrderSide != "SELL" {
+		t.Fatalf("expected order_side=SELL, got %q", ev.OrderSide)
+	}
+	if ev.LiqSide != "long" {
+		t.Fatalf("expected liq_side=long, got %q", ev.LiqSide)
+	}
+	if ev.Status != "FILLED" {
+		t.Fatalf("expected status=FILLED, got %q", ev.Status)
+	}
+	if ev.Price != "50010" {
+		t.Fatalf("expected avg price, got %q", ev.Price)
+	}
+	if ev.Qty != "0.08" {
+		t.Fatalf("expected filled qty, got %q", ev.Qty)
+	}
+	if ev.TsEventMs != 1710000000456 {
+		t.Fatalf("expected trade time, got %d", ev.TsEventMs)
+	}
+	if ev.TsIngestMs != 1710000000999 {
+		t.Fatalf("expected ingest time, got %d", ev.TsIngestMs)
+	}
+}
+
+func TestParseBinanceForceOrder_AllMarketArray(t *testing.T) {
+	// Формат !forceOrder@arr — массив элементов.
+	raw := []byte(`[
+		{"e":"forceOrder","E":1710000000123,"o":{"s":"BTCUSDT","S":"SELL","X":"FILLED","ap":"50010","z":"0.08","T":1710000000456}},
+		{"e":"forceOrder","E":1710000001123,"o":{"s":"ETHUSDT","S":"BUY","X":"FILLED","ap":"3000","z":"1.2","T":1710000001456}}
+	]`)
+	evs, err := ParseBinanceForceOrderMessage(raw, 1710000001999)
+	if err != nil {
+		t.Fatalf("unexpected err: %v", err)
+	}
+	if len(evs) != 2 {
+		t.Fatalf("expected 2 events, got %d", len(evs))
+	}
+	if evs[0].Symbol != "BTCUSDT" || evs[0].LiqSide != "long" {
+		t.Fatalf("bad ev0: %+v", evs[0])
+	}
+	if evs[1].Symbol != "ETHUSDT" || evs[1].OrderSide != "BUY" || evs[1].LiqSide != "short" {
+		t.Fatalf("bad ev1: %+v", evs[1])
+	}
+}
diff --git a/internal/liquidation/bybit_all_liquidation.go b/internal/liquidation/bybit_all_liquidation.go
new file mode 100644
index 0000000..a1a742a
--- /dev/null
+++ b/internal/liquidation/bybit_all_liquidation.go
@@ -0,0 +1,88 @@
+package liquidation
+
+import (
+	"encoding/json"
+	"errors"
+	"strings"
+)
+
+// Bybit V5 public liquidation stream (linear).
+// Topic: allLiquidation.<symbol>
+//
+// В ответе приходят сообщения разных типов (ping/pong/subscribed/etc).
+// Мы вынимаем только payload с data[].
+
+type bybitLiquidationMsg struct {
+	Topic string `json:"topic"`
+	Type  string `json:"type"`
+	TS    int64  `json:"ts"`
+	Data  []struct {
+		Symbol string `json:"symbol"`
+		Side   string `json:"side"`   // "Buy"/"Sell"
+		Price  string `json:"price"`  // string
+		Size   string `json:"size"`   // qty string
+		Time   int64  `json:"time"`   // ms
+	} `json:"data"`
+}
+
+// ParseBybitAllLiquidation возвращает 0..N событий из одного WS сообщения.
+func ParseBybitAllLiquidation(raw []byte, nowMs int64) ([]LiqEventV1, error) {
+	var msg bybitLiquidationMsg
+	if err := json.Unmarshal(raw, &msg); err != nil {
+		return nil, err
+	}
+	if len(msg.Data) == 0 {
+		return nil, nil
+	}
+
+	evs := make([]LiqEventV1, 0, len(msg.Data))
+	for _, row := range msg.Data {
+		symbol, err := normalizeSymbol(row.Symbol)
+		if err != nil {
+			// best-effort: пропускаем плохой элемент.
+			continue
+		}
+		orderSide, liqSide, err := normalizeBybitSide(row.Side)
+		if err != nil {
+			continue
+		}
+
+		price := strings.TrimSpace(row.Price)
+		qty := strings.TrimSpace(row.Size)
+		if !isPositiveDecimalString(price) {
+			continue
+		}
+		if !isPositiveDecimalString(qty) {
+			continue
+		}
+		notional, err := mulDecimalStrings(price, qty)
+		if err != nil {
+			continue
+		}
+		ts := row.Time
+		if ts <= 0 {
+			if msg.TS > 0 {
+				ts = msg.TS
+			} else {
+				ts = nowMs
+			}
+		}
+		evs = append(evs, LiqEventV1{
+			TsEventMs:   ts,
+			TsIngestMs:  nowMs,
+			Venue:       "bybit_linear",
+			Symbol:      symbol,
+			OrderSide:   orderSide,
+			LiqSide:     liqSide,
+			Price:       price,
+			Qty:         qty,
+			NotionalUsd: notional,
+			Status:      "",
+		})
+	}
+	if len(evs) == 0 {
+		// если сообщение было data[], но всё плохое — вернём ошибку, чтобы оно попадало в quarantine.
+		return nil, wrapReason("bad_rows", errors.New("all rows rejected"))
+	}
+	return evs, nil
+}
diff --git a/internal/liquidation/bybit_all_liquidation_test.go b/internal/liquidation/bybit_all_liquidation_test.go
