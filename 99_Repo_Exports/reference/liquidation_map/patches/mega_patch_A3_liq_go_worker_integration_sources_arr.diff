+package liquidation
+
+import (
+	"os"
+	"strconv"
+	"strings"
+	"time"
+)
+
+// Config — конфигурация ingestion сервиса ликвидаций.
+//
+// ENV ключи:
+//	LIQ_WS_ENABLED=true|false
+//	LIQ_SYMBOLS=BTCUSDT,ETHUSDT              (fallback = FUTURES_SYMBOLS)
+//	LIQ_SOURCES=binance,bybit                (опционально; если задан — переопределяет *_ENABLED)
+//
+//	LIQ_BINANCE_ENABLED=true|false           (если LIQ_SOURCES не задан)
+//	LIQ_BINANCE_WS_URL=wss://fstream.binance.com/ws/!forceOrder@arr
+//
+//	LIQ_BYBIT_ENABLED=true|false             (если LIQ_SOURCES не задан)
+//	LIQ_BYBIT_WS_URL=wss://stream.bybit.com/v5/public/linear
+//	LIQ_BYBIT_PING_MS=20000
+//
+//	LIQ_STREAM=stream:liq_evt
+//	LIQ_QUARANTINE_STREAM=stream:liq_evt:quarantine
+//	LIQ_QUARANTINE_SAMPLE_RATE=0.01
+//
+//	LIQ_BATCH_SIZE=200
+//	LIQ_FLUSH_MS=20
+//	LIQ_STREAM_MAXLEN=200000
+//
+//	LIQ_RAW_SAMPLE_RATE=0.001
+//	LIQ_RAW_MAX_BYTES=2048
+//
+//	LIQ_MAX_EVENT_AGE_MS=10000               (alias: LIQ_MAX_PAST_MS)
+//	LIQ_MAX_FUTURE_SKEW_MS=2000              (alias: LIQ_MAX_FUTURE_MS)
+//	LIQ_MAX_OOO_MS=2000
+//	LIQ_ENABLE_QUARANTINE=true|false
+//
+// Примечание по Binance:
+//	!forceOrder@arr — all-market stream и присылает ARRAY событий.
+//	Парсер поддерживает как одиночное событие (<symbol>@forceOrder), так и массив.
+//
+// Режимы:
+//	Дефолты соответствуют SAFE (минимальный риск, без влияния на core pipeline).
+//	STRICT режим (агрессивные лимиты времени/OOO) включайте только после проверки на ваших сетевых реалиях.
+//
+// Детерминизм:
+//	цены/кол-ва передаём строками как в payload; notional_usd считаем через big.Rat и тоже пишем строкой.
+//	Это исключает накопление float ошибок и упрощает "train==serve" для downstream.
+//
+// Потоки:
+//	stream:liq_evt — основной поток
+//	stream:liq_evt:quarantine — bad time/parse/DQ/drop (сэмплируемо)
+//
+// Типизация/контракты в downstream:
+//	NestJS/Python должны трактовать поля как строки (Decimal) и конвертировать детерминированно.
+//	В MVP допускается float в downstream, но ingestion уже отдаёт строковый Decimal.
+//
+// See also: internal/liquidation/types.go (DTO) + dq.go (data-quality policy).
+//
+// ---
+// Поля Config отражают только ingestion/transport слой.
+// Heatmap/кластеризация делаются downstream (Python).
+// ---
+type Config struct {
+	Enabled bool
+
+	Symbols []string
+
+	BinanceEnabled bool
+	BinanceWSURL   string
+
+	BybitEnabled bool
+	BybitWSURL   string
+
+	Stream           string
+	QuarantineStream string
+
+	BatchSize     int
+	FlushInterval time.Duration
+	StreamMaxLen  int64
+
+	// RawSampleRate — доля событий, для которых в основной stream добавляется поле raw.
+	// 0.0 означает «никогда не добавлять raw в основной поток».
+	RawSampleRate float64
+	RawMaxBytes   int
+
+	// QuarantineSampleRate — доля событий, которые будут записаны в quarantine stream.
+	// Это защищает Redis от лавинообразных ошибок (например, при несовместимом payload).
+	QuarantineSampleRate float64
+
+	DQ DQPolicy
+
+	BybitPingPeriod time.Duration
+}
+
+func parseBoolEnv(key string, def bool) bool {
+	v := strings.TrimSpace(os.Getenv(key))
+	if v == "" {
+		return def
+	}
+	switch strings.ToLower(v) {
+	case "0", "false", "off", "no":
+		return false
+	case "1", "true", "on", "yes":
+		return true
+	default:
+		return def
+	}
+}
+
+func parseIntEnv(key string, def int) int {
+	v := strings.TrimSpace(os.Getenv(key))
+	if v == "" {
+		return def
+	}
+	i, err := strconv.Atoi(v)
+	if err != nil {
+		return def
+	}
+	return i
+}
+
+func parseInt64Env(key string, def int64) int64 {
+	v := strings.TrimSpace(os.Getenv(key))
+	if v == "" {
+		return def
+	}
+	i, err := strconv.ParseInt(v, 10, 64)
+	if err != nil {
+		return def
+	}
+	return i
+}
+
+func parseFloatEnv(key string, def float64) float64 {
+	v := strings.TrimSpace(os.Getenv(key))
+	if v == "" {
+		return def
+	}
+	f, err := strconv.ParseFloat(v, 64)
+	if err != nil {
+		return def
+	}
+	if f < 0 {
+		return def
+	}
+	if f > 1 {
+		return 1
+	}
+	return f
+}
+
+func parseDurationMsEnv(key string, def time.Duration) time.Duration {
+	v := strings.TrimSpace(os.Getenv(key))
+	if v == "" {
+		return def
+	}
+	ms, err := strconv.ParseInt(v, 10, 64)
+	if err != nil || ms <= 0 {
+		return def
+	}
+	return time.Duration(ms) * time.Millisecond
+}
+
+func parseDurationMsEnvAlias(primaryKey, aliasKey string, def time.Duration) time.Duration {
+	// Если aliasKey задан — он имеет приоритет (чтобы поддержать более короткие имена).
+	if strings.TrimSpace(os.Getenv(aliasKey)) != "" {
+		return parseDurationMsEnv(aliasKey, def)
+	}
+	return parseDurationMsEnv(primaryKey, def)
+}
+
+func parseSymbolsEnv(key string, fallback []string) []string {
+	raw := strings.TrimSpace(os.Getenv(key))
+	if raw == "" {
+		return fallback
+	}
+	parts := strings.Split(raw, ",")
+	out := make([]string, 0, len(parts))
+	for _, p := range parts {
+		s := strings.ToUpper(strings.TrimSpace(p))
+		if s != "" {
+			out = append(out, s)
+		}
+	}
+	if len(out) == 0 {
+		return fallback
+	}
+	return out
+}
+
+func parseSourcesEnv(key string) []string {
+	raw := strings.TrimSpace(os.Getenv(key))
+	if raw == "" {
+		return nil
+	}
+	parts := strings.Split(raw, ",")
+	out := make([]string, 0, len(parts))
+	for _, p := range parts {
+		s := strings.ToLower(strings.TrimSpace(p))
+		if s != "" {
+			out = append(out, s)
+		}
+	}
+	if len(out) == 0 {
+		return nil
+	}
+	return out
+}
+
+func hasSource(sources []string, name string) bool {
+	for _, s := range sources {
+		if s == name {
+			return true
+		}
+	}
+	return false
+}
+
+// LoadConfigFromEnv выставляет безопасные дефолты (SAFE режим).
+func LoadConfigFromEnv(fallbackSymbols []string) Config {
+	symbols := parseSymbolsEnv("LIQ_SYMBOLS", fallbackSymbols)
+	sources := parseSourcesEnv("LIQ_SOURCES")
+
+	cfg := Config{
+		Enabled:              parseBoolEnv("LIQ_WS_ENABLED", false),
+		Symbols:              symbols,
+		BinanceEnabled:       parseBoolEnv("LIQ_BINANCE_ENABLED", true),
+		BinanceWSURL:         strings.TrimSpace(os.Getenv("LIQ_BINANCE_WS_URL")),
+		BybitEnabled:         parseBoolEnv("LIQ_BYBIT_ENABLED", false),
+		BybitWSURL:           strings.TrimSpace(os.Getenv("LIQ_BYBIT_WS_URL")),
+		Stream:               strings.TrimSpace(os.Getenv("LIQ_STREAM")),
+		QuarantineStream:     strings.TrimSpace(os.Getenv("LIQ_QUARANTINE_STREAM")),
+		BatchSize:            parseIntEnv("LIQ_BATCH_SIZE", 200),
+		FlushInterval:        parseDurationMsEnv("LIQ_FLUSH_MS", 20*time.Millisecond),
+		StreamMaxLen:         parseInt64Env("LIQ_STREAM_MAXLEN", 200_000),
+		RawSampleRate:        parseFloatEnv("LIQ_RAW_SAMPLE_RATE", 0.0),
+		RawMaxBytes:          parseIntEnv("LIQ_RAW_MAX_BYTES", 2048),
+		QuarantineSampleRate: parseFloatEnv("LIQ_QUARANTINE_SAMPLE_RATE", 0.01),
+		BybitPingPeriod:      parseDurationMsEnv("LIQ_BYBIT_PING_MS", 20*time.Second),
+	}
+
+	// LIQ_SOURCES имеет приоритет над *_ENABLED (чтобы проще конфигурировать).
+	if len(sources) > 0 {
+		if hasSource(sources, "all") {
+			cfg.BinanceEnabled = true
+			cfg.BybitEnabled = true
+		} else {
+			cfg.BinanceEnabled = hasSource(sources, "binance")
+			cfg.BybitEnabled = hasSource(sources, "bybit")
+		}
+	}
+
+	if cfg.BinanceWSURL == "" {
+		cfg.BinanceWSURL = "wss://fstream.binance.com/ws/!forceOrder@arr"
+	}
+	if cfg.BybitWSURL == "" {
+		cfg.BybitWSURL = "wss://stream.bybit.com/v5/public/linear"
+	}
+	if cfg.Stream == "" {
+		cfg.Stream = "stream:liq_evt"
+	}
+	if cfg.QuarantineStream == "" {
+		cfg.QuarantineStream = "stream:liq_evt:quarantine"
+	}
+
+	dq := DefaultDQPolicy(symbols)
+	// Aliases: LIQ_MAX_PAST_MS / LIQ_MAX_FUTURE_MS
+	dq.MaxEventAge = parseDurationMsEnvAlias("LIQ_MAX_EVENT_AGE_MS", "LIQ_MAX_PAST_MS", 10*time.Second)
+	dq.MaxFutureSkew = parseDurationMsEnvAlias("LIQ_MAX_FUTURE_SKEW_MS", "LIQ_MAX_FUTURE_MS", 2*time.Second)
+	dq.MaxOutOfOrder = parseDurationMsEnv("LIQ_MAX_OOO_MS", 2*time.Second)
+	dq.EnableQuarantine = parseBoolEnv("LIQ_ENABLE_QUARANTINE", true)
+	cfg.DQ = dq
+
+	return cfg
+}
diff --git a/internal/liquidation/controller.go b/internal/liquidation/controller.go
new file mode 100644
index 0000000..8bfe81d
--- /dev/null
+++ b/internal/liquidation/controller.go
@@ -0,0 +1,295 @@
+package liquidation
+
+import (
+	"context"
+	"log"
+	"math"
+	"os"
+	"sync"
+	"time"
+
+	goredis "github.com/go-redis/redis/v8"
+	"github.com/gorilla/websocket"
+
+	"go-worker/internal/monitoring"
+	"go-worker/internal/wsconn"
+)
+
+// Controller отвечает за получение liquidation feeds из WS и публикацию в Redis Streams.
+//
+// Граница ответственности:
+//   - ingestion + нормализация + базовая DQ фильтрация
+//   - публикация нормализованных событий (плоский DTO) в Redis Stream
+//
+// НЕ делает:
+//   - построение heatmap/кластеров (это Python worker)
+//   - хранение истории (это Timescale/ETL)
+//
+// Важный нюанс по Binance:
+//   - !forceOrder@arr возвращает ARRAY событий.
+//     Поэтому парсер возвращает []LiqEventV1.
+type Controller struct {
+	cfg Config
+
+	logger  *log.Logger
+	metrics *monitoring.LiquidationMetrics
+
+	pub *Publisher
+
+	wg sync.WaitGroup
+}
+
+func NewController(rdb *goredis.Client, cfg Config, logger *log.Logger) *Controller {
+	if logger == nil {
+		logger = log.New(os.Stdout, "[liq] ", log.LstdFlags|log.Lmicroseconds)
+	}
+	return &Controller{
+		cfg:     cfg,
+		logger:  logger,
+		metrics: monitoring.NewLiquidationMetrics(),
+		pub:     NewPublisher(rdb, cfg),
+	}
+}
+
+func (c *Controller) Start(ctx context.Context) {
+	if !c.cfg.Enabled {
+		c.logger.Printf("liquidation WS disabled (LIQ_WS_ENABLED=false)")
+		return
+	}
+
+	c.pub.Start(ctx)
+
+	if c.cfg.BinanceEnabled {
+		c.wg.Add(1)
+		go func() {
+			defer c.wg.Done()
+			c.runBinance(ctx)
+		}()
+	}
+	if c.cfg.BybitEnabled {
+		c.wg.Add(1)
+		go func() {
+			defer c.wg.Done()
+			c.runBybit(ctx)
+		}()
+	}
+}
+
+func (c *Controller) Stop(timeout time.Duration) {
+	done := make(chan struct{})
+	go func() {
+		c.wg.Wait()
+		close(done)
+	}()
+	select {
+	case <-done:
+	case <-time.After(timeout):
+	}
+
+	c.pub.Close(2 * time.Second)
+}
+
+func (c *Controller) runBinance(ctx context.Context) {
+	venue := "binance_usdtm"
+	backoff := time.Second
+
+	wsCfg := wsconn.DefaultConfig
+	wsCfg.ReadTimeout = 60 * time.Second
+
+	for {
+		select {
+		case <-ctx.Done():
+			c.metrics.SetConnected(venue, false)
+			return
+		default:
+		}
+
+		conn, err := wsconn.Dial(ctx, c.cfg.BinanceWSURL, wsCfg)
+		if err != nil {
+			c.metrics.SetConnected(venue, false)
+			c.logger.Printf("binance dial error: %v", err)
+			time.Sleep(backoff)
+			backoff = time.Duration(math.Min(float64(15*time.Second), float64(backoff*2)))
+			continue
+		}
+		backoff = time.Second
+		c.metrics.SetConnected(venue, true)
+		c.logger.Printf("binance connected: %s", c.cfg.BinanceWSURL)
+
+		_ = conn.SetReadDeadline(time.Now().Add(wsCfg.ReadTimeout))
+		conn.SetPongHandler(func(appData string) error {
+			_ = conn.SetReadDeadline(time.Now().Add(wsCfg.ReadTimeout))
+			return nil
+		})
+
+		for {
+			select {
+			case <-ctx.Done():
+				_ = conn.Close()
+				c.metrics.SetConnected(venue, false)
+				return
+			default:
+			}
+
+			_, msg, err := conn.ReadMessage()
+			if err != nil {
+				c.metrics.SetConnected(venue, false)
+				c.logger.Printf("binance read error: %v", err)
+				_ = conn.Close()
+				break
+			}
+			nowMs := time.Now().UnixMilli()
+
+			evs, err := ParseBinanceForceOrderMessage(msg, nowMs)
+			if err != nil {
+				reason := parseReason(err)
+				c.metrics.ParseErr(venue)
+				c.metrics.Drop(venue, reason, 1)
+				c.pub.QuarantineRaw(venue, msg, nowMs, reason)
+				continue
+			}
+			if len(evs) == 0 {
+				continue
+			}
+
+			c.metrics.IncIn(venue, len(evs))
+			for _, ev := range evs {
+				ok, reason := c.cfg.DQ.Validate(ev, nowMs)
+				if !ok {
+					c.metrics.Drop(venue, reason, 1)
+					c.pub.QuarantineEvent(ev, msg, reason)
+					continue
+				}
+				c.metrics.ObserveLag(venue, nowMs-ev.TsEventMs)
+
+				if !c.pub.Publish(ev, msg) {
+					c.metrics.Drop(venue, "queue_full", 1)
+					c.pub.QuarantineEvent(ev, msg, "queue_full")
+					continue
+				}
+				c.metrics.IncPublished(venue, 1)
+			}
+			c.metrics.TickRate(venue, len(evs))
+		}
+	}
+}
+
+func (c *Controller) runBybit(ctx context.Context) {
+	venue := "bybit_linear"
+	backoff := time.Second
+
+	wsCfg := wsconn.DefaultConfig
+	wsCfg.ReadTimeout = 90 * time.Second
+
+	topics := make([]string, 0, len(c.cfg.Symbols))
+	for _, s := range c.cfg.Symbols {
+		topics = append(topics, "allLiquidation."+s)
+	}
+	if len(topics) == 0 {
+		c.logger.Printf("bybit enabled but no symbols; disabling bybit ingestion")
+		return
+	}
+	subscribeMsg := map[string]interface{}{
+		"op":   "subscribe",
+		"args": topics,
+	}
+
+	for {
+		select {
+		case <-ctx.Done():
+			c.metrics.SetConnected(venue, false)
+			return
+		default:
+		}
+
+		conn, err := wsconn.Dial(ctx, c.cfg.BybitWSURL, wsCfg)
+		if err != nil {
+			c.metrics.SetConnected(venue, false)
+			c.logger.Printf("bybit dial error: %v", err)
+			time.Sleep(backoff)
+			backoff = time.Duration(math.Min(float64(15*time.Second), float64(backoff*2)))
+			continue
+		}
+		backoff = time.Second
+		c.metrics.SetConnected(venue, true)
+		c.logger.Printf("bybit connected: %s", c.cfg.BybitWSURL)
+
+		if err := conn.WriteJSON(subscribeMsg); err != nil {
+			c.logger.Printf("bybit subscribe write error: %v", err)
+			_ = conn.Close()
+			c.metrics.SetConnected(venue, false)
+			continue
+		}
+
+		// Heartbeat (op:ping) — Bybit V5 требует application-level ping.
+		pingStop := make(chan struct{})
+		go func() {
+			ticker := time.NewTicker(c.cfg.BybitPingPeriod)
+			defer ticker.Stop()
+			for {
+				select {
+				case <-pingStop:
+					return
+				case <-ctx.Done():
+					return
+				case <-ticker.C:
+					_ = conn.WriteJSON(map[string]interface{}{"op": "ping"})
+				}
+			}
+		}()
+
+		for {
+			select {
+			case <-ctx.Done():
+				close(pingStop)
+				_ = conn.Close()
+				c.metrics.SetConnected(venue, false)
+				return
+			default:
+			}
+
+			mt, msg, err := conn.ReadMessage()
+			if err != nil {
+				close(pingStop)
+				c.metrics.SetConnected(venue, false)
+				c.logger.Printf("bybit read error: %v", err)
+				_ = conn.Close()
+				break
+			}
+			if mt != websocket.TextMessage && mt != websocket.BinaryMessage {
+				continue
+			}
+
+			nowMs := time.Now().UnixMilli()
+			evs, err := ParseBybitAllLiquidation(msg, nowMs)
+			if err != nil {
+				reason := parseReason(err)
+				c.metrics.ParseErr(venue)
+				c.metrics.Drop(venue, reason, 1)
+				c.pub.QuarantineRaw(venue, msg, nowMs, reason)
+				continue
+			}
+			if len(evs) == 0 {
+				continue
+			}
+			c.metrics.IncIn(venue, len(evs))
+			for _, ev := range evs {
+				ok, reason := c.cfg.DQ.Validate(ev, nowMs)
+				if !ok {
+					c.metrics.Drop(venue, reason, 1)
+					c.pub.QuarantineEvent(ev, msg, reason)
+					continue
+				}
+				c.metrics.ObserveLag(venue, nowMs-ev.TsEventMs)
+
+				if !c.pub.Publish(ev, msg) {
+					c.metrics.Drop(venue, "queue_full", 1)
+					c.pub.QuarantineEvent(ev, msg, "queue_full")
+					continue
+				}
+				c.metrics.IncPublished(venue, 1)
+			}
+			c.metrics.TickRate(venue, len(evs))
+		}
+	}
+}
