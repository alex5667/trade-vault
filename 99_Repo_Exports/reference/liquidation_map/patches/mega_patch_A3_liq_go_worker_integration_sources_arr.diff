index 0000000..3d904e7
--- /dev/null
+++ b/internal/liquidation/raw.go
@@ -0,0 +1,37 @@
+package liquidation
+
+import "unicode/utf8"
+
+// truncateRaw ограничивает raw payload по байтам и гарантирует валидный UTF-8.
+//
+// Почему важно:
+//   - Redis Streams хранят строки; большие raw могут раздувать сеть/память
+//   - бинарные/битые UTF-8 строки могут ломать UI/логгеры
+func truncateRaw(raw []byte, maxBytes int) string {
+	if maxBytes <= 0 || len(raw) == 0 {
+		return ""
+	}
+	if len(raw) <= maxBytes {
+		// если уже валидный UTF-8 — ок
+		if utf8.Valid(raw) {
+			return string(raw)
+		}
+		// иначе вернём только валидный префикс
+		for i := len(raw); i > 0; i-- {
+			if utf8.Valid(raw[:i]) {
+				return string(raw[:i])
+			}
+		}
+		return ""
+	}
+	b := raw[:maxBytes]
+	if utf8.Valid(b) {
+		return string(b)
+	}
+	for i := len(b); i > 0; i-- {
+		if utf8.Valid(b[:i]) {
+			return string(b[:i])
+		}
+	}
+	return ""
+}
diff --git a/internal/liquidation/types.go b/internal/liquidation/types.go
new file mode 100644
index 0000000..fc22a5b
--- /dev/null
+++ b/internal/liquidation/types.go
@@ -0,0 +1,59 @@
+package liquidation
+
+// LiqEventV1 — унифицированное событие ликвидации для Redis Streams.
+//
+// Контракт (A2):
+//   - ts_event_ms: timestamp события от биржи (epoch ms, UTC)
+//   - ts_ingest_ms: timestamp приёма в системе (epoch ms, UTC)
+//   - venue: источник (binance_usdtm / bybit_linear)
+//   - symbol: UPPERCASE
+//   - order_side: BUY|SELL (сторона ордера из сообщения)
+//   - liq_side: long|short (какую позицию ликвидировали)
+//   - price/qty/notional_usd: Decimal-as-string (без float), чтобы избежать rounding и сохранить детерминизм
+//   - status: опционально (Binance o.X)
+//
+// Примечание: поле raw добавляется ТОЛЬКО в quarantine и/или сэмплируется в основной поток,
+// чтобы не DDOS-ить Redis и не раздувать трафик.
+// raw — это ограниченная по размеру строка (усечённый JSON).
+//
+// Важно: не путать liquidation (ликвидации позиций) с liquidity (ликвидность стакана) — поэтому venue/liq_side
+// находятся в отдельном DTO/stream.
+type LiqEventV1 struct {
+	TsEventMs  int64 // ts_event_ms
+	TsIngestMs int64 // ts_ingest_ms
+
+	Venue string // binance_usdtm | bybit_linear
+
+	Symbol string // BTCUSDT
+
+	OrderSide string // BUY|SELL
+	LiqSide   string // long|short
+
+	Price       string // decimal string
+	Qty         string // decimal string
+	NotionalUsd string // decimal string
+
+	Status string // optional (Binance o.X)
+}
+
+// ToRedisValues формирует плоское представление для XADD.
+// raw/reason добавляются снаружи (контроллером), потому что:
+//   - raw может быть большим
+//   - reason нужен только для quarantine
+func (e LiqEventV1) ToRedisValues() map[string]interface{} {
+	values := map[string]interface{}{
+		"ts_event_ms":  e.TsEventMs,
+		"ts_ingest_ms": e.TsIngestMs,
+		"venue":        e.Venue,
+		"symbol":       e.Symbol,
+		"order_side":   e.OrderSide,
+		"liq_side":     e.LiqSide,
+		"price":        e.Price,
+		"qty":          e.Qty,
+		"notional_usd": e.NotionalUsd,
+	}
+	if e.Status != "" {
+		values["status"] = e.Status
+	}
+	return values
+}
