+
+    Dedup/cooldown:
+      - suppress identical alerts for N seconds by signature (default 6h)
+    """
+    enabled = os.getenv("ENABLE_PROM_RULES_BUNDLE_SMOKE", "1")
+    if str(enabled).lower() not in ("1", "true", "yes", "on"):
