+from __future__ import annotations
+
+import os
+from contextlib import contextmanager
+from pathlib import Path
+
+from services.orderflow.exec_health_observability import (
+    record_exec_health_observability,
+    record_exec_health_reader_error,
+)
+from services.orderflow.exec_health_rollups import decide_exec_health_from_env
+from services.orderflow.metrics_exec_health_p6 import (
+    exec_health_decision_total,
+    exec_health_policy_mode,
+    exec_health_policy_threshold_bps,
+    exec_health_reader_errors_total,
+    exec_health_rollup_present,
+    exec_health_rollup_value_bps,
+    exec_health_rollup_worst_delta_sec,
+)
+
+
+@contextmanager
+def _env(**kwargs):
+    old = {k: os.environ.get(k) for k in kwargs}
+    try:
+        for k, v in kwargs.items():
+            os.environ[k] = str(v)
+        yield
+    finally:
+        for k, v in old.items():
+            if v is None:
+                os.environ.pop(k, None)
+            else:
+                os.environ[k] = v
+
+
+def _sample_value(metric, labels: dict[str, str], suffix: str | None = None) -> float | None:
+    wanted = metric._name + (suffix or "")
+    for fam in metric.collect():
+        for s in fam.samples:
+            if s.name == wanted and all(s.labels.get(k) == v for k, v in labels.items()):
+                return float(s.value)
+    return None
+
+
+def test_exec_health_observability_emits_policy_mode_and_thresholds() -> None:
+    with _env(EXEC_HEALTH_MODE="auto", EXEC_MAX_IS_P95_BPS="5.5"):
+        record_exec_health_observability(
+            symbol="TESTOBS_A",
+            scope="edge",
+            profile="strict",
+            rollups={},
+            decision=None,
+            now_ms=123456,
+        )
+
+    assert _sample_value(exec_health_policy_mode, {"scope": "edge", "mode": "tighten"}) == 1.0
+    assert _sample_value(exec_health_policy_threshold_bps, {"scope": "edge", "metric": "is_p95_bps"}) == 5.5
+    assert _sample_value(exec_health_rollup_present, {"scope": "edge", "symbol": "TESTOBS_A", "metric": "is_p95_bps"}) == 0.0
+
+
+def test_exec_health_observability_emits_rollups_and_veto_decision() -> None:
+    rollups = {
+        "is_p95_bps": 8.0,
+        "perm_impact_p95_bps": 4.0,
+        "perm_impact_p95_bps_delta_sec": 5,
+        "realized_spread_p50_bps": -1.5,
+        "realized_spread_p50_bps_delta_sec": 1,
+    }
+    with _env(
+        EXEC_HEALTH_MODE="auto",
+        EXEC_MAX_IS_P95_BPS="5",
+        EXEC_MAX_PERM_IMPACT_P95_BPS="3",
+        EXEC_MIN_REALIZED_SPREAD_P50_BPS="-999",
+        EXEC_VETO_REQUIRE_BOTH_IS_AND_IMPACT="1",
+    ):
+        dec = decide_exec_health_from_env(profile="hard", rollups=rollups, scope="pipeline")
+        record_exec_health_observability(
+            symbol="TESTOBS_B",
+            scope="pipeline",
+            profile="hard",
+            rollups=rollups,
+            decision=dec,
+            now_ms=222222,
+        )
+
+    assert dec.veto is True
+    assert _sample_value(exec_health_rollup_present, {"scope": "pipeline", "symbol": "TESTOBS_B", "metric": "is_p95_bps"}) == 1.0
+    assert _sample_value(exec_health_rollup_value_bps, {"scope": "pipeline", "symbol": "TESTOBS_B", "metric": "perm_impact_p95_bps"}) == 4.0
+    assert _sample_value(exec_health_rollup_worst_delta_sec, {"scope": "pipeline", "symbol": "TESTOBS_B", "metric": "perm_impact_p95_bps"}) == 5.0
+    assert _sample_value(
+        exec_health_decision_total,
+        {
+            "scope": "pipeline",
+            "symbol": "TESTOBS_B",
+            "mode": "veto",
+            "outcome": "veto",
+            "reason": "VETO_IMPL_SHORTFALL_P95",
+        },
+        suffix="_total",
+    ) == 1.0
+
+
+def test_exec_health_reader_error_counter_increments() -> None:
+    before = _sample_value(exec_health_reader_errors_total, {"scope": "entry_policy", "where": "read_rollups"}, suffix="_total") or 0.0
+    record_exec_health_reader_error(scope="entry_policy", where="read_rollups")
+    after = _sample_value(exec_health_reader_errors_total, {"scope": "entry_policy", "where": "read_rollups"}, suffix="_total") or 0.0
+    assert after >= before + 1.0
+
+
+def test_signal_pipeline_has_single_exec_health_overlay_block() -> None:
+    main_path = Path(__file__).resolve().parents[1] / "signal_pipeline.py"
+    mirror_path = Path(__file__).resolve().parents[3] / "tick_flow_full" / "services" / "orderflow" / "signal_pipeline.py"
+    needle = "PRE-PUBLISH EXECUTION HEALTH (single source of truth with EntryPolicy/EdgeCost)"
+    assert main_path.read_text().count(needle) == 1
+    assert mirror_path.read_text().count(needle) == 1
