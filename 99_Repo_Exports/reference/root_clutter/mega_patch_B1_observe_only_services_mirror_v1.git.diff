+++ b/core_snapshot/runtime_clock.py
@@ -0,0 +1,52 @@
+"""Runtime clock helpers.
+
+Why: observe-only warmup must be based on process-monotonic time (NTP-safe),
+but we also want a deterministic `runtime_start_ts_ms` to attach to decision records.
+
+We compute:
+  - uptime_sec: seconds since process start (time.monotonic based)
+  - runtime_start_ts_ms: derived as (event_ts_ms - uptime_ms) when event_ts_ms is provided
+
+The derived `runtime_start_ts_ms` is deterministic relative to the stream time and
+is stable even if wall clock changes.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from typing import Optional, Any
+import time
+
+
+_PROCESS_START_MONO = time.monotonic()
+
+
+@dataclass(frozen=True)
+class RuntimeClockSnapshot:
+    uptime_sec: float
+    runtime_start_ts_ms: Optional[int]
+
+
+def snapshot(event_ts_ms: Optional[Any] = None) -> RuntimeClockSnapshot:
+    """Return monotonic uptime + derived runtime_start_ts_ms.
+
+    Args:
+        event_ts_ms: epoch milliseconds of current event/tick (optional).
+            If present and parseable to int, runtime_start_ts_ms is derived
+            deterministically as event_ts_ms - uptime_ms.
+
+    Returns:
+        RuntimeClockSnapshot
+    """
+    now_mono = time.monotonic()
+    uptime_sec = max(0.0, float(now_mono - _PROCESS_START_MONO))
+
+    start_ts_ms: Optional[int] = None
+    if event_ts_ms is not None:
+        try:
+            ev_ms = int(float(event_ts_ms))
+            start_ts_ms = max(0, int(ev_ms - int(uptime_sec * 1000.0)))
+        except Exception:
+            start_ts_ms = None
+
+    return RuntimeClockSnapshot(uptime_sec=uptime_sec, runtime_start_ts_ms=start_ts_ms)

diff --git a/core_snapshot/dq_observe_only.py b/core_snapshot/dq_observe_only.py
new file mode 100644
--- /dev/null
+++ b/core_snapshot/dq_observe_only.py
@@ -0,0 +1,107 @@
+"""Observe-only warmup controller for DQ hard veto (book-seq).
+
+Spec (B1):
+  - dq_level is always computed (0/1/2)
+  - dq_veto should only become 1 for book-seq hard cases when:
+        dq_book_veto_enabled == True
+    AND uptime_sec >= dq_observe_only_sec
+  - During warmup or when disabled, dq_level/reasons stay visible; only dq_veto is suppressed.
+
+This module is pure and unit-testable: it does not compute dq_level, it only gates veto.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from typing import Any, Dict, List, Optional
+import os
+
+
+@dataclass(frozen=True)
+class ObserveOnlyResult:
+    dq_veto: int
+    suppressed: bool
+    suppress_reason: Optional[str]
+
+
+def _as_bool(v: Any, default: bool = False) -> bool:
+    if v is None:
+        return default
+    if isinstance(v, bool):
+        return v
+    if isinstance(v, (int, float)):
+        return bool(int(v))
+    if isinstance(v, str):
+        s = v.strip().lower()
+        if s in ("1", "true", "yes", "y", "on"):
+            return True
+        if s in ("0", "false", "no", "n", "off", ""):
+            return False
+    return default
+
+
+def _as_int(v: Any, default: int) -> int:
+    if v is None:
+        return default
+    try:
+        return int(float(v))
+    except Exception:
+        return default
+
+
+def _cfg_bool(cfg: Dict[str, Any], key: str, env_key: str, default: bool) -> bool:
+    if key in cfg and cfg.get(key) is not None:
+        return _as_bool(cfg.get(key), default=default)
+    return _as_bool(os.getenv(env_key), default=default)
+
+
+def _cfg_int(cfg: Dict[str, Any], key: str, env_key: str, default: int) -> int:
+    if key in cfg and cfg.get(key) is not None:
+        return _as_int(cfg.get(key), default=default)
+    return _as_int(os.getenv(env_key), default=default)
+
+
+def _is_book_case(dq_reason_bucket: str, dq_reasons: List[str]) -> bool:
+    if dq_reason_bucket == "book_seq":
+        return True
+    for r in dq_reasons:
+        rr = (r or "").lower()
+        if "book_seq" in rr or "book_hard" in rr or "book_missing_seq" in rr:
+            return True
+    return False
+
+
+def apply_observe_only_book_veto(
+    *,
+    dq_level: int,
+    dq_veto: int,
+    dq_reason_bucket: str,
+    dq_reasons: List[str],
+    uptime_sec: float,
+    cfg: Dict[str, Any],
+) -> ObserveOnlyResult:
+    """Gate book-seq hard veto according to observe-only warmup window."""
+    dq_level_i = int(dq_level or 0)
+    dq_veto_i = int(dq_veto or 0)
+
+    # Only applies to L2 book-seq hard cases.
+    if dq_level_i != 2 or not _is_book_case(str(dq_reason_bucket or ""), dq_reasons or []):
+        return ObserveOnlyResult(dq_veto=dq_veto_i, suppressed=False, suppress_reason=None)
+
+    enabled = _cfg_bool(cfg, "dq_book_veto_enabled", "DQ_BOOK_VETO_ENABLED", default=False)
+
+    # Primary key per spec; keep backward-compat with older warmup var name.
+    warmup = _cfg_int(cfg, "dq_observe_only_sec", "DQ_OBSERVE_ONLY_SEC", default=86400)
+    if "dq_observe_only_sec" not in cfg and os.getenv("DQ_OBSERVE_ONLY_SEC") is None:
+        warmup = _cfg_int(cfg, "dq_book_veto_warmup_s", "DQ_BOOK_VETO_WARMUP_S", default=warmup)
+
+    up = float(uptime_sec or 0.0)
+
+    if not enabled:
+        # Suppress only book-veto path.
+        return ObserveOnlyResult(dq_veto=0, suppressed=True, suppress_reason="disabled")
+
+    if up < float(max(0, warmup)):
+        return ObserveOnlyResult(dq_veto=0, suppressed=True, suppress_reason="warmup")
+
+    return ObserveOnlyResult(dq_veto=dq_veto_i, suppressed=False, suppress_reason=None)

diff --git a/tests/test_b1_observe_only_book_veto_v1.py b/tests/test_b1_observe_only_book_veto_v1.py
new file mode 100644
--- /dev/null
+++ b/tests/test_b1_observe_only_book_veto_v1.py
@@ -0,0 +1,43 @@
+from core_snapshot.dq_observe_only import apply_observe_only_book_veto
+
+
+def test_b1_observe_only_blocks_book_veto_during_warmup():
+    out = apply_observe_only_book_veto(
+        dq_level=2,
+        dq_veto=1,
+        dq_reason_bucket="book_seq",
+        dq_reasons=["book_seq_hard"],
+        uptime_sec=10.0,
+        cfg={"dq_book_veto_enabled": True, "dq_observe_only_sec": 86400},
+    )
+    assert out.dq_veto == 0
+    assert out.suppressed is True
+    assert out.suppress_reason == "warmup"
+
+
+def test_b1_observe_only_allows_book_veto_after_warmup():
+    out = apply_observe_only_book_veto(
+        dq_level=2,
+        dq_veto=1,
+        dq_reason_bucket="book_seq",
+        dq_reasons=["book_seq_hard"],
+        uptime_sec=90000.0,
+        cfg={"dq_book_veto_enabled": True, "dq_observe_only_sec": 86400},
+    )
+    assert out.dq_veto == 1
+    assert out.suppressed is False
+    assert out.suppress_reason is None
+
+
+def test_b1_observe_only_disables_book_veto_when_flag_off():
+    out = apply_observe_only_book_veto(
+        dq_level=2,
+        dq_veto=1,
+        dq_reason_bucket="book_seq",
+        dq_reasons=["book_seq_hard"],
+        uptime_sec=999999.0,
+        cfg={"dq_book_veto_enabled": False, "dq_observe_only_sec": 86400},
+    )
+    assert out.dq_veto == 0
+    assert out.suppressed is True
+    assert out.suppress_reason == "disabled"
