@@ -0,0 +1,39 @@
+from pathlib import Path
+import importlib.util
+import sys
+
+mod_path = Path(__file__).resolve().parent / 'execution_state_replay.py'
+spec = importlib.util.spec_from_file_location('execution_state_replay', mod_path)
+mod = importlib.util.module_from_spec(spec)
+sys.modules[spec.name] = mod
+spec.loader.exec_module(mod)
+
+
+class FakeRedis:
+    def __init__(self):
+        self.kv = {
+            'orders:exec:replay:cursor:s1': '100-1',
+            'orders:exec:replay:cursor:s2': '300-1',
+        }
+        self.rows = [('200-1', {'sid': 's2'}), ('300-1', {'sid': 's2'})]
+
+    def scan_iter(self, match=None):
+        for k in list(self.kv.keys()):
+            if match is None or match.rstrip('*') in k:
+                yield k
+
+    def get(self, key):
+        return self.kv.get(key)
+
+    def xrange(self, _stream, start, end, count=1):
+        return [('200-1', {'sid': 'x'})]
+
+    def xrevrange(self, _stream, end, start, count=1000):
+        return self.rows[:count]
+
+
+def test_stream_retention_guard_report_detects_breach():
+    r = FakeRedis()
+    rep = mod.stream_retention_guard_report(r, exec_stream='orders:exec', checkpoint_prefix='orders:exec:replay:cursor:')
+    assert rep['breached_checkpoints'] >= 1
+    assert rep['status'] == 'critical'
