+package bybit
+
+import (
+	"os"
+	"reflect"
+	"testing"
+)
+
+func TestParseBaseSymbols_Fallback(t *testing.T) {
+	_ = os.Unsetenv("BYBIT_FUTURES_SYMBOLS")
+	_ = os.Unsetenv("FUTURES_SYMBOLS")
+	s := ParseBaseSymbols()
+	if len(s) == 0 {
+		t.Fatalf("expected non-empty")
+	}
+}
+
+func TestParseSymbolMap(t *testing.T) {
+	m := parseSymbolMap("BTCUSDT:BTCUSDT,ETH:ETHUSDT")
+	if m["BTCUSDT"] != "BTCUSDT" || m["ETH"] != "ETHUSDT" {
+		t.Fatalf("map=%v", m)
+	}
+}
+
+func TestMapSymbol(t *testing.T) {
+	m := map[string]string{"BTCUSDT": "XBTUSDT"}
+	if got := mapSymbol("btcusdt", m); got != "XBTUSDT" {
+		t.Fatalf("got=%s", got)
+	}
+}
+
+func TestBuildArgs(t *testing.T) {
+	os.Setenv("BYBIT_BOOK_DEPTH", "50")
+	os.Setenv("BYBIT_TRADES_ENABLED", "true")
+	os.Setenv("BYBIT_ORDERBOOK_ENABLED", "true")
+	c := NewFuturesStreamController(nil, nil, nil)
+	args := c.buildArgs([]string{"BTCUSDT"})
+	expected := []string{"orderbook.50.BTCUSDT", "publicTrade.BTCUSDT"}
+	if !reflect.DeepEqual(args, expected) {
+		t.Fatalf("args=%v expected=%v", args, expected)
+	}
+}
