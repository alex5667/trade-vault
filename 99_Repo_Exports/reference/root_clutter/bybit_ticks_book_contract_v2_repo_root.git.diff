diff --git a/internal/bybit/futures_normalizer.go b/internal/bybit/futures_normalizer.go
new file mode 100644
index 0000000..831b4c9
--- /dev/null
+++ b/internal/bybit/futures_normalizer.go
@@ -0,0 +1,360 @@
+package bybit
+
+import (
+	"bytes"
+	"encoding/json"
+	"errors"
+	"fmt"
+	"hash/fnv"
+	"sort"
+	"strconv"
+	"strings"
+	"sync"
+
+	"go-worker/pkg/timeutil"
+)
+
+// flexInt64 supports JSON numbers and strings.
+type flexInt64 struct {
+	value int64
+	valid bool
+}
+
+func (f *flexInt64) UnmarshalJSON(raw []byte) error {
+	raw = bytes.TrimSpace(raw)
+	if len(raw) == 0 || bytes.Equal(raw, []byte("null")) {
+		f.valid = false
+		f.value = 0
+		return nil
+	}
+	if raw[0] == '"' {
+		s, err := strconv.Unquote(string(raw))
+		if err != nil {
+			f.valid = false
+			f.value = 0
+			return nil
+		}
+		s = strings.TrimSpace(s)
+		if s == "" {
+			f.valid = false
+			f.value = 0
+			return nil
+		}
+		if n, err := strconv.ParseInt(s, 10, 64); err == nil {
+			f.valid = true
+			f.value = n
+			return nil
+		}
+		f.valid = false
+		f.value = 0
+		return nil
+	}
+	dec := json.NewDecoder(bytes.NewReader(raw))
+	dec.UseNumber()
+	var v any
+	if err := dec.Decode(&v); err != nil {
+		f.valid = false
+		f.value = 0
+		return nil
+	}
+	switch t := v.(type) {
+	case json.Number:
+		if n, err := t.Int64(); err == nil {
+			f.valid = true
+			f.value = n
+			return nil
+		}
+		if fl, err := t.Float64(); err == nil {
+			f.valid = true
+			f.value = int64(fl)
+			return nil
+		}
+	case float64:
+		f.valid = true
+		f.value = int64(t)
+		return nil
+	}
+	f.valid = false
+	f.value = 0
+	return nil
+}
+
+func (f flexInt64) OrDefault(def int64) int64 {
+	if f.valid {
+		return f.value
+	}
+	return def
+}
+
+type bybitEnvelope struct {
+	Topic string          `json:"topic"`
+	Type  string          `json:"type"` // snapshot|delta
+	Ts    flexInt64       `json:"ts"`
+	Data  json.RawMessage `json:"data"`
+	Op    string          `json:"op"`
+}
+
+type bybitTrade struct {
+	T    flexInt64 `json:"T"`
+	S    string    `json:"s"`
+	Side string    `json:"S"` // Buy/Sell
+	V    string    `json:"v"`
+	P    string    `json:"p"`
+	ID   string    `json:"i"`
+	Seq  flexInt64 `json:"seq"`
+}
+
+type bybitOrderbook struct {
+	S   string     `json:"s"`
+	B   [][]string `json:"b"`
+	A   [][]string `json:"a"`
+	U   flexInt64  `json:"u"`
+	Seq flexInt64  `json:"seq"`
+}
+
+func NormalizedTickValues(symbol string, ts int64, price, qty, side, source, market string, tradeID int64, extras map[string]any) map[string]any {
+	vals := map[string]any{
+		"symbol":     strings.ToUpper(symbol),
+		"ts":         ts,
+		"price":      price,
+		"qty":        qty,
+		"side":       side,
+		"source":     source,
+		"market":     market,
+		"trade_id":   tradeID,
+		"written_at": timeutil.GetCurrentTimestampMs(),
+	}
+	for k, v := range extras {
+		vals[k] = v
+	}
+	return vals
+}
+
+func NormalizedBookValues(symbol string, ts int64, firstID, finalID, prevFinal int64, bids, asks [][]string, source, market string, extras map[string]any) map[string]any {
+	bidsJSON, _ := json.Marshal(bids)
+	asksJSON, _ := json.Marshal(asks)
+	vals := map[string]any{
+		"symbol":     strings.ToUpper(symbol),
+		"ts":         ts,
+		"first_id":   firstID,
+		"final_id":   finalID,
+		"prev_final": prevFinal,
+		"bids":       string(bidsJSON),
+		"asks":       string(asksJSON),
+		"source":     source,
+		"market":     market,
+		"written_at": timeutil.GetCurrentTimestampMs(),
+	}
+	for k, v := range extras {
+		vals[k] = v
+	}
+	return vals
+}
+
+var (
+	errEmptyPayload = errors.New("empty bybit payload")
+)
+
+type BookState struct {
+	bids  map[string]string
+	asks  map[string]string
+	lastU int64
+	mu    sync.Mutex
+}
+
+func newBookState() *BookState {
+	return &BookState{bids: make(map[string]string), asks: make(map[string]string)}
+}
+
+func (bs *BookState) resetFromSnapshot(bids, asks [][]string, u int64) {
+	bs.bids = make(map[string]string, len(bids))
+	for _, lvl := range bids {
+		if len(lvl) < 2 {
+			continue
+		}
+		px := strings.TrimSpace(lvl[0])
+		sz := strings.TrimSpace(lvl[1])
+		if px == "" || sz == "" || sz == "0" {
+			continue
+		}
+		bs.bids[px] = sz
+	}
+	bs.asks = make(map[string]string, len(asks))
+	for _, lvl := range asks {
+		if len(lvl) < 2 {
+			continue
+		}
+		px := strings.TrimSpace(lvl[0])
+		sz := strings.TrimSpace(lvl[1])
+		if px == "" || sz == "" || sz == "0" {
+			continue
+		}
+		bs.asks[px] = sz
+	}
+	bs.lastU = u
+}
+
+func (bs *BookState) applyDelta(sideMap map[string]string, updates [][]string) {
+	for _, lvl := range updates {
+		if len(lvl) < 2 {
+			continue
+		}
+		px := strings.TrimSpace(lvl[0])
+		sz := strings.TrimSpace(lvl[1])
+		if px == "" {
+			continue
+		}
+		if sz == "0" || sz == "" {
+			delete(sideMap, px)
+			continue
+		}
+		sideMap[px] = sz
+	}
+}
+
+func (bs *BookState) snapshotTopN(n int) (bids [][]string, asks [][]string) {
+	type kv struct{ px, sz string }
+	b := make([]kv, 0, len(bs.bids))
+	for px, sz := range bs.bids {
+		b = append(b, kv{px: px, sz: sz})
+	}
+	a := make([]kv, 0, len(bs.asks))
+	for px, sz := range bs.asks {
+		a = append(a, kv{px: px, sz: sz})
+	}
+	sort.Slice(b, func(i, j int) bool {
+		fi, ei := strconv.ParseFloat(b[i].px, 64)
+		fj, ej := strconv.ParseFloat(b[j].px, 64)
+		if ei == nil && ej == nil {
+			return fi > fj
+		}
+		return b[i].px > b[j].px
+	})
+	sort.Slice(a, func(i, j int) bool {
+		fi, ei := strconv.ParseFloat(a[i].px, 64)
+		fj, ej := strconv.ParseFloat(a[j].px, 64)
+		if ei == nil && ej == nil {
+			return fi < fj
+		}
+		return a[i].px < a[j].px
+	})
+	if n > 0 && len(b) > n {
+		b = b[:n]
+	}
+	if n > 0 && len(a) > n {
+		a = a[:n]
+	}
+	bids = make([][]string, 0, len(b))
+	for _, it := range b {
+		bids = append(bids, []string{it.px, it.sz})
+	}
+	asks = make([][]string, 0, len(a))
+	for _, it := range a {
+		asks = append(asks, []string{it.px, it.sz})
+	}
+	return bids, asks
+}
+
+type BookStore struct {
+	states map[string]*BookState
+	mu     sync.Mutex
+}
+
+func NewBookStore() *BookStore {
+	return &BookStore{states: make(map[string]*BookState)}
+}
+
+func (bs *BookStore) state(symbol string) *BookState {
+	symbol = strings.ToUpper(symbol)
+	bs.mu.Lock()
+	defer bs.mu.Unlock()
+	st, ok := bs.states[symbol]
+	if ok {
+		return st
+	}
+	st = newBookState()
+	bs.states[symbol] = st
+	return st
+}
+
+func NormalizeMessage(raw []byte, mapping map[string]string, store *BookStore, bookMaxLevels int) (ticks []struct{ Symbol string; Values map[string]any }, books []struct{ Symbol string; Values map[string]any }, err error) {
+	if len(raw) == 0 {
+		return nil, nil, errEmptyPayload
+	}
+	var env bybitEnvelope
+	if err := json.Unmarshal(raw, &env); err != nil {
+		return nil, nil, fmt.Errorf("decode envelope: %w", err)
+	}
+	if env.Topic == "" {
+		return nil, nil, nil
+	}
+
+	if strings.HasPrefix(env.Topic, "publicTrade.") {
+		var items []bybitTrade
+		if err := json.Unmarshal(env.Data, &items); err != nil {
+			return nil, nil, fmt.Errorf("decode trade: %w", err)
+		}
+		for _, it := range items {
+			sym := mapSymbol(it.S, mapping)
+			if sym == "" {
+				continue
+			}
+			ts := it.T.OrDefault(env.Ts.OrDefault(timeutil.GetCurrentTimestampMs()))
+			side := "BUY"
+			if strings.EqualFold(strings.TrimSpace(it.Side), "Sell") {
+				side = "SELL"
+			}
+			tradeID, tradeIDRaw := parseTradeID(it.ID)
+			extras := map[string]any{"seq": it.Seq.OrDefault(0)}
+			if tradeIDRaw != "" {
+				extras["trade_id_raw"] = tradeIDRaw
+			}
+			vals := NormalizedTickValues(sym, ts, it.P, it.V, side, "bybit-linear", "USDT-M", tradeID, extras)
+			ticks = append(ticks, struct{ Symbol string; Values map[string]any }{Symbol: sym, Values: vals})
+		}
+		return ticks, nil, nil
+	}
+
+	if strings.HasPrefix(env.Topic, "orderbook.") {
+		var ob bybitOrderbook
+		if err := json.Unmarshal(env.Data, &ob); err != nil {
+			return nil, nil, fmt.Errorf("decode orderbook: %w", err)
+		}
+		sym := mapSymbol(ob.S, mapping)
+		if sym == "" {
+			return nil, nil, nil
+		}
+		st := store.state(sym)
+		st.mu.Lock()
+		defer st.mu.Unlock()
+		u := ob.U.OrDefault(0)
+		prev := st.lastU
+		if strings.EqualFold(strings.TrimSpace(env.Type), "snapshot") || prev == 0 {
+			st.resetFromSnapshot(ob.B, ob.A, u)
+		} else {
+			st.applyDelta(st.bids, ob.B)
+			st.applyDelta(st.asks, ob.A)
+			st.lastU = u
+		}
+		bids, asks := st.snapshotTopN(bookMaxLevels)
+		ts := env.Ts.OrDefault(timeutil.GetCurrentTimestampMs())
+		vals := NormalizedBookValues(sym, ts, u, u, prev, bids, asks, "bybit-linear", "USDT-M", map[string]any{"seq": ob.Seq.OrDefault(0)})
+		books = append(books, struct{ Symbol string; Values map[string]any }{Symbol: sym, Values: vals})
+		return nil, books, nil
+	}
+
+	return nil, nil, nil
+}
+
+func parseTradeID(raw string) (id int64, rawOut string) {
+	s := strings.TrimSpace(raw)
+	if s == "" {
+		return 0, ""
+	}
+	if n, err := strconv.ParseInt(s, 10, 64); err == nil {
+		return n, ""
+	}
+	h := fnv.New64a()
+	_, _ = h.Write([]byte(s))
+	return int64(h.Sum64()), s
+}
