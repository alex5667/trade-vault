@@ -0,0 +1,475 @@
+package bybit
+
+import (
+	"context"
+	"errors"
+	"fmt"
+	"log"
+	"net"
+	"os"
+	"sort"
+	"strings"
+	"sync"
+	"time"
+
+	"go-worker/internal/monitoring"
+	internalredis "go-worker/internal/redis"
+	"go-worker/internal/wsconn"
+
+	"github.com/go-redis/redis/v8"
+	"github.com/gorilla/websocket"
+)
+
+type wsCommand struct {
+	Op    string   `json:"op"`
+	Args  []string `json:"args,omitempty"`
+	ReqID string   `json:"req_id,omitempty"`
+}
+
+// FuturesWSManager maintains a single Bybit public WS connection.
+type FuturesWSManager struct {
+	conn    *websocket.Conn
+	log     *log.Logger
+	mu      sync.Mutex
+	writeMu sync.Mutex
+	cfg     wsconn.Config
+	url     string
+
+	subs           map[string]struct{}
+	bookStore      *BookStore
+	symbolMap      map[string]string
+	bookMaxLevels  int
+}
+
+func NewFuturesWSManager(url string, cfg wsconn.Config, logger *log.Logger, symbolMap map[string]string, bookMaxLevels int) *FuturesWSManager {
+	if logger == nil {
+		logger = log.New(os.Stdout, "[bybit] ", log.LstdFlags|log.Lmicroseconds)
+	}
+	return &FuturesWSManager{
+		log:          logger,
+		cfg:          cfg,
+		url:          url,
+		subs:         make(map[string]struct{}),
+		bookStore:    NewBookStore(),
+		symbolMap:    symbolMap,
+		bookMaxLevels: bookMaxLevels,
+	}
+}
+
+func (m *FuturesWSManager) Connect(ctx context.Context) error {
+	m.mu.Lock()
+	defer m.mu.Unlock()
+	if m.conn != nil {
+		_ = m.conn.Close()
+		m.conn = nil
+	}
+	conn, err := wsconn.Dial(ctx, m.url, m.cfg)
+	if err != nil {
+		return err
+	}
+	wsconn.SetupPingPong(conn, m.cfg.ReadTimeout, m.cfg.WriteWait, func(msg []byte) error {
+		m.writeMu.Lock()
+		defer m.writeMu.Unlock()
+		return conn.WriteControl(websocket.PongMessage, msg, time.Now().Add(m.cfg.WriteWait))
+	})
+	_ = conn.SetReadDeadline(time.Now().Add(m.cfg.ReadTimeout))
+	m.conn = conn
+	return nil
+}
+
+func (m *FuturesWSManager) Close() {
+	m.mu.Lock()
+	defer m.mu.Unlock()
+	if m.conn != nil {
+		_ = m.conn.Close()
+		m.conn = nil
+	}
+}
+
+func (m *FuturesWSManager) sendJSON(v any) error {
+	m.mu.Lock()
+	conn := m.conn
+	m.mu.Unlock()
+	if conn == nil {
+		return nil
+	}
+	m.writeMu.Lock()
+	defer m.writeMu.Unlock()
+	_ = conn.SetWriteDeadline(time.Now().Add(m.cfg.WriteWait))
+	return conn.WriteJSON(v)
+}
+
+func (m *FuturesWSManager) subscribe(args []string) error {
+	if len(args) == 0 {
+		return nil
+	}
+	if err := m.sendJSON(wsCommand{Op: "subscribe", Args: args}); err != nil {
+		return err
+	}
+	monitoring.RecordBybitLiveSubscription("subscribe")
+	return nil
+}
+
+func (m *FuturesWSManager) unsubscribe(args []string) error {
+	if len(args) == 0 {
+		return nil
+	}
+	if err := m.sendJSON(wsCommand{Op: "unsubscribe", Args: args}); err != nil {
+		return err
+	}
+	monitoring.RecordBybitLiveSubscription("unsubscribe")
+	return nil
+}
+
+func (m *FuturesWSManager) ping() error {
+	return m.sendJSON(wsCommand{Op: "ping"})
+}
+
+func (m *FuturesWSManager) ReadLoop(ctx context.Context, publisher internalredis.Publisher) error {
+	m.mu.Lock()
+	conn := m.conn
+	m.mu.Unlock()
+	if conn == nil {
+		return errors.New("bybit ws conn is nil")
+	}
+
+	msgChan := make(chan []byte, m.cfg.MsgChanCapacity)
+	handlerDone := make(chan struct{})
+	go func() {
+		defer close(handlerDone)
+		for msg := range msgChan {
+			ticks, books, err := NormalizeMessage(msg, m.symbolMap, m.bookStore, m.bookMaxLevels)
+			if err != nil {
+				monitoring.RecordBybitParseError()
+				continue
+			}
+			for _, t := range ticks {
+				_ = publisher.PublishTick(ctx, t.Symbol, t.Values)
+				monitoring.RecordBybitMessage(t.Symbol, "trade")
+			}
+			for _, b := range books {
+				_ = publisher.PublishBook(ctx, b.Symbol, b.Values)
+				monitoring.RecordBybitMessage(b.Symbol, "book")
+			}
+		}
+	}()
+
+	pingCtx, cancel := context.WithCancel(ctx)
+	defer cancel()
+
+	errCh := make(chan error, 1)
+	go func() {
+		ticker := time.NewTicker(m.cfg.PingPeriod)
+		defer ticker.Stop()
+		for {
+			select {
+			case <-pingCtx.Done():
+				return
+			case <-ticker.C:
+				if err := m.ping(); err != nil {
+					errCh <- err
+					return
+				}
+				_ = conn.SetReadDeadline(time.Now().Add(m.cfg.ReadTimeout))
+			}
+		}
+	}()
+
+	defer func() {
+		close(msgChan)
+		<-handlerDone
+	}()
+
+	readTimeout := m.cfg.ReadTimeout
+	lastMessage := time.Now()
+
+	for {
+		select {
+		case err := <-errCh:
+			return err
+		case <-ctx.Done():
+			return ctx.Err()
+		default:
+		}
+
+		_, msg, err := conn.ReadMessage()
+		if err != nil {
+			if netErr, ok := err.(net.Error); ok && netErr.Timeout() {
+				if time.Since(lastMessage) > readTimeout {
+					return fmt.Errorf("read timeout: %w", err)
+				}
+				continue
+			}
+			return fmt.Errorf("read error: %w", err)
+		}
+		lastMessage = time.Now()
+		_ = conn.SetReadDeadline(time.Now().Add(readTimeout))
+		select {
+		case msgChan <- msg:
+		default:
+			monitoring.RecordFuturesMessageDropped("BYBIT_PUBLIC")
+		}
+	}
+}
+
+type FuturesStreamController struct {
+	client    *redis.Client
+	publisher internalredis.Publisher
+	logger    *log.Logger
+
+	symbolsKey      string
+	refreshInterval time.Duration
+
+	mu            sync.Mutex
+	currentSymbols []string
+	cancel        context.CancelFunc
+	manager       *FuturesWSManager
+
+	cfg          wsconn.Config
+	wsURL        string
+	symbolMap    map[string]string
+	bookDepth    int
+	bookMaxLevels int
+	tradesEnabled bool
+	bookEnabled   bool
+}
+
+func NewFuturesStreamController(client *redis.Client, publisher internalredis.Publisher, logger *log.Logger) *FuturesStreamController {
+	cfg := wsconn.DefaultConfig()
+	cfg.HandshakeTimeout = getEnvDuration("BYBIT_WS_HANDSHAKE_TIMEOUT", cfg.HandshakeTimeout)
+	cfg.DialTimeout = getEnvDuration("BYBIT_WS_DIAL_TIMEOUT", cfg.DialTimeout)
+	cfg.TCPKeepAlive = getEnvDuration("BYBIT_WS_TCP_KEEPALIVE", cfg.TCPKeepAlive)
+	cfg.ReadTimeout = getEnvDuration("BYBIT_WS_READ_TIMEOUT", 90*time.Second)
+	cfg.PingPeriod = getEnvDuration("BYBIT_WS_PING_PERIOD", 20*time.Second)
+	cfg.WriteWait = getEnvDuration("BYBIT_WS_WRITE_WAIT", cfg.WriteWait)
+	cfg.MsgChanCapacity = getEnvInt("BYBIT_MSG_CHAN_CAP", cfg.MsgChanCapacity)
+
+	return &FuturesStreamController{
+		client:          client,
+		publisher:       publisher,
+		logger:          logger,
+		symbolsKey:      getEnv("BYBIT_SYMBOLS_REDIS_KEY", "bybit:futures:linear:symbols"),
+		refreshInterval: getEnvDuration("BYBIT_SYMBOLS_REFRESH_INTERVAL", 30*time.Second),
+		cfg:             cfg,
+		wsURL:           getEnv("BYBIT_FUTURES_WS_URL", "wss://stream.bybit.com/v5/public/linear"),
+		symbolMap:       parseSymbolMap(getEnv("BYBIT_SYMBOL_MAP", "")),
+		bookDepth:       getEnvInt("BYBIT_BOOK_DEPTH", 50),
+		bookMaxLevels:   getEnvInt("BYBIT_BOOK_MAX_LEVELS", 50),
+		tradesEnabled:   getEnvBool("BYBIT_TRADES_ENABLED", true),
+		bookEnabled:     getEnvBool("BYBIT_ORDERBOOK_ENABLED", true),
+	}
+}
+
+func (c *FuturesStreamController) Run(ctx context.Context, baseSymbols []string) {
+	if c.logger == nil {
+		c.logger = log.New(os.Stdout, "[bybit] ", log.LstdFlags|log.Lmicroseconds)
+	}
+	c.logger.Printf("Bybit Futures controller стартует. Redis key: %s", c.symbolsKey)
+
+	desired := c.loadSymbols(ctx, baseSymbols)
+	c.reconcile(ctx, desired)
+
+	ticker := time.NewTicker(c.refreshInterval)
+	defer ticker.Stop()
+	for {
+		select {
+		case <-ctx.Done():
+			c.logger.Println("Bybit Futures controller остановка по контексту")
+			c.Stop()
+			return
+		case <-ticker.C:
+			desired = c.loadSymbols(ctx, baseSymbols)
+			c.reconcile(ctx, desired)
+		}
+	}
+}
+
+func (c *FuturesStreamController) Stop() {
+	c.mu.Lock()
+	defer c.mu.Unlock()
+	if c.cancel != nil {
+		c.cancel()
+		c.cancel = nil
+	}
+	if c.manager != nil {
+		c.manager.Close()
+		c.manager = nil
+	}
+}
+
+func (c *FuturesStreamController) loadSymbols(ctx context.Context, base []string) []string {
+	set := make(map[string]struct{}, len(base))
+	for _, s := range base {
+		x := strings.ToUpper(strings.TrimSpace(s))
+		if x != "" {
+			set[x] = struct{}{}
+		}
+	}
+	if c.client != nil && c.symbolsKey != "" {
+		syms, err := c.client.SMembers(ctx, c.symbolsKey).Result()
+		if err == nil {
+			for _, s := range syms {
+				x := strings.ToUpper(strings.TrimSpace(s))
+				if x != "" {
+					set[x] = struct{}{}
+				}
+			}
+		}
+	}
+	out := make([]string, 0, len(set))
+	for s := range set {
+		out = append(out, s)
+	}
+	sort.Strings(out)
+	return out
+}
+
+func (c *FuturesStreamController) reconcile(ctx context.Context, symbols []string) {
+	c.mu.Lock()
+	defer c.mu.Unlock()
+
+	if len(symbols) == len(c.currentSymbols) {
+		match := true
+		curr := make(map[string]struct{}, len(c.currentSymbols))
+		for _, s := range c.currentSymbols {
+			curr[s] = struct{}{}
+		}
+		for _, s := range symbols {
+			if _, ok := curr[s]; !ok {
+				match = false
+				break
+			}
+		}
+		if match {
+			return
+		}
+	}
+
+	if c.manager == nil {
+		mgr := NewFuturesWSManager(c.wsURL, c.cfg, c.logger, c.symbolMap, c.bookMaxLevels)
+		c.manager = mgr
+		mctx, cancel := context.WithCancel(ctx)
+		c.cancel = cancel
+		if err := mgr.Connect(mctx); err != nil {
+			c.logger.Printf("Bybit WS connect error: %v", err)
+			monitoring.RecordBybitReconnect("connect_error")
+			c.manager = nil
+			cancel()
+			c.cancel = nil
+			return
+		}
+		args := c.buildArgs(symbols)
+		if err := mgr.subscribe(args); err != nil {
+			c.logger.Printf("Bybit subscribe error: %v", err)
+			monitoring.RecordBybitReconnect("subscribe_error")
+			mgr.Close()
+			c.manager = nil
+			cancel()
+			c.cancel = nil
+			return
+		}
+		for _, a := range args {
+			mgr.subs[a] = struct{}{}
+		}
+		c.currentSymbols = symbols
+		go func() {
+			err := mgr.ReadLoop(mctx, c.publisher)
+			if err != nil && !wsconn.IsContextError(err) {
+				c.logger.Printf("Bybit readloop exit: %v", err)
+				monitoring.RecordBybitReconnect("readloop_exit")
+			}
+		}()
+		return
+	}
+
+	currSet := make(map[string]struct{}, len(c.currentSymbols))
+	for _, s := range c.currentSymbols {
+		currSet[s] = struct{}{}
+	}
+	newSet := make(map[string]struct{}, len(symbols))
+	for _, s := range symbols {
+		newSet[s] = struct{}{}
+	}
+	var add, rem []string
+	for s := range newSet {
+		if _, ok := currSet[s]; !ok {
+			add = append(add, s)
+		}
+	}
+	for s := range currSet {
+		if _, ok := newSet[s]; !ok {
+			rem = append(rem, s)
+		}
+	}
+	sort.Strings(add)
+	sort.Strings(rem)
+	addArgs := c.buildArgs(add)
+	remArgs := c.buildArgs(rem)
+	if len(remArgs) > 0 {
+		if err := c.manager.unsubscribe(remArgs); err != nil {
+			c.logger.Printf("Bybit unsubscribe error: %v", err)
+			monitoring.RecordBybitReconnect("unsubscribe_error")
+		}
+		for _, a := range remArgs {
+			delete(c.manager.subs, a)
+		}
+	}
+	if len(addArgs) > 0 {
+		if err := c.manager.subscribe(addArgs); err != nil {
+			c.logger.Printf("Bybit subscribe(add) error: %v", err)
+			monitoring.RecordBybitReconnect("subscribe_add_error")
+		}
+		for _, a := range addArgs {
+			c.manager.subs[a] = struct{}{}
+		}
+	}
+	c.currentSymbols = symbols
+}
+
+func (c *FuturesStreamController) buildArgs(symbols []string) []string {
+	args := make([]string, 0, len(symbols)*2)
+	for _, sym := range symbols {
+		s := strings.ToUpper(strings.TrimSpace(sym))
+		if s == "" {
+			continue
+		}
+		if c.bookEnabled {
+			args = append(args, fmt.Sprintf("orderbook.%d.%s", c.bookDepth, s))
+		}
+		if c.tradesEnabled {
+			args = append(args, fmt.Sprintf("publicTrade.%s", s))
+		}
+	}
+	maxArgs := getEnvInt("BYBIT_MAX_ARGS_PER_SUB", 0)
+	if maxArgs > 0 && len(args) > maxArgs {
+		args = args[:maxArgs]
+	}
+	return args
+}
+
+func ParseBaseSymbols() []string {
+	raw := strings.TrimSpace(os.Getenv("BYBIT_FUTURES_SYMBOLS"))
+	if raw == "" {
+		raw = strings.TrimSpace(os.Getenv("FUTURES_SYMBOLS"))
+	}
+	if raw == "" {
+		return []string{"BTCUSDT", "ETHUSDT"}
+	}
+	parts := strings.Split(raw, ",")
+	out := make([]string, 0, len(parts))
+	for _, p := range parts {
+		s := strings.ToUpper(strings.TrimSpace(p))
+		if s != "" {
+			out = append(out, s)
+		}
+	}
+	if len(out) == 0 {
+		return []string{"BTCUSDT", "ETHUSDT"}
+	}
+	sort.Strings(out)
+	return out
+}
+
+func IsEnabled() bool {
+	return getEnvBool("BYBIT_FUTURES_WS_ENABLED", false)
+}
