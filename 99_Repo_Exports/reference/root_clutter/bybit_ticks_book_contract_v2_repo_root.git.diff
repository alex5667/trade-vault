@@ -0,0 +1,64 @@
+package bybit
+
+import "testing"
+
+func TestNormalizeTrade_OK(t *testing.T) {
+	raw := []byte(`{"topic":"publicTrade.BTCUSDT","type":"snapshot","ts":1672304486868,"data":[{"T":1672304486865,"s":"BTCUSDT","S":"Buy","v":"0.001","p":"16578.50","i":"123","seq":100}]}`)
+	store := NewBookStore()
+	ticks, books, err := NormalizeMessage(raw, nil, store, 50)
+	if err != nil {
+		t.Fatalf("err: %v", err)
+	}
+	if len(books) != 0 {
+		t.Fatalf("expected no books")
+	}
+	if len(ticks) != 1 {
+		t.Fatalf("expected 1 tick, got %d", len(ticks))
+	}
+	if ticks[0].Symbol != "BTCUSDT" {
+		t.Fatalf("symbol=%s", ticks[0].Symbol)
+	}
+	if ticks[0].Values["side"].(string) != "BUY" {
+		t.Fatalf("side=%v", ticks[0].Values["side"])
+	}
+}
+
+func TestNormalizeOrderbook_SnapshotThenDelta(t *testing.T) {
+	snap := []byte(`{"topic":"orderbook.50.BTCUSDT","type":"snapshot","ts":1672304486000,"data":{"s":"BTCUSDT","b":[["100","1"],["99","2"]],"a":[["101","1"],["102","2"]],"u":10,"seq":1}}`)
+	delta := []byte(`{"topic":"orderbook.50.BTCUSDT","type":"delta","ts":1672304487000,"data":{"s":"BTCUSDT","b":[["100","0"],["98","3"]],"a":[["101","1.5"]],"u":11,"seq":2}}`)
+	store := NewBookStore()
+	_, books1, err := NormalizeMessage(snap, nil, store, 10)
+	if err != nil {
+		t.Fatalf("err: %v", err)
+	}
+	if len(books1) != 1 {
+		t.Fatalf("expected 1 book, got %d", len(books1))
+	}
+	_, books2, err := NormalizeMessage(delta, nil, store, 10)
+	if err != nil {
+		t.Fatalf("err: %v", err)
+	}
+	if len(books2) != 1 {
+		t.Fatalf("expected 1 book, got %d", len(books2))
+	}
+	bids := books2[0].Values["bids"].(string)
+	if !contains(bids, "\"99\"") || !contains(bids, "\"98\"") {
+		t.Fatalf("unexpected bids json: %s", bids)
+	}
+	if contains(bids, "\"100\"") {
+		t.Fatalf("expected bid 100 removed, got: %s", bids)
+	}
+}
+
+func contains(s, sub string) bool {
+	return indexOf(s, sub) >= 0
+}
+
+func indexOf(s, sub string) int {
+	for i := 0; i <= len(s)-len(sub); i++ {
+		if s[i:i+len(sub)] == sub {
+			return i
+		}
+	}
+	return -1
+}
