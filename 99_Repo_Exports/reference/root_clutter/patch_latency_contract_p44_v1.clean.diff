+ROOT = Path(__file__).resolve().parents[2]
+
+
+def test_parse_env_file_text_skips_comments() -> None:
+    env = parse_env_file_text("#x\nA=1\nB='two'\n")
+    assert env['A'] == '1'
+    assert env['B'] == 'two'
+
+
+def test_lint_contract_ok_against_repo_examples() -> None:
