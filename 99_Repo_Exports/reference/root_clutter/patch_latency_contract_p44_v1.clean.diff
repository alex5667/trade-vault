+        repo_root=ROOT,
+        purpose='conf_score_guardrails_apply',
+        env={
+            'TRADE_REPO_ROOT': '/opt/trade/staging/repo',
+            'TRADE_ORDERFLOW_IMAGE': 'trade-orderflow:staging',
