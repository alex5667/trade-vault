+    cfg = _cfg()
+    mod.cmd_ack(r, cfg, purpose='meta_cov_rollout_controller', operator='alex', ticket='INC-1', reason='known', minutes=30, now_ms=1000)
+    prep = mod.cmd_prepare_override(
