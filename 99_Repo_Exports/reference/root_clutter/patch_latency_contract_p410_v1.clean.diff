+        cfg,
+        purpose='meta_cov_rollout_controller',
+        operator='alex',
+        ticket='INC-1',
+        escalation_ticket='SEV-9',
+        reason='need longer silence',
+        minutes=45,
+        now_ms=2000,
+    )
+    req_id = prep['request_id']
+    appr = mod.cmd_approve_override(r, cfg, request_id=req_id, operator='bob', reason='approved', now_ms=3000)
+    assert appr['status']['status'] == 'approved'
+    out = mod.cmd_ack(
+        r,
+        cfg,
+        purpose='meta_cov_rollout_controller',
+        operator='alex',
+        ticket='INC-1',
+        escalation_ticket='SEV-9',
+        approval_request_id=req_id,
+        reason='bridge approved',
+        minutes=45,
+        now_ms=4000,
+    )
+    assert out['ok'] is True
+    assert out['status']['policy_current_override_active'] is True
+    assert out['status']['dual_control_required'] is True
+    assert out['status']['dual_control_request_id'] == req_id
+    approval_key = f'cfg:orderflow:latency_contract:deploy_lint:silence_approval:req:{req_id}'
