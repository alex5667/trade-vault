+def _deadline_for_status(*, now_ms: int, status: str, prepared_freshness_s: int, approved_freshness_s: int) -> int:
+    if status == 'prepared':
+        return now_ms + max(1, int(prepared_freshness_s)) * 1000
+    if status == 'approved':
+        return now_ms + max(1, int(approved_freshness_s)) * 1000
+    return 0
