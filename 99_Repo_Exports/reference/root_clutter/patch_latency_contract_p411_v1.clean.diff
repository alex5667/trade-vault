+from orderflow_services import latency_contract_deploy_lint_silence_v1 as mod
+
+
+class FakeRedis:
+    def __init__(self):
+        self.h = {}
+        self.exp = {}
+        self.stream = []
+        self.kv = {}
+    def hgetall(self, k):
+        return dict(self.h.get(k, {}))
+    def hset(self, k, mapping=None, **kwargs):
+        cur = self.h.setdefault(k, {})
+        cur.update(mapping or kwargs)
+    def expire(self, k, ttl):
+        self.exp[k] = ttl
+    def xadd(self, stream, fields, maxlen=None, approximate=None):
+        self.stream.append((stream, dict(fields)))
+        return f"{len(self.stream)}-0"
+    def get(self, k):
+        return self.kv.get(k)
+    def set(self, k, v, ex=None):
+        self.kv[k] = v
+        if ex is not None:
+            self.exp[k] = ex
+
+
+def _cfg() -> mod.Cfg:
+    return mod.Cfg(
+        redis_url='redis://unused',
+        state_prefix='metrics:latency_contract:deploy_lint:last',
+        silence_prefix='cfg:orderflow:latency_contract:deploy_lint:silence',
+        approval_prefix='cfg:orderflow:latency_contract:deploy_lint:silence_approval',
+        ops_stream='ops:latency_contract:events:v1',
+        silence_ttl_s=3600,
+        approval_ttl_s=3600,
+        approval_prepared_freshness_s=60,
+        approval_approved_freshness_s=30,
+        default_minutes=60,
+        policy_window_s=168 * 3600,
+        policy_max_budget_minutes=60,
+        policy_max_acks=1,
+        policy_denied_exit_code=27,
+        dual_control_minutes=45,
+    )
+
+
+def test_prepared_request_auto_expires_after_freshness_window() -> None:
+    r = FakeRedis()
+    cfg = _cfg()
+    prep = mod.cmd_prepare_override(
+        r,
+        cfg,
+        purpose='meta_cov_rollout_controller',
+        operator='alex',
+        ticket='INC-1',
+        escalation_ticket='SEV-9',
+        reason='need long silence',
+        minutes=45,
+        now_ms=1000,
+    )
+    req_id = prep['request_id']
+    status = mod.cmd_status(r, cfg, purpose='meta_cov_rollout_controller', now_ms=62000)
+    row = status['rows'][0]
+    assert row['latest_approval_request_id'] == req_id
+    assert row['latest_approval_status'] == 'expired'
+    assert row['latest_approval_expired_reason'] == 'prepared_freshness_elapsed'
+    assert any(evt[1]['kind'] == 'latency_deploy_lint_override_approval_expired' for evt in r.stream)
+
+
+def test_approved_request_auto_cancels_and_ack_is_denied() -> None:
+    r = FakeRedis()
+    cfg = _cfg()
+    r.h['metrics:latency_contract:deploy_lint:last:meta_cov_rollout_controller'] = {'gate_active': '1'}
+    mod.cmd_ack(r, cfg, purpose='meta_cov_rollout_controller', operator='alex', ticket='INC-1', reason='known', minutes=30, now_ms=1000)
+    prep = mod.cmd_prepare_override(
+        r,
+        cfg,
+        purpose='meta_cov_rollout_controller',
+        operator='alex',
+        ticket='INC-1',
+        escalation_ticket='SEV-9',
+        reason='need longer silence',
+        minutes=45,
+        now_ms=2000,
+    )
+    req_id = prep['request_id']
+    mod.cmd_approve_override(r, cfg, request_id=req_id, operator='bob', reason='approved', now_ms=3000)
+    out = mod.cmd_ack(
+        r,
+        cfg,
+        purpose='meta_cov_rollout_controller',
+        operator='alex',
+        ticket='INC-1',
+        escalation_ticket='SEV-9',
+        approval_request_id=req_id,
+        reason='bridge approved',
+        minutes=45,
+        now_ms=35000,
+    )
+    assert out['ok'] is False
+    assert out['policy']['dual_control_required'] is True
+    assert out['policy']['denied_reason'] == 'dual_control_approval_cancelled'
+    approval_key = f'cfg:orderflow:latency_contract:deploy_lint:silence_approval:req:{req_id}'
+    assert r.h[approval_key]['status'] == 'cancelled'
+    assert any(evt[1]['kind'] == 'latency_deploy_lint_override_approval_cancelled' for evt in r.stream)
