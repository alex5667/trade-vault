+    deadline_ts_ms = st.freshness_deadline_ts_ms
+    if deadline_ts_ms <= 0:
+        deadline_ts_ms = _deadline_for_status(
+            now_ms=st.prepared_ts_ms if st.status == 'prepared' else st.approved_ts_ms or now_ms,
+            status=st.status,
