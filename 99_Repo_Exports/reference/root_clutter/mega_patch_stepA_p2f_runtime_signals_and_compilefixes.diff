@@ -0,0 +1,56 @@
+from __future__ import annotations
+
+
+class _RuntimeStub:
+    def __init__(self):
+        self.tick_gap_p50_ms = 12.0
+        self.tick_gap_p95_ms = 55.0
+        self.tick_gap_n = 321
+        self.tick_missing_seq_ema = 0.25
+        self.book_missing_seq_ema = 0.10
+
+        self.tick_gap_count_total = 3
+        self.tick_dup_count_total = 4
+        self.tick_reorder_count_total = 5
+        self.tick_seq_last_reason = 2
+        self.tick_seq_last_missing = 7
+
+        self.book_seq_last_reason = 1
+        self.book_seq_last_missing = 0
+
+
+def test_surface_dq_indicators_sets_required_keys():
+    from core.seq_dq_v1 import surface_dq_indicators
+
+    rt = _RuntimeStub()
+    indicators = {}
+    surface_dq_indicators(rt, indicators)
+
+    assert indicators["tick_gap_p50_ms"] == 12.0
+    assert indicators["tick_gap_p95_ms"] == 55.0
+    assert indicators["tick_gap_n"] == 321
+
+    assert indicators["tick_missing_seq_ema"] == 0.25
+    assert indicators["book_missing_seq_ema"] == 0.10
+
+    assert indicators["tick_gap_count"] == 3
+    assert indicators["tick_dup_count"] == 4
+    assert indicators["tick_reorder_count"] == 5
+
+    assert indicators["tick_seq_last_reason"] == 2
+    assert indicators["tick_seq_last_missing"] == 7
+
+    assert indicators["book_seq_last_reason"] == 1
+    assert indicators["book_seq_last_missing"] == 0
+
+
+def test_surface_dq_indicators_fail_open_on_missing_attrs():
+    from core.seq_dq_v1 import surface_dq_indicators
+
+    class Empty:
+        pass
+
+    indicators = {"tick_gap_p50_ms": 1.0}
+    out = surface_dq_indicators(Empty(), indicators)
+    # Does not crash and keeps pre-existing keys.
+    assert out["tick_gap_p50_ms"] == 1.0

