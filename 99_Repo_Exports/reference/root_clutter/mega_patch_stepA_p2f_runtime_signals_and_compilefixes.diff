+def surface_dq_indicators(runtime, indicators: dict) -> dict:
+    """Ensure DQ keys exist in `indicators` (Train==Serve contract).
+
+    Duck-typed: `runtime` may be SymbolRuntime or a test stub.
+
+    Policy:
+      - If `runtime` provides a value -> write it into indicators.
+      - If `runtime` is missing the attribute / provides None -> keep existing indicator if present,
+        otherwise set a sensible default (0 / 0.0).
+
+    This makes the helper safe to call in both prod runtime and unit tests.
+    """
+    _S = object()
+    try:
+        v = getattr(runtime, 'tick_gap_p50_ms', _S)
+        if v is not _S and v is not None:
+            indicators['tick_gap_p50_ms'] = float(v)
+        else:
+            indicators.setdefault('tick_gap_p50_ms', 0.0)
+
+        v = getattr(runtime, 'tick_gap_p95_ms', _S)
+        if v is not _S and v is not None:
+            indicators['tick_gap_p95_ms'] = float(v)
+        else:
+            indicators.setdefault('tick_gap_p95_ms', 0.0)
+
+        v = getattr(runtime, 'tick_gap_n', _S)
+        if v is not _S and v is not None:
+            indicators['tick_gap_n'] = int(v)
+        else:
+            indicators.setdefault('tick_gap_n', 0)
+
+        v = getattr(runtime, 'tick_missing_seq_ema', _S)
+        if v is not _S and v is not None:
+            indicators['tick_missing_seq_ema'] = float(v)
+        else:
+            indicators.setdefault('tick_missing_seq_ema', 0.0)
+
+        v = getattr(runtime, 'book_missing_seq_ema', _S)
+        if v is not _S and v is not None:
+            indicators['book_missing_seq_ema'] = float(v)
+        else:
+            indicators.setdefault('book_missing_seq_ema', 0.0)
+
+        # Optional debug surfaces (numeric codes only; stable label cardinality).
+        v = getattr(runtime, 'tick_gap_count_total', _S)
+        if v is not _S and v is not None:
+            indicators['tick_gap_count'] = int(v)
+        else:
+            indicators.setdefault('tick_gap_count', 0)
+
+        v = getattr(runtime, 'tick_dup_count_total', _S)
+        if v is not _S and v is not None:
+            indicators['tick_dup_count'] = int(v)
+        else:
+            indicators.setdefault('tick_dup_count', 0)
+
+        v = getattr(runtime, 'tick_reorder_count_total', _S)
+        if v is not _S and v is not None:
+            indicators['tick_reorder_count'] = int(v)
+        else:
+            indicators.setdefault('tick_reorder_count', 0)
+
+        v = getattr(runtime, 'tick_seq_last_reason', _S)
+        if v is not _S and v is not None:
+            indicators['tick_seq_last_reason'] = int(v)
+        else:
+            indicators.setdefault('tick_seq_last_reason', 0)
+
+        v = getattr(runtime, 'tick_seq_last_missing', _S)
+        if v is not _S and v is not None:
+            indicators['tick_seq_last_missing'] = int(v)
+        else:
+            indicators.setdefault('tick_seq_last_missing', 0)
+
+        v = getattr(runtime, 'book_seq_last_reason', _S)
+        if v is not _S and v is not None:
+            indicators['book_seq_last_reason'] = int(v)
+        else:
+            indicators.setdefault('book_seq_last_reason', 0)
+
+        v = getattr(runtime, 'book_seq_last_missing', _S)
+        if v is not _S and v is not None:
+            indicators['book_seq_last_missing'] = int(v)
+        else:
+            indicators.setdefault('book_seq_last_missing', 0)
+    except Exception:
+        # fail-open: keep whatever is already in indicators
+        pass
+    return indicators

