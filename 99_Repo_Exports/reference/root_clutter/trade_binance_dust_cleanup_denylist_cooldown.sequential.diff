+
+    def _purge(self, key=None):
+        if key is not None:
+            exp = self.expiry_ms.get(key)
+            if exp is not None and exp <= self.now_ms:
+                self.kv.pop(key, None)
+                self.expiry_ms.pop(key, None)
+            return
+        for k in list(self.expiry_ms.keys()):
