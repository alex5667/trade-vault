diff -ruN '--exclude=20260224_of_gate_metrics_rollups_p78.sql' a/services/prom_rules_bundle_smoke_runner_v1.py b/services/prom_rules_bundle_smoke_runner_v1.py
--- a/services/prom_rules_bundle_smoke_runner_v1.py	1970-01-01 00:00:00.000000000 +0000
+++ b/services/prom_rules_bundle_smoke_runner_v1.py	2026-02-25 19:11:39.414701397 +0000
@@ -0,0 +1,84 @@
+"""Prometheus rules bundle repo validator smoke runner (P102).
+
+Goal:
+- Validate that all Prometheus rule files referenced by the repository bundle are parseable.
+- Fail-closed by setting a global auto-apply block key when validation fails.
+
+This is designed to be executed from an orchestrator (docker-compose timer / systemd).
+
+Exit codes:
+- 0: OK
+- 2: Validation failed (intentional signal for orchestrator/alerts)
+- 1: Unexpected error
+"""
+
+from __future__ import annotations
+
+import os
+import sys
+import time
+import traceback
+
+from orderflow_services.validate_prometheus_rules_bundle_v1 import validate_prometheus_rules_bundle
+
+try:
+    import redis  # type: ignore
+except Exception:  # pragma: no cover
+    redis = None
+
+AUTO_APPLY_BLOCK_PREFIX = "cfg:suggestions:entry_policy:auto_apply_block"
+
+
+def _redis_client():
+    if redis is None:
+        raise RuntimeError("redis python package is required")
+
+    redis_url = os.environ.get("REDIS_URL")
+    if not redis_url:
+        raise RuntimeError("REDIS_URL is required")
+
+    # decode_responses=True so values are strings and logs are readable
+    return redis.Redis.from_url(redis_url, decode_responses=True)
+
+
+def _set_global_block(reason: str, hold_s: int = 300) -> None:
+    """Set a global fail-closed auto-apply block for the entry-policy promoter."""
+    r = _redis_client()
+    key = f"{AUTO_APPLY_BLOCK_PREFIX}:prom_rules_bundle:{reason}"
+    ts_ms = int(time.time() * 1000)
+    r.set(key, str(ts_ms), ex=max(60, int(hold_s)))
+
+
+def main() -> int:
+    repo_root = os.environ.get("PROM_RULES_REPO_ROOT", ".")
+    promtool = os.environ.get("PROMTOOL_PATH")  # optional
+    hold_s = int(os.environ.get("AUTO_APPLY_BLOCK_HOLD_S", "300"))
+
+    try:
+        ok, report = validate_prometheus_rules_bundle(
+            repo_root=repo_root,
+            promtool_path=promtool,
+        )
+        if ok:
+            print("OK: prom rules bundle validation")
+            return 0
+
+        # Fail-closed: set global auto-apply block so nothing is promoted automatically.
+        print("FAIL: prom rules bundle validation")
+        print(report)
+        _set_global_block(reason="invalid_rules", hold_s=hold_s)
+        return 2
+
+    except Exception:
+        print("ERROR: prom rules bundle smoke runner crashed")
+        traceback.print_exc()
+        try:
+            _set_global_block(reason="runner_crash", hold_s=hold_s)
+        except Exception:
+            # Don't mask original error
+            pass
+        return 1
+
+
+if __name__ == "__main__":
+    sys.exit(main())
