@@ -0,0 +1,59 @@
+from __future__ import annotations
+
+import json
+import os
+from http.server import BaseHTTPRequestHandler, HTTPServer
+from typing import Any
+
+try:  # pragma: no cover
+    import redis  # type: ignore
+except Exception:  # pragma: no cover
+    redis = None  # type: ignore
+
+try:  # pragma: no cover
+    from services.execution_projection_worker import _worker_from_env
+except Exception:  # pragma: no cover
+    from execution_projection_worker import _worker_from_env
+
+
+def _redis_from_env() -> Any:  # pragma: no cover
+    url = os.getenv('REDIS_URL', 'redis://redis-worker-1:6379/0')
+    if redis is None:
+        raise RuntimeError('redis package is required for execution_projection_health_server')
+    return redis.from_url(url, decode_responses=True)
+
+
+class _Handler(BaseHTTPRequestHandler):  # pragma: no cover
+    def do_GET(self):
+        if self.path not in ('/healthz', '/readyz', '/api/execution-projection/health'):
+            self.send_response(404)
+            self.end_headers()
+            return
+        worker = self.server.worker  # type: ignore[attr-defined]
+        snap = worker.health_snapshot().to_dict()
+        is_ready_path = self.path in ('/readyz', '/api/execution-projection/health')
+        status = 200 if (snap.get('ready') if is_ready_path else snap.get('ok')) else 503
+        body = json.dumps(snap, ensure_ascii=False).encode('utf-8')
+        self.send_response(status)
+        self.send_header('Content-Type', 'application/json; charset=utf-8')
+        self.send_header('Content-Length', str(len(body)))
+        self.end_headers()
+        self.wfile.write(body)
+
+    def log_message(self, fmt, *args):
+        return
+
+
+def main() -> int:  # pragma: no cover
+    r = _redis_from_env()
+    worker = _worker_from_env(r)
+    host = os.getenv('EXEC_PROJECTION_HEALTH_HOST', '0.0.0.0')
+    port = int(os.getenv('EXEC_PROJECTION_HEALTH_PORT', '8786'))
+    server = HTTPServer((host, port), _Handler)
+    server.worker = worker  # type: ignore[attr-defined]
+    server.serve_forever()
+    return 0
+
+
+if __name__ == '__main__':  # pragma: no cover
+    raise SystemExit(main())
