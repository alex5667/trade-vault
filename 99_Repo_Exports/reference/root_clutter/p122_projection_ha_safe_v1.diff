+class FakeRedis:
+    def __init__(self):
+        self.kv = {}
+        self.streams = {}
+        self._seq = 0
+
+    def get(self, key):
+        return self.kv.get(key)
+
+    def set(self, key, value, ex=None, nx=False, xx=False, px=None):
+        exists = key in self.kv
+        if nx and exists:
+            return False
+        if xx and not exists:
+            return False
+        self.kv[key] = value
+        return True
+
+    def incr(self, key):
+        cur = int(self.kv.get(key) or 0)
+        cur += 1
+        self.kv[key] = str(cur)
+        return cur
+
+    def delete(self, key):
+        existed = key in self.kv
+        self.kv.pop(key, None)
+        return 1 if existed else 0
+
+    def scan_iter(self, match=None):
+        if not match or match == '*':
+            yield from list(self.kv.keys())
+            return
+        if match.endswith('*'):
+            prefix = match[:-1]
+            for key in list(self.kv.keys()):
+                if str(key).startswith(prefix):
+                    yield key
+            return
+        for key in list(self.kv.keys()):
+            if key == match:
+                yield key
+
+    def xadd(self, key, fields, maxlen=None, approximate=None):
+        self._seq += 1
+        import time
+        sid = f"{int(time.time() * 1000) + self._seq}-0"
+        self.streams.setdefault(key, []).append((sid, dict(fields)))
+        return sid
+
+    def xrange(self, key, start='-', end='+', count=None):
+        rows = list(self.streams.get(key, []))
+        def _gt(stream_id, ref):
+            a, b = stream_id.split('-', 1)
+            c, d = ref.split('-', 1)
+            return (int(a), int(b)) >= (int(c), int(d))
+        if start not in ('-', '+'):
+            rows = [row for row in rows if _gt(row[0], start)]
+        if count is not None:
+            rows = rows[: int(count)]
+        return rows
+
+    def xrevrange(self, key, end='+', start='-', count=None):
+        rows = list(reversed(self.streams.get(key, [])))
+        if count is not None:
+            rows = rows[: int(count)]
+        return rows
+
+
+def _mk_exec(redis_obj, *, inline_projection=False):
+    ex = exec_mod.BinanceExecutor.__new__(exec_mod.BinanceExecutor)
+    ex.r = redis_obj
+    ex.exec_stream = 'orders:exec'
+    ex.state_key_prefix = 'orders:state:'
+    ex.state_ttl = 86400
+    ex.exec_rehydrate_on_state_miss = True
+    ex.exec_replay_scan_count = 500
+    ex.exec_replay_checkpoint_key_prefix = 'orders:exec:replay:cursor:'
+    ex.exec_replay_quarantine_on_mismatch = False
+    ex.exec_journal_primary = True
+    ex.exec_state_derived_view = True
+    ex.exec_inline_state_projection = inline_projection
+    ex.execution_journal = None
+    return ex
+
+
+def test_projection_worker_leader_lease_blocks_follower_writes():
+    r = FakeRedis()
+    ex = _mk_exec(r, inline_projection=False)
+    sid = 'sid-leader'
+    ex._exec_event({
+        'sid': sid,
+        'symbol': 'BTCUSDT',
+        'action': 'open',
+        'event_type': 'state_transition',
+        'status': 'ok',
+        'fsm_state': 'ENTRY_FILLED',
+        'binance_order_id': 11,
+    })
+    leader = worker_mod.ExecutionProjectionWorker(
+        r,
+        exec_stream='orders:exec',
+        state_key_prefix='orders:state:',
+        leader_lease_enable=True,
+        lease_key='orders:exec:projection:leader',
+        fencing_key='orders:exec:projection:fencing',
+        owner_id='leader-a',
+    )
+    follower = worker_mod.ExecutionProjectionWorker(
+        r,
+        exec_stream='orders:exec',
+        state_key_prefix='orders:state:',
+        leader_lease_enable=True,
+        lease_key='orders:exec:projection:leader',
+        fencing_key='orders:exec:projection:fencing',
+        owner_id='leader-b',
+    )
+    first = leader.run_once()
+    second = follower.run_once()
+    state = json.loads(r.get(f'orders:state:{sid}'))
+    assert first.processed == 1
+    assert first.is_leader is True
+    assert first.fencing_token == 1
+    assert second.processed == 0
+    assert second.is_leader is False
+    assert int(state['projection_fencing_token']) == 1
+    assert state['projection_owner_id'] == 'leader-a'
+
+
+def test_rebuild_from_journal_restores_materialized_state_and_cursor():
+    r = FakeRedis()
+    ex = _mk_exec(r, inline_projection=False)
+    sid = 'sid-rebuild'
+    ex._exec_event({
+        'sid': sid,
+        'symbol': 'ETHUSDT',
+        'action': 'open',
+        'event_type': 'state_transition',
+        'status': 'ok',
+        'fsm_state': 'PROTECTED',
+        'binance_order_id': 21,
+        'tp1_algo_id': 31,
+        'tp1_client_algo_id': 'tp1-a',
+    })
+    worker = worker_mod.ExecutionProjectionWorker(r, exec_stream='orders:exec', state_key_prefix='orders:state:')
+    rebuilt = worker.rebuild_from_journal(reset_existing=True, set_cursor_to_tip=True)
+    state = json.loads(r.get(f'orders:state:{sid}'))
+    assert rebuilt.processed_events == 1
+    assert rebuilt.rebuilt_sids == 1
+    assert rebuilt.cursor_updated is True
+    assert r.get('orders:exec:projection:cursor') == rebuilt.last_stream_id
+    assert state['fsm_state'] == 'PROTECTED'
+    assert state['protective']['tp_algo_ids'] == [31]
+
+
+def test_health_snapshot_and_http_endpoint_are_lag_aware():
+    r = FakeRedis()
+    ex = _mk_exec(r, inline_projection=False)
+    sid = 'sid-health'
+    ex._exec_event({
+        'sid': sid,
+        'symbol': 'SOLUSDT',
+        'action': 'open',
+        'event_type': 'state_transition',
+        'status': 'ok',
+        'fsm_state': 'ENTRY_ACKED',
+        'binance_order_id': 41,
+    })
+    worker = worker_mod.ExecutionProjectionWorker(
+        r,
+        exec_stream='orders:exec',
+        state_key_prefix='orders:state:',
+        leader_lease_enable=True,
+        lease_key='orders:exec:projection:leader',
+        fencing_key='orders:exec:projection:fencing',
+        owner_id='leader-health',
+        health_max_lag_ms=10,
+        health_max_cursor_age_ms=100000,
+    )
+    snap_before = worker.health_snapshot()
+    assert snap_before.ready is False
+    assert snap_before.reason == 'no_leader' or snap_before.reason == 'cursor_missing'
+
+    worker.run_once()
+    snap_after = worker.health_snapshot()
+    assert snap_after.ready is True
+    assert snap_after.has_leader is True
+
+    sock = socket.socket()
+    sock.bind(('127.0.0.1', 0))
+    host, port = sock.getsockname()
+    sock.close()
+    server = health_mod.HTTPServer((host, port), health_mod._Handler)
+    server.worker = worker
+    th = threading.Thread(target=server.serve_forever, daemon=True)
+    th.start()
+    try:
+        with urllib.request.urlopen(f'http://{host}:{port}/readyz', timeout=2) as resp:
+            payload = json.loads(resp.read().decode('utf-8'))
+            assert resp.status == 200
+            assert payload['ready'] is True
+            assert payload['leader_owner_id'] == 'leader-health'
+    finally:
+        server.shutdown()
+        th.join(timeout=2)
