-        _env(
-            "SMOKE_DASHBOARD_PATHS",
-            "/grafana/d/edge_stack_overview/edge-stack-overview?orgId=1,"
-            "/grafana/d/chatops_security/chatops-security?orgId=1,"
-            "/grafana/d/monitoring_smoke/monitoring-smoke-nightly-contract?orgId=1",
-        )
-    )
+    dashboards_default = (
+        "/grafana/d/edge_stack_overview/edge-stack-overview?orgId=1,"
+        "/grafana/d/chatops_security/chatops-security?orgId=1,"
+        "/grafana/d/monitoring_smoke/monitoring-smoke-nightly-contract?orgId=1"
+    )
+
+    # precedence:
+    # 1) explicit env overrides
+    # 2) redis cfg generated from alert annotations
+    # 3) defaults
+    runbooks_env = _env("SMOKE_RUNBOOK_PATHS", "")
+    dashboards_env = _env("SMOKE_DASHBOARD_PATHS", "")
+    runbooks: List[str] = _split_csv(runbooks_env) if runbooks_env else []
+    dashboards: List[str] = _split_csv(dashboards_env) if dashboards_env else []
+
+    if (not runbooks) or (not dashboards):
+        if _env("SMOKE_TARGETS_FROM_REDIS", "1") in ("1", "true", "yes", "on"):
+            rb2, dp2 = _targets_from_redis()
+            if (not runbooks) and rb2:
