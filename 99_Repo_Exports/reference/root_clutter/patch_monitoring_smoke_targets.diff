+from __future__ import annotations
+
+import glob
+import json
+import os
+import re
+import time
+from typing import Any, Dict, List, Set, Tuple
+
+import yaml
+
+
+def _env(name: str, default: str = "") -> str:
+    return (os.getenv(name) or default).strip()
+
+
+REQUIRED_FOR = {"critical", "warning"}
+
+
+def _as_list(x: Any) -> List[Any]:
+    if x is None:
+        return []
+    if isinstance(x, list):
+        return x
+    return [x]
+
+
+def _now_ms() -> int:
+    return int(time.time() * 1000)
+
+
+def _load_yaml(path: str) -> Any:
+    with open(path, "r", encoding="utf-8") as f:
+        return yaml.safe_load(f)
+
+
+def _extract_uid_from_dashboard_path(dashboard_path: str) -> str:
+    p = (dashboard_path or "").strip()
+    if not p:
+        return ""
+    p = p.split("?", 1)[0]
+    m = re.match(r"^/(d|d-solo)/([^/]+)/", p)
+    if not m:
+        return ""
+    return m.group(2)
+
+
+def _normalize_runbook_path(runbook_path: str) -> str:
+    """Convert alert runbook_path (e.g., '/web_uptime.md') to public-proxy path '/runbooks/web_uptime.md'."""
+    rb = (runbook_path or "").strip()
+    if not rb:
+        return ""
+    if not rb.startswith("/"):
+        rb = "/" + rb
+    if rb.startswith("/runbooks/"):
+        return rb
+    return "/runbooks" + rb
+
+
+def _normalize_dashboard_path(dashboard_path: str) -> str:
+    """Convert alert dashboard_path (e.g., '/d/<uid>/<slug>?orgId=1') to public-proxy path '/grafana/d/<uid>/<slug>?orgId=1'."""
+    dp = (dashboard_path or "").strip()
+    if not dp:
+        return ""
+    if not dp.startswith("/"):
+        dp = "/" + dp
+    if dp.startswith("/grafana/"):
+        return dp
+    if dp.startswith("/d/") or dp.startswith("/d-solo/"):
+        return "/grafana" + dp
+    return dp
+
+
+def build_targets_from_alerts(alerts_glob: str = "ok_rate_logic/prometheus_alerts_*.yml") -> Tuple[List[str], List[str]]:
+    runbooks: Set[str] = set()
+    dashboards: Set[str] = set()
+
+    files = sorted(glob.glob(alerts_glob))
+    for fp in files:
+        doc = _load_yaml(fp) or {}
+        groups = _as_list(doc.get("groups"))
+        for g in groups:
+            rules = _as_list((g or {}).get("rules"))
+            for r in rules:
+                labels: Dict[str, Any] = (r or {}).get("labels") or {}
+                ann: Dict[str, Any] = (r or {}).get("annotations") or {}
+                sev = str(labels.get("severity") or "").strip().lower()
+                if sev not in REQUIRED_FOR:
+                    continue
+
+                rb = str(ann.get("runbook_path") or "").strip()
+                dp = str(ann.get("dashboard_path") or "").strip()
+
+                rb2 = _normalize_runbook_path(rb)
+                if rb2:
+                    runbooks.add(rb2)
+
+                dp2 = _normalize_dashboard_path(dp)
+                if dp2:
+                    dashboards.add(dp2)
+
+    return sorted(runbooks), sorted(dashboards)
+
+
+def write_targets_to_redis(runbooks: List[str], dashboards: List[str]) -> Dict[str, Any]:
+    redis_url = _env("REDIS_URL", "")
+    key = _env("MONITORING_SMOKE_TARGETS_KEY", "cfg:monitoring_smoke:targets")
+    ttl_s = int(_env("MONITORING_SMOKE_TARGETS_TTL_S", "604800"))  # 7d
+    if not redis_url:
+        return {"ok": False, "error": "REDIS_URL not set"}
+    try:
+        import redis  # type: ignore
+
+        r = redis.Redis.from_url(redis_url, decode_responses=True)
+        payload = {
+            "updated_ts_ms": str(_now_ms()),
+            "runbook_paths": ",".join(runbooks),
+            "dashboard_paths": ",".join(dashboards),
+            "source": "alerts_annotations",
+        }
+        r.hset(key, mapping=payload)
+        r.expire(key, ttl_s)
+        return {"ok": True, "key": key, "runbooks": len(runbooks), "dashboards": len(dashboards)}
+    except Exception as e:
+        return {"ok": False, "error": f"{type(e).__name__}"}
+
+
+def main() -> int:
+    alerts_glob = _env("ALERTS_GLOB", "ok_rate_logic/prometheus_alerts_*.yml")
+    runbooks, dashboards = build_targets_from_alerts(alerts_glob=alerts_glob)
+    res = write_targets_to_redis(runbooks, dashboards) if _env("WRITE_TO_REDIS", "1") in ("1", "true", "yes", "on") else {"ok": True, "write": "disabled"}
+    out = {"runbooks": runbooks, "dashboards": dashboards, "redis": res}
+    print(json.dumps(out, ensure_ascii=False))
+    return 0 if res.get("ok") else 2
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
