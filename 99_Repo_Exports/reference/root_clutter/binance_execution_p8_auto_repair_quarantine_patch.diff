+class _FakeCursor:
+    def __init__(self, sink):
+        self.sink = sink
+    def __enter__(self):
+        return self
+    def __exit__(self, exc_type, exc, tb):
+        return False
+    def execute(self, sql, params):
+        self.sink.append((sql, params))
