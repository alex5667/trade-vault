+class _Summary:
+    def __init__(self, critical: int, mismatches=None):
+        self.critical_mismatches = critical
+        self.mismatches = mismatches or []
+    def to_dict(self):
+        return {'critical_mismatches': self.critical_mismatches, 'mismatches': self.mismatches}
