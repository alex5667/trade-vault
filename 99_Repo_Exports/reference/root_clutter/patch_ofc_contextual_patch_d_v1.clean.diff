+OFC_CTX_CANARY_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
+OFC_CTX_ROLLOUT_APPLY=1
+OFC_CTX_ROLLOUT_MIN_OBSERVATIONS=300
+OFC_CTX_MAX_SHADOW_DISAGREE_RATE=0.15
+OFC_CTX_MAX_FAIL_OPEN_RATE=0.02
+OFC_CTX_MAX_FALLBACK_RATE=0.25
+OFC_CTX_MAX_BUNDLE_AGE_SEC=21600
+OFC_CTX_MAX_WRITER_LAG_SEC=120
+OFC_CTX_ROLLOUT_MIN_HOLD_SEC=1800
+
+# Exporters
+OFC_CTX_EXPORTER_PORT=9846
+OFC_CTX_ROLLOUT_EXPORTER_PORT=9848
+OFC_CTX_ROLLOUT_EXPORTER_INTERVAL_S=15

