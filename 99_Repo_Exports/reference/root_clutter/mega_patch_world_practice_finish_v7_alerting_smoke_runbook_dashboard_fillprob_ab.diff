+groups:
+  # ─────────────────────────────────────────────────────────────────────────────
+  # World-practice trackers v1 – low-cardinality gauges (sym × bucket)
+  # ─────────────────────────────────────────────────────────────────────────────
+
+- name: of_world_practice_trackers_v1
+  interval: 60s
+  rules:
+
+  # ── Warn: vol_ratio_z high but exec_regime_bucket still NORMAL (bucket wiring/regime label bug) ──
+  - alert: OF_WP_VolRatioZHighInNormalBucket_Warn
+    expr: trade_vol_ratio_z{bucket="NORMAL"} > 3
+    for: 10m
+    labels:
+      severity: warning
+    annotations:
+      summary: "{{ $labels.sym }}: vol_ratio_z high but bucket=NORMAL ({{ $value | printf \"%.2f\" }})"
+      description: |
+        Symbol {{ $labels.sym }}: trade_vol_ratio_z is high while exec_regime_bucket remains NORMAL.
+        Typical causes: vol_regime_label stuck at "na" or bucket classifier mismatch.
+      runbook_path: /runbooks/world_practice_trackers_v1.md
+      dashboard_path: /d/world_practice_trackers_v1
+
+  # ── Warn: very low fill-prob in HIGH_VOL_LOW_LIQ when system is active ─────────
+  - alert: OF_WP_FillProbLowHVLL_Warn
+    expr: |
+      (
+        trade_fill_prob{bucket="HIGH_VOL_LOW_LIQ"} < 0.15
+      )
+      and on(sym)
+      (
+        label_replace(
+          sum by (symbol) (rate(decision_record_written_total{result="allow"}[5m])),
+          "sym", "$1", "symbol", "(.*)"
+        ) > 0.02
+      )
+    for: 15m
+    labels:
+      severity: warning
+    annotations:
+      summary: "{{ $labels.sym }}: fill_prob low in HIGH_VOL_LOW_LIQ ({{ $value | printf \"%.2f\" }})"
+      description: |
+        Symbol {{ $labels.sym }}: trade_fill_prob is low in HIGH_VOL_LOW_LIQ while allow decisions are being produced.
+        This may indicate degraded passive executability (thin book / churn) or wiring issues if stuck at 0.0.
+      runbook_path: /runbooks/world_practice_trackers_v1.md
+      dashboard_path: /d/world_practice_trackers_v1
+
+  # ── Warn: eta_fill too high in HIGH_VOL_LOW_LIQ when system is active ──────────
+  - alert: OF_WP_EtaFillHighHVLL_Warn
+    expr: |
+      (
+        trade_eta_fill_sec{bucket="HIGH_VOL_LOW_LIQ"} > 8
+      )
+      and on(sym)
+      (
+        label_replace(
+          sum by (symbol) (rate(decision_record_written_total{result="allow"}[5m])),
+          "sym", "$1", "symbol", "(.*)"
+        ) > 0.02
+      )
+    for: 15m
+    labels:
+      severity: warning
+    annotations:
+      summary: "{{ $labels.sym }}: eta_fill high in HIGH_VOL_LOW_LIQ ({{ $value | printf \"%.1f\" }}s)"
+      description: |
+        Symbol {{ $labels.sym }}: trade_eta_fill_sec is high in HIGH_VOL_LOW_LIQ while allow decisions are being produced.
+        Check depth_near, taker_rate_ema and churn.
+      runbook_path: /runbooks/world_practice_trackers_v1.md
+      dashboard_path: /d/world_practice_trackers_v1
+
+  # ── Crit: vol trackers likely broken (ratio stuck at 0) while system is active ─
+  - alert: OF_WP_VolTrackersStuckZero_Crit
+    expr: |
+      (
+        max_over_time(trade_vol_ratio[20m]) == 0
+      )
+      and on(sym)
+      (
+        label_replace(
+          sum by (symbol) (rate(decision_record_written_total{result="allow"}[5m])),
+          "sym", "$1", "symbol", "(.*)"
+        ) > 0.05
+      )
+    for: 20m
+    labels:
+      severity: critical
+    annotations:
+      summary: "{{ $labels.sym }}: vol trackers stuck at 0 while active"
+      description: |
+        Symbol {{ $labels.sym }}: trade_vol_ratio has been 0 for 20m while allow decisions exist.
+        This typically indicates broken snapshot wiring (bar_processor -> runtime -> indicators -> gauges).
+      runbook_path: /runbooks/world_practice_trackers_v1.md
+      dashboard_path: /d/world_practice_trackers_v1
