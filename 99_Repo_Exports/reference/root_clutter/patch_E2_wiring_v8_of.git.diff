+def test_feature_registry_schema_versions_include_v8():
+    """Smoke: v8_of/v8_of_stable schemas resolve, extend v7_of, contain DQ + liqmap keys."""
+    from core.feature_registry import get_schema_info
+
+    info_v7 = get_schema_info("v7_of")
+    for ver in ("v8_of", "v8_of_stable"):
+        info = get_schema_info(ver)
+        assert info.ver == ver
+        assert isinstance(info.feature_names, list)
+        assert len(info.feature_names) > 10
+        # must be unique
+        assert len(set(info.feature_names)) == len(info.feature_names)
+        # v8 must contain DQ keys (as num)
+        for k in ("n:tick_gap_p95_ms", "n:tick_missing_seq_ema", "n:book_missing_seq_ema"):
+            assert k in set(info.feature_names), f"{ver} missing DQ key: {k}"
+        # v8 must contain liqmap keys (1h baseline)
+        for k in (
+            "n:liqmap_1h_total_usd",
+            "n:liqmap_1h_near_total_usd",
+            "n:liqmap_1h_near_imb",
+            "n:liqmap_1h_dist_up_bps",
+            "n:liqmap_1h_dist_dn_bps",
+            "n:liqmap_1h_peak_up1_usd",
+            "n:liqmap_1h_peak_dn1_usd",
+            "n:liqmap_1h_age_ms",
+        ):
+            assert k in set(info.feature_names), f"{ver} missing liqmap key: {k}"
+
+        # v8_of must be superset of v7_of (modulo stable denylist)
+        if ver == "v8_of":
+            assert len(info.feature_names) >= len(info_v7.feature_names), (
