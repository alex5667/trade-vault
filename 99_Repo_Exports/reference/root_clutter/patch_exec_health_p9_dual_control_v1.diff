+      - alert: OF_ExecHealth_FreezeDualControl_InvalidCommit_Crit
+        expr: exec_health_freeze_dual_control_violation{kind=~"invalid_commit_signature|invalid_control_commit_signature|commit_without_approval|commit_without_prepare"} > 0
