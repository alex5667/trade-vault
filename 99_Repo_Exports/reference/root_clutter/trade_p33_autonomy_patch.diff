+          description: "Rebuild report shows one or more replay checkpoints behind stream retention."
+      - alert: TradeExecutionRetentionGuardQuarantineSpike
+        expr: increase(execution_quarantine_events_total{action="RETENTION_GUARD_QUARANTINED"}[15m]) > 0
+        for: 0m
+        labels:
+          severity: critical
+          component: trade-execution
