 groups:
   - name: web-uptime
     rules:
+      - alert: BlackboxExporterScrapeDownCritical
+        expr: min(up{job=~"blackbox_http|blackbox_public"}) == 0
+        for: 5m
+        labels:
+          severity: critical
+          team: trade
+          component: monitoring
+        annotations:
+          summary: "Blackbox exporter scrape DOWN"
+          description: "Prometheus cannot scrape blackbox jobs (blackbox_http/blackbox_public). This can mute uptime alerts. Check blackbox-exporter container and Prometheus->blackbox connectivity."
+          runbook_path: "/web_uptime.md"
+          dashboard_path: "/d/web_uptime/web-uptime-blackbox?orgId=1"
+
+      - alert: BlackboxProbeMetricsMissingInternal
+        expr: absent(probe_success{job="blackbox_http"})
+        for: 20m
+        labels:
+          severity: warning
+          team: trade
+          component: monitoring
+        annotations:
+          summary: "Blackbox probe metrics missing (internal job)"
+          description: "probe_success{job=\"blackbox_http\"} is absent for 20m. Uptime coverage may be broken. Check Prometheus config/relabel and blackbox-exporter."
+          runbook_path: "/web_uptime.md"
+          dashboard_path: "/d/web_uptime/web-uptime-blackbox?orgId=1"
+
+      - alert: BlackboxProbeMetricsMissingPublic
+        expr: absent(probe_success{job="blackbox_public"})
+        for: 20m
+        labels:
+          severity: warning
+          team: trade
+          component: monitoring
+        annotations:
+          summary: "Blackbox probe metrics missing (public job)"
+          description: "probe_success{job=\"blackbox_public\"} is absent for 20m. Public routing/TLS coverage may be broken. Check Prometheus config/relabel and blackbox-exporter."
+          runbook_path: "/web_uptime.md"
+          dashboard_path: "/d/web_uptime/web-uptime-blackbox?orgId=1"
+
       - alert: WebServiceDownCritical
         expr: probe_success{job="blackbox_http"} == 0
         for: 5m
         labels:
           severity: critical
@@ -83,3 +133,11 @@ groups:
           summary: "Public probe latency high (>5s)"
           description: "Blackbox probe_duration_seconds exceeded 5s for {{ $labels.instance }} (max over 10m). Check public-proxy load, DNS, upstream slowness."
           runbook_path: "/web_uptime.md"
           dashboard_path: "/d/web_uptime/web-uptime-blackbox?orgId=1"
