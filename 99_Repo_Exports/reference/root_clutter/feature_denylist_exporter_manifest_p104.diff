+def _module_exists(module: str) -> bool:
+    try:
+        return importlib.util.find_spec(module) is not None
+    except Exception:
+        return False
+
+
+def run_feature_denylist_proposal_exporter() -> bool:
+    """Export Feature-Denylist proposal/AB stats to node_exporter textfile collector.
+
+    SAFE-BY-DEFAULT:
+      - runs only if ENABLE_FEATURE_DENYLIST_EXPORTER=1
+      - if the exporter module isn't present, it becomes a no-op
+    """
+    enabled = os.getenv("ENABLE_FEATURE_DENYLIST_EXPORTER", "0")
+    if str(enabled).lower() not in ("1", "true", "yes", "on"):
+        return True
+
+    module = os.getenv(
+        "FEATURE_DENYLIST_EXPORTER_MODULE",
+        "ml_analysis.tools.feature_denylist_proposal_exporter_v1",
+    )
+    if not _module_exists(module):
+        logger.info(f"Feature-denylist exporter: skipped (module not found): {module}")
+        return True
+
+    timeout_s = int(os.getenv("FEATURE_DENYLIST_EXPORTER_TIMEOUT_S", "30"))
+    rc, stdout, stderr = run_tool_rc(module=module, args=[], timeout=timeout_s)
+    if rc == 0:
+        logger.info("Feature-denylist exporter: OK")
+        return True
+
+    head = (stdout or "").strip().replace("\n", " | ")[:500]
+    tail = (stderr or "").strip().replace("\n", " | ")[:500]
+    msg = (
+        "[P103] Feature-denylist exporter ERROR\n"
+        f"rc={rc}\n"
+        f"stdout={head}\n"
+        f"stderr={tail}"
+    )
+    _notify_stream(msg, severity="warning", source="feature_denylist_exporter")
+    return False
+
+
+
