diff -ruN '--exclude=__pycache__' '--exclude=.pytest_cache' p34/binance_execution/rollout_flags.py p5/binance_execution/rollout_flags.py
--- p34/binance_execution/rollout_flags.py	1970-01-01 00:00:00.000000000 +0000
+++ p5/binance_execution/rollout_flags.py	2026-03-06 19:53:40.813664171 +0000
@@ -0,0 +1,89 @@
+from __future__ import annotations
+
+"""Central rollout/feature-flag contract for execution hardening phases.
+
+The project now has multiple progressively enabled layers:
+  * P0/P1 execution safety + maker ladder
+  * P2 reconcile + user stream
+  * P3/P4 DQ hard veto + portfolio risk + SQL journal
+
+Operationally these must be rolled out independently and quickly rolled back
+without editing Python code or re-building images. This module centralises the
+flag names and default semantics so executor / signal publisher / compose
+files all speak the same language.
+"""
+
+from dataclasses import dataclass
+import os
+from typing import Dict, Any
+
+
+def _b(name: str, default: bool) -> bool:
+    v = os.getenv(name)
+    if v is None or str(v).strip() == "":
+        return bool(default)
+    return str(v).strip().lower() in {"1", "true", "yes", "on"}
+
+
+@dataclass(frozen=True)
+class RolloutFlags:
+    exec_algo_canonical_v2: bool = True
+    exec_reconcile_enable: bool = True
+    exec_user_stream_enable: bool = True
+    exec_maker_tp_enable: bool = True
+    exec_journal_sql_enable: bool = True
+    trade_dq_hard_veto_enable: bool = True
+    trade_risk_engine_v2_enable: bool = True
+    exec_force_safety_first: bool = False
+    exec_degraded_mode_force_safety_first: bool = True
+    exec_degraded_mode_disable_maker: bool = True
+
+    @classmethod
+    def from_env(cls) -> "RolloutFlags":
+        """Build rollout flags from environment.
+
+        Names are intentionally explicit so operators can grep configs and
+        overrides quickly during incidents.
+        """
+        return cls(
+            exec_algo_canonical_v2=_b("EXEC_ALGO_CANONICAL_V2", True),
+            exec_reconcile_enable=_b("EXEC_RECONCILE_ENABLE", True),
+            exec_user_stream_enable=_b("EXEC_USER_STREAM_ENABLE", True),
+            exec_maker_tp_enable=_b("EXEC_MAKER_TP_ENABLE", True),
+            exec_journal_sql_enable=_b("EXEC_JOURNAL_SQL_ENABLE", True),
+            trade_dq_hard_veto_enable=_b("TRADE_DQ_HARD_VETO_ENABLE", True),
+            trade_risk_engine_v2_enable=_b("TRADE_RISK_ENGINE_V2_ENABLE", True),
+            exec_force_safety_first=_b("EXEC_FORCE_SAFETY_FIRST", False),
+            exec_degraded_mode_force_safety_first=_b("EXEC_DEGRADED_MODE_FORCE_SAFETY_FIRST", True),
+            exec_degraded_mode_disable_maker=_b("EXEC_DEGRADED_MODE_DISABLE_MAKER", True),
+        )
+
+    def as_dict(self) -> Dict[str, Any]:
+        return {
+            "exec_algo_canonical_v2": self.exec_algo_canonical_v2,
+            "exec_reconcile_enable": self.exec_reconcile_enable,
+            "exec_user_stream_enable": self.exec_user_stream_enable,
+            "exec_maker_tp_enable": self.exec_maker_tp_enable,
+            "exec_journal_sql_enable": self.exec_journal_sql_enable,
+            "trade_dq_hard_veto_enable": self.trade_dq_hard_veto_enable,
+            "trade_risk_engine_v2_enable": self.trade_risk_engine_v2_enable,
+            "exec_force_safety_first": self.exec_force_safety_first,
+            "exec_degraded_mode_force_safety_first": self.exec_degraded_mode_force_safety_first,
+            "exec_degraded_mode_disable_maker": self.exec_degraded_mode_disable_maker,
+        }
+
+    def maker_allowed(self, *, infra_degraded: bool = False) -> bool:
+        if self.exec_force_safety_first:
+            return False
+        if not self.exec_maker_tp_enable:
+            return False
+        if infra_degraded and self.exec_degraded_mode_disable_maker:
+            return False
+        return True
+
+    def safety_forced(self, *, infra_degraded: bool = False) -> bool:
+        if self.exec_force_safety_first:
+            return True
+        if infra_degraded and self.exec_degraded_mode_force_safety_first:
+            return True
+        return False
diff -ruN '--exclude=__pycache__' '--exclude=.pytest_cache' p34/binance_execution/test_backfill_execution_journal_v1.py p5/binance_execution/test_backfill_execution_journal_v1.py
--- p34/binance_execution/test_backfill_execution_journal_v1.py	1970-01-01 00:00:00.000000000 +0000
+++ p5/binance_execution/test_backfill_execution_journal_v1.py	2026-03-06 19:58:46.072017145 +0000
@@ -0,0 +1,34 @@
+from __future__ import annotations
+
+import importlib.util
+from pathlib import Path
+import json
+
+SCRIPT = Path(__file__).resolve().parent.parent / 'scripts' / 'backfill_execution_journal_from_orders_exec.py'
+SPEC = importlib.util.spec_from_file_location('backfill_execution_journal_from_orders_exec', SCRIPT)
+import sys
+mod = importlib.util.module_from_spec(SPEC)
+assert SPEC and SPEC.loader
+sys.modules[SPEC.name] = mod
+SPEC.loader.exec_module(mod)
+
+
+def test_parse_exec_stream_entry_uses_action_as_default_event_type():
+    row = mod.parse_exec_stream_entry('1-0', {'sid': 's1', 'symbol': 'BTCUSDT', 'action': 'open', 'ts_ms': '1000'})
+    assert row.sid == 's1'
+    assert row.event_type == 'open'
+    assert row.event_ts_ms == 1000
+
+
+def test_derive_snapshot_rows_merges_latest_by_sid():
+    events = [
+        mod.ExecEventRow('1-0', 's1', 'BTCUSDT', 'open', 1000, json.dumps({'sid': 's1', 'symbol': 'BTCUSDT', 'action': 'open', 'status': 'submitted', 'fsm_state': 'ENTRY_SUBMITTED'})),
+        mod.ExecEventRow('2-0', 's1', 'BTCUSDT', 'protect', 2000, json.dumps({'sid': 's1', 'symbol': 'BTCUSDT', 'sl_algo_id': 11, 'tp1_algo_id': 12, 'fsm_state': 'PROTECTED'})),
+    ]
+    snapshots, refs = mod.derive_snapshot_rows(events)
+    assert len(snapshots) == 1
+    assert snapshots[0].sid == 's1'
+    assert snapshots[0].fsm_state == 'PROTECTED'
+    assert len(refs) == 1
+    assert refs[0].sl_algo_id == 11
+    assert refs[0].tp1_algo_id == 12
diff -ruN '--exclude=__pycache__' '--exclude=.pytest_cache' p34/binance_execution/test_rollout_flags_v1.py p5/binance_execution/test_rollout_flags_v1.py
--- p34/binance_execution/test_rollout_flags_v1.py	1970-01-01 00:00:00.000000000 +0000
+++ p5/binance_execution/test_rollout_flags_v1.py	2026-03-06 19:53:40.824648778 +0000
@@ -0,0 +1,33 @@
+from __future__ import annotations
+
+import os
+import sys
+from pathlib import Path
+
+ROOT = Path(__file__).resolve().parent
+if str(ROOT) not in sys.path:
+    sys.path.insert(0, str(ROOT))
+
+from rollout_flags import RolloutFlags
+
+
+def test_rollout_flags_defaults(monkeypatch):
+    monkeypatch.delenv("EXEC_MAKER_TP_ENABLE", raising=False)
+    flags = RolloutFlags.from_env()
+    assert flags.exec_reconcile_enable is True
+    assert flags.exec_user_stream_enable is True
+    assert flags.maker_allowed(infra_degraded=False) is True
+
+
+def test_rollout_flags_degraded_mode_disables_maker(monkeypatch):
+    monkeypatch.setenv("EXEC_DEGRADED_MODE_DISABLE_MAKER", "1")
+    flags = RolloutFlags.from_env()
+    assert flags.maker_allowed(infra_degraded=True) is False
+    assert flags.maker_allowed(infra_degraded=False) is True
+
+
+def test_rollout_flags_force_safety(monkeypatch):
+    monkeypatch.setenv("EXEC_FORCE_SAFETY_FIRST", "true")
+    flags = RolloutFlags.from_env()
+    assert flags.safety_forced(infra_degraded=False) is True
+    assert flags.maker_allowed(infra_degraded=False) is False
diff -ruN '--exclude=__pycache__' '--exclude=.pytest_cache' p34/config/docker-compose.execution-p5.override.yml p5/config/docker-compose.execution-p5.override.yml
--- p34/config/docker-compose.execution-p5.override.yml	1970-01-01 00:00:00.000000000 +0000
+++ p5/config/docker-compose.execution-p5.override.yml	2026-03-06 19:55:26.257630593 +0000
@@ -0,0 +1,94 @@
+version: '3.9'
+
+# P5 rollout overlay for execution hardening.
+# Apply on top of the project's existing compose files, for example:
+#   docker compose \
+#     -f config/docker-compose-binance.yml \
+#     -f config/docker-compose-crypto-orderflow.yml \
+#     -f config/docker-compose-monitoring.yml \
+#     -f config/docker-compose.execution-p5.override.yml up -d
+#
+# Design goals:
+#   * enable/disable P1-P4 layers with env flags only
+#   * add mandatory user-stream worker for reconcile-first mode
+#   * mount Grafana dashboard/provisioning artefacts without modifying the base stack
+#   * keep rollback trivial: remove this overlay or flip the flags in env.execution-p5.example
+
+services:
+  binance-executor:
+    environment:
+      - EXEC_ALGO_CANONICAL_V2=${EXEC_ALGO_CANONICAL_V2:-1}
+      - EXEC_RECONCILE_ENABLE=${EXEC_RECONCILE_ENABLE:-1}
+      - EXEC_USER_STREAM_ENABLE=${EXEC_USER_STREAM_ENABLE:-1}
+      - EXEC_MAKER_TP_ENABLE=${EXEC_MAKER_TP_ENABLE:-1}
+      - EXEC_JOURNAL_SQL_ENABLE=${EXEC_JOURNAL_SQL_ENABLE:-1}
+      - EXEC_FORCE_SAFETY_FIRST=${EXEC_FORCE_SAFETY_FIRST:-0}
+      - EXEC_DEGRADED_MODE_FORCE_SAFETY_FIRST=${EXEC_DEGRADED_MODE_FORCE_SAFETY_FIRST:-1}
+      - EXEC_DEGRADED_MODE_DISABLE_MAKER=${EXEC_DEGRADED_MODE_DISABLE_MAKER:-1}
+      - USER_STREAM_STREAM=${USER_STREAM_STREAM:-orders:user_stream}
+      - USER_STREAM_CACHE_PREFIX=${USER_STREAM_CACHE_PREFIX:-orders:user_stream:}
+      - EXECUTION_JOURNAL_DSN=${EXECUTION_JOURNAL_DSN:-}
+      - BINANCE_RECV_WINDOW_MS=${BINANCE_RECV_WINDOW_MS:-3000}
+      - BINANCE_TIME_SYNC_INTERVAL_MS=${BINANCE_TIME_SYNC_INTERVAL_MS:-30000}
+      - MAX_CLOCK_DRIFT_MS=${MAX_CLOCK_DRIFT_MS:-250}
+      - TP_LIMIT_WATCHDOG_ENABLE=${TP_LIMIT_WATCHDOG_ENABLE:-1}
+      - TP_LIMIT_WATCHDOG_TIMEOUT_MS=${TP_LIMIT_WATCHDOG_TIMEOUT_MS:-4000}
+      - PROTECTION_ARM_TIMEOUT_MS=${PROTECTION_ARM_TIMEOUT_MS:-2500}
+
+  # Dedicated worker keeps listenKey alive, consumes ORDER_TRADE_UPDATE/ALGO_UPDATE,
+  # and stores normalized events in Redis so executor reconcile can prefer event-driven
+  # verification before REST polling.
+  binance-user-stream-worker:
+    build:
+      context: .
+      dockerfile: python-worker/Dockerfile
+    image: scanner-python-worker:latest
+    container_name: scanner-binance-user-stream-worker
+    restart: on-failure:5
+    environment:
+      - REDIS_URL=${REDIS_URL:-redis://redis-worker-1:6379/0}
+      - BINANCE_API_KEY=${BINANCE_API_KEY:-}
+      - BINANCE_API_SECRET=${BINANCE_API_SECRET:-}
+      - BINANCE_FUTURES_BASE_URL=${BINANCE_FUTURES_BASE_URL:-https://fapi.binance.com}
+      - BINANCE_HTTP_TIMEOUT_S=${BINANCE_HTTP_TIMEOUT_S:-8.0}
+      - BINANCE_RECV_WINDOW_MS=${BINANCE_RECV_WINDOW_MS:-3000}
+      - BINANCE_TIME_SYNC_INTERVAL_MS=${BINANCE_TIME_SYNC_INTERVAL_MS:-30000}
+      - USER_STREAM_STREAM=${USER_STREAM_STREAM:-orders:user_stream}
+      - USER_STREAM_CACHE_PREFIX=${USER_STREAM_CACHE_PREFIX:-orders:user_stream:}
+      - USER_STREAM_CACHE_TTL_SEC=${USER_STREAM_CACHE_TTL_SEC:-900}
+      - EXEC_USER_STREAM_ENABLE=${EXEC_USER_STREAM_ENABLE:-1}
+      - LOG_LEVEL=${LOG_LEVEL:-INFO}
+    depends_on:
+      redis-worker-1:
+        condition: service_healthy
+    networks:
+      - scanner-network
+    volumes:
+      - ./python-worker:/app
+    command:
+      - python
+      - -m
+      - services.binance_user_stream_worker
+
+  crypto-orderflow-service:
+    environment:
+      - TRADE_DQ_HARD_VETO_ENABLE=${TRADE_DQ_HARD_VETO_ENABLE:-1}
+      - TRADE_RISK_ENGINE_V2_ENABLE=${TRADE_RISK_ENGINE_V2_ENABLE:-1}
+      - PORTFOLIO_RISK_HARD_VETO=${PORTFOLIO_RISK_HARD_VETO:-1}
+      - RISK_MAX_DAILY_LOSS_PCT=${RISK_MAX_DAILY_LOSS_PCT:-2.0}
+      - RISK_MAX_TOTAL_EXPOSURE_RATIO=${RISK_MAX_TOTAL_EXPOSURE_RATIO:-2.5}
+      - RISK_MAX_SYMBOL_EXPOSURE_RATIO=${RISK_MAX_SYMBOL_EXPOSURE_RATIO:-0.75}
+      - RISK_MAX_CLUSTER_EXPOSURE_RATIO=${RISK_MAX_CLUSTER_EXPOSURE_RATIO:-1.25}
+      - RISK_TIER_A_MAX_LEVERAGE=${RISK_TIER_A_MAX_LEVERAGE:-10}
+      - RISK_TIER_B_MAX_LEVERAGE=${RISK_TIER_B_MAX_LEVERAGE:-5}
+      - RISK_TIER_C_MAX_LEVERAGE=${RISK_TIER_C_MAX_LEVERAGE:-3}
+      - REDIS_DQ_QUEUE_LAG_HARD_MS=${REDIS_DQ_QUEUE_LAG_HARD_MS:-2500}
+      - REDIS_DQ_TICK_STALE_HARD_MS=${REDIS_DQ_TICK_STALE_HARD_MS:-2500}
+      - REDIS_DQ_BOOK_STALE_HARD_MS=${REDIS_DQ_BOOK_STALE_HARD_MS:-2500}
+      - REDIS_DQ_TIMEOUT_EVENTS_HARD=${REDIS_DQ_TIMEOUT_EVENTS_HARD:-5}
+      - REDIS_DQ_XACK_FAIL_HARD=${REDIS_DQ_XACK_FAIL_HARD:-2}
+
+  grafana:
+    volumes:
+      - ./monitoring/grafana/dashboards:/etc/grafana/provisioning/dashboards-json:ro
+      - ./monitoring/grafana/provisioning/dashboards:/etc/grafana/provisioning/dashboards:ro
