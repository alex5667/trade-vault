+++ tick_flow_full/orderflow_services/exec_health_freeze_acl_policy_v1.py
@@ -0,0 +1,92 @@
+#!/usr/bin/env python3
+from __future__ import annotations
+
+import argparse
+import json
+import os
+import sys
+from typing import Any, Dict, Iterable, List
+
+try:
+    import redis  # type: ignore
+except Exception:  # pragma: no cover
+    redis = None
+
+from services.orderflow.exec_health_freeze_acl_contract import compare_acl_contract, render_acl_save_load_commands, render_acl_setuser_commands, render_auth_dsn_templates
+from services.orderflow.exec_health_freeze_service_identity import ensure_service_identity_sync, render_service_identity_env_templates
+from services.orderflow.exec_health_freeze_reconnect_healing import heal_service_identity_sync
+
+
+def _jprint(obj: Dict[str, Any]) -> None:
+    print(json.dumps(obj, ensure_ascii=False, indent=2, sort_keys=True))
+
+
+class PolicyController:
+    def __init__(self, redis_url: str | None = None) -> None:
+        self.redis_url = redis_url or os.getenv('EXEC_HEALTH_REDIS_BOOTSTRAP_URL') or os.getenv('REDIS_URL', 'redis://redis-worker-1:6379/0')
+        self.r = redis.Redis.from_url(self.redis_url, decode_responses=True) if redis is not None else None
+        if self.r is not None:
+            ensure_service_identity_sync(self.r, "exec_health_freeze_acl_policy_v1")
+            heal_service_identity_sync(self.r, "exec_health_freeze_acl_policy_v1", force=True)
+
+    def render(self) -> Dict[str, Any]:
+        return {
+            'acl_commands': render_acl_setuser_commands(),
+            'acl_save_load_commands': render_acl_save_load_commands(),
+            'mandatory_auth_dsn_templates': render_auth_dsn_templates(),
+            'service_identity_env_templates': render_service_identity_env_templates(),
+        }
+
+    def apply(self, *, save: bool = True, reload_check: bool = False) -> Dict[str, Any]:
+        if self.r is None:
+            raise RuntimeError('redis dependency missing')
+        heal_service_identity_sync(self.r, "exec_health_freeze_acl_policy_v1")
+        applied: List[str] = []
+        for cmd in render_acl_setuser_commands():
+            argv = cmd.split()
+            self.r.execute_command(*argv)
+            applied.append(cmd)
+        save_rc = None
+        load_rc = None
+        if save:
+            save_rc = self.r.execute_command('ACL', 'SAVE')
+        if reload_check:
+            load_rc = self.r.execute_command('ACL', 'LOAD')
+        drift = compare_acl_contract(self.r.execute_command('ACL', 'LIST') or [])
+        return {'ok': bool(drift.get('ok')), 'applied_commands': applied, 'acl_save': save_rc, 'acl_load': load_rc, 'drift': drift}
+
+    def check(self) -> Dict[str, Any]:
+        if self.r is None:
+            raise RuntimeError('redis dependency missing')
+        heal_service_identity_sync(self.r, "exec_health_freeze_acl_policy_v1")
+        drift = compare_acl_contract(self.r.execute_command('ACL', 'LIST') or [])
+        return {'ok': bool(drift.get('ok')), 'drift': drift}
+
+
+def main(argv: List[str] | None = None) -> int:
+    ap = argparse.ArgumentParser(description='ExecHealth Redis ACL deployment policy')
+    sub = ap.add_subparsers(dest='cmd', required=False)
+    sub.add_parser('render')
+    ap_apply = sub.add_parser('apply')
+    ap_apply.add_argument('--no-save', action='store_true')
+    ap_apply.add_argument('--reload-check', action='store_true')
+    sub.add_parser('check')
+    ns = ap.parse_args(argv)
+    cmd = ns.cmd or 'render'
+    ctl = PolicyController()
+    if cmd == 'render':
+        _jprint(ctl.render())
+        return 0
+    if cmd == 'apply':
+        out = ctl.apply(save=not bool(ns.no_save), reload_check=bool(ns.reload_check))
+        _jprint(out)
+        return 0 if out.get('ok') else 1
+    if cmd == 'check':
+        out = ctl.check()
+        _jprint(out)
+        return 0 if out.get('ok') else 1
+    raise SystemExit(2)
+
+
+if __name__ == '__main__':
+    raise SystemExit(main())
