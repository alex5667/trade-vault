--- tick_flow_full/orderflow_services/exec_health_freeze_acl_drift_exporter_v1.py
+++ tick_flow_full/orderflow_services/exec_health_freeze_acl_drift_exporter_v1.py
@@ -0,0 +1,168 @@
+#!/usr/bin/env python3
+from __future__ import annotations
+
+import os
+import time
+from typing import Any, Dict, Iterable, List
+
+try:
+    import redis  # type: ignore
+except Exception:  # pragma: no cover
+    redis = None
+from prometheus_client import Counter, Gauge, start_http_server
+
+from services.orderflow.exec_health_freeze_service_identity import ensure_service_identity_sync
+from services.orderflow.exec_health_freeze_reconnect_healing import heal_service_identity_sync
+from services.orderflow.exec_health_freeze_acl_contract import (
+    AUDIT_USER,
+    BOOTSTRAP_USER,
+    DEFAULT_USER,
+    READER_USER,
+    WRITER_USER,
+    compare_acl_contract,
+    parse_client_list_users,
+)
+
+UP = Gauge('exec_health_freeze_acl_drift_up', '1 if ExecHealth ACL drift exporter loop is healthy')
+STATE_AGE_S = Gauge('exec_health_freeze_acl_drift_state_age_seconds', 'Age of ExecHealth ACL drift exporter state in seconds')
+LAST_TS_MS = Gauge('exec_health_freeze_acl_drift_last_check_ts_ms', 'Last ACL drift check timestamp in epoch ms')
+CONTRACT_MATCH = Gauge('exec_health_freeze_acl_contract_match', '1 if actual ACL LIST matches expected contract for user', ['user'])
+VIOLATION = Gauge('exec_health_freeze_acl_drift_violation', 'One-hot ACL drift violation', ['kind', 'user'])
+DEFAULT_DISABLED = Gauge('exec_health_freeze_acl_default_user_disabled', '1 if Redis default user is disabled and has no commands')
+DEFAULT_CLIENTS = Gauge('exec_health_freeze_acl_default_user_connections', 'Current CLIENT LIST connections on default user')
+UNKNOWN_CLIENTS = Gauge('exec_health_freeze_acl_unknown_user_connections', 'Current CLIENT LIST connections on unknown users')
+ACLFILE_CONFIGURED = Gauge('exec_health_freeze_acl_aclfile_configured', '1 if Redis aclfile config is non-empty')
+DRIFT_TOTAL = Counter('exec_health_freeze_acl_drift_total', 'ExecHealth ACL drift observations', ['kind', 'user'])
+
+
+def _now_ms() -> int:
+    return int(time.time() * 1000)
+
+
+def _s(x: Any, d: str = '') -> str:
+    try:
+        return str(x) if x is not None else str(d)
+    except Exception:
+        return str(d)
+
+
+def _i(x: Any, d: int = 0) -> int:
+    try:
+        return int(float(x))
+    except Exception:
+        return int(d)
+
+
+class Exporter:
+    def __init__(self) -> None:
+        if redis is None:
+            raise RuntimeError('redis dependency missing')
+        self.redis_url = os.getenv('EXEC_HEALTH_REDIS_AUDIT_URL') or os.getenv('REDIS_URL', 'redis://redis-worker-1:6379/0')
+        self.state_key = os.getenv('EXEC_HEALTH_FREEZE_ACL_DRIFT_STATE_KEY', 'metrics:exec_health:freeze_acl_drift:last')
+        self.loop_s = max(5, int(os.getenv('EXEC_HEALTH_FREEZE_ACL_DRIFT_INTERVAL_S', '30') or 30))
+        self.r = redis.Redis.from_url(self.redis_url, decode_responses=True)
+        ensure_service_identity_sync(self.r, "exec_health_freeze_acl_drift_exporter_v1")
+        heal_service_identity_sync(self.r, "exec_health_freeze_acl_drift_exporter_v1", force=True)
+
+    def _read_state(self) -> Dict[str, Any]:
+        try:
+            return self.r.hgetall(self.state_key) or {}
+        except Exception:
+            return {}
+
+    def _write_state(self, mapping: Dict[str, Any]) -> None:
+        try:
+            self.r.hset(self.state_key, mapping={str(k): str(v) for k, v in mapping.items()})
+            self.r.expire(self.state_key, 86400 * 7)
+        except Exception:
+            pass
+
+    def run_once(self) -> Dict[str, Any]:
+        try:
+            heal_service_identity_sync(self.r, "exec_health_freeze_acl_drift_exporter_v1")
+        except Exception:
+            pass
+        now = _now_ms()
+        acl_lines = self.r.execute_command('ACL', 'LIST') or []
+        drift = compare_acl_contract(acl_lines)
+        actual = dict(drift.get('actual', {}) or {})
+        expected_users = [DEFAULT_USER, READER_USER, WRITER_USER, AUDIT_USER, BOOTSTRAP_USER]
+        for user in expected_users:
+            CONTRACT_MATCH.labels(user=user).set(1.0 if actual.get(user) == drift['expected'].get(user) else 0.0)
+        active_keys = set()
+        for viol in drift.get('violations', []):
+            kind = _s(viol.get('kind') or 'unknown')
+            user = _s(viol.get('user') or 'unknown')
+            active_keys.add((kind, user))
+            VIOLATION.labels(kind=kind, user=user).set(1.0)
+            DRIFT_TOTAL.labels(kind=kind, user=user).inc()
+        # keep a bounded known list reset
+        for kind in ['user_missing', 'user_rule_mismatch', 'unexpected_user', 'default_user_enabled', 'default_user_missing', 'default_user_connection', 'unknown_user_connection', 'aclfile_missing']:
+            for user in expected_users + ['unknown']:
+                if (kind, user) not in active_keys:
+                    VIOLATION.labels(kind=kind, user=user).set(0.0)
+        DEFAULT_DISABLED.set(1.0 if drift.get('default_user_disabled') else 0.0)
+
+        client_list = self.r.execute_command('CLIENT', 'LIST') or ''
+        user_counts = parse_client_list_users(client_list)
+        default_clients = int(user_counts.get(DEFAULT_USER, 0))
+        unknown_clients = int(sum(v for u, v in user_counts.items() if u not in set(expected_users)))
+        if default_clients > 0:
+            VIOLATION.labels(kind='default_user_connection', user=DEFAULT_USER).set(1.0)
+            DRIFT_TOTAL.labels(kind='default_user_connection', user=DEFAULT_USER).inc()
+        if unknown_clients > 0:
+            VIOLATION.labels(kind='unknown_user_connection', user='unknown').set(1.0)
+            DRIFT_TOTAL.labels(kind='unknown_user_connection', user='unknown').inc()
+        DEFAULT_CLIENTS.set(float(default_clients))
+        UNKNOWN_CLIENTS.set(float(unknown_clients))
+
+        aclfile = ''
+        try:
+            raw = self.r.execute_command('CONFIG', 'GET', 'aclfile') or []
+            if isinstance(raw, (list, tuple)) and len(raw) >= 2:
+                aclfile = _s(raw[1])
+        except Exception:
+            aclfile = ''
+        if not aclfile:
+            VIOLATION.labels(kind='aclfile_missing', user='unknown').set(1.0)
+            DRIFT_TOTAL.labels(kind='aclfile_missing', user='unknown').inc()
+        ACLFILE_CONFIGURED.set(1.0 if aclfile else 0.0)
+
+        st = self._read_state()
+        st.update({
+            'updated_ts_ms': int(now),
+            'last_check_ts_ms': int(now),
+            'drift_ok': 1 if drift.get('ok') else 0,
+            'default_user_disabled': 1 if drift.get('default_user_disabled') else 0,
+            'default_user_connections': int(default_clients),
+            'unknown_user_connections': int(unknown_clients),
+            'aclfile_configured': 1 if aclfile else 0,
+            'violation_count': int(len(drift.get('violations', []))),
+        })
+        self._write_state(st)
+        LAST_TS_MS.set(float(now))
+        age_s = max(0.0, float(_now_ms() - int(now)) / 1000.0)
+        STATE_AGE_S.set(age_s)
+        UP.set(1.0)
+        return {
+            'ok': bool(drift.get('ok')) and default_clients == 0 and unknown_clients == 0 and bool(aclfile),
+            'violation_count': int(len(drift.get('violations', []))),
+            'default_user_connections': int(default_clients),
+            'unknown_user_connections': int(unknown_clients),
+            'aclfile_configured': bool(aclfile),
+        }
+
+
+def main() -> None:
+    ex = Exporter()
+    start_http_server(int(os.getenv('EXEC_HEALTH_FREEZE_ACL_DRIFT_EXPORTER_PORT', '9832')))
+    while True:
+        try:
+            ex.run_once()
+        except Exception:
+            UP.set(0.0)
+        time.sleep(ex.loop_s)
+
+
+if __name__ == '__main__':
+    main()
