+
+      - alert: FeatureDriftBatchStale
+        expr: feature_drift_batch_last_age_seconds > 36 * 3600
+        for: 30m
+        labels:
+          severity: warning
+          team: trade
+          component: feature_drift_batch
+          service: nightly
+        annotations:
+          summary: "Nightly feature drift batch report stale (>36h)"
+          description: "No fresh PSI/KS drift report found. Check nightly feature selection/drift timers and baseline/current data paths."
+          runbook_path: "/runbook_feature_drift_batch_v1.md"
+
+      - alert: FeatureDriftBatchCriticalFeatures
+        expr: feature_drift_batch_crit_n > 0
+        for: 30m
+        labels:
+          severity: critical
+          team: trade
+          component: feature_drift_batch
+          service: nightly
+        annotations:
+          summary: "Critical feature drift detected in nightly PSI/KS report"
+          description: "At least one Tier-1 feature breached critical PSI/KS drift thresholds. Review report JSON/CSV and consider shadow-disable or denylist AB."
+          runbook_path: "/runbook_feature_drift_batch_v1.md"
