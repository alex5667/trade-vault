+          service: nightly
+        annotations:
+          summary: "Multiple features suggested for denylist AB"
+          description: "Nightly drift report suggests several features for denylist/shadow-disable workflow. Review feature selection loop and autogen proposal inputs."
+          runbook_path: "/runbook_feature_drift_batch_v1.md"
