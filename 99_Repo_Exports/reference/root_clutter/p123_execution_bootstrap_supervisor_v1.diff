@@ -0,0 +1,22 @@
+groups:
+  - name: trade-execution-bootstrap-p123
+    rules:
+      - alert: TradeExecutionBootstrapNotReady
+        expr: trade_execution_bootstrap_ready == 0
+        for: 2m
+        labels:
+          severity: page
+          domain: execution-bootstrap
+        annotations:
+          summary: Execution bootstrap dependencies are not ready
+          description: Projection cluster and/or Binance user-stream contour are unhealthy; executor startup should remain blocked.
+
+      - alert: TradeExecutionBootstrapUserStreamNotReady
+        expr: trade_execution_bootstrap_user_stream_ready == 0
