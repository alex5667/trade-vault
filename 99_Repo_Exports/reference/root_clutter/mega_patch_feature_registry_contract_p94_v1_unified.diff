+          service: of-timers
+        annotations:
+          summary: "Feature Registry contract status stale (>6h)"
+          description: "No recent update in metrics:feature_registry_contract:last. Check of-timers worker schedule and Redis connectivity."
+          runbook_path: "/runbook_feature_registry_p94.md"
+
+      - alert: FeatureRegistryContractExporterDown
+        expr: feature_registry_contract_exporter_up == 0
+        for: 10m
+        labels:
+          severity: warning
+          team: trade
+          component: feature_registry
+          service: exporter
+        annotations:
+          summary: "Feature Registry contract exporter down"
+          description: "Prometheus exporter cannot read Redis metrics. Check exporter container/service and Redis URL."
+          runbook_path: "/runbook_feature_registry_p94.md"
