+def run_feature_registry_contract_smoke_check() -> bool:
+    """Run Feature Registry contract smoke-check (P94).
+
+    Behavior:
+      - exit=0 -> ok
+      - exit=2 -> alert (pins missing or hash mismatch)
+      - other  -> error
+
