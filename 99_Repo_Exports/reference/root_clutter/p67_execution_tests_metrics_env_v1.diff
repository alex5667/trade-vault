+from services.binance_futures_client import BinanceFuturesClient
+
+
+class DummyClient(BinanceFuturesClient):
+    def __init__(self):
+        super().__init__(api_key="k", api_secret="s")
+        self.calls = []
+
+    def post_plain_order(self, params):
+        self.calls.append(("plain", dict(params)))
+        return {"route": "plain", **params}
+
+    def post_algo_order(self, params):
+        self.calls.append(("algo", dict(params)))
+        return {"route": "algo", **params}
+
+    def cancel_algo_order(self, symbol, *, algo_id=None, client_algo_id=None):
+        self.calls.append(("cancel_algo", {"symbol": symbol, "algo_id": algo_id, "client_algo_id": client_algo_id}))
+        return {"status": "CANCELED", "algoId": algo_id, "clientAlgoId": client_algo_id}
+
+
+def test_stop_market_routes_via_algo_endpoint():
+    c = DummyClient()
+    j = c.post_order({"symbol": "BTCUSDT", "type": "STOP_MARKET", "triggerPrice": "99"})
+    assert j["route"] == "algo"
+    assert c.calls[0][0] == "algo"
+
+
+def test_take_profit_market_routes_via_algo_endpoint():
+    c = DummyClient()
+    j = c.post_order({"symbol": "BTCUSDT", "type": "TAKE_PROFIT_MARKET", "triggerPrice": "101"})
+    assert j["route"] == "algo"
+
+
+def test_market_routes_via_plain_endpoint():
+    c = DummyClient()
+    j = c.post_order({"symbol": "BTCUSDT", "type": "MARKET", "quantity": "1"})
+    assert j["route"] == "plain"
+
+
+def test_replace_algo_order_cancel_then_create():
+    c = DummyClient()
+    j = c.replace_algo_order(
+        "BTCUSDT",
+        cancel_algo_id=777,
+        new_params={"symbol": "BTCUSDT", "type": "TAKE_PROFIT_MARKET", "triggerPrice": "101"},
+    )
+    assert j["cancel"]["algoId"] == 777
+    assert j["create"]["route"] == "algo"
+    assert [x[0] for x in c.calls] == ["cancel_algo", "algo"]
