+from pathlib import Path
+import importlib.util
+import sys
+
+val_path = Path(__file__).resolve().parents[1] / "execution_intent_validator.py"
+spec = importlib.util.spec_from_file_location("execution_intent_validator_p6", val_path)
+mod = importlib.util.module_from_spec(spec)
+sys.modules[spec.name] = mod
+assert spec.loader is not None
+spec.loader.exec_module(mod)
+
+exec_path = Path(__file__).resolve().parents[1] / "binance_executor.py"
+espec = importlib.util.spec_from_file_location("binance_executor_p6", exec_path)
+exmod = importlib.util.module_from_spec(espec)
+sys.modules[espec.name] = exmod
+assert espec.loader is not None
+espec.loader.exec_module(exmod)
+
+
+def test_validator_rejects_invalid_working_type():
+    res = mod.validate_exit_intent(
+        position_mode="oneway",
+        position_side=None,
+        exit_intent="close",
+        reduce_only=True,
+        close_position=False,
+        quantity=1.0,
+        order_type="STOP_MARKET",
+        working_type="LAST_PRICE",
+        is_algo=True,
+    )
+    assert res.is_valid_exit_contract is False
+    assert res.reason == "invalid_workingType"
+
+
+def test_validator_rejects_close_position_with_reduce_only():
