+from services.binance_user_stream_worker import BinanceUserStreamWorker
+
+
+class DummyClient:
+    def start_user_stream(self):
+        return "listen-key"
+
+    def keepalive_user_stream(self, listen_key):
+        assert listen_key == "listen-key"
+        return {"ok": True}
+
+    def close_user_stream(self, listen_key):
+        assert listen_key == "listen-key"
+        return {"ok": True}
+
+
+def test_listen_key_lifecycle_methods_do_not_drop_state():
+    worker = BinanceUserStreamWorker.__new__(BinanceUserStreamWorker)
+    worker.client = DummyClient()
+    worker.listen_key = None
+    key = worker.start_listen_key()
+    assert key == "listen-key"
+    worker.keepalive_listen_key()
+    worker.close_listen_key()
+    assert worker.listen_key is None
