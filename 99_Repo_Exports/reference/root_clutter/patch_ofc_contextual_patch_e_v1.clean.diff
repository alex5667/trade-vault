+# Copy to /etc/default/trade-latency-sensitive-jobs-staging or prod and adapt.
+TRADE_REPO_ROOT=/opt/trade/prod/repo
+TRADE_ORDERFLOW_IMAGE=trade-orderflow:prod
+REDIS_URL=redis://redis-worker-1:6379/0
+
+# Actual runtime command to supervise.
+# Example only — replace with your real OFC runtime entrypoint.
+OFC_RUNTIME_COMMAND=python3 -m services.orderflow.main
+
+# Patch D outputs / controls.
+OFC_CTX_RUNTIME_OVERLAY_ENV_FILE=/var/lib/trade/ofc_contextual_rollout.env
+OFC_CTX_ROLLBACK_FLAG_PATH=/var/lib/trade/ofc_contextual.rollback
+
+# Patch E supervisor settings.
+OFC_CTX_RUNTIME_POLL_SEC=5
+OFC_CTX_RUNTIME_RESTART_COOLDOWN_SEC=15
+OFC_CTX_RUNTIME_TERM_GRACE_SEC=20
+OFC_CTX_RUNTIME_RELOADER_STATE_PATH=/var/lib/trade/ofc_contextual_runtime_reloader_state.json
diff --git a/orderflow_services/tests/test_ofc_contextual_runtime_reloader_v1.py b/orderflow_services/tests/test_ofc_contextual_runtime_reloader_v1.py
--- a/orderflow_services/tests/test_ofc_contextual_runtime_reloader_v1.py	1970-01-01 00:00:00.000000000 +0000
+++ b/orderflow_services/tests/test_ofc_contextual_runtime_reloader_v1.py	2026-03-14 12:14:10.041884879 +0000
@@ -0,0 +1,35 @@
+from pathlib import Path
+
+from orderflow_services.ofc_contextual_runtime_reloader_v1 import (
+    fingerprint_overlay,
+    load_env_file,
+    merge_child_env,
+)
+
+
+def test_load_env_file_parses_basic_pairs(tmp_path: Path):
+    p = tmp_path / "overlay.env"
+    p.write_text(
+        "# comment\n"
+        "OFC_CTX_ENABLE=1\n"
+        "export OFC_CTX_MODE=shadow\n"
+        "QUOTED='abc def'\n",
+        encoding="utf-8",
+    )
+    got = load_env_file(str(p))
+    assert got["OFC_CTX_ENABLE"] == "1"
+    assert got["OFC_CTX_MODE"] == "shadow"
+    assert got["QUOTED"] == "abc def"
+
+
+def test_merge_child_env_overlay_wins():
+    got = merge_child_env({"A": "1", "B": "2"}, {"B": "9", "C": "3"})
+    assert got["A"] == "1"
+    assert got["B"] == "9"
+    assert got["C"] == "3"
+
+
+def test_fingerprint_changes_on_rollback_flag():
+    fp1 = fingerprint_overlay({"OFC_CTX_MODE": "shadow"}, False)
+    fp2 = fingerprint_overlay({"OFC_CTX_MODE": "shadow"}, True)
+    assert fp1 != fp2
diff --git a/orderflow_services/tests/test_ofc_contextual_runtime_deploy_v1.py b/orderflow_services/tests/test_ofc_contextual_runtime_deploy_v1.py
