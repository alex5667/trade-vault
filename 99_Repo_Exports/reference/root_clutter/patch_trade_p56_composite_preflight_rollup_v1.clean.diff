+        labels:
+          severity: warning
+        annotations:
+          summary: High 30d orchestration block ratio
+          description: Composite preflight block ratio exceeded 5% over 30d for a purpose.
+
+      - alert: TradeOrchestrationCompositePreflightInvalidRatioHigh7dWarn
+        expr: max by (purpose) (orchestration_composite_preflight_rollup_invalid_ratio{window="7d"}) > 0.03
+        for: 30m
+        labels:
+          severity: warning
+        annotations:
+          summary: High 7d orchestration invalid ratio
