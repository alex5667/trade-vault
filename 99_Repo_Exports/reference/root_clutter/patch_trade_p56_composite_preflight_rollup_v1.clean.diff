+groups:
+  - name: trade_orchestration_composite_preflight_rollup_p56
+    rules:
+      - alert: TradeOrchestrationCompositePreflightRollupStaleWarn
+        expr: orchestration_composite_preflight_rollup_lag_seconds > 1800
+        for: 20m
+        labels:
+          severity: warning
+        annotations:
+          summary: Orchestration composite preflight rollup is stale
+          description: Incremental rollup has not advanced for more than 30 minutes.
