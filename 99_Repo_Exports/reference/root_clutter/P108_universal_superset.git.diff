+import json
+
+from services.ml_confirm.denylist_pinning import (
+    check_denylist_pinning,
+    compute_denylist_hash16,
+)
+
+
+def _write_denylist(path, deny_num=None, deny_bool=None):
+    doc = {
+        "deny_num": deny_num or [],
+        "deny_bool": deny_bool or [],
+    }
+    path.write_text(json.dumps(doc, ensure_ascii=False, indent=2), encoding="utf-8")
+
+
+def test_denylist_pinning_ok(monkeypatch, tmp_path):
+    p = tmp_path / "deny.json"
+    _write_denylist(p, deny_num=["n:obi_z"], deny_bool=["b:flag_x"])
+
+    h, err = compute_denylist_hash16(str(p))
+    assert err is None
+    assert h and len(h) == 16
+
+    monkeypatch.setenv("ML_FEATURE_DENYLIST_PATH", str(p))
+    res = check_denylist_pinning(model_pack={"denylist_hash16": h})
+    assert res.status == "ok"
+    assert res.runtime_hash16 == h
+    assert res.model_hash16 == h
+
+
+def test_denylist_pinning_mismatch(monkeypatch, tmp_path):
+    p = tmp_path / "deny.json"
+    _write_denylist(p, deny_num=["n:obi_z"], deny_bool=[])
+
+    h, err = compute_denylist_hash16(str(p))
+    assert err is None
+
+    monkeypatch.setenv("ML_FEATURE_DENYLIST_PATH", str(p))
+    res = check_denylist_pinning(model_pack={"denylist_hash16": "deadbeefdeadbeef"})
+    assert res.status == "mismatch"
+    assert res.runtime_hash16 == h
+    assert res.model_hash16 == "deadbeefdeadbeef"
+
+
+def test_denylist_pinning_missing_model_hash(monkeypatch, tmp_path):
+    p = tmp_path / "deny.json"
+    _write_denylist(p, deny_num=[], deny_bool=["b:flag_y"])
+
+    monkeypatch.setenv("ML_FEATURE_DENYLIST_PATH", str(p))
+    res = check_denylist_pinning(model_pack={})
+    assert res.status == "missing_model_hash"
+    assert res.runtime_hash16 != "na"
+    assert res.model_hash16 == "na"
