+from __future__ import annotations
+
+import hashlib
+import json
+import os
+import threading
+from dataclasses import dataclass
+from typing import Any, Dict, Optional, Tuple
+
+_DEFAULT_REL_PATH = "core/feature_denylist_v1.json"
+
+_cache_lock = threading.Lock()
+# path -> ((mtime, size), hash16, err)
+_cache: Dict[str, Tuple[Tuple[float, int], Optional[str], Optional[str]]] = {}
+
+
+def resolve_denylist_path(explicit_path: Optional[str] = None) -> str:
+    """Single source of truth for runtime denylist path.
+
+    Order:
+      1) explicit_path
+      2) ENV ML_FEATURE_DENYLIST_PATH
+      3) repo default (core/feature_denylist_v1.json)
+    """
+    if explicit_path:
+        return str(explicit_path)
+    env = os.getenv("ML_FEATURE_DENYLIST_PATH", "")
+    if str(env).strip():
+        return str(env).strip()
+    return _DEFAULT_REL_PATH
+
+
+def _normalize_list(v: Any) -> list[str]:
+    if not isinstance(v, list):
+        return []
+    out: list[str] = []
+    for x in v:
+        s = str(x).strip()
+        if s:
+            out.append(s)
+    # stable order
+    return sorted(set(out))
+
+
+def _canonical_denylist(doc: Any) -> Dict[str, Any]:
+    # tolerate future keys / slightly different schema
+    if not isinstance(doc, dict):
+        doc = {}
+    deny_num = doc.get("deny_num")
+    if deny_num is None:
+        deny_num = doc.get("deny_numeric")
+    deny_bool = doc.get("deny_bool")
+    if deny_bool is None:
+        deny_bool = doc.get("deny_boolean")
+
+    return {
+        "deny_num": _normalize_list(deny_num),
+        "deny_bool": _normalize_list(deny_bool),
+    }
+
+
+def _hash16_from_canon(canon: Dict[str, Any]) -> str:
+    b = json.dumps(canon, sort_keys=True, separators=(",", ":"), ensure_ascii=False).encode("utf-8")
+    return hashlib.sha256(b).hexdigest()[:16]
+
+
+def compute_denylist_hash16(path: str) -> Tuple[Optional[str], Optional[str]]:
+    """Return (hash16, err). Uses (mtime,size) cache."""
+    p = str(path)
+    try:
+        st = os.stat(p)
+    except FileNotFoundError:
+        return None, "file_not_found"
+    except Exception as e:
+        return None, f"stat_error:{type(e).__name__}"[:120]
+
+    key = (float(st.st_mtime), int(st.st_size))
+    with _cache_lock:
+        hit = _cache.get(p)
+        if hit and hit[0] == key:
+            return hit[1], hit[2]
+
+    try:
+        with open(p, "rb") as f:
+            raw = f.read()
+        doc = json.loads(raw.decode("utf-8"))
+        canon = _canonical_denylist(doc)
+        h16 = _hash16_from_canon(canon)
+        err = None
+    except Exception as e:
+        h16 = None
+        err = f"load_error:{type(e).__name__}"[:120]
+
+    with _cache_lock:
+        _cache[p] = (key, h16, err)
+    return h16, err
+
+
+def extract_model_denylist_hash16(model_pack: Any) -> Optional[str]:
+    """Best-effort extraction of denylist_hash16 from model pack."""
+    if not isinstance(model_pack, dict):
+        return None
+
+    # common locations
+    for k in (
+        "denylist_hash16",
+        "denylist_hash",
+        "__denylist_hash16",
+        "feature_denylist_hash16",
+    ):
+        v = model_pack.get(k)
+        if isinstance(v, str) and v.strip():
+            return v.strip()
+
+    meta = model_pack.get("meta")
+    if isinstance(meta, dict):
+        v = meta.get("denylist_hash16")
+        if isinstance(v, str) and v.strip():
+            return v.strip()
+
+    schema = model_pack.get("schema")
+    if isinstance(schema, dict):
+        v = schema.get("denylist_hash16")
+        if isinstance(v, str) and v.strip():
+            return v.strip()
+
+    return None
+
+
+@dataclass(frozen=True)
+class DenylistPinningResult:
+    enabled: bool
+    denylist_path: str
+    runtime_hash16: str
+    model_hash16: str
+    status: str  # ok|mismatch|missing_model_hash|missing_runtime|load_error|disabled
+    err: str
+
+
+def check_denylist_pinning(
+    *,
+    model_pack: Any,
+    denylist_path: Optional[str] = None,
+    enabled: Optional[bool] = None,
+) -> DenylistPinningResult:
+    """Compare runtime denylist hash with model-embedded hash.
+
+    Policy:
+      - If model hash missing -> status=missing_model_hash (legacy allowed).
+      - If runtime denylist missing/unreadable -> status=missing_runtime/load_error.
+      - If both exist and differ -> status=mismatch.
+      - If equal -> ok.
+    """
+    if enabled is None:
+        enabled = int(os.getenv("ML_FEATURE_DENYLIST_PINNING", "1") or 1) == 1
+
+    p = resolve_denylist_path(denylist_path)
+
+    if not bool(enabled):
+        return DenylistPinningResult(
+            enabled=False,
+            denylist_path=p,
+            runtime_hash16="na",
+            model_hash16=str(extract_model_denylist_hash16(model_pack) or "na"),
+            status="disabled",
+            err="",
+        )
+
+    model_h = extract_model_denylist_hash16(model_pack)
+    model_hs = str(model_h or "na")
+
+    runtime_h, runtime_err = compute_denylist_hash16(p)
+    if runtime_h is None:
+        status = "missing_runtime" if runtime_err == "file_not_found" else "load_error"
+        return DenylistPinningResult(
+            enabled=True,
+            denylist_path=p,
+            runtime_hash16="na",
+            model_hash16=model_hs,
+            status=status,
+            err=str(runtime_err or "")
+        )
+
+    if not model_h or str(model_h).strip().lower() in ("na", "none", "null"):
+        return DenylistPinningResult(
+            enabled=True,
+            denylist_path=p,
+            runtime_hash16=str(runtime_h),
+            model_hash16="na",
+            status="missing_model_hash",
+            err="",
+        )
+
+    if str(runtime_h) != str(model_h).strip():
+        return DenylistPinningResult(
+            enabled=True,
+            denylist_path=p,
+            runtime_hash16=str(runtime_h),
+            model_hash16=str(model_h).strip(),
+            status="mismatch",
+            err="",
+        )
+
+    return DenylistPinningResult(
+        enabled=True,
+        denylist_path=p,
+        runtime_hash16=str(runtime_h),
+        model_hash16=str(model_h).strip(),
+        status="ok",
+        err="",
+    )
