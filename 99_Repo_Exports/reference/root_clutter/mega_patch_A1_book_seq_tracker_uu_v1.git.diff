+          - Duplicates/old events (u <= prev_u) are NOT treated as missing.
+          - If U/u are absent (partial book snapshots), we do not compute missing-seq.
+        """
+        prev_u = int(getattr(runtime, "book_seq_last_u", 0) or 0)
+        prev_ema = float(getattr(runtime, "book_missing_seq_ema", 0.0) or 0.0)
+        alpha = float(getattr(runtime, "config", {}).get("book_missing_seq_ema_alpha", 0.10) or 0.10)
+
+        cur_U = _safe_int(book_raw.get("U") or book_raw.get("firstUpdateId") or 0)
+        cur_u = _safe_int(book_raw.get("u") or book_raw.get("lastUpdateId") or 0)
+
+        # Default per-event diagnostic.
+        runtime.book_missing_seq_last_gap = 0
+
+        # Without both U and u, strict continuity is impossible.
+        if cur_U <= 0 or cur_u <= 0:
+            runtime.book_seq_last_reason = "no_seq_fields"
+            return
+
+        # First seen update id.
+        if prev_u <= 0:
+            runtime.book_seq_last_u = int(cur_u)
+            runtime.book_seq_last_reason = "init"
+            return
+
+        expected_U = prev_u + 1
+        missing_event = 0.0
+        reason = "ok"
+
+        # DUP/OLD: event is entirely behind our last_u (common after reconnect).
+        if cur_u <= prev_u:
+            reason = "dup"
+            missing_event = 0.0
+        else:
+            if cur_U > expected_U:
+                # GAP: missing one or more book updates.
+                gap = int(cur_U - prev_u - 1)
+                if gap < 0:
+                    gap = 0
+                runtime.book_missing_seq_last_gap = int(gap)
+                reason = "gap"
+                missing_event = 1.0
+                try:
+                    book_missing_seq_events_total.labels(symbol=str(runtime.symbol)).inc(1)
+                except Exception:
+                    pass
+            else:
+                # OK / OVERLAP: expected_U is covered by the update range.
+                if cur_U < expected_U and cur_u >= expected_U:
+                    reason = "overlap"
+                elif cur_U < expected_U and cur_u < expected_U:
+                    reason = "reorder"
+                else:
+                    reason = "ok"
+                missing_event = 0.0
+
+        # EMA update (except init/no_seq_fields).
+        runtime.book_missing_seq_ema = float(self._ema_update(prev_ema, missing_event, alpha))
+        runtime.book_seq_last_reason = str(reason)
+
+        # Monotone last_u: do NOT regress on overlap/dup.
+        if cur_u > prev_u:
+            runtime.book_seq_last_u = int(cur_u)
+
+        # Export gauge ASAP (book path may run even when no ticks arrive).
+        try:
+            book_missing_seq_ema_gauge.labels(symbol=str(runtime.symbol)).set(float(runtime.book_missing_seq_ema))
+        except Exception:
+            pass
