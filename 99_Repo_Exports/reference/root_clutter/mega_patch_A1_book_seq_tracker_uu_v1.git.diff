+    def _update_book_missing_seq(self, *, runtime: SymbolRuntime, book_raw: dict) -> None:
+        """Update strict book missing-seq EMA using Binance depthUpdate U/u.
+
+        Binance depthUpdate payload contains:
+          - U: firstUpdateId
+          - u: lastUpdateId
+
