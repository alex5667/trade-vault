+    timeout_s = int(os.getenv("OF_INPUTS_DLQ_AUTO_REPLAY_TIMEOUT_S", "120"))
+    cooldown_s = int(os.getenv("OF_INPUTS_DLQ_AUTO_REPLAY_COOLDOWN_S", str(6 * 3600)))
