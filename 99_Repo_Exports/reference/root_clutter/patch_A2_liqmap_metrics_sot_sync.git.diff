+def test_liqmap_injection_parse_error_increments_prom_counters():
+    # Use a unique symbol to avoid interference from other tests.
+    sym = "ZZZUSDT"
+    now_ms = 30_000
+
+    key = f"liqmap:snapshot:{sym}:1h"
+
+    # Invalid JSON triggers parse failure -> should increment counters.
+    r = _DummyRedis({key: "{not-json"})
+    tp = _make_tp(r, refresh_ms=0)
+    runtime = _DummyRuntime(sym)
+
+    from services.orderflow.metrics import (
+        liqmap_parse_errors_total,
+        liqmap_snapshot_parse_errors_total,
+    )
+
+    d_before = liqmap_parse_errors_total.labels(symbol=sym, window="1h", where="parse_or_compute")._value.get()
+    s_before = liqmap_snapshot_parse_errors_total.labels(symbol=sym)._value.get()
+
+    ind = {}
+    asyncio.run(tp._inject_liqmap_features(runtime=runtime, now_ms=now_ms, price=100.0, indicators=ind))
+
+    d_after = liqmap_parse_errors_total.labels(symbol=sym, window="1h", where="parse_or_compute")._value.get()
+    s_after = liqmap_snapshot_parse_errors_total.labels(symbol=sym)._value.get()
+
+    assert d_after == d_before + 1
+    assert s_after == s_before + 1

--- a/tick_flow_full/services/orderflow/tests/test_liqmap_metrics_exports_v1.py+++ b/tick_flow_full/services/orderflow/tests/test_liqmap_metrics_exports_v1.py@@ -0,0 +1,42 @@+from __future__ import annotations
+
+import sys
+from pathlib import Path
+
+# Ensure tick_flow_full/ is first so `services.*` resolves to SoT, not mirror.
+_TFF_ROOT = str(Path(__file__).resolve().parents[3])  # .../tick_flow_full
+if _TFF_ROOT not in sys.path:
+    sys.path.insert(0, _TFF_ROOT)
+
+# Project root is required for shared helpers in other imports; keep after SoT.
+_PROJ_ROOT = str(Path(__file__).resolve().parents[4])
+if _PROJ_ROOT not in sys.path:
+    sys.path.insert(1, _PROJ_ROOT)
+
+
+def test_sot_metrics_export_liqmap_symbols_and_label_contract() -> None:
+    """A2 contract:
+
+    tick_flow_full/services/orderflow/metrics.py (SoT) must expose LiqMap metrics
+    that TickProcessor may import and that dashboards/alerts can rely on.
+
+    This test imports the SoT metrics as a normal python module (services.*).
+    """
+
+    from services.orderflow import metrics as sot
+
+    required = [
+        "liqmap_snapshot_age_ms_gauge",
+        "liqmap_snapshot_parse_errors_total",
+        "liqmap_gate_shadow_hit_total",
+        "liqmap_gate_veto_total",
+    ]
+
+    for k in required:
+        assert hasattr(sot, k), f"SoT metrics missing: {k}"
+
+    # Label contract (keep low-cardinality for alerts).
+    sot.liqmap_snapshot_age_ms_gauge.labels(symbol="BTCUSDT", window="1h").set(0.0)
+    sot.liqmap_snapshot_parse_errors_total.labels(symbol="BTCUSDT").inc(0)
+    sot.liqmap_gate_shadow_hit_total.labels(symbol="BTCUSDT", dir="LONG", window="1h").inc(0)
+    sot.liqmap_gate_veto_total.labels(symbol="BTCUSDT", dir="LONG", reason="hot_near").inc(0)
