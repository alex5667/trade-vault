+#!/usr/bin/env python3
+from __future__ import annotations
+
+"""Binance USDT-M account reporter → Telegram (hourly).
+
+Primary job (P0):
+  - once per hour, fetch factual account state from Binance Futures
+  - send a compact report to Telegram
+
+This service is intentionally standalone and fail-open:
+  - if Binance is temporarily unavailable, it logs and retries next interval
+  - if Telegram is unavailable, it drops the message (no crash)
+
+Env (required):
+  BINANCE_API_KEY
+  BINANCE_API_SECRET
+  TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID   (or legacy BOT_TOKEN/CHAT_ID)
+
+Env (optional):
+  BINANCE_FUTURES_BASE_URL (default https://fapi.binance.com)
+  BINANCE_TIME_SYNC=1      (sync server time offset for signatures)
+
+  REPORT_INTERVAL_SEC=3600
+  REPORT_ALIGN_TO_HOUR=1      (align to UTC hour boundaries)
+  REPORT_TOPN_POSITIONS=5
+  REPORT_INCLUDE_OPEN_ORDERS=1
+
+  REDIS_URL=redis://redis-worker-1:6379/0
+  ACCOUNT_SNAPSHOT_KEY=account:snapshot:binance_usdtm
+  ACCOUNT_SNAPSHOT_TTL_SEC=7200
+"""
+
+import json
+import os
+import time
+from typing import Any, Dict, List, Optional, Tuple
+
+import redis
+
+from services.binance_futures_client import BinanceFuturesClient
+from services.telegram.telegram_client import TelegramClient
+
+
+def _f(x: Any, default: float = 0.0) -> float:
+    try:
+        if x is None:
+            return default
+        return float(x)
+    except Exception:
+        return default
+
+
+def _i(x: Any, default: int = 0) -> int:
+    try:
+        if x is None:
+            return default
+        return int(float(x))
+    except Exception:
+        return default
+
+
+def _bool_env(name: str, default: bool = False) -> bool:
+    v = (os.getenv(name) or "").strip().lower()
+    if not v:
+        return default
+    return v in {"1", "true", "yes", "on"}
+
+
+def _fmt_money(x: float) -> str:
+    return f"{x:,.2f}"
+
+
+def _align_sleep(interval_s: int) -> None:
+    # Align to UTC hour boundary to make reports easier to reason about.
+    now = int(time.time())
+    next_tick = ((now // interval_s) + 1) * interval_s
+    sleep_s = max(1, next_tick - now)
+    time.sleep(sleep_s)
+
+
+def build_snapshot(client: BinanceFuturesClient, *, top_n: int, include_open_orders: bool) -> Dict[str, Any]:
+    acc = client.get_account()
+    risks = client.get_position_risk()
+    orders: List[Dict[str, Any]] = []
+    if include_open_orders:
+        try:
+            orders = client.get_open_orders() or []
+        except Exception:
+            orders = []
+
+    wallet = _f(acc.get("totalWalletBalance"))
+    margin = _f(acc.get("totalMarginBalance"))
+    available = _f(acc.get("availableBalance"))
+    upnl = _f(acc.get("totalUnrealizedProfit"))
+    im = _f(acc.get("totalInitialMargin"))
+    mm = _f(acc.get("totalMaintMargin"))
+
+    open_positions: List[Dict[str, Any]] = []
+    notional_sum = 0.0
+
+    for p in risks or []:
+        amt = _f(p.get("positionAmt"))
+        if abs(amt) <= 0.0:
+            continue
+        notional = abs(_f(p.get("notional")))
+        notional_sum += notional
+        sym = str(p.get("symbol") or "")
+        side = "LONG" if amt > 0 else "SHORT"
+        open_positions.append(
+            {
+                "symbol": sym,
+                "side": side,
+                "amt": amt,
+                "notional": notional,
+                "entry": _f(p.get("entryPrice")),
+                "mark": _f(p.get("markPrice")),
+                "upnl": _f(p.get("unRealizedProfit")),
+                "liq": _f(p.get("liquidationPrice")),
+                "leverage": _i(p.get("leverage"), 0),
+            }
+        )
+
+    open_positions_sorted = sorted(open_positions, key=lambda x: abs(float(x.get("notional") or 0.0)), reverse=True)
+    top_positions = open_positions_sorted[: max(0, int(top_n))]
+
+    snap = {
+        "ts_ms": int(time.time() * 1000),
+        "wallet_balance_usdt": wallet,
+        "margin_balance_usdt": margin,
+        "available_balance_usdt": available,
+        "unrealized_pnl_usdt": upnl,
+        "initial_margin_usdt": im,
+        "maint_margin_usdt": mm,
+        "open_positions_n": len(open_positions_sorted),
+        "open_notional_abs_usdt": notional_sum,
+        "open_orders_n": len(orders) if orders else 0,
+        "top_positions": top_positions,
+    }
+    return snap
+
+
+def format_report(snap: Dict[str, Any]) -> str:
+    ts_ms = _i(snap.get("ts_ms"), int(time.time() * 1000))
+    dt = time.gmtime(ts_ms / 1000.0)
+    ts = time.strftime("%Y-%m-%d %H:%M:%S UTC", dt)
+
+    wallet = _f(snap.get("wallet_balance_usdt"))
+    margin = _f(snap.get("margin_balance_usdt"))
+    available = _f(snap.get("available_balance_usdt"))
+    upnl = _f(snap.get("unrealized_pnl_usdt"))
+    im = _f(snap.get("initial_margin_usdt"))
+    mm = _f(snap.get("maint_margin_usdt"))
+    pos_n = _i(snap.get("open_positions_n"))
+    notional = _f(snap.get("open_notional_abs_usdt"))
+    ord_n = _i(snap.get("open_orders_n"))
+
+    # Conservative, Telegram-safe HTML (no links, no markdown)
+    lines: List[str] = []
+    lines.append("<b>Binance Futures Account</b>")
+    lines.append(f"<i>{ts}</i>")
+    lines.append("")
+    lines.append(f"Wallet: <b>{_fmt_money(wallet)}</b> USDT")
+    lines.append(f"Margin: <b>{_fmt_money(margin)}</b> USDT")
+    lines.append(f"Available: <b>{_fmt_money(available)}</b> USDT")
+    lines.append(f"uPnL: <b>{_fmt_money(upnl)}</b> USDT")
+    lines.append(f"IM/MM: <b>{_fmt_money(im)}</b> / <b>{_fmt_money(mm)}</b> USDT")
+    lines.append("")
+    lines.append(f"Open positions: <b>{pos_n}</b> | Notional(abs): <b>{_fmt_money(notional)}</b> USDT")
+    lines.append(f"Open orders: <b>{ord_n}</b>")
+
+    top = snap.get("top_positions") or []
+    if top:
+        lines.append("")
+        lines.append("<b>Top positions</b>")
+        for p in top[:10]:
+            sym = str(p.get("symbol") or "")
+            side = str(p.get("side") or "")
+            notional_p = _f(p.get("notional"))
+            upnl_p = _f(p.get("upnl"))
+            lev = _i(p.get("leverage"), 0)
+            lines.append(f"• {sym} {side} | notional { _fmt_money(notional_p) } | uPnL { _fmt_money(upnl_p) } | lev {lev}")
+
+    # Telegram has 4096 limit. Truncate defensively.
+    text = "\n".join(lines)
+    return text[:3900]
+
+
+def maybe_store_snapshot(r: Optional[redis.Redis], key: str, ttl_sec: int, snap: Dict[str, Any]) -> None:
+    if not r or not key:
+        return
+    try:
+        r.set(key, json.dumps(snap, ensure_ascii=False), ex=int(ttl_sec) if ttl_sec > 0 else None)
+    except Exception:
+        return
+
+
+def main() -> None:
+    interval_sec = int(os.getenv("REPORT_INTERVAL_SEC", "3600"))
+    align = _bool_env("REPORT_ALIGN_TO_HOUR", True)
+    top_n = int(os.getenv("REPORT_TOPN_POSITIONS", "5"))
+    include_orders = _bool_env("REPORT_INCLUDE_OPEN_ORDERS", True)
+
+    snapshot_key = (os.getenv("ACCOUNT_SNAPSHOT_KEY") or "").strip()
+    snapshot_ttl = int(os.getenv("ACCOUNT_SNAPSHOT_TTL_SEC", "7200"))
+
+    redis_url = (os.getenv("REDIS_URL") or "").strip()
+    r: Optional[redis.Redis] = None
+    if redis_url:
+        try:
+            r = redis.from_url(redis_url, decode_responses=True)
+        except Exception:
+            r = None
+
+    tg = TelegramClient.from_env()
+    if tg is None:
+        raise RuntimeError("Telegram is not configured (TELEGRAM_BOT_TOKEN/TELEGRAM_CHAT_ID or BOT_TOKEN/CHAT_ID)")
+
+    client = BinanceFuturesClient.from_env()
+
+    print("📣 Binance account reporter starting")
+    print(f"   interval_sec={interval_sec} align_to_hour={align}")
+    print(f"   top_n={top_n} include_open_orders={include_orders}")
+    print(f"   snapshot_key={snapshot_key or '(disabled)'}")
+
+    while True:
+        try:
+            snap = build_snapshot(client, top_n=top_n, include_open_orders=include_orders)
+            maybe_store_snapshot(r, snapshot_key, snapshot_ttl, snap)
+            text = format_report(snap)
+            _ = tg.send_text(text)
+        except Exception as e:
+            # Fail-open: do not crash the service.
+            print(f"❌ reporter error: {e}")
+
+        if align:
+            _align_sleep(interval_sec)
+        else:
+            time.sleep(max(1, int(interval_sec)))
+
+
+if __name__ == "__main__":
+    main()
