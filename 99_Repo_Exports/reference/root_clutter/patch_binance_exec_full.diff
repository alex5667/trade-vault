+#!/usr/bin/env python3
+from __future__ import annotations
+
+"""Binance USDT-M Futures executor (reads Redis queue → places orders → writes exec facts).
+
+Queue contract (already in your project):
+  action: open | modify | cancel | resize
+  sid, symbol, timestamp are required.
+
+Binance specifics:
+  - Entry is an order (MARKET or LIMIT)
+  - SL/TP must be separate reduceOnly orders
+  - For production we need ack/retry/DLQ, and factual `orders:exec` events.
+
+This implementation focuses on correctness and safety:
+  - BRPOPLPUSH queue → processing list (at-least-once)
+  - errors are classified into transient vs fatal
+  - fatal → DLQ (so queue doesn't grow forever)
+  - writes `orders:exec` events for both success and failures
+
+Env:
+  REDIS_URL=redis://redis-worker-1:6379/0
+  ORDERS_QUEUE_BINANCE=orders:queue:binance
+  ORDERS_QUEUE_BINANCE_PROCESSING=orders:queue:binance:processing
+  ORDERS_QUEUE_BINANCE_DLQ=orders:queue:binance:dlq
+  EXEC_STREAM=orders:exec
+
+  BINANCE_API_KEY, BINANCE_API_SECRET
+  BINANCE_POSITION_MODE=oneway|hedge (default oneway)
+  BINANCE_SYMBOL_ALLOWLIST=BTCUSDT,ETHUSDT,... (optional)
+
+  BINANCE_INIT_SYMBOL_SETTINGS=1
+  BINANCE_MARGIN_TYPE=ISOLATED|CROSSED (default ISOLATED)
+  BINANCE_DEFAULT_LEVERAGE=20
+
+  BINANCE_ASSUME_LOT_IS_QTY=0  (default: require qty/quantity)
+  BINANCE_MAX_RETRY=3
+  BINANCE_FILL_TIMEOUT_S=8.0
+  BINANCE_FILL_POLL_S=0.25
+
+Telegram (optional, for errors):
+  TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID (or legacy BOT_TOKEN/CHAT_ID)
+"""
+
+import hashlib
+import json
+import math
+import os
+import threading
+import time
+from dataclasses import dataclass
+from typing import Any, Dict, List, Optional, Tuple
+
+try:
+    import redis  # type: ignore
+except Exception:  # pragma: no cover
+    redis = None  # type: ignore
+
+from services.binance_futures_client import BinanceAPIError, BinanceFuturesClient
+from services.telegram.telegram_client import TelegramClient
+
+
+def _bool_env(name: str, default: bool = False) -> bool:
+    v = (os.getenv(name) or "").strip().lower()
+    if not v:
+        return default
+    return v in {"1", "true", "yes", "on"}
+
+
+def _ms_now() -> int:
+    return int(time.time() * 1000)
+
+
+def _f(x: Any, default: float = 0.0) -> float:
+    try:
+        if x is None:
+            return default
+        return float(x)
+    except Exception:
+        return default
+
+
+def _i(x: Any, default: int = 0) -> int:
+    try:
+        if x is None:
+            return default
+        return int(float(x))
+    except Exception:
+        return default
+
+
+def _sha1_8(s: str) -> str:
+    return hashlib.sha1(s.encode("utf-8")).hexdigest()[:8]
+
+
+def _make_cid(sid: str, tag: str) -> str:
+    # Futures newClientOrderId max is 36 chars (keep safe).
+    token = _sha1_8(sid)
+    base = sid.replace(" ", "").replace(":", "-")
+    base = base[: max(6, 36 - (len(tag) + len(token) + 2))]
+    cid = f"{base}-{token}-{tag}"
+    return cid[:36]
+
+
+def _round_down(x: float, step: float) -> float:
+    if step <= 0:
+        return x
+    return math.floor(x / step) * step
+
+
+def _truthy(v: Any) -> bool:
+    if v is None:
+        return False
+    if isinstance(v, bool):
+        return v
+    if isinstance(v, (int, float)):
+        return float(v) != 0.0
+    s = str(v).strip().lower()
+    return s in {"1", "true", "yes", "on"}
+
+
+def _clamp(x: float, lo: float, hi: float) -> float:
+    return max(lo, min(hi, x))
+
+
+def _round_half_up(x: float, decimals: int = 1) -> float:
+    """Round halves up (unlike Python's bankers rounding).
+
+    Binance trailing callbackRate uses 0.1% steps. With floats, `round(0.35, 1)`
+    can yield 0.3 due to binary representation; this helper keeps it stable.
+    """
+    p = 10 ** int(decimals)
+    return math.floor(x * p + 0.5) / p
+
+
+def compute_trailing_callback_rate_pct(
+    payload: Dict[str, Any],
+    *,
+    entry_price: Optional[float],
+    atr: Optional[float],
+    min_pct: float,
+    max_pct: float,
+    default_pct: float,
+    atr_mult_default: float,
+) -> float:
+    """Compute Binance callbackRate (percent) for TRAILING_STOP_MARKET.
+
+    Supported payload overrides:
+      - trail_callback_rate / trail_callback_pct / trail_callback_percent : percent (0.1..5)
+      - trail_callback_bps : bps (10 bps = 0.10%)
+      - trail_atr_mult : multiplier used when deriving from ATR
+
+    Fallback: derive from ATR as: (atr * mult / entry_price) * 100.
+    """
+
+    # Explicit percent.
+    for k in ("trail_callback_rate", "trail_callback_pct", "trail_callback_percent"):
+        if payload.get(k) is not None:
+            try:
+                v = float(payload.get(k))
+                v = _clamp(v, min_pct, max_pct)
+                return _round_half_up(v, 1)  # Binance uses 0.1% step
+            except Exception:
+                pass
+
+    # Explicit bps.
+    if payload.get("trail_callback_bps") is not None:
+        try:
+            bps = float(payload.get("trail_callback_bps"))
+            v = bps / 100.0
+            v = _clamp(v, min_pct, max_pct)
+            return _round_half_up(v, 1)
+        except Exception:
+            pass
+
+    # Derive from ATR.
+    try:
+        if atr is not None and entry_price is not None and entry_price > 0 and atr > 0:
+            mult = atr_mult_default
+            if payload.get("trail_atr_mult") is not None:
+                try:
+                    mult = float(payload.get("trail_atr_mult"))
+                except Exception:
+                    mult = atr_mult_default
+            v = (float(atr) * float(mult) / float(entry_price)) * 100.0
+            v = _clamp(v, min_pct, max_pct)
+            return _round_half_up(v, 1)
+    except Exception:
+        pass
+
+    v = _clamp(float(default_pct), min_pct, max_pct)
+    return _round_half_up(v, 1)
+
+
+@dataclass
+class SymbolFilters:
+    tick_size: float
+    step_size: float
+    min_qty: float
+    min_notional: float
+
+
+class FiltersCache:
+    def __init__(self, client: BinanceFuturesClient):
+        self.client = client
+        self._cache: Dict[str, SymbolFilters] = {}
+
+    def get(self, symbol: str) -> SymbolFilters:
+        s = symbol.upper()
+        if s in self._cache:
+            return self._cache[s]
+
+        info = self.client.get_exchange_info()
+        sym_list = info.get("symbols") or []
+        by_symbol = {str(x.get("symbol")).upper(): x for x in sym_list if x.get("symbol")}
+        if s not in by_symbol:
+            raise RuntimeError(f"Unknown Binance symbol: {s}")
+
+        filters = by_symbol[s].get("filters") or []
+        tick = 0.0
+        step = 0.0
+        min_qty = 0.0
+        min_notional = 0.0
+        for f in filters:
+            t = str(f.get("filterType") or "")
+            if t == "PRICE_FILTER":
+                tick = _f(f.get("tickSize"), tick)
+            elif t == "LOT_SIZE":
+                step = _f(f.get("stepSize"), step)
+                min_qty = _f(f.get("minQty"), min_qty)
+            elif t == "MIN_NOTIONAL":
+                min_notional = _f(f.get("notional"), min_notional)
+
+        sf = SymbolFilters(tick_size=tick or 0.0, step_size=step or 0.0, min_qty=min_qty or 0.0, min_notional=min_notional or 0.0)
+        self._cache[s] = sf
+        return sf
+
+
+def _normalize_side(payload: Dict[str, Any]) -> Tuple[str, str]:
+    # returns (binance_side, logical_side)
+    side = str(payload.get("side") or payload.get("direction") or "").upper().strip()
+    if side in {"BUY", "SELL"}:
+        return side, "LONG" if side == "BUY" else "SHORT"
+    if side in {"LONG", "SHORT"}:
+        return ("BUY" if side == "LONG" else "SELL"), side
+    raise ValueError(f"bad side: {payload.get('side')}")
+
+
+def _normalize_qty(payload: Dict[str, Any], assume_lot_is_qty: bool) -> float:
+    if payload.get("qty") is not None:
+        return _f(payload.get("qty"))
+    if payload.get("quantity") is not None:
+        return _f(payload.get("quantity"))
+    if assume_lot_is_qty and payload.get("lot") is not None:
+        return _f(payload.get("lot"))
+    raise ValueError("missing qty (provide qty/quantity; lot is MT5-specific)")
+
+
+def _classify_error(e: Exception) -> str:
+    """Return 'transient' or 'fatal'."""
+    if isinstance(e, BinanceAPIError):
+        payload = e.payload if isinstance(e.payload, dict) else {}
+        code = payload.get("code")
+        # transient-ish
+        if code in (-1021, -1003, -1001, -1007, -1100):
+            return "transient"
+        # insufficient margin, reduceOnly violations, invalid params are fatal
+        return "fatal"
+    # network-ish
+    msg = str(e).lower()
+    if "timed out" in msg or "temporary" in msg or "connection" in msg:
+        return "transient"
+    return "fatal"
+
+
+def _position_side_for_mode(position_mode: str, logical_side: str) -> Optional[str]:
+    # Binance hedge mode requires positionSide LONG/SHORT. One-way doesn't.
+    if position_mode != "hedge":
+        return None
+    return "LONG" if logical_side == "LONG" else "SHORT"
+
+
+class BinanceExecutor:
+    def __init__(self):
+        if redis is None:
+            raise RuntimeError("redis-py is required (pip install redis)")
+        self.redis_url = os.getenv("REDIS_URL", "redis://redis-worker-1:6379/0")
+
+        # Default queue: keep compatibility with the existing project contract (orders:queue).
+        self.queue = os.getenv("ORDERS_QUEUE_BINANCE") or os.getenv("ORDERS_QUEUE") or "orders:queue"
+        self.queue_processing = os.getenv("ORDERS_QUEUE_BINANCE_PROCESSING") or f"{self.queue}:processing"
+        self.queue_dlq = os.getenv("ORDERS_QUEUE_BINANCE_DLQ") or f"{self.queue}:dlq"
+        self.exec_stream = os.getenv("EXEC_STREAM", "orders:exec")
+
+        allow = (os.getenv("BINANCE_SYMBOL_ALLOWLIST") or "").strip()
+        self.allowlist = {s.strip().upper() for s in allow.split(",") if s.strip()} if allow else set()
+
+        self.position_mode = (os.getenv("BINANCE_POSITION_MODE") or "oneway").strip().lower()
+        if self.position_mode not in {"oneway", "hedge"}:
+            self.position_mode = "oneway"
+
+        self.assume_lot_is_qty = _bool_env("BINANCE_ASSUME_LOT_IS_QTY", False)
+        self.max_retry = int(os.getenv("BINANCE_MAX_RETRY", "3"))
+        self.fill_timeout_s = float(os.getenv("BINANCE_FILL_TIMEOUT_S", "8.0"))
+        self.fill_poll_s = float(os.getenv("BINANCE_FILL_POLL_S", "0.25"))
+
+        self.init_symbol_settings = _bool_env("BINANCE_INIT_SYMBOL_SETTINGS", False)
+        self.margin_type = (os.getenv("BINANCE_MARGIN_TYPE") or "ISOLATED").strip().upper()
+        self.default_leverage = int(os.getenv("BINANCE_DEFAULT_LEVERAGE", "20"))
+
+        self.tg = TelegramClient.from_env()
+        self.client = BinanceFuturesClient.from_env()
+        self.filters = FiltersCache(self.client)
+
+        # Trailing stop settings (Binance futures TRAILING_STOP_MARKET).
+        # Your upstream pipeline sets `trail_after_tp1` flag; executor will only use trailing when the flag is true.
+        self.trail_cb_min = float(os.getenv("BINANCE_TRAIL_CALLBACK_MIN", "0.1"))
+        self.trail_cb_max = float(os.getenv("BINANCE_TRAIL_CALLBACK_MAX", "5.0"))
+        self.trail_cb_default = float(os.getenv("BINANCE_TRAIL_CALLBACK_DEFAULT", "0.3"))
+        self.trail_atr_mult_default = float(os.getenv("BINANCE_TRAIL_ATR_MULT", "1.0"))
+        self.trail_arm_poll_s = float(os.getenv("BINANCE_TRAIL_ARM_POLL_S", "1.0"))
+        self.trail_arm_timeout_s = float(os.getenv("BINANCE_TRAIL_ARM_TIMEOUT_S", "7200"))
+        self.trail_notify = _bool_env("BINANCE_TRAIL_NOTIFY", True)
+
+        self.r = redis.from_url(self.redis_url, decode_responses=True)
+
+    def _exec_event(self, fields: Dict[str, Any]) -> None:
+        # Ensure minimal fields
+        fields = dict(fields)
+        fields.setdefault("ts_ms", str(_ms_now()))
+        fields.setdefault("venue", "binance")
+        try:
+            self.r.xadd(self.exec_stream, {k: str(v) for k, v in fields.items() if v is not None})
+        except Exception:
+            # fail-open
+            return
+
+    def _dlq(self, raw: str, reason: str) -> None:
+        try:
+            self.r.lpush(self.queue_dlq, json.dumps({"reason": reason, "raw": raw, "ts_ms": _ms_now()}))
+        except Exception:
+            pass
+
+    def _ack_processing(self, raw: str) -> None:
+        # remove one occurrence
+        try:
+            self.r.lrem(self.queue_processing, 1, raw)
+        except Exception:
+            pass
+
+    def _requeue(self, payload: Dict[str, Any], raw: str, reason: str) -> None:
+        retry_n = int(payload.get("retry_n") or 0)
+        payload["retry_n"] = retry_n + 1
+        payload["retry_reason"] = reason
+        new_raw = json.dumps(payload, ensure_ascii=False, default=str)
+        try:
+            self.r.rpush(self.queue, new_raw)
+        except Exception:
+            # if we cannot requeue, DLQ the original
+            self._dlq(raw, f"requeue_failed:{reason}")
+
+    def _ensure_symbol_settings(self, symbol: str) -> None:
+        if not self.init_symbol_settings:
+            return
+        try:
+            _ = self.client.post_margin_type(symbol, self.margin_type)
+        except Exception:
+            # marginType is idempotent-ish: Binance returns error if unchanged; ignore
+            pass
+        try:
+            _ = self.client.post_leverage(symbol, self.default_leverage)
+        except Exception:
+            pass
+
+    def _quantize(self, symbol: str, qty: float, price: Optional[float]) -> Tuple[float, Optional[float]]:
+        f = self.filters.get(symbol)
+        q = qty
+        if f.step_size and f.step_size > 0:
+            q = _round_down(qty, f.step_size)
+        if f.min_qty and q < f.min_qty:
+            raise ValueError(f"qty below minQty: {q} < {f.min_qty}")
+        p = price
+        if price is not None and f.tick_size and f.tick_size > 0:
+            p = _round_down(price, f.tick_size)
+        return q, p
+
+    def _wait_fill(self, symbol: str, order_id: int, *, timeout_s: float) -> Dict[str, Any]:
+        deadline = time.time() + timeout_s
+        last = None
+        while time.time() < deadline:
+            j = self.client.get_order(symbol, order_id=order_id)
+            last = j
+            st = str(j.get("status") or "").upper()
+            if st == "FILLED":
+                return j
+            if st in {"CANCELED", "REJECTED", "EXPIRED"}:
+                return j
+            time.sleep(max(0.05, self.fill_poll_s))
+        return last or {}
+
+    def _split_tp_qtys(self, symbol: str, total_qty: float, n: int) -> List[float]:
+        if n <= 0:
+            return []
+        f = self.filters.get(symbol)
+        step = f.step_size or 0.0
+        if n == 1:
+            return [total_qty]
+
+        base = total_qty / float(n)
+        parts = []
+        remaining = total_qty
+        for i in range(n):
+            if i == n - 1:
+                q = remaining
+            else:
+                q = base
+                if step > 0:
+                    q = _round_down(q, step)
+                remaining -= q
+            if q <= 0:
+                continue
+            parts.append(q)
+        # ensure sum <= total_qty (rounding can leave dust)
+        s = sum(parts)
+        if s > total_qty and step > 0:
+            parts[-1] = _round_down(parts[-1] - (s - total_qty), step)
+        return [q for q in parts if q > 0]
+
+    def _place_protective(self, *, sid: str, symbol: str, logical_side: str, qty: float, sl: Optional[float], tps: List[float]) -> Dict[str, Any]:
+        # place SL/TP reduceOnly orders opposite to entry side
+        out: Dict[str, Any] = {}
+        exit_side = "SELL" if logical_side == "LONG" else "BUY"
+        pos_side = _position_side_for_mode(self.position_mode, logical_side)
+        reduce_only_allowed = self.position_mode == "oneway"
+
+        if sl is not None and sl > 0:
+            q_sl, sl_q = self._quantize(symbol, qty, sl)
+            p: Dict[str, Any] = {
+                "symbol": symbol,
+                "side": exit_side,
+                "type": "STOP_MARKET",
+                "stopPrice": sl_q,
+                "newClientOrderId": _make_cid(sid, "sl"),
+            }
+            # In one-way mode, prefer closePosition SL (it always closes the remaining position,
+            # even after partial TP fills).
+            if reduce_only_allowed:
+                p["closePosition"] = True
+            else:
+                # Hedge mode: reduceOnly is forbidden by Binance, so we specify quantity + positionSide.
+                p["quantity"] = q_sl
+                if pos_side:
+                    p["positionSide"] = pos_side
+            j = self.client.post_order(p)
+            out["sl_order_id"] = j.get("orderId")
+            out["sl_client_id"] = p["newClientOrderId"]
+
+        if tps:
+            parts = self._split_tp_qtys(symbol, qty, len(tps))
+            for idx, (tp, q_tp) in enumerate(zip(tps, parts), start=1):
+                q_tp2, tp_q = self._quantize(symbol, q_tp, tp)
+                p = {
+                    "symbol": symbol,
+                    "side": exit_side,
+                    "type": "TAKE_PROFIT_MARKET",
+                    "stopPrice": tp_q,
+                    "quantity": q_tp2,
+                    "newClientOrderId": _make_cid(sid, f"tp{idx}"),
+                }
+                if reduce_only_allowed:
+                    p["reduceOnly"] = True
+                elif pos_side:
+                    p["positionSide"] = pos_side
+                j = self.client.post_order(p)
+                out[f"tp{idx}_order_id"] = j.get("orderId")
+                out[f"tp{idx}_client_id"] = p["newClientOrderId"]
+        return out
+
+    def _cancel_by_token(self, symbol: str, sid: str) -> int:
+        token = _sha1_8(sid)
+        canceled = 0
+        orders = self.client.get_open_orders(symbol) or []
+        for o in orders:
+            cid = str(o.get("clientOrderId") or "")
+            if token and token not in cid:
+                continue
+            try:
+                oid = _i(o.get("orderId"), 0)
+                if oid:
+                    _ = self.client.delete_order(symbol, order_id=oid)
+                    canceled += 1
+            except Exception:
+                continue
+        return canceled
+
+    def _get_position_qty(self, symbol: str, logical_side: Optional[str] = None) -> float:
+        risks = self.client.get_position_risk() or []
+        for p in risks:
+            if str(p.get("symbol") or "").upper() != symbol.upper():
+                continue
+            amt = _f(p.get("positionAmt"))
+            if self.position_mode == "oneway":
+                return abs(amt)
+            # hedge: prefer the matching positionSide if present
+            ps = str(p.get("positionSide") or "").upper().strip()
+            if logical_side and ps and ps in {"LONG", "SHORT"}:
+                if logical_side.upper() == ps and abs(amt) > 0:
+                    return abs(amt)
+                continue
+            # fallback to abs net
+            return abs(amt)
+        return 0.0
+
+    def _place_trailing_stop(
+        self,
+        *,
+        sid: str,
+        symbol: str,
+        logical_side: str,
+        qty: float,
+        callback_rate_pct: float,
+    ) -> Dict[str, Any]:
+        """Place TRAILING_STOP_MARKET for the current position (reduce-only in one-way).
+
+        Important: In hedge mode Binance forbids reduceOnly param. We rely on positionSide to ensure it reduces.
+        """
+        exit_side = "SELL" if logical_side == "LONG" else "BUY"
+        pos_side = _position_side_for_mode(self.position_mode, logical_side)
+        q, _ = self._quantize(symbol, qty, None)
+        if q <= 0:
+            raise ValueError("trail qty <= 0")
+
+        p: Dict[str, Any] = {
+            "symbol": symbol,
+            "side": exit_side,
+            "type": "TRAILING_STOP_MARKET",
+            "quantity": q,
+            "callbackRate": float(callback_rate_pct),
+            "newClientOrderId": _make_cid(sid, "trail"),
+        }
+        if self.position_mode == "oneway":
+            p["reduceOnly"] = True
+        if pos_side:
+            p["positionSide"] = pos_side
+
+        j = self.client.post_order(p)
+        return {
+            "trail_order_id": j.get("orderId"),
+            "trail_client_id": p["newClientOrderId"],
+        }
+
+    def _arm_trailing_after_tp1_thread(
+        self,
+        *,
+        sid: str,
+        symbol: str,
+        logical_side: str,
+        tp1: float,
+        callback_rate_pct: float,
+        sl_order_id: Optional[int],
+    ) -> None:
+        """Background worker: when TP1 touched → replace SL with trailing stop.
+
+        Rationale:
+          - upstream strategy uses `trail_after_tp1`
+          - we keep the hard SL until TP1 is reached
+          - after TP1, trailing stop manages the remainder
+        """
+        try:
+            deadline = time.time() + float(self.trail_arm_timeout_s)
+            poll_s = max(0.2, float(self.trail_arm_poll_s))
+            touched = False
+
+            while time.time() < deadline:
+                # mark price is less noisy than last trade
+                mp = float(self.client.get_mark_price(symbol) or 0.0)
+                if mp <= 0:
+                    time.sleep(poll_s)
+                    continue
+
+                if logical_side == "LONG":
+                    touched = mp >= float(tp1)
+                else:
+                    touched = mp <= float(tp1)
+
+                if touched:
+                    break
+                time.sleep(poll_s)
+
+            if not touched:
+                self._exec_event({
+                    "sid": sid,
+                    "symbol": symbol,
+                    "action": "trail_arm",
+                    "status": "timeout",
+                    "trail_tp1": tp1,
+                    "trail_callback_rate_pct": callback_rate_pct,
+                })
+                return
+
+            # Ensure position is still open.
+            qty = self._get_position_qty(symbol, logical_side=logical_side)
+            if qty <= 0:
+                self._exec_event({
+                    "sid": sid,
+                    "symbol": symbol,
+                    "action": "trail_arm",
+                    "status": "no_position",
+                })
+                return
+
+            # Best effort: cancel the previous SL (avoid double-stops).
+            if sl_order_id:
+                try:
+                    _ = self.client.delete_order(symbol, order_id=int(sl_order_id))
+                except Exception:
+                    pass
+
+            trail = self._place_trailing_stop(
+                sid=sid,
+                symbol=symbol,
+                logical_side=logical_side,
+                qty=qty,
+                callback_rate_pct=callback_rate_pct,
+            )
+
+            ev = {
+                "sid": sid,
+                "symbol": symbol,
+                "action": "trail_arm",
+                "status": "armed",
+                "side": logical_side,
+                "qty": qty,
+                "trail_tp1": tp1,
+                "trail_callback_rate_pct": callback_rate_pct,
+                **trail,
+            }
+            self._exec_event(ev)
+
+            if self.tg is not None and self.trail_notify:
+                self.tg.send_text(
+                    f"🧷 BINANCE trailing armed\n"
+                    f"symbol={symbol} side={logical_side}\n"
+                    f"sid={sid[:24]}...\n"
+                    f"tp1={tp1} cb={callback_rate_pct:.1f}%"
+                )
+        except Exception as e:
+            self._exec_event({
+                "sid": sid,
+                "symbol": symbol,
+                "action": "trail_arm",
+                "status": "error",
+                "msg": str(e)[:900],
+            })
+
+    def _maybe_start_trailing_after_tp1(
+        self,
+        *,
+        payload: Dict[str, Any],
+        sid: str,
+        symbol: str,
+        logical_side: str,
+        entry_price: Optional[float],
+        sl_order_id: Optional[int],
+        tp_levels: List[float],
+    ) -> Dict[str, Any]:
+        """Start background trailing arming if upstream requests it."""
+        if not _truthy(payload.get("trail_after_tp1")):
+            return {}
+        if not tp_levels:
+            return {"trail_after_tp1": True, "trail_status": "no_tp_levels"}
+
+        atr = None
+        if payload.get("atr") is not None:
+            try:
+                atr = float(payload.get("atr"))
+            except Exception:
+                atr = None
+
+        cb = compute_trailing_callback_rate_pct(
+            payload,
+            entry_price=entry_price,
+            atr=atr,
+            min_pct=float(self.trail_cb_min),
+            max_pct=float(self.trail_cb_max),
+            default_pct=float(self.trail_cb_default),
+            atr_mult_default=float(self.trail_atr_mult_default),
+        )
+        tp1 = float(tp_levels[0])
+
+        t = threading.Thread(
+            target=self._arm_trailing_after_tp1_thread,
+            kwargs={
+                "sid": sid,
+                "symbol": symbol,
+                "logical_side": logical_side,
+                "tp1": tp1,
+                "callback_rate_pct": cb,
+                "sl_order_id": int(sl_order_id) if sl_order_id else None,
+            },
+            daemon=True,
+        )
+        t.start()
+
+        return {
+            "trail_after_tp1": True,
+            "trail_tp1": tp1,
+            "trail_callback_rate_pct": cb,
+            "trail_status": "arming",
+        }
+
+    def handle_open(self, payload: Dict[str, Any]) -> Dict[str, Any]:
+        sid = str(payload.get("sid") or "").strip()
+        symbol = str(payload.get("symbol") or "").strip().upper()
+        if not sid or not symbol:
+            raise ValueError("sid/symbol required")
+        if self.allowlist and symbol not in self.allowlist:
+            raise ValueError(f"symbol not in allowlist: {symbol}")
+
+        self._ensure_symbol_settings(symbol)
+
+        side, logical = _normalize_side(payload)
+        qty = _normalize_qty(payload, self.assume_lot_is_qty)
+        entry = payload.get("entry")
+        price = None
+        if entry not in (None, 0, "", "0"):
+            price = _f(entry)
+
+        order_type = str(payload.get("type") or ("limit" if price else "market")).upper()
+        order_type = "MARKET" if order_type in {"MARKET", "MKT"} else "LIMIT"
+
+        q, p = self._quantize(symbol, qty, price)
+        if q <= 0:
+            raise ValueError("qty <= 0")
+
+        params: Dict[str, Any] = {
+            "symbol": symbol,
+            "side": side,
+            "type": order_type,
+            "quantity": q,
+            "newClientOrderId": _make_cid(sid, "entry"),
+        }
+
+        pos_side = _position_side_for_mode(self.position_mode, logical)
+        if pos_side:
+            params["positionSide"] = pos_side
+
+        if order_type == "LIMIT":
+            if p is None or p <= 0:
+                raise ValueError("limit order requires entry price")
+            params["price"] = p
+            params["timeInForce"] = "GTC"
+
+        j_entry = self.client.post_order(params)
+        order_id = _i(j_entry.get("orderId"), 0)
+        if not order_id:
+            raise RuntimeError(f"no orderId in response: {j_entry}")
+
+        j_final = self._wait_fill(symbol, order_id, timeout_s=self.fill_timeout_s)
+        status = str(j_final.get("status") or "").upper()
+        filled_qty = _f(j_final.get("executedQty"), 0.0)
+        avg_price = _f(j_final.get("avgPrice"), 0.0)
+        if status not in {"FILLED", "PARTIALLY_FILLED"}:
+            raise RuntimeError(f"entry not filled: status={status} order={j_final}")
+        if filled_qty <= 0:
+            raise RuntimeError(f"filled_qty=0: order={j_final}")
+
+        sl = _f(payload.get("sl"), 0.0) if payload.get("sl") is not None else None
+        sl = sl if sl and sl > 0 else None
+        tps_raw = payload.get("tp_levels") or []
+        tps = [float(x) for x in tps_raw if x not in (None, "")]
+        tps = [tp for tp in tps if tp > 0]
+
+        prot = self._place_protective(sid=sid, symbol=symbol, logical_side=logical, qty=filled_qty, sl=sl, tps=tps)
+
+        trail = self._maybe_start_trailing_after_tp1(
+            payload=payload,
+            sid=sid,
+            symbol=symbol,
+            logical_side=logical,
+            entry_price=avg_price if avg_price > 0 else (p or None),
+            sl_order_id=_i(prot.get("sl_order_id"), 0) or None,
+            tp_levels=tps,
+        )
+
+        return {
+            "sid": sid,
+            "symbol": symbol,
+            "action": "open",
+            "status": status.lower(),
+            "side": logical,
+            "qty": filled_qty,
+            "exec_price": avg_price,
+            "binance_order_id": order_id,
+            **prot,
+            **trail,
+            "json": json.dumps({"entry": j_final, "protective": prot, "trailing": trail}, ensure_ascii=False, default=str),
+        }
+
+    def handle_modify(self, payload: Dict[str, Any]) -> Dict[str, Any]:
+        sid = str(payload.get("sid") or "").strip()
+        symbol = str(payload.get("symbol") or "").strip().upper()
+        if not sid or not symbol:
+            raise ValueError("sid/symbol required")
+        if self.allowlist and symbol not in self.allowlist:
+            raise ValueError(f"symbol not in allowlist: {symbol}")
+
+        canceled = self._cancel_by_token(symbol, sid)
+
+        # determine current position side/qty
+        risks = self.client.get_position_risk() or []
+        amt = 0.0
+        for p in risks:
+            if str(p.get("symbol") or "").upper() != symbol:
+                continue
+            amt = _f(p.get("positionAmt"), 0.0)
+            break
+
+        if amt == 0.0:
+            return {
+                "sid": sid,
+                "symbol": symbol,
+                "action": "modify",
+                "status": "no_position",
+                "canceled_orders": canceled,
+            }
+
+        logical = "LONG" if amt > 0 else "SHORT"
+        qty = abs(amt)
+
+        sl = _f(payload.get("sl"), 0.0) if payload.get("sl") is not None else None
+        sl = sl if sl and sl > 0 else None
+        tps_raw = payload.get("tp_levels") or []
+        tps = [float(x) for x in tps_raw if x not in (None, "")]
+        tps = [tp for tp in tps if tp > 0]
+
+        prot = self._place_protective(sid=sid, symbol=symbol, logical_side=logical, qty=qty, sl=sl, tps=tps)
+
+        entry_price = None
+        if payload.get("entry") not in (None, 0, "", "0"):
+            try:
+                entry_price = float(payload.get("entry"))
+            except Exception:
+                entry_price = None
+        if entry_price is None:
+            try:
+                mp = float(self.client.get_mark_price(symbol) or 0.0)
+                entry_price = mp if mp > 0 else None
+            except Exception:
+                entry_price = None
+
+        trail = self._maybe_start_trailing_after_tp1(
+            payload=payload,
+            sid=sid,
+            symbol=symbol,
+            logical_side=logical,
+            entry_price=entry_price,
+            sl_order_id=_i(prot.get("sl_order_id"), 0) or None,
+            tp_levels=tps,
+        )
+        return {
+            "sid": sid,
+            "symbol": symbol,
+            "action": "modify",
+            "status": "ok",
+            "side": logical,
+            "qty": qty,
+            "canceled_orders": canceled,
+            **prot,
+            **trail,
+            "json": json.dumps({"canceled": canceled, "protective": prot, "trailing": trail}, ensure_ascii=False, default=str),
+        }
+
+    def handle_cancel(self, payload: Dict[str, Any]) -> Dict[str, Any]:
+        sid = str(payload.get("sid") or "").strip()
+        symbol = str(payload.get("symbol") or "").strip().upper()
+        if not sid or not symbol:
+            raise ValueError("sid/symbol required")
+        if self.allowlist and symbol not in self.allowlist:
+            raise ValueError(f"symbol not in allowlist: {symbol}")
+
+        canceled = self._cancel_by_token(symbol, sid)
+
+        # close position if exists
+        risks = self.client.get_position_risk() or []
+        amt = 0.0
+        for p in risks:
+            if str(p.get("symbol") or "").upper() != symbol:
+                continue
+            amt = _f(p.get("positionAmt"), 0.0)
+            break
+
+        closed = False
+        close_order_id = None
+        logical = None
+        qty = 0.0
+        if amt != 0.0:
+            logical = "LONG" if amt > 0 else "SHORT"
+            qty = abs(amt)
+            exit_side = "SELL" if amt > 0 else "BUY"
+            pos_side = _position_side_for_mode(self.position_mode, logical)
+            q, _ = self._quantize(symbol, qty, None)
+            p = {
+                "symbol": symbol,
+                "side": exit_side,
+                "type": "MARKET",
+                "quantity": q,
+                "newClientOrderId": _make_cid(sid, "close"),
+            }
+            if self.position_mode == "oneway":
+                p["reduceOnly"] = True
+            if pos_side:
+                p["positionSide"] = pos_side
+            j = self.client.post_order(p)
+            close_order_id = _i(j.get("orderId"), 0)
+            closed = True
+
+        return {
+            "sid": sid,
+            "symbol": symbol,
+            "action": "cancel",
+            "status": "ok",
+            "side": logical or "",
+            "qty": qty,
+            "canceled_orders": canceled,
+            "close_order_id": close_order_id or "",
+            "closed": str(closed).lower(),
+        }
+
+    def handle_resize(self, payload: Dict[str, Any]) -> Dict[str, Any]:
