diff --git a/services/tests/test_binance_trailing_unit_v1.py b/services/tests/test_binance_trailing_unit_v1.py
new file mode 100644
index 0000000..938febb
--- /dev/null
+++ b/services/tests/test_binance_trailing_unit_v1.py
@@ -0,0 +1,72 @@
+import math
+
+from services.binance_executor import compute_trailing_callback_rate_pct, _truthy
+
+
+def test_truthy_basic():
+    assert _truthy(True) is True
+    assert _truthy(False) is False
+    assert _truthy(1) is True
+    assert _truthy(0) is False
+    assert _truthy("true") is True
+    assert _truthy("yes") is True
+    assert _truthy("on") is True
+    assert _truthy("0") is False
+    assert _truthy(None) is False
+
+
+def test_trailing_callback_explicit_pct_rounding():
+    payload = {"trail_callback_rate": 0.27}
+    v = compute_trailing_callback_rate_pct(
+        payload,
+        entry_price=100.0,
+        atr=1.0,
+        min_pct=0.1,
+        max_pct=5.0,
+        default_pct=0.3,
+        atr_mult_default=1.0,
+    )
+    assert math.isclose(v, 0.3)
+
+
+def test_trailing_callback_bps_to_pct():
+    payload = {"trail_callback_bps": 35}
+    v = compute_trailing_callback_rate_pct(
+        payload,
+        entry_price=100.0,
+        atr=1.0,
+        min_pct=0.1,
+        max_pct=5.0,
+        default_pct=0.3,
+        atr_mult_default=1.0,
+    )
+    assert math.isclose(v, 0.4)
+
+
+def test_trailing_callback_from_atr():
+    payload = {}
+    v = compute_trailing_callback_rate_pct(
+        payload,
+        entry_price=100.0,
+        atr=0.42,
+        min_pct=0.1,
+        max_pct=5.0,
+        default_pct=0.3,
+        atr_mult_default=1.0,
+    )
+    # 0.42/100*100 = 0.42% -> rounds to 0.4
+    assert math.isclose(v, 0.4)
+
+
+def test_trailing_callback_clamp_max():
+    payload = {}
+    v = compute_trailing_callback_rate_pct(
+        payload,
+        entry_price=100.0,
+        atr=50.0,  # 50%
+        min_pct=0.1,
+        max_pct=5.0,
+        default_pct=0.3,
+        atr_mult_default=1.0,
+    )
+    assert math.isclose(v, 5.0)
