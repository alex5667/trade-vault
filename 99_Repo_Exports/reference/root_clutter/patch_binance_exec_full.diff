+    def process_one(self, raw: str) -> None:
+        try:
+            payload = json.loads(raw)
+        except Exception:
+            self._dlq(raw, "bad_json")
+            self._ack_processing(raw)
+            return
+
+        action = str(payload.get("action") or "").strip().lower()
+        sid = str(payload.get("sid") or "").strip()
+        symbol = str(payload.get("symbol") or "").strip().upper()
+
+        if not action or not sid or not symbol:
+            self._dlq(raw, "missing_required_fields")
+            self._exec_event({"sid": sid or "", "symbol": symbol or "", "action": action or "", "severity": "error", "msg": "missing_required_fields"})
+            self._ack_processing(raw)
+            return
+
+        try:
+            if action == "open":
+                out = self.handle_open(payload)
+            elif action == "modify":
+                out = self.handle_modify(payload)
+            elif action == "cancel":
+                out = self.handle_cancel(payload)
+            elif action == "resize":
+                out = self.handle_resize(payload)
+            else:
+                raise ValueError(f"unknown action: {action}")
+
+            self._exec_event(out)
+            self._ack_processing(raw)
+        except Exception as e:
+            cls = _classify_error(e)
+            msg = str(e)
+            self._exec_event({"sid": sid, "symbol": symbol, "action": action, "severity": "error", "msg": msg, "error_class": cls})
+            if self.tg is not None:
+                # keep it very short
+                self.tg.send_text(f"❌ BINANCE EXEC error\naction={action} symbol={symbol}\nsid={sid[:24]}...\n{msg[:500]}")
+
+            if isinstance(e, BinanceAPIError):
+                # timestamp drift: attempt time sync once and retry
+                payload_e = e.payload if isinstance(e.payload, dict) else {}
+                if payload_e.get("code") == -1021:
+                    try:
+                        self.client.sync_time()
+                        cls = "transient"
+                    except Exception:
+                        pass
+
+            if cls == "transient":
+                retry_n = int(payload.get("retry_n") or 0)
+                if retry_n < self.max_retry:
+                    self._requeue(payload, raw, msg)
+                    self._ack_processing(raw)
+                    time.sleep(0.25)
+                    return
+            # fatal OR exceeded retries
+            self._dlq(raw, f"{cls}:{msg}")
+            self._ack_processing(raw)
+
+    def run_forever(self) -> None:
+        print("🚀 BinanceExecutor starting")
+        print(f"   queue={self.queue}")
+        print(f"   processing={self.queue_processing}")
+        print(f"   dlq={self.queue_dlq}")
+        print(f"   exec_stream={self.exec_stream}")
+        print(f"   position_mode={self.position_mode}")
+        if self.allowlist:
+            print(f"   allowlist={sorted(self.allowlist)}")
+
+        while True:
+            try:
+                raw = self.r.brpoplpush(self.queue, self.queue_processing, timeout=5)
+                if not raw:
+                    continue
+                self.process_one(raw)
+            except Exception as e:
+                # Global fail-open loop protection
+                print(f"❌ executor loop error: {e}")
+                time.sleep(1.0)
+
+
+def main() -> None:
+    BinanceExecutor().run_forever()
+
+
+if __name__ == "__main__":
+    main()
diff --git a/services/binance_futures_client.py b/services/binance_futures_client.py
new file mode 100644
index 0000000..4e07f45
--- /dev/null
+++ b/services/binance_futures_client.py
@@ -0,0 +1,218 @@
+from __future__ import annotations
+
+"""Binance USDT-M Futures REST client (stdlib-only).
+
+Goal: provide a minimal, production-safe building block for:
+  - account reporting (P0)
+  - execution (P1)
+
+Design goals:
+  - Deterministic signing (HMAC SHA256)
+  - Conservative timeouts
+  - Clear error surfaces (raise with response payload)
+  - No external deps (requests/httpx)
+
+Notes:
+  - Binance requires `timestamp` in ms and `signature`.
+  - If server time skew exists, enable time sync (BINANCE_TIME_SYNC=1).
+"""
+
+import hashlib
+import hmac
+import json
+import os
+import time
+import urllib.parse
+import urllib.request
+from dataclasses import dataclass
+from typing import Any, Dict, Optional, Tuple
+
+
+class BinanceAPIError(RuntimeError):
+    def __init__(self, status: int, payload: Any, message: str = ""):
+        super().__init__(message or f"Binance API error status={status} payload={payload}")
+        self.status = status
+        self.payload = payload
+
+
+def _ms_now() -> int:
+    return int(time.time() * 1000)
+
+
+def _safe_json_loads(raw: bytes) -> Any:
+    try:
+        return json.loads(raw.decode("utf-8"))
+    except Exception:
+        # preserve raw for debugging
+        return {"_raw": raw[:4096].decode("utf-8", errors="replace")}
+
+
+def _hmac_sha256(secret: str, msg: str) -> str:
+    return hmac.new(secret.encode("utf-8"), msg.encode("utf-8"), hashlib.sha256).hexdigest()
+
+
+def _encode_params(params: Dict[str, Any]) -> str:
+    # Binance expects standard querystring; keep a stable encoding.
+    items = []
+    for k in sorted(params.keys()):
+        v = params[k]
+        if v is None:
+            continue
+        if isinstance(v, bool):
+            v = "true" if v else "false"
+        items.append((k, str(v)))
+    return urllib.parse.urlencode(items)
+
+
+@dataclass
+class BinanceFuturesClient:
+    api_key: str
+    api_secret: str
+    base_url: str = "https://fapi.binance.com"
+    timeout_s: float = 8.0
+    recv_window: int = 5000
+    timestamp_offset_ms: int = 0
+
+    @staticmethod
+    def from_env() -> "BinanceFuturesClient":
+        key = (os.getenv("BINANCE_API_KEY") or "").strip()
+        sec = (os.getenv("BINANCE_API_SECRET") or "").strip()
+        if not key or not sec:
+            raise RuntimeError("BINANCE_API_KEY/BINANCE_API_SECRET are required")
+
+        base = (os.getenv("BINANCE_FUTURES_BASE_URL") or "https://fapi.binance.com").strip()
+        timeout_s = float(os.getenv("BINANCE_HTTP_TIMEOUT_S", "8.0"))
+        recv_window = int(os.getenv("BINANCE_RECV_WINDOW", "5000"))
+        c = BinanceFuturesClient(api_key=key, api_secret=sec, base_url=base, timeout_s=timeout_s, recv_window=recv_window)
+
+        if (os.getenv("BINANCE_TIME_SYNC") or "").strip().lower() in {"1", "true", "yes", "on"}:
+            c.sync_time()
+        return c
+
+    # ---------------------------- core HTTP ----------------------------
+
+    def _request(self, method: str, path: str, *, params: Optional[Dict[str, Any]] = None, signed: bool = False) -> Any:
+        method = method.upper()
+        params = dict(params or {})
+        headers = {
+            "X-MBX-APIKEY": self.api_key,
+            "User-Agent": "scanner_infra/binance_client_v1",
+        }
+
+        qs = ""
+        body: Optional[bytes] = None
+
+        if signed:
+            params.setdefault("timestamp", _ms_now() + int(self.timestamp_offset_ms))
+            params.setdefault("recvWindow", int(self.recv_window))
+            qs = _encode_params(params)
+            sig = _hmac_sha256(self.api_secret, qs)
+            qs = qs + "&signature=" + sig
+        else:
+            qs = _encode_params(params) if params else ""
+
+        url = self.base_url.rstrip("/") + path
+        if method in {"GET", "DELETE"}:
+            if qs:
+                url = url + ("?" if "?" not in url else "&") + qs
+        else:
+            # POST: send as application/x-www-form-urlencoded (Binance accepts both)
+            body = qs.encode("utf-8") if qs else b""
+
+        req = urllib.request.Request(url, data=body, method=method)
+        for k, v in headers.items():
+            req.add_header(k, v)
+        if method in {"POST", "PUT"}:
+            req.add_header("Content-Type", "application/x-www-form-urlencoded")
+
+        try:
+            with urllib.request.urlopen(req, timeout=self.timeout_s) as resp:
+                raw = resp.read()
+                if 200 <= resp.status < 300:
+                    return _safe_json_loads(raw)
+                raise BinanceAPIError(resp.status, _safe_json_loads(raw))
+        except urllib.error.HTTPError as e:
+            raw = e.read() if hasattr(e, "read") else b""
+            payload = _safe_json_loads(raw) if raw else {"_error": str(e)}
+            raise BinanceAPIError(getattr(e, "code", 0) or 0, payload)
+
+    # ---------------------------- public endpoints ----------------------------
+
+    def ping(self) -> Any:
+        return self._request("GET", "/fapi/v1/ping")
+
+    def get_server_time(self) -> int:
+        j = self._request("GET", "/fapi/v1/time")
+        return int(j.get("serverTime"))
+
+    def sync_time(self) -> None:
+        """Compute local->server offset to reduce signature rejections due to time drift."""
+        try:
+            t0 = _ms_now()
+            st = self.get_server_time()
+            t1 = _ms_now()
+            # Assume serverTime corresponds to mid-point of local request.
+            mid = (t0 + t1) // 2
+            self.timestamp_offset_ms = int(st - mid)
+        except Exception:
+            # fail-open: offset remains 0
+            self.timestamp_offset_ms = 0
+
+    def get_exchange_info(self) -> Any:
+        return self._request("GET", "/fapi/v1/exchangeInfo")
+
+    def get_premium_index(self, symbol: str) -> Any:
+        """Return premium index payload, including markPrice.
+
+        Endpoint: GET /fapi/v1/premiumIndex (public).
+        This is a convenient and cheap way to fetch mark price for trailing arming.
+        """
+        return self._request("GET", "/fapi/v1/premiumIndex", params={"symbol": str(symbol).upper()})
+
+    def get_mark_price(self, symbol: str) -> float:
+        j = self.get_premium_index(symbol)
+        try:
+            return float(j.get("markPrice"))
+        except Exception:
+            return 0.0
+
+    # ---------------------------- signed/account endpoints ----------------------------
+
+    def get_account(self) -> Any:
+        return self._request("GET", "/fapi/v2/account", signed=True)
+
+    def get_position_risk(self) -> Any:
+        return self._request("GET", "/fapi/v2/positionRisk", signed=True)
+
+    def get_open_orders(self, symbol: Optional[str] = None) -> Any:
+        params: Dict[str, Any] = {}
+        if symbol:
+            params["symbol"] = symbol
+        return self._request("GET", "/fapi/v1/openOrders", params=params, signed=True)
+
+    # ---------------------------- signed/trading endpoints ----------------------------
+
+    def post_leverage(self, symbol: str, leverage: int) -> Any:
+        return self._request("POST", "/fapi/v1/leverage", params={"symbol": symbol, "leverage": leverage}, signed=True)
+
+    def post_margin_type(self, symbol: str, margin_type: str) -> Any:
+        return self._request("POST", "/fapi/v1/marginType", params={"symbol": symbol, "marginType": margin_type}, signed=True)
+
+    def post_order(self, params: Dict[str, Any]) -> Any:
+        return self._request("POST", "/fapi/v1/order", params=params, signed=True)
+
+    def get_order(self, symbol: str, *, order_id: Optional[int] = None, client_order_id: Optional[str] = None) -> Any:
+        p: Dict[str, Any] = {"symbol": symbol}
+        if order_id is not None:
+            p["orderId"] = int(order_id)
+        if client_order_id is not None:
+            p["origClientOrderId"] = client_order_id
+        return self._request("GET", "/fapi/v1/order", params=p, signed=True)
+
+    def delete_order(self, symbol: str, *, order_id: Optional[int] = None, client_order_id: Optional[str] = None) -> Any:
+        p: Dict[str, Any] = {"symbol": symbol}
+        if order_id is not None:
+            p["orderId"] = int(order_id)
+        if client_order_id is not None:
+            p["origClientOrderId"] = client_order_id
+        return self._request("DELETE", "/fapi/v1/order", params=p, signed=True)
