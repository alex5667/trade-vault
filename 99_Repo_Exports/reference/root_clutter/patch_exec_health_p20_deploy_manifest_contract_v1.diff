--- a/orderflow_services/runbook_exec_health_freeze_rollout_deploy_contract_v1.md
+++ b/orderflow_services/runbook_exec_health_freeze_rollout_deploy_contract_v1.md
@@ -0,0 +1,33 @@
+# ExecHealth rollout deploy manifest / env contract (v1)
+
+Purpose:
+- fail before starting sensitive rollout-gated jobs if host/container env is incomplete or drifted.
+
+Schema/version:
+- `EXEC_HEALTH_ROLLOUT_PREFLIGHT_SCHEMA_VERSION=exec_health_freeze_rollout_preflight_contract_v1`
+
+Required for guarded jobs:
+- `EXEC_HEALTH_REDIS_AUDIT_URL` -> named user `exec_health_freeze_audit`
+- `EXEC_HEALTH_REDIS_BOOTSTRAP_URL` -> named user `exec_health_freeze_bootstrap`
+- purpose-specific target URL:
+  - ACL policy apply -> `EXEC_HEALTH_REDIS_BOOTSTRAP_URL`
+  - commit-thaw -> `REDIS_URL` with writer user
+- `EXEC_HEALTH_ROLLOUT_PREFLIGHT_CLIENT_NAME`
+- `EXEC_HEALTH_ROLLOUT_PREFLIGHT_LIB_NAME`
+- `EXEC_HEALTH_REDIS_CLIENT_NAME`
+- `EXEC_HEALTH_REDIS_LIB_NAME`
+
+Expected client identities:
+- preflight -> `exec-health-freeze-rollout-preflight-v1` / `exec-health-freeze-audit`
+- acl policy apply -> `exec-health-freeze-acl-policy-v1` / `exec-health-freeze-bootstrap`
+- override commit-thaw -> `exec-health-freeze-override-v1` / `exec-health-freeze-writer`
+
+Checks:
+1. host-side wrapper exports schema version and purpose.
+2. Python preflight validates env contract before Redis connect.
+3. target service validates its runtime env contract on startup.
+4. rollout gate still checked after env validation.
+
+Example manifests:
+- `orderflow_services/deploy/env/exec-health-freeze-acl-policy-apply.env.example`
+- `orderflow_services/deploy/env/exec-health-freeze-override-commit-thaw.env.example`
--- a/tick_flow_full/orderflow_services/exec_health_freeze_rollout_preflight_v1.py
+++ b/tick_flow_full/orderflow_services/exec_health_freeze_rollout_preflight_v1.py
@@ -0,0 +1,79 @@
+#!/usr/bin/env python3
+from __future__ import annotations
+
+import argparse
+import json
+import os
+from typing import Any, Dict, List
+
+try:
+    import redis  # type: ignore
+except Exception:  # pragma: no cover
+    redis = None
+
+from services.orderflow.exec_health_freeze_deploy_contract import assert_sensitive_deploy_env_contract, ROLLOUT_PREFLIGHT_SCHEMA_VERSION
+from services.orderflow.exec_health_freeze_reconnect_healing import heal_service_identity_sync
+from services.orderflow.exec_health_freeze_rollout_gate import assert_rollout_gate_open, get_rollout_gate_state
+from services.orderflow.exec_health_freeze_service_identity import ensure_service_identity_sync
+
+SERVICE = 'exec_health_freeze_rollout_preflight_v1'
+DEFAULT_EXIT_CODE = 24
+
+
+def _redis_url() -> str:
+    return (
+        os.getenv('EXEC_HEALTH_REDIS_AUDIT_URL')
+        or os.getenv('EXEC_HEALTH_REDIS_BOOTSTRAP_URL')
+        or os.getenv('REDIS_URL')
+        or 'redis://redis-worker-1:6379/0'
+    )
+
+
+def _jprint(obj: Dict[str, Any]) -> None:
+    print(json.dumps(obj, ensure_ascii=False, indent=2, sort_keys=True))
+
+
+class PreflightController:
+    def __init__(self, *, purpose: str, redis_url: str | None = None) -> None:
+        if redis is None:
+            raise RuntimeError('redis dependency missing')
+        self.purpose = purpose
+        self.deploy_contract = assert_sensitive_deploy_env_contract(purpose)
+        self.redis_url = redis_url or _redis_url()
+        self.r = redis.Redis.from_url(self.redis_url, decode_responses=True)
+        ensure_service_identity_sync(self.r, SERVICE)
+        heal_service_identity_sync(self.r, SERVICE, force=True)
+
+    def check(self, *, purpose: str, exit_code: int = DEFAULT_EXIT_CODE) -> Dict[str, Any]:
+        heal_service_identity_sync(self.r, SERVICE)
+        assert_rollout_gate_open(self.r, purpose=purpose, exit_code=exit_code)
+        st = get_rollout_gate_state(self.r)
+        return {
+            'ok': True,
+            'service': SERVICE,
+            'purpose': purpose,
+            'preflight_schema_version': ROLLOUT_PREFLIGHT_SCHEMA_VERSION,
+            'gate_active': bool(st.get('active')),
+            'redis_url': self.redis_url,
+        }
+
+
+def build_arg_parser() -> argparse.ArgumentParser:
+    ap = argparse.ArgumentParser(description='ExecHealth rollout preflight guard')
+    ap.add_argument('--purpose', required=True)
+    ap.add_argument('--exit-code', type=int, default=int(os.getenv('EXEC_HEALTH_ROLLOUT_PREFLIGHT_EXIT_CODE', str(DEFAULT_EXIT_CODE)) or DEFAULT_EXIT_CODE))
+    ap.add_argument('--quiet', action='store_true')
+    return ap
+
+
+def main(argv: List[str] | None = None) -> int:
+    ns = build_arg_parser().parse_args(argv)
+    ctl = PreflightController(purpose=ns.purpose)
+    out = ctl.check(purpose=ns.purpose, exit_code=int(ns.exit_code))
+    if not ns.quiet:
+        _jprint(out)
+    return 0
+
+
+if __name__ == '__main__':
+    raise SystemExit(main())
