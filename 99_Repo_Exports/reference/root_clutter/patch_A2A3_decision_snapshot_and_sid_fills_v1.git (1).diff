diff -ruN python-worker/services/orderflow/decision_ctx_fields.py python-worker/services/orderflow/decision_ctx_fields.py
--- python-worker/services/orderflow/decision_ctx_fields.py	1970-01-01 00:00:00.000000000 +0000
+++ python-worker/services/orderflow/decision_ctx_fields.py	2026-03-06 20:09:34.791905950 +0000
@@ -0,0 +1,235 @@
+
+from __future__ import annotations
+
+"""Decision-context enrichment for post-trade analysis (A1).
+
+This module freezes a minimal "decision snapshot" into the in-flight ctx right before EMIT.
+It is intentionally **fail-open** and must never block signal publishing.
+
+Why:
+- TCA requires a stable join key (sid) and decision/arrival price/time.
+- In event-time systems we must separate:
+    ts_event_ms  (exchange time) vs ts_emit_ms (decision time) vs ts_fill_ms (execution).
+
+Design constraints:
+- Deterministic timestamps: prefer values already present in ctx (tick_ts/ts_ms/ts_emit_ms).
+- Low overhead: only cheap computations (bbo, simple depth/slope proxies).
+"""
+
+from typing import Any, Dict, Optional
+import math
+
+
+def _safe_float(v: Any) -> Optional[float]:
+    try:
+        f = float(v)
+    except Exception:
+        return None
+    if not math.isfinite(f):
+        return None
+    return float(f)
+
+
+def _bbo_from_runtime(runtime: Any) -> tuple[Optional[float], Optional[float]]:
+    """Best-effort read of best bid/ask from runtime.last_book."""
+    try:
+        book = getattr(runtime, 'last_book', None)
+        if not isinstance(book, dict):
+            return None, None
+        bids = book.get('bids') or []
+        asks = book.get('asks') or []
+        bid = _safe_float(bids[0][0]) if bids else None
+        ask = _safe_float(asks[0][0]) if asks else None
+        return bid, ask
+    except Exception:
+        return None, None
+
+
+def _depth_notional(book_side: list, n: int) -> Optional[float]:
+    """Sum price*qty for top-N levels (notional)."""
+    try:
+        if not book_side:
+            return None
+        s = 0.0
+        k = 0
+        for lvl in book_side[:n]:
+            if not isinstance(lvl, (list, tuple)) or len(lvl) < 2:
+                continue
+            p = _safe_float(lvl[0])
+            q = _safe_float(lvl[1])
+            if p is None or q is None:
+                continue
+            s += p * q
+            k += 1
+        return float(s) if k > 0 else None
+    except Exception:
+        return None
+
+
+def _book_slope(book_side: list, mid: float, is_bid: bool, n: int = 10) -> Optional[float]:
+    """A cheap liquidity gradient proxy: sum(notional_i / dist_bps_i).
+
+    - For bids: dist_bps = (mid - price)/mid*1e4
+    - For asks: dist_bps = (price - mid)/mid*1e4
+
+    We cap dist_bps at >= 0.1 to avoid blow-ups.
+    """
+    try:
+        if not book_side or mid <= 0:
+            return None
+        acc = 0.0
+        used = 0
+        for lvl in book_side[:n]:
+            if not isinstance(lvl, (list, tuple)) or len(lvl) < 2:
+                continue
+            p = _safe_float(lvl[0])
+            q = _safe_float(lvl[1])
+            if p is None or q is None:
+                continue
+            dist_bps = ((mid - p) / mid * 10000.0) if is_bid else ((p - mid) / mid * 10000.0)
+            if dist_bps <= 0:
+                continue
+            dist_bps = max(dist_bps, 0.1)
+            acc += (p * q) / dist_bps
+            used += 1
+        return float(acc) if used > 0 else None
+    except Exception:
+        return None
+
+
+def _dws_bps(book: dict, mid: float, n: int = 5) -> Optional[float]:
+    """Depth-weighted spread proxy via VWAP(topN asks) - VWAP(topN bids), in bps."""
+    try:
+        if not book or mid <= 0:
+            return None
+        bids = book.get('bids') or []
+        asks = book.get('asks') or []
+        def vwap(side):
+            num = den = 0.0
+            for lvl in side[:n]:
+                if not isinstance(lvl, (list, tuple)) or len(lvl) < 2:
+                    continue
+                p = _safe_float(lvl[0]); q = _safe_float(lvl[1])
+                if p is None or q is None or q <= 0:
+                    continue
+                num += p*q
+                den += q
+            return (num/den) if den > 0 else None
+        vbid = vwap(bids)
+        vask = vwap(asks)
+        if vbid is None or vask is None:
+            return None
+        return float((vask - vbid) / mid * 10000.0)
+    except Exception:
+        return None
+
+
+def ensure_decision_ctx_fields(
+    ctx: Dict[str, Any],
+    *,
+    indicators: Optional[Dict[str, Any]] = None,
+    runtime: Any = None,
+    now_ms: Optional[int] = None,
+) -> Dict[str, Any]:
+    """Enrich ctx with decision_* fields.
+
+    This function mutates ctx in-place and returns it for convenience.
+    """
+    indicators = indicators or {}
+
+    # decision timestamp
+    ts_emit = ctx.get('ts_emit_ms')
+    if ts_emit is None:
+        # prefer deterministic sources
+        ts_emit = ctx.get('tick_ts') or ctx.get('ts_ms') or ctx.get('ts') or now_ms
+        if ts_emit is not None:
+            ctx['ts_emit_ms'] = int(ts_emit)
+    decision_ts_ms = int(ctx.get('decision_ts_ms') or ctx.get('ts_emit_ms') or 0)
+    if decision_ts_ms > 0:
+        ctx['decision_ts_ms'] = decision_ts_ms
+
+    # resolve bid/ask
+    bid = _safe_float(ctx.get('decision_bid'))
+    ask = _safe_float(ctx.get('decision_ask'))
+    if bid is None:
+        bid = _safe_float(ctx.get('best_bid') or ctx.get('bid') or (ctx.get('micro') or {}).get('best_bid'))
+    if ask is None:
+        ask = _safe_float(ctx.get('best_ask') or ctx.get('ask') or (ctx.get('micro') or {}).get('best_ask'))
+    if runtime is not None and (bid is None or ask is None):
+        rb, ra = _bbo_from_runtime(runtime)
+        bid = bid if bid is not None else rb
+        ask = ask if ask is not None else ra
+
+    flags: list[str] = []
+    if bid is None or ask is None:
+        flags.append('missing_bbo')
+
+    mid = _safe_float(ctx.get('decision_mid'))
+    if mid is None and bid is not None and ask is not None:
+        mid = (bid + ask) / 2.0
+
+    if mid is None or mid <= 0:
+        flags.append('bad_mid')
+
+    # crossed book
+    if bid is not None and ask is not None and bid >= ask:
+        flags.append('crossed_bbo')
+
+    spread_bps = _safe_float(ctx.get('decision_spread_bps'))
+    if spread_bps is None and mid and mid > 0 and bid is not None and ask is not None:
+        spread_bps = (ask - bid) / mid * 10000.0
+
+    if spread_bps is not None and spread_bps < 0:
+        flags.append('bad_spread')
+    if spread_bps is not None and spread_bps > 5000:
+        flags.append('spread_insane')
+
+    # depth/slope/dws best-effort
+    book = getattr(runtime, 'last_book', None) if runtime is not None else None
+    if isinstance(book, dict):
+        db5 = _depth_notional(book.get('bids') or [], 5)
+        da5 = _depth_notional(book.get('asks') or [], 5)
+        db20 = _depth_notional(book.get('bids') or [], 20)
+        da20 = _depth_notional(book.get('asks') or [], 20)
+        if db5 is not None: ctx.setdefault('decision_depth_bid_5', float(db5))
+        if da5 is not None: ctx.setdefault('decision_depth_ask_5', float(da5))
+        if db20 is not None: ctx.setdefault('decision_depth_bid_20', float(db20))
+        if da20 is not None: ctx.setdefault('decision_depth_ask_20', float(da20))
+        if mid is not None and mid > 0:
+            sb = _book_slope(book.get('bids') or [], mid, True)
+            sa = _book_slope(book.get('asks') or [], mid, False)
+            if sb is not None: ctx.setdefault('decision_book_slope_bid', float(sb))
+            if sa is not None: ctx.setdefault('decision_book_slope_ask', float(sa))
+            dws = _dws_bps(book, mid)
+            if dws is not None: ctx.setdefault('decision_dws_bps', float(dws))
+
+    # override from indicators if present
+    for k_src, k_dst in [
+        ('book_slope_bid', 'decision_book_slope_bid'),
+        ('book_slope_ask', 'decision_book_slope_ask'),
+        ('dws_bps', 'decision_dws_bps'),
+        ('ofi_norm', 'decision_ofi_norm'),
+        ('expected_slippage_bps', 'decision_expected_slippage_bps'),
+        ('exec_risk_norm', 'decision_exec_risk_norm'),
+    ]:
+        v = _safe_float(indicators.get(k_src))
+        if v is not None:
+            ctx[k_dst] = float(v)
+
+    # set canonical decision_* primitives
+    if bid is not None: ctx['decision_bid'] = float(bid)
+    if ask is not None: ctx['decision_ask'] = float(ask)
+    if mid is not None: ctx['decision_mid'] = float(mid)
+    if spread_bps is not None: ctx['decision_spread_bps'] = float(spread_bps)
+
+    # decision_price: start with mid
+    if mid is not None:
+        ctx.setdefault('decision_price', float(mid))
+
+    # audit fields
+    ctx['book_sanity_flags'] = flags
+    sid = ctx.get('sid') or ctx.get('signal_id')
+    tca_ready = bool(sid) and (decision_ts_ms > 0) and (mid is not None and mid > 0) and ('missing_bbo' not in flags) and ('crossed_bbo' not in flags)
+    ctx['tca_ready'] = bool(tca_ready)
+
+    return ctx
