+
+from __future__ import annotations
+
+"""Decision snapshot builder + publisher (A2).
+
+This event is the warm-path input for post-trade TCA (effective/realized spreads, IS, impact).
+It must be compact, joinable and idempotent-friendly.
+
+Stream contract:
+- Redis Stream: events:decision_snapshot
+- Field: payload (JSON)
+- Required keys:
+    schema_version, producer, sid, symbol, decision_ts_ms,
+    decision_mid (and decision_bid/decision_ask), direction
+
+Fail-open: publishing errors must never block signal emission.
+"""
+
+import os
+from typing import Any, Dict, Optional
+
+from services.async_signal_publisher import AsyncSignalPublisher, StreamSink
+
+
+def _pick(d: Dict[str, Any], *keys: str) -> Any:
+    for k in keys:
+        if k in d and d.get(k) is not None:
+            return d.get(k)
+    return None
+
+
+def build_decision_snapshot(
+    ctx: Dict[str, Any],
+    *,
+    runtime: Any = None,
+    indicators: Optional[Dict[str, Any]] = None,
+    schema_version: int = 1,
+) -> Dict[str, Any]:
+    indicators = indicators or {}
+
+    sid = str(_pick(ctx, 'sid', 'signal_id') or '')
+    symbol = str(_pick(ctx, 'symbol') or getattr(runtime, 'symbol', '') or '')
+    direction = str(_pick(ctx, 'direction') or '').upper()
+
+    # decision time
+    decision_ts_ms = int(_pick(ctx, 'decision_ts_ms', 'ts_emit_ms', 'tick_ts', 'ts_ms', 'ts') or 0)
+
+    # venue/session/tf/kind are best-effort (do not block)
+    venue = str(_pick(ctx, 'venue') or getattr(getattr(runtime, 'config', None), 'get', lambda *_: None)('venue') if runtime is not None else None or os.getenv('VENUE', 'binance'))
+    session = str(_pick(ctx, 'session') or indicators.get('session') or '')
+    tf = str(_pick(ctx, 'tf') or indicators.get('tf') or '')
+    kind = str(_pick(ctx, 'kind') or indicators.get('kind') or '')
+
+    snap: Dict[str, Any] = {
+        'schema_version': int(schema_version),
+        'producer': str(os.getenv('SERVICE_NAME', 'python-worker')),
+        'sid': sid,
+        'signal_id': str(_pick(ctx, 'signal_id') or sid),
+        'symbol': symbol,
+        'venue': venue,
+        'session': session,
+        'tf': tf,
+        'kind': kind,
+        'direction': direction,
+        'side': 'LONG' if direction == 'LONG' else ('SHORT' if direction == 'SHORT' else ''),
+        'decision_ts_ms': int(decision_ts_ms),
+        # core prices
+        'decision_bid': _pick(ctx, 'decision_bid'),
+        'decision_ask': _pick(ctx, 'decision_ask'),
+        'decision_mid': _pick(ctx, 'decision_mid'),
+        'decision_spread_bps': _pick(ctx, 'decision_spread_bps'),
+        'decision_price': _pick(ctx, 'decision_price', 'decision_mid'),
+        # liquidity geometry (best-effort)
+        'decision_depth_bid_5': _pick(ctx, 'decision_depth_bid_5'),
+        'decision_depth_ask_5': _pick(ctx, 'decision_depth_ask_5'),
+        'decision_depth_bid_20': _pick(ctx, 'decision_depth_bid_20'),
+        'decision_depth_ask_20': _pick(ctx, 'decision_depth_ask_20'),
+        'decision_book_slope_bid': _pick(ctx, 'decision_book_slope_bid'),
+        'decision_book_slope_ask': _pick(ctx, 'decision_book_slope_ask'),
+        'decision_dws_bps': _pick(ctx, 'decision_dws_bps'),
+        # flow toxicity (best-effort)
+        'decision_ofi_norm': _pick(ctx, 'decision_ofi_norm'),
+        # exec model inputs (best-effort)
+        'decision_expected_slippage_bps': _pick(ctx, 'decision_expected_slippage_bps'),
+        'decision_exec_risk_norm': _pick(ctx, 'decision_exec_risk_norm'),
+        # audit
+        'tca_ready': bool(ctx.get('tca_ready')),
+        'book_sanity_flags': list(ctx.get('book_sanity_flags') or []),
+    }
+
+    return snap
+
+
+async def publish_decision_snapshot(
+    *,
+    publisher: AsyncSignalPublisher,
+    snapshot: Dict[str, Any],
+    stream: str,
+    maxlen: int,
+    symbol: str,
+) -> None:
+    # Best-effort; let exceptions bubble to caller for logging (caller must fail-open).
+    await publisher.xadd_json(
+        sink=StreamSink(name=str(stream), field='payload', maxlen=int(maxlen)),
+        payload=snapshot,
+        symbol=str(symbol),
+    )
