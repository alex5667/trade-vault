+    """Selector: prefer deterministic `U/u` if present, else fallback to time-gap proxy."""
+    if (book_raw.get("U") is not None) and (book_raw.get("u") is not None) and int(book_raw.get("U") or 0) > 0:
+        _update_book_seq_uu_dq(runtime, ingest_ts_ms, book_raw)
