+def _update_book_seq_uu_dq(runtime: Any, ingest_ts_ms: int, book_raw: Dict[str, Any]) -> None:
+    """Deterministic book missing-seq tracker for Binance depthUpdate streams using `U/u`.
+
+    This handles both Binance Futures and Spot *diff depth* style messages where the payload carries:
+      - U: firstUpdateId
+      - u: lastUpdateId
+
+    Continuity check:
+      gap_detected = (prev_u + 1 != cur_U)
+      gap = cur_U - prev_u - 1  (missed diff updates)
+
+    We update:
+      - runtime.book_seq_last_u (monotonic max)
+      - runtime.book_seq_last_reason (init/ok/overlap/gap/dup/reorder)
+      - runtime.book_missing_seq_last_gap (gap size for diagnostics)
+      - runtime.book_missing_seq_ema (binary EMA over gap events)
+      - runtime.book_resync_requested (one-shot flag; orchestrator publishes control message)
+    """
+    try:
+        cfg = getattr(runtime, "config", {}) or {}
+        now_ms = int(ingest_ts_ms or 0)
+
+        tau_ms = int(cfg.get("dq_book_seq_tau_ms", 1000) or 1000)
+
+        # Lazy init of the EMA tracker (fail-open).
+        if not hasattr(runtime, "book_seq_gap") or getattr(runtime, "book_seq_gap") is None:
+            from core.seq_gap_tracker_v1 import GapEmaTracker
+            runtime.book_seq_gap = GapEmaTracker(tau_ms=tau_ms, init=0.0)
+
+        # Defaults
+        if not hasattr(runtime, "book_missing_seq_ema"):
+            runtime.book_missing_seq_ema = 0.0
+        if not hasattr(runtime, "book_missing_seq_last_gap"):
+            runtime.book_missing_seq_last_gap = 0
+        if not hasattr(runtime, "book_seq_last_reason"):
+            runtime.book_seq_last_reason = "init"
+        if not hasattr(runtime, "book_resync_requested"):
+            runtime.book_resync_requested = False
+        if not hasattr(runtime, "book_resync_last_ts_ms"):
+            runtime.book_resync_last_ts_ms = 0
+
+        prev_u = int(getattr(runtime, "book_seq_last_u", 0) or 0)
+        cur_U = int(book_raw.get("U") or 0)
+        cur_u = int(book_raw.get("u") or 0)
+
+        # Init
+        if prev_u <= 0:
+            runtime.book_seq_last_u = cur_u or cur_U
+            runtime.book_seq_last_reason = "init"
+            runtime.book_missing_seq_last_gap = 0
+            runtime.book_missing_seq_ema = float(runtime.book_seq_gap.update(False, now_ms))
+            return
+
+        reason = "ok"
+        is_gap = False
+        last_gap = 0
+
+        # DUP/OLD: the whole update is older (or equal) than what we've already applied.
+        if cur_u and cur_u <= prev_u:
+            reason = "dup"
+
+        # GAP: missing diff-updates between last_u and current_U.
+        elif cur_U and cur_U > (prev_u + 1):
+            is_gap = True
+            last_gap = int(cur_U - prev_u - 1)
+            reason = "gap"
+
+        # OVERLAP / OK: the expected next update id is covered by [U..u]
+        elif cur_U and cur_u and (cur_U <= (prev_u + 1) <= cur_u):
+            if cur_U <= prev_u:
+                reason = "overlap"
+            else:
+                reason = "ok"
+
+        # REORDER / unknown edge: keep fail-open.
+        else:
+            reason = "reorder"
+
+        runtime.book_seq_last_reason = reason
+        runtime.book_missing_seq_last_gap = last_gap
+        runtime.book_missing_seq_ema = float(runtime.book_seq_gap.update(is_gap, now_ms))
+
+        # Keep last_u monotonic on overlaps.
+        if cur_u:
+            runtime.book_seq_last_u = max(prev_u, cur_u)
+        elif cur_U:
+            runtime.book_seq_last_u = max(prev_u, cur_U)
+
+        # Optional: request resync on sustained gaps (cooldown-protected).
+        if is_gap:
+            thr = float(cfg.get("book_resync_ema_threshold", 0.30) or 0.30)
+            cooldown_ms = int(cfg.get("book_resync_cooldown_ms", 10_000) or 10_000)
+            last_req = int(getattr(runtime, "book_resync_last_ts_ms", 0) or 0)
+            if (float(runtime.book_missing_seq_ema) >= thr) and (now_ms - last_req >= cooldown_ms):
+                runtime.book_resync_requested = True
+                runtime.book_resync_last_ts_ms = now_ms
+                # Provide structured context for the orchestrator / Go-worker.
+                runtime.book_resync_reason = "gap"
+                runtime.book_resync_action = "resubscribe"
+
+    except Exception:
+        pass
+
+
