+// runBookResyncListener listens to a Redis Stream with control-plane messages emitted by the Python worker.
+//
+// Stream schema (XADD):
+//   symbol=<SYM> ts_ms=<epoch_ms> reason=<gap|timegap|...> action=<resubscribe|reconnect> ema=<float> last_gap=<int>
+//
+// Behavior:
+//   - resubscribe: unsubscribe+subscribe (depth20 + aggTrade) for that symbol on the active multiplex manager
+//   - reconnect:   force a full reconnect by canceling the active manager (heavy; use sparingly)
+//
+// Safety:
+//   - opt-in via env FUTURES_BOOK_RESYNC_ENABLED=1
+//   - per-symbol cooldown to avoid thrash
+func (c *FuturesStreamController) runBookResyncListener(ctx context.Context) {
+	enabled := os.Getenv("FUTURES_BOOK_RESYNC_ENABLED")
+	if enabled == "" {
+		enabled = "0"
+	}
+	if enabled != "1" && enabled != "true" && enabled != "TRUE" {
+		return
+	}
+
+	stream := os.Getenv("FUTURES_BOOK_RESYNC_STREAM")
+	if stream == "" {
+		stream = "stream:book_resync_requests"
+	}
+	group := os.Getenv("FUTURES_BOOK_RESYNC_GROUP")
+	if group == "" {
+		group = "go-worker"
+	}
+	consumer := os.Getenv("FUTURES_BOOK_RESYNC_CONSUMER")
+	if consumer == "" {
+		if h, err := os.Hostname(); err == nil && h != "" {
+			consumer = h
+		} else {
+			consumer = "go-worker"
+		}
+	}
+
+	cooldownMs := int64(5000)
+	if v := os.Getenv("FUTURES_BOOK_RESYNC_COOLDOWN_MS"); v != "" {
+		if n, err := strconv.ParseInt(v, 10, 64); err == nil && n > 0 {
+			cooldownMs = n
+		}
+	}
+
+	// Create consumer group (mkstream), ignore BUSYGROUP.
+	_ = c.client.XGroupCreateMkStream(ctx, stream, group, "$").Err()
+
+	last := make(map[string]time.Time)
+	for {
+		select {
+		case <-ctx.Done():
+			return
+		default:
+		}
+
+		res, err := c.client.XReadGroup(ctx, &redis.XReadGroupArgs{
+			Group:    group,
+			Consumer: consumer,
+			Streams:  []string{stream, ">"},
+			Count:    16,
+			Block:    5 * time.Second,
+		}).Result()
+		if err != nil {
+			if err == redis.Nil {
+				continue
+			}
+			// fail-open: keep the main stream controller alive
+			time.Sleep(500 * time.Millisecond)
+			continue
+		}
+
+		for _, xs := range res {
+			for _, msg := range xs.Messages {
+				sym := ""
+				if v, ok := msg.Values["symbol"]; ok {
+					sym = fmt.Sprint(v)
+				} else if v, ok := msg.Values["sym"]; ok {
+					sym = fmt.Sprint(v)
+				}
+				reason := ""
+				if v, ok := msg.Values["reason"]; ok {
+					reason = fmt.Sprint(v)
+				}
+				action := "resubscribe"
+				if v, ok := msg.Values["action"]; ok {
+					action = fmt.Sprint(v)
+				}
+
+				if sym == "" {
+					_, _ = c.client.XAck(ctx, stream, group, msg.ID).Result()
+					continue
+				}
+
+				now := time.Now()
+				if t0, ok := last[sym]; ok {
+					if now.Sub(t0) < (time.Duration(cooldownMs) * time.Millisecond) {
+						_, _ = c.client.XAck(ctx, stream, group, msg.ID).Result()
+						continue
+					}
+				}
+				last[sym] = now
+
+				if action == "reconnect" {
+					c.forceReconnect(ctx, "book_resync:"+reason)
+				} else {
+					c.resubscribeSymbol(sym)
+				}
+
+				_, _ = c.client.XAck(ctx, stream, group, msg.ID).Result()
+			}
+		}
+	}
+}
+
+
+// resubscribeSymbol performs a best-effort unsubscribe+subscribe cycle for one symbol on the active manager.
+// This is cheaper than reconnecting all streams and is usually enough to recover from local book gaps.
+func (c *FuturesStreamController) resubscribeSymbol(sym string) {
+	c.mu.Lock()
+	mgr := c.activeManager
+	c.mu.Unlock()
+	if mgr == nil {
+		return
+	}
+
+	// Remove + add back to force the server-side subscription to refresh.
+	_ = mgr.UpdateSubscriptions(nil, []string{sym})
+	time.Sleep(200 * time.Millisecond)
+	_ = mgr.UpdateSubscriptions([]string{sym}, nil)
+}
+
+
+// forceReconnect cancels the active manager so the controller reconnects the full multiplex stream.
+// Heavy hammer; use when resubscribe is not sufficient.
+func (c *FuturesStreamController) forceReconnect(ctx context.Context, reason string) {
+	c.mu.Lock()
+	cancel := c.activeManagerCancel
+	c.mu.Unlock()
+	if cancel != nil {
+		cancel()
+	}
+	// The main Run() loop will start a fresh manager on the next refresh tick.
+	_ = reason
+}
