+def should_enforce_dq_veto(dq_veto: int, dq_reason_bucket: str, cfg2: Dict[str, Any], uptime_s: float) -> bool:
+    """Rollout guard for DQ hard-veto.
+
+    We enforce dq_veto only when:
+      - dq_gate_mode is one of: enforce | both | veto
+      - For bucket == 'book_seq': explicitly enabled AND warmup elapsed
+
+    This keeps *observe-only* behavior as default for book-seq gaps, while still
+    reporting dq_level/dq_veto for dashboards.
+    """
+    if not int(dq_veto or 0):
+        return False
+    mode = str((cfg2 or {}).get("dq_gate_mode", "off") or "off").lower()
+    if mode not in ("enforce", "both", "veto"):
+        return False
+
+    if dq_reason_bucket == "book_seq":
+        enabled = int((cfg2 or {}).get("dq_book_veto_enabled", 0) or 0)
+        warmup_s = float((cfg2 or {}).get("dq_book_veto_warmup_s", 86400) or 86400)
+        if enabled <= 0:
+            return False
+        if float(uptime_s or 0.0) < warmup_s:
+            return False
+
+    return True
