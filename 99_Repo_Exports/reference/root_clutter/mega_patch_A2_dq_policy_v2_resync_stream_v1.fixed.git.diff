+import time
+
+from tick_flow_full.core.of_confirm_engine import should_enforce_dq_veto
+
+
+def test_should_enforce_dq_veto_off_mode():
+    cfg2 = {"dq_gate_mode": "off", "dq_book_veto_enabled": 1, "dq_book_veto_warmup_s": 0}
+    assert should_enforce_dq_veto(1, "tick_gap", cfg2, uptime_s=10.0) is False
+
+
+def test_should_enforce_dq_veto_non_book_bucket_enforces_when_mode_enforce():
+    cfg2 = {"dq_gate_mode": "enforce", "dq_book_veto_enabled": 0, "dq_book_veto_warmup_s": 86400}
+    assert should_enforce_dq_veto(1, "tick_gap", cfg2, uptime_s=0.0) is True
+
+
+def test_should_enforce_dq_veto_book_bucket_requires_enable_flag():
+    cfg2 = {"dq_gate_mode": "enforce", "dq_book_veto_enabled": 0, "dq_book_veto_warmup_s": 0}
+    assert should_enforce_dq_veto(1, "book_seq", cfg2, uptime_s=99999.0) is False
+
+
+def test_should_enforce_dq_veto_book_bucket_requires_warmup_elapsed():
+    cfg2 = {"dq_gate_mode": "enforce", "dq_book_veto_enabled": 1, "dq_book_veto_warmup_s": 3600}
+    assert should_enforce_dq_veto(1, "book_seq", cfg2, uptime_s=10.0) is False
+    assert should_enforce_dq_veto(1, "book_seq", cfg2, uptime_s=3600.0) is True
diff --git a/tick_flow_full/tests/services/orderflow/components/test_book_seq_tracker_uu.py b/tick_flow_full/tests/services/orderflow/components/test_book_seq_tracker_uu.py
new file mode 100644
index 0000000..66d67af
--- /dev/null
+++ b/tick_flow_full/tests/services/orderflow/components/test_book_seq_tracker_uu.py
@@ -0,0 +1,35 @@
+from types import SimpleNamespace
+
+from tick_flow_full.services.orderflow.components.book_processor import _update_book_seq_uu_dq
+
+
+def test_book_seq_tracker_uu_ok_and_gap_and_resync_flag():
+    runtime = SimpleNamespace()
+    runtime.config = {
+        "dq_book_seq_tau_ms": 1000,             # ~alpha 0.1 at 10Hz
+        "book_resync_ema_threshold": 0.05,      # trigger quickly for the test
+        "book_resync_cooldown_ms": 0,           # disable cooldown in unit test
+    }
+
+    # init (no ema "gap")
+    _update_book_seq_uu_dq(runtime, ingest_ts_ms=0, book_raw={"U": 100, "u": 105})
+    assert runtime.book_seq_last_reason == "init"
+    assert int(runtime.book_seq_last_u) == 105
+    assert float(runtime.book_missing_seq_ema) == 0.0
+    assert int(runtime.book_missing_seq_last_gap) == 0
+    assert getattr(runtime, "book_resync_requested", False) is False
+
+    # overlap/ok
+    _update_book_seq_uu_dq(runtime, ingest_ts_ms=100, book_raw={"U": 106, "u": 110})
+    assert runtime.book_seq_last_reason in ("ok", "overlap")
+    assert int(runtime.book_seq_last_u) == 110
+    assert int(runtime.book_missing_seq_last_gap) == 0
+
+    # gap (U skips ahead)
+    _update_book_seq_uu_dq(runtime, ingest_ts_ms=200, book_raw={"U": 120, "u": 125})
+    assert runtime.book_seq_last_reason == "gap"
+    assert int(runtime.book_missing_seq_last_gap) == 9  # 120 - 110 - 1
+    assert float(runtime.book_missing_seq_ema) > 0.0
+    assert getattr(runtime, "book_resync_requested", False) is True
+    assert getattr(runtime, "book_resync_reason", "") == "gap"
+    assert getattr(runtime, "book_resync_action", "") == "resubscribe"
