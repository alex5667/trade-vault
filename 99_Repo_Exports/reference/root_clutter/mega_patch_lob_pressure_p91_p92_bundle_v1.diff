+++ /mnt/data/proj_lob_p92/tick_flow_full/services/orderflow/tests/test_lob_pressure_v1.py	2026-02-24 21:05:53.115252190 +0000
@@ -0,0 +1,54 @@
+"""
+Unit tests for core.lob_pressure (P91).
+
+Covers:
+- queue imbalance per level
+- microprice vs mid divergence (bps)
+- depth-weighted OBI sign and magnitude
+"""
+
+import os
+import sys
+import math
+
+import pytest
+
+# Ensure tick_flow_full/ is on PYTHONPATH so `import core.*` works in pytest environments.
+REPO_ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__), "../../.."))
+TICK_FLOW_FULL = os.path.join(REPO_ROOT, "tick_flow_full")
+if TICK_FLOW_FULL not in sys.path:
+    sys.path.insert(0, TICK_FLOW_FULL)
+
+from core.lob_pressure import compute_lob_pressure
+
+
+def test_basic_queue_imbalance_and_microprice():
+    bids = [(100.0, 10.0), (99.0, 9.0), (98.0, 8.0), (97.0, 7.0), (96.0, 6.0)]
+    asks = [(101.0, 5.0), (102.0, 4.0), (103.0, 3.0), (104.0, 2.0), (105.0, 1.0)]
+
+    lp = compute_lob_pressure(bids=bids, asks=asks)
+
+    # L1 queue imbalance: (10-5)/(10+5)=1/3
+    assert lp.qi_levels[0] == pytest.approx(1.0 / 3.0, rel=1e-6)
+
+    # Mean should be positive (more bid qty overall by construction)
+    assert lp.qi_mean > 0.0
+
+    # Microprice should be between best bid and best ask => divergence sign should be positive
+    assert lp.micro_mid_div_bps > 0.0
+
+    # Depth-weighted OBI should be positive
+    assert lp.dw_obi > 0.0
+
+
+def test_micro_shift_uses_prev_when_available():
+    bids1 = [(100.0, 10.0), (99.0, 9.0), (98.0, 8.0), (97.0, 7.0), (96.0, 6.0)]
+    asks1 = [(101.0, 5.0), (102.0, 4.0), (103.0, 3.0), (104.0, 2.0), (105.0, 1.0)]
+
+    bids0 = [(100.0, 5.0), (99.0, 5.0), (98.0, 5.0), (97.0, 5.0), (96.0, 5.0)]
+    asks0 = [(101.0, 10.0), (102.0, 10.0), (103.0, 10.0), (104.0, 10.0), (105.0, 10.0)]
+
+    lp = compute_lob_pressure(bids=bids1, asks=asks1, prev_bids=bids0, prev_asks=asks0)
+
+    # shift should be non-zero because prev micro differs (qtys swapped)
+    assert abs(lp.micro_shift_bps) > 0.0
