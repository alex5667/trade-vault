+groups:
+- name: lob_pressure_p92
+  interval: 30s
+  rules:
+      # ─────────────────────────────
+      # Recording rules (P92)
+      # ─────────────────────────────
+  - record: of_lob:micro_mid_div_p99_10m
+    expr: quantile_over_time(0.99, of_lob_micro_mid_div_bps[10m])
+  - record: of_lob:micro_mid_div_p01_10m
+    expr: quantile_over_time(0.01, of_lob_micro_mid_div_bps[10m])
+
+  - record: of_lob:micro_shift_p99_10m
+    expr: quantile_over_time(0.99, of_lob_micro_shift_bps[10m])
+  - record: of_lob:micro_shift_p01_10m
+    expr: quantile_over_time(0.01, of_lob_micro_shift_bps[10m])
+
+  - record: of_lob:queue_imb_max_abs_p95_10m
+    expr: quantile_over_time(0.95, of_lob_queue_imbalance_max_abs[10m])
+
+  - record: of_lob:dw_obi_z_p99_30m
+    expr: quantile_over_time(0.99, of_lob_dw_obi_z[30m])
+  - record: of_lob:dw_obi_z_p01_30m
+    expr: quantile_over_time(0.01, of_lob_dw_obi_z[30m])
+
+      # ─────────────────────────────
+      # Alerts (P92)
+      # ─────────────────────────────
+  - alert: OF_LOB_MicroMidDivExtreme_Warn
+    expr: (of_lob:micro_mid_div_p99_10m > 12) or (of_lob:micro_mid_div_p01_10m < -12)
+    for: 10m
+    labels:
+      severity: warning
+    annotations:
+      summary: "LOB: microprice divergence extreme (p99/p01)"
+      description: "Microprice divergence vs mid is extreme (p99>12bps or p01<-12bps) for 10m. Can be regime shift or stale/partial book feed."
+
+      runbook_path: /runbooks/runbook_lob_pressure_p92.md
+      dashboard_path: /d/lob_pressure_p92
+  - alert: OF_LOB_MicroMidDivExtreme_Crit
+    expr: (of_lob:micro_mid_div_p99_10m > 20) or (of_lob:micro_mid_div_p01_10m < -20)
+    for: 10m
+    labels:
+      severity: critical
+    annotations:
+      summary: "LOB: microprice divergence extreme (crit)"
+      description: "Microprice divergence vs mid is very extreme (p99>20bps or p01<-20bps) for 10m."
+
+      runbook_path: /runbooks/runbook_lob_pressure_p92.md
+      dashboard_path: /d/lob_pressure_p92
+
+  - alert: OF_LOB_MicroShiftExtreme_Warn
+    expr: (of_lob:micro_shift_p99_10m > 15) or (of_lob:micro_shift_p01_10m < -15)
+    for: 5m
+    labels:
+      severity: warning
+    annotations:
+      summary: "LOB: microprice shift extreme (p99/p01)"
+      description: "Microprice shift is extreme (p99>15bps or p01<-15bps) for 5m. Often signals fast pressure / thin liquidity."
+
+      runbook_path: /runbooks/runbook_lob_pressure_p92.md
+      dashboard_path: /d/lob_pressure_p92
+  - alert: OF_LOB_MicroShiftExtreme_Crit
+    expr: (of_lob:micro_shift_p99_10m > 25) or (of_lob:micro_shift_p01_10m < -25)
+    for: 5m
+    labels:
+      severity: critical
+    annotations:
+      summary: "LOB: microprice shift extreme (crit)"
+      description: "Microprice shift is very extreme (p99>25bps or p01<-25bps) for 5m."
+
+      runbook_path: /runbooks/runbook_lob_pressure_p92.md
+      dashboard_path: /d/lob_pressure_p92
+
+  - alert: OF_LOB_QueueImbalancePersistent_Warn
+    expr: of_lob:queue_imb_max_abs_p95_10m > 0.75
+    for: 15m
+    labels:
