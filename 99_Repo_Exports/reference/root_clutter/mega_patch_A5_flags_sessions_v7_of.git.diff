+"""MLFeatureSchemaV7OF
+
+v7_of = v6_of + A5 flags (bool -> 0/1) + session one-hot in edge-stack spec.
+
+Важно:
+- В сам schema добавлены только A5 flags (bool_keys).
+- Session one-hot (session_asia/eu/us/off) не является частью schema-ключей, потому что
+  эти колонки генерируются gate-слоем детерминированно из ts_ms (train==serve).
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+
+from core.ml_feature_schema_v6_of import MLFeatureSchemaV6OF
+
+
+_A5_BOOL_KEYS = [
+    # A5: runtime flags (encoded as 0/1)
+    "flag_high_vol",
+    "flag_low_liquidity",
+    "flag_large_trade",
+    "flag_mean_reversion_mode",
+    "flag_session_open",
+    "flag_session_close",
+    "flag_macro_event",
+]
+
+
+@dataclass
+class MLFeatureSchemaV7OF(MLFeatureSchemaV6OF):
+    """v7_of = v6_of + A5 flags."""
+
+    def __post_init__(self) -> None:
+        super().__post_init__()
+        # keep order stable and de-dup
+        bk = list(self.bool_keys or [])
+        for k in _A5_BOOL_KEYS:
+            if k not in bk:
+                bk.append(k)
+        self.bool_keys = bk
