diff --git a/internal/liquidation/binance_forceorder.go b/internal/liquidation/binance_forceorder.go
new file mode 100644
index 0000000..21e3ec6
--- /dev/null
+++ b/internal/liquidation/binance_forceorder.go
@@ -0,0 +1,108 @@
+package liquidation
+
+import (
+	"encoding/json"
+	"errors"
+	"strings"
+	"time"
+)
+
+// Binance USDT-M Force Order Stream.
+//
+// Для all-market stream используется endpoint:
+//   wss://fstream.binance.com/ws/!forceOrder@arr
+//
+// Формат сообщения совпадает с обычным <symbol>@forceOrder.
+//
+// Семантика стороны:
+//   В payload Binance поле o.S — сторона ордера (BUY/SELL).
+//   Для force liquidation это обычно означает:
+//     * SELL ордер закрывает LONG позицию  => ликвидирован LONG
+//     * BUY  ордер закрывает SHORT позицию => ликвидирован SHORT
+//
+// Поле o.X — статус ордера (NEW / PARTIALLY_FILLED / FILLED / ...).
+// Для heatmap нас интересуют прежде всего события с ненулевым filled qty.
+type binanceForceOrderMsg struct {
+	EventTime int64                `json:"E"`
+	Order     binanceForceOrderObj `json:"o"`
+}
+
+type binanceForceOrderObj struct {
+	Symbol string `json:"s"`
+	Side   string `json:"S"`  // BUY/SELL
+	Status string `json:"X"`  // order status
+	Price  string `json:"p"`  // order price
+	AvgPx  string `json:"ap"` // average price
+	Qty    string `json:"q"`  // orig qty
+	FillQ  string `json:"z"`  // filled qty
+	T      int64  `json:"T"`  // trade time
+}
+
+// ParseBinanceForceOrder нормализует одно Binance сообщение в LiqEventV1.
+func ParseBinanceForceOrder(raw []byte, nowMs int64) (LiqEventV1, error) {
+	var msg binanceForceOrderMsg
+	if err := json.Unmarshal(raw, &msg); err != nil {
+		return LiqEventV1{}, err
+	}
+
+	sym := strings.ToUpper(strings.TrimSpace(msg.Order.Symbol))
+	if sym == "" {
+		return LiqEventV1{}, wrapReason("missing_symbol", errors.New("missing symbol"))
+	}
+
+	orderSide := strings.ToUpper(strings.TrimSpace(msg.Order.Side))
+	liqSide := ""
+	switch orderSide {
+	case "SELL":
+		liqSide = "long"
+	case "BUY":
+		liqSide = "short"
+	default:
+		return LiqEventV1{}, wrapReason("unknown_side", errors.New("unknown side"))
+	}
+
+	// Предпочитаем average price (ap), если она есть.
+	price := strings.TrimSpace(msg.Order.AvgPx)
+	if price == "" || price == "0" {
+		price = strings.TrimSpace(msg.Order.Price)
+	}
+
+	qty := strings.TrimSpace(msg.Order.FillQ)
+	if qty == "" || qty == "0" {
+		qty = strings.TrimSpace(msg.Order.Qty)
+	}
+
+	// Trade time точнее для heatmap.
+	ts := msg.Order.T
+	if ts <= 0 {
+		ts = msg.EventTime
+	}
+	if ts <= 0 {
+		ts = time.Now().UnixMilli()
+	}
+
+	if !isPositiveDecimalString(price) {
+		return LiqEventV1{}, wrapReason("bad_price", errors.New("non-positive price"))
+	}
+	if !isPositiveDecimalString(qty) {
+		return LiqEventV1{}, wrapReason("bad_qty", errors.New("non-positive qty"))
+	}
+
+	notional, err := mulDecimalStrings(price, qty)
+	if err != nil {
+		return LiqEventV1{}, wrapReason("bad_notional", err)
+	}
+
+	return LiqEventV1{
+		TsEventMs:   ts,
+		TsIngestMs:  nowMs,
+		Venue:       "binance_usdtm",
+		Symbol:      sym,
+		OrderSide:   orderSide,
+		LiqSide:     liqSide,
+		Price:       price,
+		Qty:         qty,
+		NotionalUsd: notional,
+		Status:      strings.TrimSpace(msg.Order.Status),
+	}, nil
+}
diff --git a/internal/liquidation/binance_forceorder_test.go b/internal/liquidation/binance_forceorder_test.go
new file mode 100644
index 0000000..c0ed9f7
--- /dev/null
+++ b/internal/liquidation/binance_forceorder_test.go
@@ -0,0 +1,39 @@
+package liquidation
+
+import "testing"
+
+func TestParseBinanceForceOrder(t *testing.T) {
+	// Минимальный пример, приближенный к реальному payload (часть полей опущена).
+	raw := []byte(`{"e":"forceOrder","E":1710000000123,"o":{"s":"BTCUSDT","S":"SELL","X":"FILLED","p":"50000","ap":"50010","q":"0.10","z":"0.08","T":1710000000456}}`)
+	ev, err := ParseBinanceForceOrder(raw, 1710000000999)
+	if err != nil {
+		t.Fatalf("unexpected err: %v", err)
+	}
+	if ev.Venue != "binance_usdtm" {
+		t.Fatalf("bad venue: %q", ev.Venue)
+	}
+	if ev.Symbol != "BTCUSDT" {
+		t.Fatalf("bad symbol: %q", ev.Symbol)
+	}
+	if ev.OrderSide != "SELL" {
+		t.Fatalf("expected order_side=SELL, got %q", ev.OrderSide)
+	}
+	if ev.LiqSide != "long" {
+		t.Fatalf("expected liq_side=long, got %q", ev.LiqSide)
+	}
+	if ev.Status != "FILLED" {
+		t.Fatalf("expected status=FILLED, got %q", ev.Status)
+	}
+	if ev.Price != "50010" {
+		t.Fatalf("expected avg price, got %q", ev.Price)
+	}
+	if ev.Qty != "0.08" {
+		t.Fatalf("expected filled qty, got %q", ev.Qty)
+	}
+	if ev.TsEventMs != 1710000000456 {
+		t.Fatalf("expected trade time, got %d", ev.TsEventMs)
+	}
+	if ev.TsIngestMs != 1710000000999 {
+		t.Fatalf("expected ingest time, got %d", ev.TsIngestMs)
+	}
+}
diff --git a/internal/liquidation/bybit_all_liquidation.go b/internal/liquidation/bybit_all_liquidation.go
new file mode 100644
index 0000000..9b2f1cb
--- /dev/null
+++ b/internal/liquidation/bybit_all_liquidation.go
@@ -0,0 +1,114 @@
+package liquidation
+
+import (
+	"encoding/json"
+	"errors"
+	"strings"
+	"time"
+)
+
+// Bybit V5 Public allLiquidation stream.
+// Topic: allLiquidation.{symbol}
+// Endpoint (USDT perpetual / futures): wss://stream.bybit.com/v5/public/linear
+//
+// Нюанс:
+//   поле data[].p в документации называется "Bankruptcy price".
+//   Heatmap сервисы часто используют именно bankruptcy price как уровень.
+//   Мы сохраняем его как price.
+//
+// Сторона (data[].S):
+//   - Buy  => long liquidation
+//   - Sell => short liquidation
+//
+// Док: https://bybit-exchange.github.io/docs/v5/websocket/public/all-liquidation
+type bybitAllLiqMsg struct {
+	Topic string           `json:"topic"`
+	Ts    int64            `json:"ts"`
+	Data  []bybitAllLiqRow `json:"data"`
+
+	// служебные поля (pong/subscribe responses)
+	Op      string `json:"op"`
+	Success *bool  `json:"success"`
+	RetMsg  string `json:"ret_msg"`
+}
+
+type bybitAllLiqRow struct {
+	T  int64  `json:"T"` // timestamp (ms)
+	S  string `json:"S"` // Buy/Sell
+	Sx string `json:"s"` // symbol
+
+	V string `json:"v"` // size
+	P string `json:"p"` // bankruptcy price
+}
+
+// ParseBybitAllLiquidation может вернуть несколько событий (data array).
+func ParseBybitAllLiquidation(raw []byte, nowMs int64) ([]LiqEventV1, error) {
+	var msg bybitAllLiqMsg
+	if err := json.Unmarshal(raw, &msg); err != nil {
+		return nil, err
+	}
+
+	// Серверные ответы (pong/subscribe) не содержат topic/data.
+	if msg.Op != "" {
+		return nil, nil
+	}
+	if len(msg.Data) == 0 {
+		return nil, nil
+	}
+
+	out := make([]LiqEventV1, 0, len(msg.Data))
+	for _, row := range msg.Data {
+		sym := strings.ToUpper(strings.TrimSpace(row.Sx))
+		if sym == "" {
+			return nil, wrapReason("missing_symbol", errors.New("missing symbol"))
+		}
+
+		rawSide := strings.TrimSpace(row.S)
+		orderSide := strings.ToUpper(rawSide)
+		liqSide := ""
+		switch strings.ToLower(rawSide) {
+		case "buy":
+			liqSide = "long"
+		case "sell":
+			liqSide = "short"
+		default:
+			return nil, wrapReason("unknown_side", errors.New("unknown side"))
+		}
+
+		price := strings.TrimSpace(row.P)
+		qty := strings.TrimSpace(row.V)
+		ts := row.T
+		if ts <= 0 {
+			ts = msg.Ts
+		}
+		if ts <= 0 {
+			ts = time.Now().UnixMilli()
+		}
+
+		if !isPositiveDecimalString(price) {
+			return nil, wrapReason("bad_price", errors.New("non-positive price"))
+		}
+		if !isPositiveDecimalString(qty) {
+			return nil, wrapReason("bad_qty", errors.New("non-positive qty"))
+		}
+
+		notional, err := mulDecimalStrings(price, qty)
+		if err != nil {
+			return nil, wrapReason("bad_notional", err)
+		}
+
+		out = append(out, LiqEventV1{
+			TsEventMs:   ts,
+			TsIngestMs:  nowMs,
+			Venue:       "bybit_linear",
+			Symbol:      sym,
+			OrderSide:   orderSide,
+			LiqSide:     liqSide,
+			Price:       price,
+			Qty:         qty,
+			NotionalUsd: notional,
+			Status:      "",
+		})
+	}
+	return out, nil
+}
diff --git a/internal/liquidation/bybit_all_liquidation_test.go b/internal/liquidation/bybit_all_liquidation_test.go
