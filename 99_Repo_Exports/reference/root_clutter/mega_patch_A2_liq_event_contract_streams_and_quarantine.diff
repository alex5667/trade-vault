+# --- Core WS (ticks / book / futures) ---
+# FUTURES_WS_ENABLED=true
+# FUTURES_SYMBOLS=BTCUSDT,ETHUSDT
+
+# --- A1/A2: Liquidations (SAFE defaults) ---
+# Enable ingestion:
+# LIQ_WS_ENABLED=true
+
+# Allowlist symbols (fallback = FUTURES_SYMBOLS):
+# LIQ_SYMBOLS=BTCUSDT,ETHUSDT
+
+# Binance (рекомендуется all-market stream):
+# LIQ_BINANCE_ENABLED=true
+# LIQ_BINANCE_WS_URL=wss://fstream.binance.com/ws/!forceOrder@arr
+
+# Bybit (subscribe per symbol):
+# LIQ_BYBIT_ENABLED=false
+# LIQ_BYBIT_WS_URL=wss://stream.bybit.com/v5/public/linear
+# LIQ_BYBIT_PING_MS=20000
+
+# Redis Streams (A2):
+#   stream:liq_evt            — основной поток
+#   stream:liq_evt:quarantine — плохие/подозрительные (bad time, parse errors, etc.)
+# LIQ_STREAM=stream:liq_evt
+# LIQ_QUARANTINE_STREAM=stream:liq_evt:quarantine
+# LIQ_STREAM_MAXLEN=200000
+
+# Quarantine sampling (защита от "storm" при несовместимом payload):
+# LIQ_QUARANTINE_SAMPLE_RATE=0.05
+
+# Raw sampling (для отладки):
+#   raw добавляется в основной stream только сэмплировано.
+#   в quarantine raw добавляется всегда (но тоже ограниченно по размеру).
+# LIQ_RAW_SAMPLE_RATE=0.0
+# LIQ_RAW_MAX_BYTES=2048
+
+# Batching:
+# LIQ_BATCH_SIZE=200
+# LIQ_FLUSH_MS=20
+
+# Data Quality (SAFE):
+# LIQ_MAX_EVENT_AGE_MS=10000
+# LIQ_MAX_FUTURE_SKEW_MS=2000
+# LIQ_MAX_OOO_MS=2000
+# LIQ_ENABLE_QUARANTINE=true
