@@ -0,0 +1,38 @@
+from __future__ import annotations
+
+import importlib.util
+import json
+import sys
+from pathlib import Path
+
+MODULE = Path(__file__).resolve().parents[2] / 'runbooks' / 'server' / 'runbook_server.py'
+SPEC = importlib.util.spec_from_file_location('runbook_server', MODULE)
+mod = importlib.util.module_from_spec(SPEC)
+assert SPEC and SPEC.loader
+sys.modules[SPEC.name] = mod
+SPEC.loader.exec_module(mod)
+
+
+def test_filter_audit_chain_items_by_sid():
+    report = {
+        'generated_at_ms': 1,
+        'generated_at_iso': '1970-01-01T00:00:00+00:00',
+        'total_broken': 2,
+        'kind_totals': {'broken_signal_fk': 1, 'broken_closed_trade_fk': 1},
+        'category_totals': {'signal_plan': 1, 'trade_link': 1, 'analytics_link': 0},
+        'checks': [
+            {'kind': 'broken_signal_fk', 'status': 'broken', 'samples': [{'sid': 'sid-1', 'signal_id': 'sig-1'}]},
+            {'kind': 'broken_closed_trade_fk', 'status': 'broken', 'samples': [{'sid': 'sid-2', 'closed_trade_id': '42'}]},
+        ],
+    }
+    out = mod.filter_audit_chain_items(report, sid='sid-2')
+    assert len(out['items']) == 1
+    assert out['items'][0]['sid'] == 'sid-2'
+    assert out['items'][0]['kind'] == 'broken_closed_trade_fk'
+
+
+def test_read_latest_audit_chain_report(tmp_path: Path):
+    path = tmp_path / 'latest_execution_audit_chain.json'
+    payload = {'generated_at_ms': 123, 'checks': []}
+    path.write_text(json.dumps(payload), encoding='utf-8')
+    assert mod.read_latest_audit_chain_report(str(path))['generated_at_ms'] == 123

