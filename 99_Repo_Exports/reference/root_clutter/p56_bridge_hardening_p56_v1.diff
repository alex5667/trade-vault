+groups:
+  - name: trade_execution_p56_audit_chain
+    rules:
+      - alert: TradeExecutionAuditChainReportStale
+        expr: absent(trade_execution_audit_chain_report_timestamp_seconds) or (time() - trade_execution_audit_chain_report_timestamp_seconds > 900)
+        for: 5m
+        labels:
+          severity: warning
+          domain: execution-audit
+        annotations:
+          summary: Execution audit-chain report is stale
+          description: The latest execution audit-chain report is missing or older than 15 minutes.
+          runbook_path: /api/audit-chain/latest
+
+      - alert: TradeExecutionAuditChainBrokenSignalPlan
+        expr: sum(trade_execution_audit_chain_broken_total{kind=~"missing_signal_id|missing_execution_plan_id|broken_signal_fk|broken_execution_plan_fk"}) > 0
+        for: 10m
+        labels:
+          severity: critical
+          domain: execution-audit
+        annotations:
+          summary: Broken signal/execution-plan audit chain detected
+          description: execution_orders contains broken signal_id or execution_plan_id linkage.
+          runbook_path: /api/audit-chain/latest?kind=broken_signal_fk
+
+      - alert: TradeExecutionAuditChainBrokenTradeLink
+        expr: sum(trade_execution_audit_chain_broken_total{kind=~"broken_closed_trade_fk"}) > 0
+        for: 10m
+        labels:
+          severity: critical
+          domain: execution-audit
+        annotations:
+          summary: Broken closed-trade linkage detected
+          description: execution_orders.closed_trade_id does not resolve into trades_closed.id.
+          runbook_path: /api/audit-chain/latest?kind=broken_closed_trade_fk
+
+      - alert: TradeExecutionAuditChainBrokenAnalyticsLink
+        expr: sum(trade_execution_audit_chain_broken_total{kind=~"missing_position_events_chain|missing_position_events_chain_schema|missing_trades_closed_chain|missing_trades_closed_chain_schema|missing_entry_policy_audit_chain|missing_entry_policy_audit_chain_schema|missing_decision_snapshot_chain|missing_decision_snapshot_chain_schema"}) > 0
+        for: 10m
+        labels:
+          severity: warning
+          domain: execution-audit
+        annotations:
+          summary: Broken analytics-chain propagation detected
+          description: One or more downstream analytics tables are missing signal_id / execution_plan_id / closed_trade_id.
+          runbook_path: /api/audit-chain/latest

