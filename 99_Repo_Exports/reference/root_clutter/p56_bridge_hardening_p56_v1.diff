new file mode 100644
index 0000000..9ae0cf1
--- /dev/null
+++ b/services/tests/test_check_execution_audit_chain_p56_v1.py
@@ -0,0 +1,73 @@
+from __future__ import annotations
+
+import importlib.util
+import json
+import sqlite3
+import sys
+from pathlib import Path
+
+SCRIPT = Path(__file__).resolve().parents[2] / 'scripts' / 'check_execution_audit_chain.py'
+SPEC = importlib.util.spec_from_file_location('check_execution_audit_chain', SCRIPT)
+mod = importlib.util.module_from_spec(SPEC)
+assert SPEC and SPEC.loader
+sys.modules[SPEC.name] = mod
+SPEC.loader.exec_module(mod)
+
+
+def _setup_db(path: Path) -> str:
+    conn = sqlite3.connect(path)
+    cur = conn.cursor()
+    cur.executescript(
+        '''
+        CREATE TABLE execution_orders (
+            sid TEXT PRIMARY KEY,
+            signal_id TEXT,
+            execution_plan_id TEXT,
+            closed_trade_id TEXT
+        );
+        CREATE TABLE signals (signal_id TEXT PRIMARY KEY);
+        CREATE TABLE signal_execution_plan (execution_plan_id TEXT PRIMARY KEY);
+        CREATE TABLE trades_closed (id INTEGER PRIMARY KEY, sid TEXT, symbol TEXT, signal_id TEXT, execution_plan_id TEXT, closed_trade_id TEXT);
+        CREATE TABLE position_events (stream_id TEXT PRIMARY KEY, position_id TEXT, sid TEXT, symbol TEXT, signal_id TEXT, execution_plan_id TEXT, closed_trade_id TEXT);
+        CREATE TABLE entry_policy_audit (stream_id TEXT PRIMARY KEY, sid TEXT, symbol TEXT, tf TEXT, signal_id TEXT, execution_plan_id TEXT, closed_trade_id TEXT);
+        CREATE TABLE decision_snapshot (sid TEXT PRIMARY KEY, symbol TEXT, ts_decision_ms INTEGER, signal_id TEXT, execution_plan_id TEXT, closed_trade_id TEXT);
+        '''
+    )
+    cur.execute("INSERT INTO signals(signal_id) VALUES ('sig_ok')")
+    cur.execute("INSERT INTO signal_execution_plan(execution_plan_id) VALUES ('plan_ok')")
+    cur.execute("INSERT INTO trades_closed(id, sid, symbol, signal_id, execution_plan_id, closed_trade_id) VALUES (1, 's_ok', 'BTCUSDT', 'sig_ok', 'plan_ok', '1')")
+    cur.execute("INSERT INTO execution_orders(sid, signal_id, execution_plan_id, closed_trade_id) VALUES ('s_ok', 'sig_ok', 'plan_ok', '1')")
+    cur.execute("INSERT INTO execution_orders(sid, signal_id, execution_plan_id, closed_trade_id) VALUES ('s_missing_sig', '', 'plan_ok', '1')")
+    cur.execute("INSERT INTO execution_orders(sid, signal_id, execution_plan_id, closed_trade_id) VALUES ('s_bad_plan', 'sig_ok', 'plan_missing', '999')")
+    cur.execute("INSERT INTO position_events(stream_id, position_id, sid, symbol, signal_id, execution_plan_id, closed_trade_id) VALUES ('1-0', 'p1', 's_ok', 'BTCUSDT', '', 'plan_ok', '1')")
+    cur.execute("INSERT INTO entry_policy_audit(stream_id, sid, symbol, tf, signal_id, execution_plan_id, closed_trade_id) VALUES ('2-0', 's_ok', 'BTCUSDT', '1m', 'sig_ok', '', '1')")
+    cur.execute("INSERT INTO decision_snapshot(sid, symbol, ts_decision_ms, signal_id, execution_plan_id, closed_trade_id) VALUES ('s_ok', 'BTCUSDT', 1000, 'sig_ok', 'plan_ok', '')")
+    conn.commit()
+    conn.close()
+    return f'sqlite:///{path}'
+
+
+def test_build_report_detects_expected_broken_kinds(tmp_path: Path):
+    dsn = _setup_db(tmp_path / 'audit.db')
+    report = mod.build_report(dsn=dsn, sample_limit=5)
+    assert report.total_broken >= 5
+    assert report.kind_totals['missing_signal_id'] == 1
+    assert report.kind_totals['broken_execution_plan_fk'] == 1
+    assert report.kind_totals['broken_closed_trade_fk'] == 1
+    assert report.kind_totals['missing_position_events_chain'] == 1
+    assert report.kind_totals['missing_entry_policy_audit_chain'] == 1
+    assert report.kind_totals['missing_decision_snapshot_chain'] == 1
+
+
+def test_write_report_and_textfile(tmp_path: Path):
+    dsn = _setup_db(tmp_path / 'audit.db')
+    report = mod.build_report(dsn=dsn)
+    report_path = tmp_path / 'latest_execution_audit_chain.json'
+    textfile_path = tmp_path / 'latest_execution_audit_chain.prom'
+    mod.write_report_json(report, str(report_path))
+    mod.write_textfile(report, str(textfile_path))
+    data = json.loads(report_path.read_text(encoding='utf-8'))
+    text = textfile_path.read_text(encoding='utf-8')
+    assert data['total_broken'] == report.total_broken
+    assert 'trade_execution_audit_chain_total_broken' in text
+    assert 'trade_execution_audit_chain_broken_total{kind="missing_signal_id"}' in text

