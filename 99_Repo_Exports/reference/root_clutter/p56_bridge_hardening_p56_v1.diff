@@ -0,0 +1,123 @@
+from __future__ import annotations
+
+"""Minimal runbook server endpoints for execution audit-chain reports (P5.6)."""
+
+from pathlib import Path
+from typing import Any, Dict, List, Optional
+import json
+import os
+
+from fastapi import FastAPI, HTTPException, Query
+
+
+def _env(name: str, default: str) -> str:
+    v = os.getenv(name)
+    return str(v) if v is not None and str(v) != '' else default
+
+
+AUDIT_CHAIN_REPORT_PATH = _env('AUDIT_CHAIN_REPORT_PATH', 'latest_execution_audit_chain.json')
+
+app = FastAPI(
+    title='Trade Runbook Server',
+    description='Operational JSON endpoints for trade execution runbooks.',
+    version='p5.6',
+)
+
+
+def read_latest_audit_chain_report(path: Optional[str] = None) -> Dict[str, Any]:
+    report_path = Path(path or AUDIT_CHAIN_REPORT_PATH)
+    if not report_path.exists():
+        raise FileNotFoundError(f'audit-chain report not found: {report_path}')
+    return json.loads(report_path.read_text(encoding='utf-8'))
+
+
+def _flatten_items(report: Dict[str, Any]) -> List[Dict[str, Any]]:
+    items = report.get('items')
+    if isinstance(items, list):
+        return [dict(x) for x in items if isinstance(x, dict)]
+    flat: List[Dict[str, Any]] = []
+    for check in report.get('checks') or []:
+        if not isinstance(check, dict):
+            continue
+        for sample in check.get('samples') or []:
+            if not isinstance(sample, dict):
+                continue
+            doc = dict(sample)
+            doc['kind'] = check.get('kind')
+            doc['status'] = check.get('status')
+            flat.append(doc)
+    return flat
+
+
+def filter_audit_chain_items(
+    report: Dict[str, Any],
+    *,
+    sid: str = '',
+    signal_id: str = '',
+    closed_trade_id: str = '',
+    kind: str = '',
+    limit: int = 100,
+) -> Dict[str, Any]:
+    sid = str(sid or '').strip()
+    signal_id = str(signal_id or '').strip()
+    closed_trade_id = str(closed_trade_id or '').strip()
+    kind = str(kind or '').strip()
+    limit = max(1, min(int(limit or 100), 1000))
+    items = _flatten_items(report)
+    filtered: List[Dict[str, Any]] = []
+    for item in items:
+        if sid and str(item.get('sid') or '') != sid:
+            continue
+        if signal_id and str(item.get('signal_id') or '') != signal_id:
+            continue
+        if closed_trade_id and str(item.get('closed_trade_id') or '') != closed_trade_id:
+            continue
+        if kind and str(item.get('kind') or '') != kind:
+            continue
+        filtered.append(item)
+        if len(filtered) >= limit:
+            break
+    return {
+        'generated_at_ms': report.get('generated_at_ms'),
+        'generated_at_iso': report.get('generated_at_iso'),
+        'total_broken': report.get('total_broken', 0),
+        'kind_totals': report.get('kind_totals', {}),
+        'category_totals': report.get('category_totals', {}),
+        'filters': {
+            'sid': sid,
+            'signal_id': signal_id,
+            'closed_trade_id': closed_trade_id,
+            'kind': kind,
+            'limit': limit,
+        },
+        'items': filtered,
+    }
+
+
+@app.get('/healthz')
+async def healthz() -> Dict[str, str]:
+    return {'status': 'ok'}
+
+
+@app.get('/api/audit-chain/latest')
+async def api_audit_chain_latest(
+    sid: str = Query('', description='Optional exact SID filter'),
+    signal_id: str = Query('', description='Optional exact signal_id filter'),
+    closed_trade_id: str = Query('', description='Optional exact closed_trade_id filter'),
+    kind: str = Query('', description='Optional exact broken-kind filter'),
+    limit: int = Query(100, ge=1, le=1000),
+) -> Dict[str, Any]:
+    try:
+        report = read_latest_audit_chain_report()
+    except FileNotFoundError as exc:
+        raise HTTPException(status_code=404, detail=str(exc))
+    except json.JSONDecodeError as exc:
+        raise HTTPException(status_code=500, detail=f'invalid audit-chain report json: {exc}')
+    return filter_audit_chain_items(
+        report,
+        sid=sid,
+        signal_id=signal_id,
+        closed_trade_id=closed_trade_id,
+        kind=kind,
+        limit=limit,
+    )

