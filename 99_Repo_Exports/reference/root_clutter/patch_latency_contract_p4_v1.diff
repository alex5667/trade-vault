+groups:
+  - name: latency_contract_v1
+    rules:
+      - alert: OF_LatencyContract_ExporterStale_Warn
+        expr: max_over_time(latency_contract_exporter_read_ok[10m]) < 1
+        for: 10m
+        labels:
+          severity: warning
+        annotations:
+          summary: "Latency contract exporter stale"
+          description: "latency_contract_exporter_v1 has not read Redis state successfully in 10 minutes."
+
+      - alert: OF_LatencyContract_FeatureToEmitBudget_Crit
+        expr: histogram_quantile(0.95, sum by (le) (rate(latency_contract_stage_ms_bucket{service="python_worker",stage="feature_to_emit",symbol!="__other__"}[15m]))) > 250
+        for: 15m
+        labels:
+          severity: critical
+        annotations:
+          summary: "feature_to_emit p95 budget breached"
+          description: "python_worker feature_to_emit p95 exceeded 250ms for 15m."
+
+      - alert: OF_LatencyContract_EndToEndBudget_Crit
+        expr: histogram_quantile(0.95, sum by (le) (rate(latency_contract_stage_ms_bucket{service="python_worker",stage="end_to_end_event",symbol!="__other__"}[15m]))) > 2000
+        for: 15m
+        labels:
+          severity: critical
+        annotations:
+          summary: "end_to_end_event p95 budget breached"
+          description: "python_worker end_to_end_event p95 exceeded 2000ms for 15m."
