+import asyncio
+
+from services.observability.latency_contract import stamp_feature_ready, observe_feature_ready_async, stamp_emit_and_observe_async
+
+
+class FakeRedis:
+    def __init__(self):
+        self.hashes = {}
+        self.ttls = {}
+    async def hset(self, key, mapping=None, **kwargs):
+        self.hashes.setdefault(key, {}).update(mapping or {})
+    async def expire(self, key, ttl):
+        self.ttls[key] = ttl
+
+
+def test_synthetic_signal_path_records_hashes():
+    async def _run():
+        r = FakeRedis()
+        signal = {'symbol': 'BTCUSDT'}
+        tick = {'event_ts_ms': 1000, 'ts_redis_read_ms': 1200}
+        stamp_feature_ready(signal, tick=tick, now_ms=1500)
+        await observe_feature_ready_async(signal, redis_client=r, symbol='BTCUSDT')
+        await stamp_emit_and_observe_async(signal, redis_client=r, symbol='BTCUSDT', now_ms=1700)
+        keys = sorted(r.hashes)
+        assert any(':redis_to_feature:' in k for k in keys)
+        assert any(':feature_to_emit:' in k for k in keys)
+        assert any(':end_to_end_event:' in k for k in keys)
+    asyncio.run(_run())
