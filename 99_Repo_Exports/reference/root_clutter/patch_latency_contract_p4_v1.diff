+#!/usr/bin/env python3
+from __future__ import annotations
+
+"""Prometheus exporter for unified latency contract state hashes.
+
+Reads Redis hashes written by Python services (and future Go/NestJS writers) under
+`metrics:latency_contract:last:<service>:<stage>:<symbol>` and exposes latest/freshness
+metrics plus static stage budgets for dashboarding/alerts.
+"""
+
+import os
+import time
+from dataclasses import dataclass
+from typing import Any, Dict
+
+from prometheus_client import Gauge, start_http_server
+
+
+def _env(name: str, default: str = "") -> str:
+    return (os.getenv(name) or default).strip()
+
+
+def _i(v: Any, d: int = 0) -> int:
+    try:
+        return int(float(v))
+    except Exception:
+        return d
+
+
+def _f(v: Any, d: float = 0.0) -> float:
+    try:
+        return float(v)
+    except Exception:
+        try:
+            return float(str(v).strip())
+        except Exception:
+            return d
+
+
+G_UP = Gauge('latency_contract_exporter_up', 'latency contract exporter loop running')
+G_STAGE_LAST = Gauge('latency_contract_stage_last_duration_ms', 'Latest stage duration from Redis state hash', ['service', 'stage', 'symbol'])
+G_STAGE_AGE = Gauge('latency_contract_stage_last_age_seconds', 'Age of latest stage update', ['service', 'stage', 'symbol'])
+G_STAGE_COUNT = Gauge('latency_contract_stage_last_count', 'Synthetic state write count (1 per live hash)', ['service', 'stage', 'symbol'])
+G_STAGE_BUDGET = Gauge('latency_contract_stage_budget_ms', 'Configured SLO budget (ms) per stage', ['stage'])
+G_EXPORTER_KEYS = Gauge('latency_contract_exporter_keys', 'Number of latency contract keys seen in Redis')
+G_EXPORTER_READ_OK = Gauge('latency_contract_exporter_read_ok', 'Exporter Redis read status')
+
+
+@dataclass
+class Cfg:
+    redis_url: str
+    port: int
+    interval_s: float
+    key_prefix: str
+    stale_s: int
+
+
+def load_cfg() -> Cfg:
+    return Cfg(
+        redis_url=_env('REDIS_URL', 'redis://redis-worker-1:6379/0'),
+        port=_i(_env('LATENCY_CONTRACT_EXPORTER_PORT', '9833'), 9833),
+        interval_s=float(_env('LATENCY_CONTRACT_EXPORTER_INTERVAL_S', '10') or 10),
+        key_prefix=_env('LATENCY_CONTRACT_KEY_PREFIX', 'metrics:latency_contract:last'),
+        stale_s=_i(_env('LATENCY_CONTRACT_EXPORTER_STALE_S', '300'), 300),
+    )
+
+
+def _budget(stage: str) -> float:
+    env_map = {
+        'ingest_to_redis': 'LATENCY_BUDGET_INGEST_TO_REDIS_MS',
+        'redis_to_feature': 'LATENCY_BUDGET_REDIS_TO_FEATURE_MS',
+        'feature_to_emit': 'LATENCY_BUDGET_FEATURE_TO_EMIT_MS',
+        'emit_to_ws': 'LATENCY_BUDGET_EMIT_TO_WS_MS',
+        'end_to_end_event': 'LATENCY_BUDGET_END_TO_END_EVENT_MS',
+    }
+    return _f(os.getenv(env_map.get(stage, ''), '0') or '0', 0.0)
+
+
+def _iter_hashes(r: Any, prefix: str):
+    cur = 0
+    match = f"{prefix}:*"
+    while True:
+        cur, keys = r.scan(cur, match=match, count=500)
+        for k in keys or []:
+            yield k
+        if not cur:
+            break
+
+
+def _parse_key(key: str, prefix: str) -> tuple[str, str, str]:
+    rest = str(key)[len(prefix):].lstrip(':')
+    parts = rest.split(':')
+    if len(parts) < 3:
+        return ('unknown', 'unknown', '__other__')
+    return parts[0], parts[1], ':'.join(parts[2:])
+
+
+def main() -> int:
+    cfg = load_cfg()
+    import redis  # type: ignore
+
+    r = redis.Redis.from_url(cfg.redis_url, decode_responses=True)
+    start_http_server(cfg.port)
+    for st in ('ingest_to_redis', 'redis_to_feature', 'feature_to_emit', 'emit_to_ws', 'end_to_end_event'):
+        G_STAGE_BUDGET.labels(stage=st).set(_budget(st))
+    while True:
+        G_UP.set(1.0)
+        now = time.time()
+        try:
+            n = 0
+            for k in _iter_hashes(r, cfg.key_prefix):
+                service, stage, symbol = _parse_key(k, cfg.key_prefix)
+                raw = r.hgetall(k) or {}
+                last_duration_ms = _f(raw.get('last_duration_ms'), 0.0)
+                last_ts_ms = _i(raw.get('last_ts_ms'), 0)
+                age_s = max(0.0, now - (float(last_ts_ms) / 1000.0)) if last_ts_ms > 0 else float(cfg.stale_s)
+                G_STAGE_LAST.labels(service=service, stage=stage, symbol=symbol).set(last_duration_ms)
+                G_STAGE_AGE.labels(service=service, stage=stage, symbol=symbol).set(age_s)
+                G_STAGE_COUNT.labels(service=service, stage=stage, symbol=symbol).set(1.0)
+                n += 1
+            G_EXPORTER_KEYS.set(float(n))
+            G_EXPORTER_READ_OK.set(1.0)
+        except Exception:
+            G_EXPORTER_READ_OK.set(0.0)
+        time.sleep(cfg.interval_s)
+
+
+if __name__ == '__main__':
+    raise SystemExit(main())
