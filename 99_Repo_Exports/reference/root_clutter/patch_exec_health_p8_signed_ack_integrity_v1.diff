+      - alert: OF_ExecHealth_FreezeIntegrity_TamperDetected_Crit
+        expr: max without(kind) (exec_health_freeze_integrity_violation{kind!="none"}) > 0
+        for: 2m
+        labels:
+          severity: critical
+        annotations:
+          summary: ExecHealth freeze control/state tamper or unsigned thaw detected
+      - alert: OF_ExecHealth_FreezeIntegrity_PendingAckStuck_Warn
+        expr: exec_health_freeze_integrity_pending_ack == 1
+        for: 30m
+        labels:
+          severity: warning
+        annotations:
+          summary: ExecHealth freeze still waits for a valid signed manual ack
