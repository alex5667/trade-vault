+def sign_manual_ack(
+    *,
+    secret: str | None = None,
+    action: str,
+    operator: str,
+    reason: str,
+    ticket: str,
+    ack_nonce: str,
+    trigger_ts_ms: int,
+    ack_ts_ms: int,
+) -> str:
+    sec = _secret(secret)
+    if not sec:
+        return ""
+    msg = build_manual_ack_signing_message(
+        action=action,
+        operator=operator,
+        reason=reason,
+        ticket=ticket,
+        ack_nonce=ack_nonce,
+        trigger_ts_ms=trigger_ts_ms,
+        ack_ts_ms=ack_ts_ms,
+    ).encode("utf-8")
+    return hmac.new(sec.encode("utf-8"), msg, hashlib.sha256).hexdigest()
