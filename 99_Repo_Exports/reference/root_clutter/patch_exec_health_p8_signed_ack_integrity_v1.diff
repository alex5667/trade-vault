@@ -0,0 +1,24 @@
+groups:
+  - name: exec-health-freeze-integrity-v1
+    rules:
+      - alert: OF_ExecHealth_FreezeIntegrity_ExporterStale_Warn
+        expr: exec_health_freeze_integrity_exporter_up == 0
+        for: 10m
+        labels:
