+++ b/services/orderflow/message_rate.py
@@ -0,0 +1,216 @@
+from __future__ import annotations
+
+"""
+Message-rate / OTR trackers (Phase E, P4)
+
+Why this module exists
+----------------------
+Mature trading systems treat "market data message health" and "order-to-trade-like"
+ratios as first-class signals for microstructure risk:
+
+- Quote stuffing / burstiness: book update rate spikes often correlate with degraded
+  execution quality, higher slippage, and higher stale-book probability.
+- OTR (order-to-trade ratio) is widely used as a proxy for excessive message churn.
+  On venues where we only see L2/aggTrade, we approximate:
+      OTR ≈ (book_update_msgs/sec) / (trade_msgs/sec)
+
+Design principles
+-----------------
+- Hot-path safe: O(1) per event, robust stats updated at 1Hz, not per message.
+- Deterministic time: consumes epoch-ms timestamps (UTC).
+- Fail-open: if timestamps are missing, we do nothing.
+- Low latency: uses bounded deques and occasional (1Hz) median/MAD recomputation.
+
+We use rolling median/MAD to compute robust z-scores on per-second rates, because
+rates are heavy-tailed and non-Gaussian during market stress.
+"""
+
+import math
+import statistics
+from dataclasses import dataclass, field
+from collections import deque
+from typing import Deque, Optional, Tuple
+
+
+_EPS = 1e-9
+_MAD_SCALE = 1.4826  # MAD -> robust std estimate for normal data
+
+
+@dataclass
+class RollingMedianMAD:
+    """Rolling median/MAD over a bounded window.
+
+    Updated at low frequency (1Hz recommended).
+    """
+    window: int = 120
+    values: Deque[float] = field(default_factory=deque)
+
+    def push(self, x: float) -> None:
+        try:
+            xf = float(x)
+        except Exception:
+            return
+        if not math.isfinite(xf):
+            return
+        self.values.append(xf)
+        while len(self.values) > int(self.window):
+            self.values.popleft()
+
+    def median_mad(self) -> Tuple[float, float]:
+        if not self.values:
+            return 0.0, 0.0
+        vals = list(self.values)
+        med = float(statistics.median(vals))
+        mad = float(statistics.median([abs(v - med) for v in vals])) if vals else 0.0
+        return med, mad
+
+    def zscore(self, x: float) -> float:
+        med, mad = self.median_mad()
+        scale = _MAD_SCALE * (mad if mad > _EPS else 0.0)
+        if scale <= _EPS:
+            return 0.0
+        return float((float(x) - med) / scale)
+
+
+@dataclass
+class MessageRateTracker:
+    """Tracks book/trade message rates and OTR.
+
+    We maintain per-second counters and update EMA + robust z on bucket rotation.
+    """
+    alpha: float = 0.20
+    window: int = 120
+
+    # Current second bucket
+    _sec_book: int = 0
+    _sec_trade: int = 0
+    _book_cnt: int = 0
+    _trade_cnt: int = 0
+
+    # EMA rates (msgs/sec)
+    book_update_rate_hz: float = 0.0
+    trade_msg_rate_hz: float = 0.0
+
+    # Robust z on per-second rates
+    book_update_rate_z: float = 0.0
+    trade_msg_rate_z: float = 0.0
+
+    # Cancel-rate (qty/sec) robust z (optional input from L3-lite)
+    cancel_rate_ema: float = 0.0
+    cancel_rate_z: float = 0.0
+
+    # OTR proxy: book_msgs/sec divided by trade_msgs/sec
+    otr: float = 0.0
+    otr_z: float = 0.0
+
+    # Internals
+    _rm_book: RollingMedianMAD = field(default_factory=lambda: RollingMedianMAD(window=120))
+    _rm_trade: RollingMedianMAD = field(default_factory=lambda: RollingMedianMAD(window=120))
+    _rm_cancel: RollingMedianMAD = field(default_factory=lambda: RollingMedianMAD(window=120))
+    _rm_otr: RollingMedianMAD = field(default_factory=lambda: RollingMedianMAD(window=120))
+
+    _last_otr_sec: int = 0
+
+    def __post_init__(self) -> None:
+        self.alpha = max(0.01, min(0.5, float(self.alpha)))
+        w = int(self.window)
+        if w < 30:
+            w = 30
+        self.window = w
+        self._rm_book.window = w
+        self._rm_trade.window = w
+        self._rm_cancel.window = w
+        self._rm_otr.window = w
+
+    @staticmethod
+    def _sec(ts_ms: int) -> int:
+        return int(ts_ms) // 1000
+
+    def on_book_msg(self, ts_ms: int) -> None:
+        """Call on each processed book snapshot/update."""
+        if ts_ms <= 0:
+            return
+        sec = self._sec(ts_ms)
+        if self._sec_book <= 0:
+            self._sec_book = sec
+        if sec != self._sec_book:
+            self._rotate_book(sec)
+        self._book_cnt += 1
+
+    def on_trade_msg(self, ts_ms: int) -> None:
+        """Call on each processed trade message (aggTrade / tick)."""
+        if ts_ms <= 0:
+            return
+        sec = self._sec(ts_ms)
+        if self._sec_trade <= 0:
+            self._sec_trade = sec
+        if sec != self._sec_trade:
+            self._rotate_trade(sec)
+        self._trade_cnt += 1
+
+    def observe_cancel_rate_ema(self, ts_ms: int, cancel_rate_ema: float) -> None:
+        """Optional: feed aggregated cancel rate (qty/sec) from L3-lite snapshot.
+
+        We update robust z at 1Hz similarly to msg rates (bucketed by event time).
+        """
+        if ts_ms <= 0:
+            return
+        sec = self._sec(ts_ms)
+        # We update cancel robust stats on the same cadence as book rotation
+        if self._sec_book <= 0:
+            self._sec_book = sec
+        if sec != self._sec_book:
+            # ensure rotations happen before we store cancel snapshot (keeps temporal alignment)
+            self._rotate_book(sec)
+        try:
+            cr = float(cancel_rate_ema or 0.0)
+        except Exception:
+            cr = 0.0
+        if not math.isfinite(cr):
+            cr = 0.0
+        self.cancel_rate_ema = cr
+        # push once per second (only when sec changes)
+        if sec != self._last_otr_sec:
+            self._rm_cancel.push(cr)
+            self.cancel_rate_z = float(self._rm_cancel.zscore(cr))
+
+    def _rotate_book(self, new_sec: int) -> None:
+        # Fill gaps with zeros (bounded) to keep baseline stable after reconnects.
+        gap = max(1, min(10, int(new_sec - self._sec_book)))
+        # last bucket rate = count / 1s (we normalize per second)
+        rate = float(self._book_cnt) / 1.0
+        # push previous bucket + zeros for missing seconds beyond 1
+        self._rm_book.push(rate)
+        for _ in range(gap - 1):
+            self._rm_book.push(0.0)
+        self.book_update_rate_z = float(self._rm_book.zscore(rate))
+        self.book_update_rate_hz = (1.0 - self.alpha) * float(self.book_update_rate_hz) + self.alpha * rate
+        self._book_cnt = 0
+        self._sec_book = int(new_sec)
+        self._maybe_update_otr(int(new_sec))
+
+    def _rotate_trade(self, new_sec: int) -> None:
+        gap = max(1, min(10, int(new_sec - self._sec_trade)))
+        rate = float(self._trade_cnt) / 1.0
+        self._rm_trade.push(rate)
+        for _ in range(gap - 1):
+            self._rm_trade.push(0.0)
+        self.trade_msg_rate_z = float(self._rm_trade.zscore(rate))
+        self.trade_msg_rate_hz = (1.0 - self.alpha) * float(self.trade_msg_rate_hz) + self.alpha * rate
+        self._trade_cnt = 0
+        self._sec_trade = int(new_sec)
+        self._maybe_update_otr(int(new_sec))
+
+    def _maybe_update_otr(self, sec: int) -> None:
+        """Update OTR once per second when either stream rotates."""
+        if sec <= 0:
+            return
+        if sec == self._last_otr_sec:
+            return
+        self._last_otr_sec = sec
+        tr = float(self.trade_msg_rate_hz)
+        br = float(self.book_update_rate_hz)
+        otr = br / max(tr, 1.0)  # trade rate can be 0 for illiquid symbols; cap denominator to avoid inf
+        self.otr = float(otr)
+        self._rm_otr.push(float(otr))
+        self.otr_z = float(self._rm_otr.zscore(float(otr)))
