+# ─────────────────────────────────────────────────────────────
+# Phase E (P4): manipulation / quote-stuffing / layering overlay
+# ─────────────────────────────────────────────────────────────
+
+def manip_gate_ok(snap: Dict[str, Any]) -> Tuple[bool, str]:
+    """
+    Lightweight entry-policy overlay.
+
+    This does not replace orderflow-side execution tightening. It provides a final
+    "do not enter during obvious microstructure abuse" guard.
+
+    Inputs are expected to come from `smt:snap_extra:<SYM>` sidecar merged into `snap`.
+    """
+    mode = _s(snap.get("manip_mode", os.getenv("MANIP_MODE", "auto")), "auto").lower()
+    profile = _s(snap.get("gate_profile", os.getenv("ENTRY_POLICY_PROFILE", os.getenv("GATE_PROFILE", "default"))), "default").lower()
+    if mode not in ("monitor", "tighten", "veto"):
+        mode = "tighten" if profile == "strict" else ("veto" if profile == "hard" else "monitor")
+
+    max_otr = _f(os.getenv("MANIP_MAX_OTR", "0") or 0.0)
+    max_msg_z = _f(os.getenv("MANIP_MAX_MSG_RATE_Z", "0") or 0.0)
+    min_layer = _f(os.getenv("MANIP_MIN_LAYERING_SCORE", "0") or 0.0)
+    min_qs = _f(os.getenv("MANIP_MIN_QUOTE_STUFFING_SCORE", "0") or 0.0)
+
+    book_z = _f(snap.get("book_update_rate_z", 0.0), 0.0)
+    otr = _f(snap.get("otr", 0.0), 0.0)
+    qs = _f(snap.get("quote_stuffing_score", 0.0), 0.0)
+    layer = _f(snap.get("layering_score", 0.0), 0.0)
+
+    flags = []
+    if max_msg_z > 0 and book_z >= max_msg_z:
+        flags.append("msg_rate_z")
+    if max_otr > 0 and otr >= max_otr:
+        flags.append("otr")
+    if min_qs > 0 and qs >= min_qs:
+        flags.append("quote_stuff")
+    if min_layer > 0 and layer >= min_layer:
+        flags.append("layering")
+
+    if not flags:
+        return True, "ok"
+
+    if mode == "veto":
+        if "layering" in flags:
+            return False, "VETO_LAYERING"
+        if "otr" in flags:
+            return False, "VETO_OTR_SPIKE"
+        return False, "VETO_QUOTE_STUFFING"
+
+    return True, "monitor:" + ",".join(flags)
