@@ -0,0 +1,217 @@
+from __future__ import annotations
+
+"""
+Manipulative / destructive pattern proxies (Phase E, P4)
+
+We avoid heavy L3 surveillance logic here. The goal is to provide:
+- lightweight, explainable heuristics that correlate with execution risk
+- bounded compute suitable for hot path
+
+Signals implemented:
+1) quote_stuffing_score:
+   Derived from message rate burstiness and cancellation burstiness.
+2) layering_score (L2 approximation):
+   Detects "ladder build" (visible depth distributed across several levels)
+   followed by a quick revert, under low trade activity.
+3) OTR spike:
+   book_msgs/sec divided by trade_msgs/sec.
+
+These are proxies: they should *tighten* execution cost in strict profiles,
+and only become hard vetoes when combined with other evidence (e.g. TCA).
+"""
+
+import math
+from dataclasses import dataclass, field
+from typing import Dict, List, Optional, Tuple
+
+from services.orderflow.message_rate import MessageRateTracker
+
+
+def _safe_f(x: object, d: float = 0.0) -> float:
+    try:
+        v = float(x)  # type: ignore[arg-type]
+    except Exception:
+        return float(d)
+    if not math.isfinite(v):
+        return float(d)
+    return float(v)
+
+
+def _mid_from_bbo(bid: float, ask: float) -> float:
+    if bid > 0 and ask > 0:
+        return 0.5 * (bid + ask)
+    return 0.0
+
+
+def _notional(levels: List[Tuple[float, float]], mid: float, exclude_best: bool) -> float:
+    if mid <= 0:
+        return 0.0
+    out = 0.0
+    for i, (px, qty) in enumerate(levels or []):
+        if exclude_best and i == 0:
+            continue
+        try:
+            out += float(qty) * float(px)
+        except Exception:
+            continue
+    return float(out)
+
+
+def _ladder_ratio(levels: List[Tuple[float, float]], mid: float) -> float:
+    """Ratio of off-top visible notional to total top5 notional."""
+    tot = _notional(levels, mid, exclude_best=False)
+    off = _notional(levels, mid, exclude_best=True)
+    if tot <= 1e-9:
+        return 0.0
+    return float(off / tot)
+
+
+@dataclass
+class ManipulationTracker:
+    """Stateful L2 proxy detector for layering + quote stuffing.
+
+    State is per (symbol,venue) via the SymbolRuntime instance.
+    """
+    # thresholds (tunable)
+    layering_build_mult: float = 1.6     # ladder mass must exceed baseline by this factor
+    layering_ratio_min: float = 0.45     # off-top mass fraction
+    layering_revert_frac: float = 0.35   # revert below peak * frac to count as pull
+    layering_revert_ms: int = 900        # max time between build and revert
+    layering_min_peak_usd: float = 5_000 # ignore tiny books
+
+    quote_msg_z_thr: float = 4.0
+    quote_cancel_z_thr: float = 3.5
+
+    # trade activity guard: layering under low trade msg rate is more suspicious
+    trade_rate_low_hz: float = 2.0
+
+    # EMA baselines
+    ema_alpha: float = 0.05
+    ladder_bid_ema_usd: float = 0.0
+    ladder_ask_ema_usd: float = 0.0
+
+    # state machine
+    _armed_side: str = ""   # "bid"|"ask"|"" 
+    _armed_ts_ms: int = 0
+    _armed_peak_usd: float = 0.0
+
+    # outputs
+    layering_score: float = 0.0
+    quote_stuffing_score: float = 0.0
+    flags: List[str] = field(default_factory=list)
+
+    def update_from_book(
+        self,
+        *,
+        ts_ms: int,
+        bids: List[Tuple[float, float]],
+        asks: List[Tuple[float, float]],
+        best_bid: float,
+        best_ask: float,
+        msg: MessageRateTracker,
+    ) -> Dict[str, object]:
+        """Update tracker on each book snapshot.
+
+        Returns a dict of *compact* outputs to be inserted into indicators/ctx.
+        """
+        self.flags = []
+        if ts_ms <= 0:
+            return self._out(ts_ms)
+
+        mid = _mid_from_bbo(_safe_f(best_bid), _safe_f(best_ask))
+        if mid <= 0:
+            self.flags.append("bad_mid")
+            return self._out(ts_ms)
+
+        # 1) Quote stuffing score (continuous)
+        self.quote_stuffing_score = self._quote_stuffing_score(msg)
+
+        if self.quote_stuffing_score > 0:
+            self.flags.append("quote_stuff")
+
+        # 2) Layering / ladder build & pull
+        self._update_layering(ts_ms=ts_ms, bids=bids, asks=asks, mid=mid, msg=msg)
+
+        if self.layering_score > 0:
+            self.flags.append("layering")
+
+        return self._out(ts_ms)
+
+    def _quote_stuffing_score(self, msg: MessageRateTracker) -> float:
+        mz = float(getattr(msg, "book_update_rate_z", 0.0) or 0.0)
+        cz = float(getattr(msg, "cancel_rate_z", 0.0) or 0.0)
+        s = 0.0
+        if mz > self.quote_msg_z_thr:
+            s += (mz - self.quote_msg_z_thr)
+        if cz > self.quote_cancel_z_thr:
+            s += 0.75 * (cz - self.quote_cancel_z_thr)
+        return float(max(0.0, min(10.0, s)))
+
+    def _update_layering(self, *, ts_ms: int, bids, asks, mid: float, msg: MessageRateTracker) -> None:
+        bid_ladder = _notional(bids, mid, exclude_best=True)
+        ask_ladder = _notional(asks, mid, exclude_best=True)
+        bid_ratio = _ladder_ratio(bids, mid)
+        ask_ratio = _ladder_ratio(asks, mid)
+
+        # Update EMA baselines (slow)
+        a = float(self.ema_alpha)
+        self.ladder_bid_ema_usd = (1.0 - a) * float(self.ladder_bid_ema_usd) + a * float(bid_ladder)
+        self.ladder_ask_ema_usd = (1.0 - a) * float(self.ladder_ask_ema_usd) + a * float(ask_ladder)
+
+        # Determine if we should arm a side
+        tr_hz = float(getattr(msg, "trade_msg_rate_hz", 0.0) or 0.0)
+        low_trade = bool(tr_hz <= float(self.trade_rate_low_hz))
+
+        def _arm(side: str, peak: float) -> None:
+            self._armed_side = side
+            self._armed_ts_ms = int(ts_ms)
+            self._armed_peak_usd = float(peak)
+
+        def _disarm() -> None:
+            self._armed_side = ""
+            self._armed_ts_ms = 0
+            self._armed_peak_usd = 0.0
+
+        # If already armed, check revert/timeout
+        if self._armed_side:
+            age = int(ts_ms - self._armed_ts_ms)
+            if age > int(self.layering_revert_ms):
+                _disarm()
+            else:
+                curr = bid_ladder if self._armed_side == "bid" else ask_ladder
+                if curr <= float(self._armed_peak_usd) * float(self.layering_revert_frac):
+                    # layering hit: built then pulled quickly
+                    # score scaled by peak size and revert strength
+                    peak = max(_safe_f(self._armed_peak_usd), 1.0)
+                    drop_frac = max(0.0, min(1.0, (peak - curr) / peak))
+                    size_boost = min(1.0, peak / max(float(self.layering_min_peak_usd), 1.0))
+                    self.layering_score = float(max(self.layering_score, 10.0 * drop_frac * size_boost))
+                    _disarm()
+                return
+
+        # Not armed: detect build on either side
+        if not low_trade:
+            # Under high trade activity, visible depth oscillations are less suspicious.
+            self.layering_score = 0.0
+            return
+
+        # Bid side build
+        if bid_ladder >= float(self.layering_min_peak_usd) and self.ladder_bid_ema_usd > 1e-6:
+            if (bid_ladder >= float(self.ladder_bid_ema_usd) * float(self.layering_build_mult) and bid_ratio >= float(self.layering_ratio_min)):
+                _arm("bid", bid_ladder)
+
+        # Ask side build
+        if ask_ladder >= float(self.layering_min_peak_usd) and self.ladder_ask_ema_usd > 1e-6:
+            if (ask_ladder >= float(self.ladder_ask_ema_usd) * float(self.layering_build_mult) and ask_ratio >= float(self.layering_ratio_min)):
+                _arm("ask", ask_ladder)
+
+        # decay if nothing happened
+        self.layering_score = float(max(0.0, self.layering_score * 0.85))
+
+    def _out(self, ts_ms: int) -> Dict[str, object]:
+        return {
+            "manip_ts_ms": int(ts_ms or 0),
+            "quote_stuffing_score": float(self.quote_stuffing_score or 0.0),
+            "layering_score": float(self.layering_score or 0.0),
+            "manip_flags": ",".join(self.flags or []),
+        }
