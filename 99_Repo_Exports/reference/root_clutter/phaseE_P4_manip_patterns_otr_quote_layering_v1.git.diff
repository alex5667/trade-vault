+"""
+Phase E (P4) unit tests: MessageRateTracker
+
+These tests are deterministic and do not require Redis.
+"""
+
+import os
+import sys
+import math
+
+# Ensure repo root is importable
+_ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__), "..", "..", ".."))
+if _ROOT not in sys.path:
+    sys.path.insert(0, _ROOT)
+
+from services.orderflow.message_rate import MessageRateTracker
+
+
+class TestMessageRateTracker:
+    def test_basic_rates_and_otr(self):
+        mr = MessageRateTracker(alpha=0.5, window=60)
+
+        # Simulate 3 seconds:
+        # sec 1: 10 book msgs, 2 trade msgs
+        # sec 2: 0 book msgs, 2 trade msgs
+        # sec 3: 6 book msgs, 1 trade msg
+        base = 1_700_000_000_000  # ms
+        # sec1
+        for i in range(10):
+            mr.on_book_msg(base + 100 + i)
+        for i in range(2):
+            mr.on_trade_msg(base + 200 + i)
+        # rotate by jumping to next second
+        mr.on_book_msg(base + 1100)
+        mr.on_trade_msg(base + 1100)
+
+        assert mr.book_update_rate_hz >= 0.0
+        assert mr.trade_msg_rate_hz >= 0.0
+        assert mr.otr >= 0.0
+
+        # sec2 (book=0, trade=2)
+        for i in range(2):
+            mr.on_trade_msg(base + 2100 + i)
+        mr.on_trade_msg(base + 3100)  # rotate to sec3
+
+        # sec3 (book=6, trade=1)
+        for i in range(6):
+            mr.on_book_msg(base + 3100 + 10 + i)
+        mr.on_trade_msg(base + 3100 + 30)
+
+        # rotate out
+        mr.on_book_msg(base + 4100)
+
+        # OTR should be finite (denom capped)
+        assert math.isfinite(mr.otr)
+        assert mr.otr >= 0.0
+
+    def test_cancel_rate_z_updates(self):
+        mr = MessageRateTracker(alpha=0.2, window=30)
+        base = 1_700_000_010_000
+        # Build baseline
+        for s in range(35):
+            ts = base + s * 1000
+            mr.observe_cancel_rate_ema(ts, 1.0)
+        # Spike
+        mr.observe_cancel_rate_ema(base + 36_000, 20.0)
+        assert math.isfinite(mr.cancel_rate_z)
