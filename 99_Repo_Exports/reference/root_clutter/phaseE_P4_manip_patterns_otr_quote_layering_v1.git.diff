+"""
+Phase E (P4) unit tests: ManipulationTracker
+
+We test:
+- quote stuffing score > 0 when msg_rate_z and cancel_rate_z exceed thresholds
+- layering score triggers on build->pull under low trade rate
+"""
+
+import os
+import sys
+import math
+
+_ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__), "..", "..", ".."))
+if _ROOT not in sys.path:
+    sys.path.insert(0, _ROOT)
+
+from services.orderflow.message_rate import MessageRateTracker
+from services.orderflow.manip_patterns import ManipulationTracker
+
+
+class TestManipulationTracker:
+    def test_quote_stuffing_score(self):
+        mr = MessageRateTracker(alpha=0.2, window=60)
+        # fake elevated z-scores
+        mr.book_update_rate_z = 6.0
+        mr.cancel_rate_z = 5.0
+
+        mp = ManipulationTracker(quote_msg_z_thr=4.0, quote_cancel_z_thr=3.5)
+        out = mp.update_from_book(
+            ts_ms=1_700_000_000_000,
+            bids=[(100.0, 1.0)]*5,
+            asks=[(101.0, 1.0)]*5,
+            best_bid=100.0,
+            best_ask=101.0,
+            msg=mr,
+        )
+        assert float(out["quote_stuffing_score"]) > 0.0
+        assert "quote_stuff" in str(out["manip_flags"])
+
+    def test_layering_build_and_pull(self):
+        mr = MessageRateTracker(alpha=0.2, window=60)
+        mr.trade_msg_rate_hz = 0.5  # low trade activity
+
+        mp = ManipulationTracker(
+            layering_build_mult=1.2,
+            layering_ratio_min=0.3,
+            layering_revert_frac=0.4,
+            layering_revert_ms=1000,
+            layering_min_peak_usd=100.0,
+            trade_rate_low_hz=2.0,
+        )
+
+        ts0 = 1_700_000_100_000
+        # baseline small ladder
+        bids0 = [(100.0, 1.0), (99.9, 0.2), (99.8, 0.2), (99.7, 0.2), (99.6, 0.2)]
+        asks0 = [(100.1, 1.0), (100.2, 0.2), (100.3, 0.2), (100.4, 0.2), (100.5, 0.2)]
+        mp.update_from_book(ts_ms=ts0, bids=bids0, asks=asks0, best_bid=100.0, best_ask=100.1, msg=mr)
+
+        # build: ladder mass increases
+        bids1 = [(100.0, 1.0), (99.9, 5.0), (99.8, 5.0), (99.7, 5.0), (99.6, 5.0)]
+        mp.update_from_book(ts_ms=ts0+200, bids=bids1, asks=asks0, best_bid=100.0, best_ask=100.1, msg=mr)
+
+        # pull quickly
+        bids2 = [(100.0, 1.0), (99.9, 0.1), (99.8, 0.1), (99.7, 0.1), (99.6, 0.1)]
+        out = mp.update_from_book(ts_ms=ts0+600, bids=bids2, asks=asks0, best_bid=100.0, best_ask=100.1, msg=mr)
+
+        assert math.isfinite(float(out["layering_score"]))
+        assert float(out["layering_score"]) > 0.0
