+      - alert: OF_LatencyDeployLint_PersistentDriftNotified_Crit
+        expr: latency_contract_deploy_lint_notifier_active > 0 and latency_contract_deploy_lint_summary_gate_active_total > 0
+        for: 5m
+        labels:
+          severity: crit
+        annotations:
+          summary: "Latency deploy-lint persistent drift active"
+          description: "Persistent deploy-lint config drift remains active and notifier is reporting it via Telegram/ops-event."
