--- repo_p45_work/orderflow_services/latency_contract_deploy_lint_notifier_v1.py	1970-01-01 00:00:00.000000000 +0000
+++ repo_p46_work/orderflow_services/latency_contract_deploy_lint_notifier_v1.py	2026-03-08 09:17:49.867473626 +0000
@@ -0,0 +1,153 @@
+#!/usr/bin/env python3
+from __future__ import annotations
+
+"""Emit ops-event/Telegram summaries for persistent latency deploy-lint drift.
+
+This notifier is intentionally separate from the Prometheus exporter:
+- exporter => continuous pull-based visibility
+- notifier => push-based ops summary when persistent config drift remains active
+
+It reads the Redis-backed state created by the deploy-lint CLI (P4.5) and emits
+an event only on status changes or after a reminder cooldown.
+"""
+
+import json
+import os
+import time
+from dataclasses import dataclass
+from typing import Any
+
+from services.observability.latency_deploy_contract import CONTRACTS
+from services.observability.latency_deploy_lint_state import state_key as lint_state_key
+from services.observability.latency_deploy_lint_notify_state import (
+    purposes_hash,
+    state_key as notify_state_key,
+    update_notifier_state,
+)
+
+
+def _env(name: str, default: str = '') -> str:
+    return (os.getenv(name) or default).strip()
+
+
+def _i(v: Any, d: int = 0) -> int:
+    try:
+        return int(float(v))
+    except Exception:
+        return d
+
+
+@dataclass
+class Cfg:
+    redis_url: str
+    state_prefix: str
+    notifier_state_key: str
+    ops_stream: str
+    notify_stream: str
+    notify_enable: bool
+    reminder_s: int
+    state_ttl_s: int
+
+
+def load_cfg() -> Cfg:
+    return Cfg(
+        redis_url=_env('REDIS_URL', 'redis://redis-worker-1:6379/0'),
+        state_prefix=_env('LATENCY_CONTRACT_DEPLOY_LINT_STATE_PREFIX', 'metrics:latency_contract:deploy_lint:last'),
+        notifier_state_key=_env('LATENCY_CONTRACT_DEPLOY_LINT_NOTIFIER_STATE_KEY', 'metrics:latency_contract:deploy_lint:notifier:last'),
+        ops_stream=_env('LATENCY_CONTRACT_DEPLOY_LINT_OPS_EVENT_STREAM', 'ops:latency_contract:events:v1'),
+        notify_stream=_env('LATENCY_CONTRACT_DEPLOY_LINT_NOTIFY_STREAM', os.getenv('NOTIFY_TELEGRAM_STREAM') or 'notify:telegram'),
+        notify_enable=_env('LATENCY_CONTRACT_DEPLOY_LINT_NOTIFY_ENABLE', '1').lower() in ('1', 'true', 'yes', 'on'),
+        reminder_s=max(60, _i(_env('LATENCY_CONTRACT_DEPLOY_LINT_NOTIFY_REMINDER_S', '21600'), 21600)),
+        state_ttl_s=max(600, _i(_env('LATENCY_CONTRACT_DEPLOY_LINT_NOTIFIER_STATE_TTL_S', '172800'), 172800)),
+    )
+
+
+def _active_state_payload(r: Any, prefix: str) -> tuple[list[str], dict[str, dict[str, str]]]:
+    active: list[str] = []
+    details: dict[str, dict[str, str]] = {}
+    for purpose in sorted(CONTRACTS.keys()):
+        raw = r.hgetall(lint_state_key(prefix, purpose)) or {}
+        details[purpose] = raw
+        if str(raw.get('gate_active', '0')) == '1':
+            active.append(purpose)
+    return active, details
+
+
+def _summary_text(active: list[str], details: dict[str, dict[str, str]]) -> str:
+    if not active:
+        return 'Latency deploy-lint persistent drift recovered: no active config-drift gates.'
+    parts: list[str] = []
+    for purpose in active:
+        raw = details.get(purpose) or {}
+        codes = str(raw.get('error_codes') or 'unknown')[:240]
+        parts.append(f'{purpose}: {codes}')
+    return 'Latency deploy-lint persistent config drift active\n' + '\n'.join(parts)
+
+
+def _emit_ops_event(r: Any, cfg: Cfg, *, event_kind: str, active: list[str], details: dict[str, dict[str, str]], now_ms: int) -> None:
+    fields = {
+        'ts_ms': str(now_ms),
+        'kind': event_kind,
+        'source': 'latency_contract_deploy_lint_notifier_v1',
+        'active_purposes_csv': ','.join(active) if active else 'none',
+        'active_purposes_count': str(len(active)),
+        'active_hash': purposes_hash(active),
+        'details_json': json.dumps({p: details.get(p) or {} for p in active}, sort_keys=True),
+    }
+    r.xadd(cfg.ops_stream, fields, maxlen=200000, approximate=True)
+
+
+def _emit_notify(r: Any, cfg: Cfg, *, event_kind: str, text: str, now_ms: int) -> None:
+    if not cfg.notify_enable:
+        return
+    fields = {
+        'type': 'report',
+        'severity': 'crit' if event_kind == 'latency_deploy_lint_persistent_drift' else 'info',
+        'text': text[:3500],
+        'ts': str(now_ms),
+        'source': 'latency_contract_deploy_lint_notifier_v1',
+    }
+    r.xadd(cfg.notify_stream, fields, maxlen=200000, approximate=True)
+
+
+def main() -> int:
+    cfg = load_cfg()
+    import redis  # type: ignore
+
+    r = redis.Redis.from_url(cfg.redis_url, decode_responses=True)
+    now_ms = int(time.time() * 1000)
+    active, details = _active_state_payload(r, cfg.state_prefix)
+    prev = r.hgetall(notify_state_key(cfg.notifier_state_key)) or {}
+    prev_hash = str(prev.get('active_hash') or '')
+    prev_status = str(prev.get('last_status') or 'unknown')
+    last_emit_ts_ms = _i(prev.get('last_emit_ts_ms'), 0)
+    current_hash = purposes_hash(active)
+    current_status = 'active' if active else 'ok'
+
+    emit = False
+    event_kind = 'noop'
+    if current_status != prev_status or current_hash != prev_hash:
+        emit = True
+        event_kind = 'latency_deploy_lint_persistent_drift' if active else 'latency_deploy_lint_recovered'
+    elif active and (now_ms - last_emit_ts_ms) >= cfg.reminder_s * 1000:
+        emit = True
+        event_kind = 'latency_deploy_lint_persistent_drift'
+
+    if emit:
+        text = _summary_text(active, details)
+        _emit_ops_event(r, cfg, event_kind=event_kind, active=active, details=details, now_ms=now_ms)
+        _emit_notify(r, cfg, event_kind=event_kind, text=text, now_ms=now_ms)
+    update_notifier_state(
+        r,
+        prefix=cfg.notifier_state_key,
+        active_purposes=active,
+        emitted=emit,
+        event_kind=event_kind,
+        ttl_s=cfg.state_ttl_s,
+        now_ms=now_ms,
+    )
+    return 0
+
+
+if __name__ == '__main__':
+    raise SystemExit(main())
