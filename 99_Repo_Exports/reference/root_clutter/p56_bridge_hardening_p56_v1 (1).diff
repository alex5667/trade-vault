+          description: >-
+            One or more execution rows lost linkage to trades_closed or position_events.
+
+      - alert: TradeExecutionAuditChainBrokenAnalyticsLink
+        expr: sum(trade_execution_audit_chain_broken_total{kind="broken_analytics_link"}) > 0
