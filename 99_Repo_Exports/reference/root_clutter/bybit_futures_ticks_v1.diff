+package bybit
+
+import (
+	"context"
+	"log"
+	"os"
+	"sort"
+	"strings"
+	"testing"
+
+	"github.com/stretchr/testify/assert"
+	"github.com/stretchr/testify/require"
+)
+
+// noopPublisher satisfies internalredis.Publisher interface for tests.
+type noopPublisher struct{
+	ticks []string
+	books []string
+}
+
+func (p *noopPublisher) PublishTick(_ context.Context, symbol string, _ map[string]any) error {
+	p.ticks = append(p.ticks, symbol)
+	return nil
+}
+
+func (p *noopPublisher) PublishBook(_ context.Context, symbol string, _ map[string]any) error {
+	p.books = append(p.books, symbol)
+	return nil
+}
+
+func newTestController() *FuturesStreamController {
+	logger := log.New(os.Stdout, "[test] ", 0)
+	return &FuturesStreamController{
+		publisher:  &noopPublisher{},
+		logger:     logger,
+		bookDepth:  50,
+		pingPeriod: 1,
+		bookStates: make(map[string]*BookState),
+	}
+}
+
+func sortedStrings(ss []string) []string {
+	out := make([]string, len(ss))
+	copy(out, ss)
+	sort.Strings(out)
+	return out
+}
+
+func TestReconcile_NoOpOnSameSymbols(t *testing.T) {
+	c := newTestController()
+	symbols := []string{"BTCUSDT", "ETHUSDT"}
+	c.currentSymbols = []string{"BTCUSDT", "ETHUSDT"}
+
+	ctx, cancel := context.WithCancel(context.Background())
+	defer cancel()
+
+	c.reconcile(ctx, symbols)
+	assert.Nil(t, c.activeManager, "no manager should be created")
+}
+
+func TestReconcile_NewSymbolsTriggersReconnect(t *testing.T) {
+	c := newTestController()
+	c.currentSymbols = []string{}
+
+	ctx, cancel := context.WithCancel(context.Background())
+	defer cancel()
+
+	symbols := []string{"BTCUSDT", "ETHUSDT", "SOLUSDT"}
+	c.reconcile(ctx, symbols)
+
+	require.Equal(t, 3, len(c.currentSymbols))
+	got := sortedStrings(c.currentSymbols)
+	want := []string{"BTCUSDT", "ETHUSDT", "SOLUSDT"}
+	for i := range want {
+		assert.Equal(t, want[i], got[i])
+	}
+	cancel()
+}
+
+func TestReconcile_SymbolsCaseNormalized(t *testing.T) {
+	c := newTestController()
+	ctx, cancel := context.WithCancel(context.Background())
+	defer cancel()
+
+	c.reconcile(ctx, []string{"btcusdt", "ethusdt"})
+	cancel()
+
+	for _, s := range c.currentSymbols {
+		assert.Equal(t, strings.ToUpper(s), s)
+	}
+}
+
+func TestLoadSymbols_BaseFallback(t *testing.T) {
+	c := newTestController()
+	c.client = nil
+	ctx := context.Background()
+	base := []string{"BTCUSDT", "ETHUSDT"}
+	got := sortedStrings(c.loadSymbols(ctx, base))
+	want := sortedStrings(base)
+	assert.Equal(t, want, got)
+}
+
+func TestFuturesMultiplexManager_UpdateSubscriptions_NoConn(t *testing.T) {
+	m := NewFuturesMultiplexManager([]string{"BTCUSDT"}, log.New(os.Stdout, "", 0), 50, 1)
+	err := m.UpdateSubscriptions([]string{"ETHUSDT"}, nil)
+	assert.Error(t, err)
+	assert.Contains(t, err.Error(), "no active connection")
+}
