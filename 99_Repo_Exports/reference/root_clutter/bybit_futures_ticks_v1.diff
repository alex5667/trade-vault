diff -ruN /mnt/data/go-worker_orig/internal/bybit/futures_normalizer.go /mnt/data/go-worker_mod/internal/bybit/futures_normalizer.go
--- /mnt/data/go-worker_orig/internal/bybit/futures_normalizer.go	1970-01-01 00:00:00.000000000 +0000
