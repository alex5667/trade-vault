+import os
+import yaml
+
+
+EXPECTED_ALERTS = {
+    "OF_SQ_TickGapP95High_Warn",
+    "OF_SQ_TickGapP95High_Crit",
+    "OF_SQ_TickGapP95Extreme_Crit",
+    "OF_SQ_TickMissingSeqEmaHigh_Warn",
+    "OF_SQ_TickMissingSeqEmaHigh_Crit",
+    "OF_SQ_BookMissingSeqEmaHigh_Ticket",
+    "OF_SQ_DQHardShareHigh_Warn",
+    "OF_SQ_DQHardShareHigh_Crit",
+}
+
+
+def _repo_root() -> str:
+    # tests/ -> orderflow_services/ -> tick_flow_full/ -> repo root
+    return os.path.abspath(os.path.join(os.path.dirname(__file__), "..", "..", ".."))
+
+
+def _load_yaml(path: str):
+    assert os.path.exists(path), f"Rules file not found at {path}"
+    with open(path, "r") as f:
+        return yaml.safe_load(f)
+
+
+def _collect_alert_names(data) -> set:
+    assert isinstance(data, dict), "YAML must parse into a dict"
+    assert "groups" in data, "No groups found in yaml"
+    names = set()
+    for group in data.get("groups", []):
+        for rule in group.get("rules", []):
+            if "alert" in rule:
+                names.add(rule["alert"])
+    return names
+
+
+def test_signal_quality_alerts_yaml_v2_present_and_valid():
+    repo = _repo_root()
+
+    # SoT
+    sot = os.path.join(repo, "orderflow_services", "prometheus_alerts_signal_quality_v2.yml")
+    # Mirror (tick_flow_full)
+    mirror = os.path.join(repo, "tick_flow_full", "orderflow_services", "prometheus_alerts_signal_quality_v2.yml")
+    # Optional legacy locations used by some deployments
+    services_sot = os.path.join(repo, "services", "orderflow", "prometheus_alerts_signal_quality_v2.yml")
+    services_mirror = os.path.join(repo, "tick_flow_full", "services", "orderflow", "prometheus_alerts_signal_quality_v2.yml")
+
+    for p in (sot, mirror, services_sot, services_mirror):
+        data = _load_yaml(p)
+        alerts = _collect_alert_names(data)
+        missing = EXPECTED_ALERTS.difference(alerts)
+        assert not missing, f"{p}: missing alerts: {sorted(missing)}"
+
+
+def test_signal_quality_alerts_yaml_v2_has_15s_interval():
+    repo = _repo_root()
+    p = os.path.join(repo, "orderflow_services", "prometheus_alerts_signal_quality_v2.yml")
+    data = _load_yaml(p)
+    groups = data.get("groups", [])
+    assert groups, "No groups in rules file"
+    assert groups[0].get("interval") == "15s"
