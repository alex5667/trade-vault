+import pytest
+
+try:
+    # Repo uses mixed absolute imports inside mirrors; some optional deps may be absent
+    # in minimal CI environments. Skip if import graph isn't available.
+    from tick_flow_full.services.orderflow.components.book_processor import BookProcessor
+    from tick_flow_full.services.orderflow.runtime import SymbolRuntime
+except Exception as e:  # pragma: no cover
+    pytest.skip(
+        f"book_missing_seq unit test skipped (import failed): {type(e).__name__}: {e}",
+        allow_module_level=True,
+    )
+
+
+def _mk_bp():
+    return BookProcessor(
+        base_threshold_bps=20.0,
+        wall_normalize_bps=50.0,
+        churn_fast=0.2,
+        churn_slow=0.05,
+        churn_slow_threshold=0.1,
+        book_churn_z_lo=-2.0,
+        book_churn_z_hi=2.0,
+    )
+
+
+def test_book_missing_seq_ema_gap_detected_and_ema_updates():
+    bp = _mk_bp()
+    rt = SymbolRuntime(symbol="BTCUSDT", config={"book_missing_seq_ema_alpha": 0.1})
+
+    # First event: no prev_u => init
+    bp._update_book_missing_seq(rt, {"U": 100, "u": 110})
+    assert rt.book_seq_last_u == 110
+    assert rt.book_missing_seq_ema == 0.0
+
+    # Continuous event: U == prev_u + 1
+    bp._update_book_missing_seq(rt, {"U": 111, "u": 120})
+    assert rt.book_seq_last_reason == "ok"
+    assert rt.book_missing_seq_ema == 0.0
+
+    # Gap event: U jumps
+    bp._update_book_missing_seq(rt, {"U": 130, "u": 140})
+    assert rt.book_seq_last_reason == "gap"
+    assert abs(rt.book_missing_seq_ema - 0.1) < 1e-9
+
+    # Next continuous: EMA decays
+    bp._update_book_missing_seq(rt, {"U": 141, "u": 150})
+    assert rt.book_seq_last_reason == "ok"
+    assert abs(rt.book_missing_seq_ema - 0.09) < 1e-9
+
+
+def test_book_missing_seq_reorder_does_not_advance_last_u():
+    bp = _mk_bp()
+    rt = SymbolRuntime(symbol="BTCUSDT", config={"book_missing_seq_ema_alpha": 0.5})
+
+    bp._update_book_missing_seq(rt, {"U": 100, "u": 110})
+    assert rt.book_seq_last_u == 110
+
+    # Out-of-order / duplicate: u does not advance.
+    bp._update_book_missing_seq(rt, {"U": 90, "u": 95})
+    assert rt.book_seq_last_reason in ("reorder_or_reset", "no_seq_fields", "init")
+    assert rt.book_seq_last_u == 110
