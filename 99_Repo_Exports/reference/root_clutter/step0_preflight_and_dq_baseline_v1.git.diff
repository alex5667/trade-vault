+#!/usr/bin/env python3
+"""Preflight / baseline snapshot (Step 0).
+
+Goals:
+- фиксируем текущие /metrics (какие метрики отдаются)
+- фиксируем алерты, которые реально грузятся Prometheus (/api/v1/rules)
+- вытаскиваем текущий book-stream path/параметры из docker-compose (best-effort)
+
+This tool is intentionally fail-open: it never raises on network/YAML errors.
+It prints a single JSON document to stdout.
+
+Usage examples:
+  python tick_flow_full/tools/preflight_baseline_v1.py \
+    --metrics-url http://localhost:9100/metrics \
+    --prom-url http://localhost:9090 \
+    --compose ./docker-compose-crypto-orderflow.yml --service binance-worker
+
+Notes:
+- Provide multiple --metrics-url to snapshot several exporters.
+- Compose parsing is heuristic: we look for env keys containing DEPTH/BOOK/STREAM.
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+import re
+import sys
+import time
+from dataclasses import dataclass
+from typing import Any, Dict, List, Optional, Tuple
+
+
+def _now_ms() -> int:
+    return int(time.time() * 1000)
+
+
+_METRIC_LINE_RE = re.compile(r"^([a-zA-Z_:][a-zA-Z0-9_:]*)")
+
+
+def parse_prometheus_text(text: str) -> Dict[str, int]:
+    """Parse Prometheus text exposition, returning sample-count per metric name.
+
+    We count each sample line (excluding comments and HELP/TYPE lines) as 1.
+    """
+    counts: Dict[str, int] = {}
+    for raw in (text or "").splitlines():
+        if not raw or raw.startswith("#"):
+            continue
+        m = _METRIC_LINE_RE.match(raw)
+        if not m:
+            continue
+        name = m.group(1)
+        counts[name] = counts.get(name, 0) + 1
+    return counts
+
+
+def parse_prom_rules_json(payload: Dict[str, Any]) -> Dict[str, Any]:
+    """Extract loaded rule groups and alert rules from /api/v1/rules JSON."""
+    out: Dict[str, Any] = {"groups": [], "alerts": []}
+    try:
+        data = (payload or {}).get("data") or {}
+        groups = data.get("groups") or []
+        for g in groups:
+            out["groups"].append(
+                {
+                    "name": g.get("name"),
+                    "file": g.get("file"),
+                    "interval": g.get("interval"),
+                    "rules": len(g.get("rules") or []),
+                }
+            )
+            for r in g.get("rules") or []:
+                if r.get("type") != "alerting":
+                    continue
+                out["alerts"].append(
+                    {
+                        "group": g.get("name"),
+                        "name": r.get("name"),
+                        "state": r.get("state"),
+                        "health": r.get("health"),
+                        "duration": r.get("duration"),
+                        "labels": r.get("labels") or {},
+                        "annotations": r.get("annotations") or {},
+                    }
+                )
+    except Exception:
+        return out
+    return out
+
+
+def _http_get(url: str, timeout_s: float = 3.0) -> Tuple[int, str]:
+    """Tiny HTTP GET without external deps."""
+    try:
+        import urllib.request
+
+        req = urllib.request.Request(url, headers={"User-Agent": "trade-preflight/1"})
+        with urllib.request.urlopen(req, timeout=timeout_s) as resp:
+            body = resp.read().decode("utf-8", errors="replace")
+            return int(getattr(resp, "status", 200)), body
+    except Exception as e:
+        return 0, f"{type(e).__name__}: {e}"
+
+
+def _http_get_json(url: str, timeout_s: float = 3.0) -> Tuple[int, Dict[str, Any]]:
+    code, body = _http_get(url, timeout_s=timeout_s)
+    if code == 0:
+        return 0, {"error": body}
+    try:
+        return code, json.loads(body)
+    except Exception as e:
+        return code, {"error": f"json_decode_failed: {type(e).__name__}: {e}", "raw": body[:1000]}
+
+
+def _extract_book_stream_from_compose(compose_path: str, service: Optional[str]) -> Dict[str, Any]:
+    """Best-effort extraction of book/depth stream config from docker-compose."""
+    out: Dict[str, Any] = {"compose_path": compose_path, "service": service, "matches": []}
+    try:
+        import yaml
+
+        data = yaml.safe_load(open(compose_path, "r", encoding="utf-8")) or {}
+        services = (data.get("services") or {})
+        if not services:
+            out["error"] = "no_services"
+            return out
+
+        target_names: List[str] = []
+        if service:
+            if service in services:
+                target_names = [service]
+            else:
+                # allow partial match
+                target_names = [k for k in services.keys() if service in k]
+        else:
+            target_names = list(services.keys())
+
+        def norm_env(env: Any) -> Dict[str, str]:
+            if isinstance(env, dict):
+                return {str(k): str(v) for k, v in env.items()}
+            if isinstance(env, list):
+                outd: Dict[str, str] = {}
+                for item in env:
+                    if not isinstance(item, str) or "=" not in item:
+                        continue
+                    k, v = item.split("=", 1)
+                    outd[str(k)] = str(v)
+                return outd
+            return {}
+
+        keys_hint = ("DEPTH", "BOOK", "STREAM", "WS", "BINANCE")
+        for name in target_names:
+            svc = services.get(name) or {}
+            env = norm_env(svc.get("environment"))
+            matches = []
+            for k, v in env.items():
+                if any(h in k.upper() for h in keys_hint) or any(h in str(v).upper() for h in keys_hint):
+                    matches.append({"key": k, "value": v})
+            if matches:
+                out["matches"].append({"service": name, "env": matches})
+    except Exception as e:
+        out["error"] = f"{type(e).__name__}: {e}"
+    return out
+
+
+def main(argv: Optional[List[str]] = None) -> int:
+    ap = argparse.ArgumentParser(description="trade Step0 preflight baseline snapshot")
+    ap.add_argument("--metrics-url", action="append", default=[], help="Exporter /metrics URL (repeatable)")
+    ap.add_argument("--prom-url", default="", help="Prometheus base URL (e.g. http://localhost:9090)")
+    ap.add_argument("--compose", default="", help="docker-compose.yml path (optional)")
+    ap.add_argument("--service", default="", help="service name in compose (optional)")
+    ap.add_argument("--timeout", type=float, default=3.0, help="HTTP timeout seconds")
+    args = ap.parse_args(argv)
+
+    out: Dict[str, Any] = {
+        "ts_ms": _now_ms(),
+        "metrics": [],
+        "prom_rules": None,
+        "book_stream": None,
+    }
+
+    # 0.1 metrics snapshot
+    for url in args.metrics_url:
+        code, body = _http_get(url, timeout_s=float(args.timeout))
+        if code == 0:
+            out["metrics"].append({"url": url, "ok": False, "error": body})
+            continue
+        counts = parse_prometheus_text(body)
+        out["metrics"].append(
+            {
+                "url": url,
+                "ok": True,
+                "http_status": code,
+                "metric_names": sorted(counts.keys()),
+                "sample_counts": counts,
+                "total_samples": int(sum(counts.values())),
+            }
+        )
+
+    # 0.1 rules snapshot
+    if args.prom_url:
+        base = args.prom_url.rstrip("/")
+        code, payload = _http_get_json(base + "/api/v1/rules", timeout_s=float(args.timeout))
+        if code == 0:
+            out["prom_rules"] = {"ok": False, "error": payload.get("error")}
+        else:
+            out["prom_rules"] = {"ok": True, "http_status": code, **parse_prom_rules_json(payload)}
+
+    # 0.1 book stream config (best-effort)
+    if args.compose:
+        out["book_stream"] = _extract_book_stream_from_compose(args.compose, args.service or None)
+
+    sys.stdout.write(json.dumps(out, ensure_ascii=False, sort_keys=True, indent=2) + "\n")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
