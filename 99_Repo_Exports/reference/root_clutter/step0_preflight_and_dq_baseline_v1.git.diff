+    def _update_book_missing_seq(self, runtime: SymbolRuntime, book_raw: Dict[str, Any]) -> None:
+        """Update runtime.book_missing_seq_ema using Binance depthUpdate continuity.
+
+        Binance depthUpdate events contain:
+          - U: firstUpdateId for this event
+          - u: lastUpdateId for this event
+
+        If the previous event ended at prev_u, then the next event is continuous iff:
+          U == prev_u + 1
+
+        We model missing updates as a Bernoulli event (gap? 1 : 0) and track its EMA.
+        This keeps the signal bounded [0..1] and stable across symbols.
+
+        Notes:
+        - Partial depth snapshots (@depth5/@depth10/@depth20) usually do not include U/u.
+          In that case we keep book_missing_seq_ema unchanged and set reason=no_seq_fields.
+        - Duplicates / reorder / resets do not count as missing updates.
+        """
+        try:
+            cur_u = int(book_raw.get("u") or 0)
+            cur_U = int(book_raw.get("U") or 0)
+        except Exception:
+            cur_u, cur_U = 0, 0
+
+        prev_u = int(getattr(runtime, "book_seq_last_u", 0) or 0)
+        prev_ema = float(getattr(runtime, "book_missing_seq_ema", 0.0) or 0.0)
+        alpha = float(runtime.config.get("book_missing_seq_ema_alpha", 0.1) or 0.1)
+
+        miss_event = 0.0
+        reason = "init"
+
+        if cur_u <= 0:
+            reason = "no_u"
+        elif cur_U <= 0 or prev_u <= 0:
