+    def _repair_open_protection(
+        self,
+        *,
+        sid: str,
+        symbol: str,
+        logical_side: str,
+        filled_qty: float,
+        sl: Optional[float],
+        tps: List[float],
+        policy: ExecutionPolicyDecision,
+        client: "BinanceFuturesClient",
+        filters: "FiltersCache",
+        ref_price: Optional[float] = None,
+    ) -> Dict[str, Any]:
+        expect_sl = bool(sl and sl > 0)
+        if not expect_sl and not tps:
+            return {"is_complete": False, "missing": ["sl_or_tp_contract_absent"], "repair_actions": []}
+        verify_before = self._verify_protection_on_exchange(
+            sid=sid, symbol=symbol, client=client, expect_sl=expect_sl, tps=tps, expect_trail=False
+        )
+        if verify_before.get("is_complete"):
+            return {**self._verified_refs_to_state(verify_before), "is_complete": True, "repair_actions": [], "verified": verify_before}
+        try:
+            self._local_headroom_check(client=client, symbol=symbol, qty=filled_qty, reference_price=float(sl or (tps[0] if tps else 0.0) or 0.0))
+        except Exception:
+            pass
+        repair_actions: List[str] = []
+        repair_state: Dict[str, Any] = {}
+        missing = list(verify_before.get("missing") or [])
+        if expect_sl and "sl" in missing:
+            repair_state.update(self._place_sl_only(
+                sid=sid, symbol=symbol, logical_side=logical_side, qty=filled_qty,
+                sl=float(sl), client=client, filters=filters, ref_price=ref_price,
+            ))
+            repair_actions.append("sl")
+        if tps:
+            parts = self._split_tp_qtys(symbol, filled_qty, len(tps), filters=filters)
+            for idx, (tp, part_qty) in enumerate(zip(tps, parts), start=1):
+                if f"tp{idx}" not in missing:
+                    continue
+                repair_state.update(self._place_tp_only(
+                    sid=sid, symbol=symbol, logical_side=logical_side, qty_for_level=float(part_qty),
+                    tp=float(tp), tp_idx=idx, tp_count_total=len(tps), policy=policy,
+                    client=client, filters=filters, ref_price=ref_price,
+                ))
+                repair_actions.append(f"tp{idx}")
+        verify_after = self._verify_protection_on_exchange(
+            sid=sid, symbol=symbol, client=client, expect_sl=expect_sl, tps=tps, expect_trail=False
+        )
+        result = {
+            **repair_state,
+            **self._verified_refs_to_state(verify_after),
+            "is_complete": bool(verify_after.get("is_complete")),
+            "missing": list(verify_after.get("missing") or []),
+            "repair_actions": repair_actions,
