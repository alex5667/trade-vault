+    @classmethod
+    def _build_client_algo_id(cls, sid: str, tag: str) -> str:
+        """Deterministic clientAlgoId contract shared with the executor.
+
+        We duplicate the short-id logic here so client-side reconcile/inspection can
+        assert exact protective refs instead of relying on fuzzy token scans only.
+        """
+        token = cls._sid_token(sid)
+        base = str(sid).replace(" ", "").replace(":", "-")
+        base = base[: max(6, 36 - (len(tag) + len(token) + 2))]
+        cid = f"{base}-{token}-{tag}"
+        return cid[:36]
