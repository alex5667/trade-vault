+    def inspect_protection_set(
+        self,
+        symbol: str,
+        *,
+        sid: str,
+        expected_tp_count: int = 0,
+        expect_sl: bool = True,
+        expect_trail: bool = False,
+    ) -> Dict[str, Any]:
+        """Inspect the currently live protective contract for one SID on exchange.
+
+        Returns a deterministic contract view keyed by exact ``clientAlgoId`` values,
+        together with a low-cardinality ``missing`` list suitable for strict
+        executor-side verification.
+        """
+        symbol_u = str(symbol).upper()
+        matched: Dict[str, Any] = {
+            "sid": str(sid),
+            "symbol": symbol_u,
+            "expected_tp_count": int(expected_tp_count),
+            "expect_sl": bool(expect_sl),
+            "expect_trail": bool(expect_trail),
+            "by_client_algo_id": {},
+            "tp_by_index": {},
+            "missing": [],
+        }
+        open_orders = self.get_open_algo_orders(symbol_u) or []
+        token = self._sid_token(sid)
+        for order in open_orders:
+            cid = str(order.get("clientAlgoId") or "").strip()
+            if not cid or f"-{token}-" not in cid:
+                continue
+            matched["by_client_algo_id"][cid] = order
+            if cid.endswith("-sl"):
+                matched["sl"] = order
+            elif cid.endswith("-trail"):
+                matched["trail"] = order
+            elif "-tp" in cid:
+                try:
+                    suffix = cid.rsplit("-tp", 1)[1]
+                    idx = int(suffix)
+                except Exception:
+                    idx = 0
+                if idx > 0:
+                    matched["tp_by_index"][idx] = order
+        if expect_sl:
+            sl_cid = self._build_client_algo_id(sid, "sl")
+            if sl_cid not in matched["by_client_algo_id"]:
+                matched["missing"].append("sl")
+        for idx in range(1, int(expected_tp_count) + 1):
+            tp_cid = self._build_client_algo_id(sid, f"tp{idx}")
+            if tp_cid not in matched["by_client_algo_id"]:
+                matched["missing"].append(f"tp{idx}")
+        if expect_trail:
+            trail_cid = self._build_client_algo_id(sid, "trail")
+            if trail_cid not in matched["by_client_algo_id"]:
+                matched["missing"].append("trail")
+        matched["is_complete"] = not matched["missing"]
+        matched["tp"] = [matched["tp_by_index"][idx] for idx in sorted(matched["tp_by_index"]) ]
+        return matched
