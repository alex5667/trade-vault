+    def _verify_protection_on_exchange(
+        self,
+        *,
+        sid: str,
+        symbol: str,
+        client: "BinanceFuturesClient",
+        expect_sl: bool,
+        tps: List[float],
+        expect_trail: bool = False,
+    ) -> Dict[str, Any]:
+        """Strictly verify protective orders against exchange truth.
+
+        Success requires exact live refs for all expected components.  This helper is
+        intentionally stricter than the old local-response check because the failure
+        mode we are fixing is precisely: entry filled, local submit path returned,
+        but one or more protective orders never became visible on exchange.
+        """
+        if hasattr(client, "inspect_protection_set"):
+            result = client.inspect_protection_set(
+                symbol,
+                sid=sid,
+                expected_tp_count=len(tps),
+                expect_sl=bool(expect_sl),
+                expect_trail=bool(expect_trail),
+            )
+        else:
+            # Conservative fallback for older client stubs used by tests.
+            matched: Dict[str, Any] = {"sid": sid, "symbol": symbol.upper(), "by_client_algo_id": {}, "tp_by_index": {}, "missing": []}
+            expected = []
+            if expect_sl:
+                expected.append(("sl", _make_cid(sid, "sl")))
+            for idx in range(1, len(tps) + 1):
+                expected.append((f"tp{idx}", _make_cid(sid, f"tp{idx}")))
+            if expect_trail:
+                expected.append(("trail", _make_cid(sid, "trail")))
+            open_orders = []
+            try:
+                open_orders = client.get_open_algo_orders(symbol) or []
+            except Exception:
+                open_orders = []
+            by_cid = {str(row.get("clientAlgoId") or "").strip(): row for row in open_orders if str(row.get("clientAlgoId") or "").strip()}
+            for key, cid in expected:
+                row = by_cid.get(cid)
+                if row is None:
+                    try:
+                        row = client.query_algo_order(symbol, client_algo_id=cid)
+                    except Exception:
+                        row = None
+                if row is None:
+                    matched["missing"].append(key)
+                    continue
+                matched["by_client_algo_id"][cid] = row
+                if key == "sl":
+                    matched["sl"] = row
+                elif key == "trail":
+                    matched["trail"] = row
+                elif key.startswith("tp"):
+                    try:
+                        idx = int(key[2:])
+                    except Exception:
+                        idx = 0
+                    if idx > 0:
+                        matched["tp_by_index"][idx] = row
+            matched["tp"] = [matched["tp_by_index"][idx] for idx in sorted(matched["tp_by_index"])]
+            matched["is_complete"] = not matched["missing"]
+            result = matched
+        result = dict(result or {})
