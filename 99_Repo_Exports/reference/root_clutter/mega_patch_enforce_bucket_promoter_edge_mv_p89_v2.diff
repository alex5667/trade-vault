diff --git a/orderflow_services/sql/create_mv_exec_slippage_eval_1h_stats_p89.sql b/orderflow_services/sql/create_mv_exec_slippage_eval_1h_stats_p89.sql
new file mode 100644
index 0000000..307c7f1
--- /dev/null
+++ b/orderflow_services/sql/create_mv_exec_slippage_eval_1h_stats_p89.sql
@@ -0,0 +1,32 @@
+-- P89: Materialized view for fast slippage QA / enforce-bucket guardrails
+-- Depends on TimescaleDB (time_bucket) and view v_exec_slippage_eval providing:
+--   ts, sym, exec_regime_bucket, slippage_residual_bps, edge_minus_expected_bps
+--
+-- Apply with psql:
+--   psql "$DATABASE_URL" -f orderflow_services/sql/create_mv_exec_slippage_eval_1h_stats_p89.sql
+--
+-- Refresh periodically (see orderflow_services/refresh_exec_slip_stats_p80.py):
+--   REFRESH MATERIALIZED VIEW mv_exec_slippage_eval_1h_stats;
+
+BEGIN;
+
+CREATE MATERIALIZED VIEW IF NOT EXISTS mv_exec_slippage_eval_1h_stats AS
+SELECT
+  sym,
+  time_bucket('1 hour', ts) AS t,
+  exec_regime_bucket,
+  count(*)::bigint AS n,
+  percentile_cont(0.95) WITHIN GROUP (ORDER BY slippage_residual_bps) AS resid_p95_bps,
+  percentile_cont(0.99) WITHIN GROUP (ORDER BY slippage_residual_bps) AS resid_p99_bps,
+  avg(CASE WHEN edge_minus_expected_bps < 0 THEN 1.0 ELSE 0.0 END) AS edge_neg_share
+FROM v_exec_slippage_eval
+GROUP BY 1,2,3;
+
+-- Useful indexes for typical queries: (sym, t, bucket)
+CREATE INDEX IF NOT EXISTS mv_exec_slippage_eval_1h_stats_sym_t_idx
+  ON mv_exec_slippage_eval_1h_stats (sym, t DESC);
+
+CREATE INDEX IF NOT EXISTS mv_exec_slippage_eval_1h_stats_bucket_t_idx
+  ON mv_exec_slippage_eval_1h_stats (exec_regime_bucket, t DESC);
+
+COMMIT;

