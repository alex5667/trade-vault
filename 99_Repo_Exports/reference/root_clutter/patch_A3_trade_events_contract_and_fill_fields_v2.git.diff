+# -*- coding: utf-8 -*-
+"""
+Trade events contract (Redis Stream: events:trades)
+
+Goal
+-----
+Provide a strict, unit-testable contract for POSITION_CLOSED events *as they are written
+into Redis Streams*. This contract exists to guarantee the join key (`sid`) and time semantics
+(epoch ms), which are required for downstream labelers, joiners and TCA.
+
+Important constraints
+---------------------
+- Redis Streams store only strings; nested dict/list must be JSON-serialized.
+- Fail-open: producer (trade_events_logger) MUST NOT crash the trading flow.
+  Instead, invalid events should be routed to a DLQ stream.
+
+This module therefore provides:
+- normalize_position_closed_event(): best-effort normalization + defaults
+- validate_position_closed_event(): strict validation (returns list of errors)
+
+Design rules
+------------
+- No high-cardinality labels or extra fields are forbidden here; we only enforce correctness
+  of critical fields for downstream joins.
+- We keep backward compatibility: accept legacy keys (`lot` -> qty, `source` -> venue, etc).
+"""
+from __future__ import annotations
+
+import json
+import re
+from typing import Any, Dict, List, Tuple, Optional
+
+_SHA1_RE = re.compile(r"^[0-9a-f]{40}$")
+
+
+def _json_dumps(v: Any) -> str:
+    return json.dumps(v, ensure_ascii=False, separators=(",", ":"), default=str)
+
+
+def _as_str(v: Any) -> str:
+    if v is None:
+        return ""
+    if isinstance(v, str):
+        return v
+    return str(v)
+
+
+def _as_float_str(v: Any) -> str:
+    if v is None or v == "":  # allow 0.0
+        return ""
+    try:
+        return str(float(v))
+    except Exception:
+        return ""
+
+
+def _as_int_ms_str(v: Any) -> str:
+    if v is None or v == "":
+        return ""
+    try:
+        i = int(float(v))
+        return str(i)
+    except Exception:
+        return ""
+
+
+def _norm_side(v: Any) -> str:
+    s = _as_str(v).strip().upper()
+    if s in ("LONG", "SHORT"):
+        return s
+    if s == "BUY":
+        return "LONG"
+    if s == "SELL":
+        return "SHORT"
+    return s
+
+
+def _compute_fee_bps(*, fees_usd: Optional[float], turnover_roundtrip: Optional[float], qty: Optional[float], price: Optional[float]) -> Optional[float]:
+    """Compute fee_bps from available data."""
+    try:
+        f = float(fees_usd) if fees_usd is not None else None
+    except Exception:
+        f = None
+    if f is None or f < 0:
+        return None
+
+    try:
+        t = float(turnover_roundtrip) if turnover_roundtrip is not None else 0.0
+    except Exception:
+        t = 0.0
+    if t and t > 0:
+        return (f / t) * 10000.0
+
+    try:
+        q = float(qty) if qty is not None else 0.0
+        p = float(price) if price is not None else 0.0
+        notional = abs(q) * p
+        if notional > 0:
+            return (f / notional) * 10000.0
+    except Exception:
+        return None
+    return None
+
+
+def normalize_position_closed_event(doc: Dict[str, Any]) -> Tuple[Dict[str, str], List[str]]:
+    d = dict(doc or {})
+    errs: List[str] = []
+
+    if _as_str(d.get("event_type") or "").strip() != "POSITION_CLOSED":
+        errs.append("event_type!=POSITION_CLOSED")
+    d["event_type"] = "POSITION_CLOSED"
+
+    event_id = _as_str(d.get("event_id") or "").strip()
+    if not event_id or not _SHA1_RE.match(event_id):
+        errs.append("bad_event_id")
+    d["event_id"] = event_id
+
+    sid = _as_str(d.get("sid") or "").strip()
+    if not sid:
+        errs.append("missing_sid")
+    d["sid"] = sid
+
+    symbol = _as_str(d.get("symbol") or "").strip().upper()
+    if not symbol:
+        errs.append("missing_symbol")
+    d["symbol"] = symbol
+
+    source = _as_str(d.get("source") or d.get("venue") or "").strip() or "unknown"
+    d["source"] = source
+    if not _as_str(d.get("venue") or "").strip():
+        d["venue"] = source
+
+    ts = _as_int_ms_str(d.get("ts"))
+    exit_ts_ms = _as_int_ms_str(d.get("exit_ts_ms"))
+    if exit_ts_ms:
+        if not ts:
+            ts = exit_ts_ms
+        else:
+            try:
+                if abs(int(ts) - int(exit_ts_ms)) > 60_000:
+                    ts = exit_ts_ms
+            except Exception:
+                ts = exit_ts_ms
+    if not ts:
+        errs.append("missing_ts")
+    if not exit_ts_ms:
+        exit_ts_ms = ts
+        errs.append("missing_exit_ts_ms")
+    d["ts"] = ts
+    d["exit_ts_ms"] = exit_ts_ms
+
+    ts_fill_ms = _as_int_ms_str(d.get("ts_fill_ms") or d.get("fill_ts_ms") or "")
+    if not ts_fill_ms:
+        ts_fill_ms = exit_ts_ms or ts
+    d["ts_fill_ms"] = ts_fill_ms
+
+    price = _as_float_str(d.get("price") or d.get("px") or "")
+    if not price:
+        errs.append("missing_price")
+    d["price"] = price
+    if not _as_str(d.get("px") or "").strip():
+        d["px"] = price
+
+    pnl = _as_float_str(d.get("pnl") or "")
+    if not pnl:
+        errs.append("missing_pnl")
+    d["pnl"] = pnl
+
+    side = _norm_side(d.get("side") or d.get("direction") or "")
+    if not side:
+        errs.append("missing_side")
+    d["side"] = side
+
+    qty = _as_float_str(d.get("qty") or d.get("quantity") or d.get("lot") or "")
+    if not qty:
+        errs.append("missing_qty")
+    d["qty"] = qty
+    if "lot" not in d and qty:
+        d["lot"] = qty
+
+    order_id = _as_str(d.get("order_id") or d.get("client_order_id") or d.get("position_id") or "").strip()
+    if not order_id:
+        errs.append("missing_order_id")
+    d["order_id"] = order_id
+
+    fee_bps = _as_float_str(d.get("fee_bps") or d.get("fees_bps") or "")
+    if not fee_bps:
+        try:
+            fees_usd = float(d.get("fees_usd")) if d.get("fees_usd") not in (None, "") else None
+        except Exception:
+            fees_usd = None
+        try:
+            turnover = float(d.get("turnover_roundtrip")) if d.get("turnover_roundtrip") not in (None, "") else None
+        except Exception:
+            turnover = None
+        try:
+            qv = float(qty) if qty else None
+        except Exception:
+            qv = None
+        try:
+            pv = float(price) if price else None
+        except Exception:
+            pv = None
+        fb = _compute_fee_bps(fees_usd=fees_usd, turnover_roundtrip=turnover, qty=qv, price=pv)
+        if fb is not None:
+            fee_bps = str(float(fb))
+    if not fee_bps:
+        errs.append("missing_fee_bps")
+        fee_bps = "0.0"
+    d["fee_bps"] = fee_bps
+
+    risk_usd = _as_float_str(d.get("risk_usd") or "")
+    if not risk_usd:
+        errs.append("missing_risk_usd")
+    d["risk_usd"] = risk_usd or "0.0"
+
+    r_mult = _as_float_str(d.get("r_mult") or "")
+    if not r_mult:
+        errs.append("missing_r_mult")
+    d["r_mult"] = r_mult or "0.0"
+
+    md = d.get("metadata")
+    meta = d.get("meta")
+    if isinstance(md, (dict, list)):
+        md_s = _json_dumps(md)
+    elif isinstance(md, str):
+        md_s = md
+    else:
+        md_s = ""
+    if isinstance(meta, (dict, list)):
+        meta_s = _json_dumps(meta)
+    elif isinstance(meta, str):
+        meta_s = meta
+    else:
+        meta_s = ""
+    if md_s and not meta_s:
+        meta_s = md_s
+    if meta_s and not md_s:
+        md_s = meta_s
+    if md_s:
+        d["metadata"] = md_s
+        d["meta"] = meta_s
+
+    out: Dict[str, str] = {}
+    for k, v in d.items():
+        if v is None:
+            continue
+        if isinstance(v, (dict, list)):
+            out[k] = _json_dumps(v)
+        else:
+            out[k] = _as_str(v)
+    return out, errs
+
+
+def validate_position_closed_event(doc: Dict[str, Any]) -> Tuple[bool, List[str]]:
+    _, errs = normalize_position_closed_event(doc)
+    return len(errs) == 0, errs
