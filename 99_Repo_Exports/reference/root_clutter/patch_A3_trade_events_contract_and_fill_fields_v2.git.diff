+# -*- coding: utf-8 -*-
+"""Redis Stream DLQ helper."""
+from __future__ import annotations
+
+import json
+import time
+from typing import Any, Dict
+
+
+def publish_dlq(
+    redis_client: Any,
+    *,
+    dlq_stream: str,
+    reason: str,
+    error: str,
+    src_stream: str,
+    src_entry_id: str,
+    payload: Dict[str, Any],
+    maxlen: int = 200000,
+    approximate: bool = True,
+    payload_max_bytes: int = 8192,
+) -> None:
+    """Best-effort publish to DLQ stream. Never raises."""
+    try:
+        raw = json.dumps(payload, ensure_ascii=False, default=str)
+        if len(raw.encode("utf-8")) > payload_max_bytes:
+            raw = raw.encode("utf-8")[:payload_max_bytes].decode("utf-8", errors="ignore")
+        fields = {
+            "ts_ms": str(int(time.time() * 1000)),
+            "reason": str(reason or "unknown"),
+            "error": str(error or ""),
+            "src_stream": str(src_stream or ""),
+            "src_entry_id": str(src_entry_id or ""),
+            "payload": raw,
+        }
+        redis_client.xadd(dlq_stream, fields, maxlen=int(maxlen), approximate=bool(approximate))
+    except Exception:
+        return
