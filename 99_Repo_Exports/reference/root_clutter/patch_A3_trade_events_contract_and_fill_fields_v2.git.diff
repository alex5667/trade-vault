+# -*- coding: utf-8 -*-
+import unittest
+import hashlib
+import os
+import sys
+from pathlib import Path
+
+# Ensure imports work when running tests from repo root
+PYWORKER_ROOT = Path(__file__).resolve().parents[2]
+if str(PYWORKER_ROOT) not in sys.path:
+    sys.path.insert(0, str(PYWORKER_ROOT))
+
+
+try:
+    from services.posttrade.trade_events_contract import normalize_position_closed_event, validate_position_closed_event
+except Exception:
+    from posttrade.trade_events_contract import normalize_position_closed_event, validate_position_closed_event  # type: ignore
+
+
+class TestTradeEventsContractV1(unittest.TestCase):
+    def test_normalize_ok_computes_fee_bps_and_fill_ts(self):
+        base = {
+            "event_type": "POSITION_CLOSED",
+            "sid": "sig-BTCUSDT-1741284000-42",
+            "symbol": "BTCUSDT",
+            "source": "binance",
+            "side": "LONG",
+            "order_id": "order-123",
+            "qty": "0.003",
+            "price": "85400.5",
+            "pnl": "127.35",
+            "risk_usd": "18.45",
+            "r_mult": "6.91",
+            "exit_ts_ms": "1741284125000",
+            "ts": "1741284125000",
+            "fees_usd": "1.28",
+            "turnover_roundtrip": "2000.0",
+        }
+        # stable event_id
+        eid = hashlib.sha1(b"POSITION_CLOSED|sig|ts").hexdigest()
+        base["event_id"] = eid
+
+        norm, errs = normalize_position_closed_event(base)
+        self.assertEqual(errs, [], f"unexpected errs: {errs}")
+        self.assertEqual(norm["sid"], base["sid"])
+        self.assertEqual(norm["symbol"], "BTCUSDT")
+        self.assertEqual(norm["ts"], base["exit_ts_ms"])
+        self.assertEqual(norm["ts_fill_ms"], base["exit_ts_ms"])
+        self.assertEqual(norm["px"], norm["price"])
+        # fee_bps computed: 1.28/2000*10000 = 6.4
+        self.assertAlmostEqual(float(norm["fee_bps"]), 6.4, places=6)
+
+    def test_missing_sid_goes_error(self):
+        base = {
+            "event_type": "POSITION_CLOSED",
+            "event_id": "0"*40,
+            "symbol": "BTCUSDT",
+            "source": "binance",
+            "side": "LONG",
+            "order_id": "o",
+            "qty": "1",
+            "price": "100",
+            "pnl": "1",
+            "risk_usd": "1",
+            "r_mult": "1",
+            "exit_ts_ms": "1741284125000",
+            "ts": "1741284125000",
+            "fee_bps": "1.0",
+        }
+        ok, errs = validate_position_closed_event(base)
+        self.assertFalse(ok)
+        self.assertIn("missing_sid", errs)
+
+
+if __name__ == "__main__":
+    unittest.main()
