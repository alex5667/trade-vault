+    {"title": "Active Sharpness", "type": "timeseries", "targets": [{"expr": "conf_cal_extended_metric{arm=\"active\",metric=\"sharpness_mean\",instance=~\"$instance\"}"}, {"expr": "conf_cal_extended_metric{arm=\"active\",metric=\"prob_mass_near_half\",instance=~\"$instance\"}"}]},
+    {"title": "Champion vs Challenger Deltas", "type": "timeseries", "targets": [{"expr": "conf_cal_extended_delta{metric=\"mce_cal\",instance=~\"$instance\"}"}, {"expr": "conf_cal_extended_delta{metric=\"sharpness_mean\",instance=~\"$instance\"}"}]}
+  ]
+}
