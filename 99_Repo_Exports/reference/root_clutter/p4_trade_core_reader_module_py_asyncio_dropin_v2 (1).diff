index 0000000..dc6f0a8
--- /dev/null
+++ b/tests/test_news_reco_reader_cache.py
@@ -0,0 +1,129 @@
+import asyncio
+
+from services.news_reco_reader.cache import NewsRecoCache, now_ms, parse_agg_map
+from services.news_reco_reader.reader import NewsRecoReader, ReaderConfig
+
+
+def _run(coro):
+    return asyncio.run(coro)
+
+
+def test_parse_agg_map_ok():
+    raw = '{"schema_ver":"v1","ts_ms":123,"reco":{"BTCUSDT":{"expires_ms":9999999999999}}}'
+    p = parse_agg_map(raw)
+    assert p is not None
+    assert p["ts_ms"] == 123
+    assert "BTCUSDT" in p["reco"]
+
+
+def test_cache_apply_and_get_expiry():
+    c = NewsRecoCache(max_symbols=10)
+    future = now_ms() + 10_000
+    c.apply_map({"BTCUSDT": {"expires_ms": future, "suggest_profile": "tighten"}}, ts_ms=111)
+    s = c.get("BTCUSDT")
+    assert s is not None
+    assert s.payload["suggest_profile"] == "tighten"
+
+
+def test_reader_applies_map_from_redis_get_override():
+    future = now_ms() + 10_000
+    payload = '{"schema_ver":"v1","ts_ms":321,"reco":{"ETHUSDT":{"expires_ms":%d,"suggest_profile":"soft"}}}' % future
+    calls = {"n": 0}
+
+    async def fake_get():
+        calls["n"] += 1
+        return payload
+
+    cfg = ReaderConfig(
+        enable=True,
+        redis_url="redis://unused",
+        map_key="trade:cache:news_reco_map",
+        poll_ms=50,
+        jitter_ms=0,
+        stale_fail_open_ms=1000,
+        max_symbols=100,
+    )
+
+    async def _case():
+        r = NewsRecoReader(cfg, redis_get=fake_get)
+        await r.start()
+        await asyncio.sleep(0.12)
+        snap = r.get("ETHUSDT")
+        assert snap is not None
+        assert snap.payload.get("suggest_profile") == "soft"
+        assert calls["n"] >= 1
+        await r.stop()
+
+    _run(_case())
+
+
+def test_reader_fail_open_drops_on_stale():
+    future = now_ms() + 200
+    good = '{"schema_ver":"v1","ts_ms":123,"reco":{"BTCUSDT":{"expires_ms":%d}}}' % future
+    calls = {"n": 0}
+
+    async def fake_get():
+        calls["n"] += 1
+        return good if calls["n"] == 1 else None
+
+    cfg = ReaderConfig(
+        enable=True,
+        redis_url="redis://unused",
+        map_key="trade:cache:news_reco_map",
+        poll_ms=50,
+        jitter_ms=0,
+        stale_fail_open_ms=120,
+        max_symbols=100,
+    )
+
+    async def _case():
+        r = NewsRecoReader(cfg, redis_get=fake_get)
+        await r.start()
+        await asyncio.sleep(0.08)
+        assert r.get("BTCUSDT") is not None
+        await asyncio.sleep(0.20)
+        assert r.get("BTCUSDT") is None
+        await r.stop()
+
+    _run(_case())
+
