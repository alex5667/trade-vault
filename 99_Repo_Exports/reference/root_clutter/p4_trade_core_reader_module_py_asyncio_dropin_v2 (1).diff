@@ -0,0 +1,173 @@
+from __future__ import annotations
+
+import time
+from dataclasses import dataclass
+from typing import Any, Dict, Optional
+
+
+def now_ms() -> int:
+    return int(time.time() * 1000)
+
+
+@dataclass(frozen=True)
+class NewsRecoSnapshot:
+    """A single recommendation snapshot for a symbol.
+
+    This mirrors `NewsTradeRecoDTO` minimally. We keep it flexible (extra keys
+    allowed) to avoid coupling trade-core to the news-agent DTO evolution.
+    """
+
+    symbol: str
+    payload: Dict[str, Any]
+    expires_ms: int
+
+    @property
+    def is_expired(self) -> bool:
+        return self.expires_ms <= now_ms()
+
+
+class NewsRecoCache:
+    """In-memory TTL cache.
+
+    Trade hot-path MUST only read from this cache.
+    Background updater will periodically replace/update entries.
+    """
+
+    def __init__(self, max_symbols: int = 2000):
+        self._max_symbols = max_symbols
+        self._by_symbol: Dict[str, NewsRecoSnapshot] = {}
+        self._last_update_ms: int = 0
+        self._last_good_update_ms: int = 0
+
+    def last_update_ms(self) -> int:
+        return self._last_update_ms
+
+    def last_good_update_ms(self) -> int:
+        return self._last_good_update_ms
+
+    def size(self) -> int:
+        return len(self._by_symbol)
+
+    def get(self, symbol: str) -> Optional[NewsRecoSnapshot]:
+        s = self._by_symbol.get(symbol)
+        if s is None:
+            return None
+        if s.expires_ms <= now_ms():
+            # Expired: remove lazily.
+            self._by_symbol.pop(symbol, None)
+            return None
+        return s
+
+    def snapshot_all(self) -> Dict[str, NewsRecoSnapshot]:
+        """Return a shallow copy (for debugging/metrics only)."""
+        # Avoid filtering here to keep it cheap; callers should treat entries
+        # as possibly-expired.
+        return dict(self._by_symbol)
+
+    def apply_map(self, reco_map: Dict[str, Dict[str, Any]], ts_ms: int) -> None:
+        """Apply a new aggregated map.
+
+        reco_map format: {"BTCUSDT": { ... }, ... }
+
+        Each entry MUST contain expires_ms.
+        """
+        self._last_update_ms = ts_ms
+        now = now_ms()
+
+        # First pass: build new entries and count.
+        new_entries: Dict[str, NewsRecoSnapshot] = {}
+        for sym, payload in reco_map.items():
+            if not isinstance(sym, str) or not sym:
+                continue
+            if not isinstance(payload, dict):
+                continue
+            exp = payload.get("expires_ms")
+            if not isinstance(exp, int):
+                continue
+            if exp <= now:
+                continue
+            new_entries[sym] = NewsRecoSnapshot(symbol=sym, payload=payload, expires_ms=exp)
+
+        # Eviction if too big: keep the longest-lived first.
+        if len(new_entries) > self._max_symbols:
+            items = sorted(new_entries.values(), key=lambda s: s.expires_ms, reverse=True)
+            new_entries = {s.symbol: s for s in items[: self._max_symbols]}
+
+        self._by_symbol = new_entries
+        self._last_good_update_ms = ts_ms
+
+    def mark_bad_update(self, ts_ms: int) -> None:
+        """Record that updater ran but failed to apply a valid map."""
+        self._last_update_ms = ts_ms
+
+
+def parse_agg_map(raw_json: str) -> Optional[Dict[str, Any]]:
+    """Parse aggregated map JSON.
+
+    Expected format produced by trade-side cache service:
+      {"schema_ver":"v1", "ts_ms": 123, "reco": {"BTCUSDT": {...}, ...}}
+    """
+
+    import json
+
+    try:
+        obj = json.loads(raw_json)
+    except Exception:
+        return None
+    if not isinstance(obj, dict):
+        return None
+    reco = obj.get("reco")
+    ts_ms = obj.get("ts_ms")
+    if not isinstance(reco, dict):
+        return None
+    if not isinstance(ts_ms, int):
+        # fallback: accept missing ts_ms, but it reduces observability
+        ts_ms = now_ms()
+    return {"ts_ms": ts_ms, "reco": reco}
+
