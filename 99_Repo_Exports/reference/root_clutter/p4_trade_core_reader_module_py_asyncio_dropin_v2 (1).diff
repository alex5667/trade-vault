+"""Trade-core reader for news_agent recommendations.
+
+This package is intentionally dependency-light and safe for hot-path usage:
+
+* The background poller performs Redis I/O.
+* The trade hot-path only reads an in-memory cache (O(1), no awaits).
+
+Integration pattern:
+  - start the reader once during process startup (asyncio task)
+  - call `get_reco(symbol)` from gates / policies.
+"""
+
+from .reader import (
+    NewsRecoReader,
+    NewsRecoSnapshot,
+    get_reco,
+    ensure_started,
+)
+
+__all__ = ["NewsRecoReader", "NewsRecoSnapshot", "get_reco", "ensure_started"]
+
