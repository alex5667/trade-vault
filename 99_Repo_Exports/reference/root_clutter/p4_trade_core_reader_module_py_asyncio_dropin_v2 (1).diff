@@ -0,0 +1,319 @@
+from __future__ import annotations
+
+import asyncio
+import os
+import random
+from dataclasses import dataclass
+from typing import Awaitable, Callable, Optional
+
+from .cache import NewsRecoCache, NewsRecoSnapshot, now_ms, parse_agg_map
+
+
+def _env_int(name: str, default: int) -> int:
+    v = os.getenv(name)
+    if v is None or v == "":
+        return default
+    try:
+        return int(v)
+    except Exception:
+        return default
+
+
+def _env_str(name: str, default: str) -> str:
+    v = os.getenv(name)
+    return default if v is None or v == "" else v
+
+
+def _env_bool(name: str, default: bool) -> bool:
+    v = os.getenv(name)
+    if v is None or v == "":
+        return default
+    return v.strip().lower() in ("1", "true", "yes", "y", "on")
+
+
+@dataclass(frozen=True)
+class ReaderConfig:
+    enable: bool
+    redis_url: str
+    map_key: str
+    poll_ms: int
+    jitter_ms: int
+    stale_fail_open_ms: int
+    max_symbols: int
+
+    @staticmethod
+    def from_env() -> "ReaderConfig":
+        return ReaderConfig(
+            enable=_env_bool("TRADE_NEWS_RECO_READER_ENABLE", True),
+            redis_url=_env_str("TRADE_NEWS_RECO_REDIS_URL", _env_str("REDIS_URL", "redis://localhost:6379/0")),
+            map_key=_env_str("TRADE_NEWS_RECO_MAP_KEY", "trade:cache:news_reco_map"),
+            poll_ms=max(50, _env_int("TRADE_NEWS_RECO_POLL_MS", 250)),
+            jitter_ms=max(0, _env_int("TRADE_NEWS_RECO_POLL_JITTER_MS", 50)),
+            stale_fail_open_ms=max(500, _env_int("TRADE_NEWS_RECO_STALE_FAIL_OPEN_MS", 5000)),
+            max_symbols=max(100, _env_int("TRADE_NEWS_RECO_MAX_SYMBOLS", 2000)),
+        )
+
+
+class NewsRecoReader:
+    """Background poller that mirrors `trade:cache:news_reco_map` into memory.
+
+    Design goals:
+      - Hot-path reads are synchronous and non-blocking.
+      - Poller failures are fail-open (cache keeps last-good until local TTL).
+      - Minimal dependencies: works with redis-py asyncio, optional.
+    """
+
+    def __init__(
+        self,
+        cfg: Optional[ReaderConfig] = None,
+        *,
+        redis_get: Optional[Callable[[], Awaitable[Optional[str]]]] = None,
+    ) -> None:
+        self.cfg = cfg or ReaderConfig.from_env()
+        self.cache = NewsRecoCache(max_symbols=self.cfg.max_symbols)
+
+        # If provided (tests), we don't create a Redis client.
+        self._redis_get = redis_get
+        self._redis = None
+
+        self._task: Optional[asyncio.Task] = None
+        self._stop = asyncio.Event()
+        self._started = False
+        self._start_lock = asyncio.Lock()
+        self._last_apply_ok_ms: int = 0
+
+    def started(self) -> bool:
+        return self._started
+
+    def last_apply_ok_ms(self) -> int:
+        return self._last_apply_ok_ms
+
+    async def start(self) -> None:
+        """Start polling loop as an asyncio task.
+
+        Safe to call multiple times.
+        """
+        async with self._start_lock:
+            if self._started:
+                return
+            if not self.cfg.enable:
+                self._started = True
+                return
+
+            if self._redis_get is None:
+                self._redis_get = await self._build_redis_get()
+            self._task = asyncio.create_task(self._run(), name="news_reco_reader")
+            self._started = True
+
+    async def stop(self) -> None:
+        self._stop.set()
+        t = self._task
+        if t is not None:
+            t.cancel()
+            try:
+                await t
+            except Exception:
+                pass
+
+    def get(self, symbol: str) -> Optional[NewsRecoSnapshot]:
+        return self.cache.get(symbol)
+
+    async def _build_redis_get(self) -> Callable[[], Awaitable[Optional[str]]]:
+        """Create a coroutine that does GET map_key.
+
+        Tries redis-py asyncio first. If not available, raises RuntimeError.
+        """
+        try:
+            import redis.asyncio as redis  # type: ignore
+        except Exception as e:
+            raise RuntimeError(
+                "redis.asyncio is required in trade core for NewsRecoReader. "
+                "Install 'redis' (redis-py) >= 4.2 or provide redis_get override."
+            ) from e
+
+        # decode_responses=True => str
+        self._redis = redis.from_url(self.cfg.redis_url, decode_responses=True)
+
+        async def _get() -> Optional[str]:
+            try:
+                return await self._redis.get(self.cfg.map_key)
+            except Exception:
+                return None
+
+        return _get
+
+    async def _run(self) -> None:
+        # Small startup delay to avoid thundering herd on deploy.
+        await asyncio.sleep(random.uniform(0.05, 0.25))
+
+        while not self._stop.is_set():
+            t0 = now_ms()
+            try:
+                raw = await self._redis_get() if self._redis_get is not None else None
+                parsed = parse_agg_map(raw) if raw else None
+
+                if parsed is None:
+                    self.cache.mark_bad_update(now_ms())
+                else:
+                    self.cache.apply_map(parsed["reco"], parsed["ts_ms"])
+                    self._last_apply_ok_ms = now_ms()
+
+            except asyncio.CancelledError:
+                raise
+            except Exception:
+                # Fail-open: keep last-good cache.
+                self.cache.mark_bad_update(now_ms())
+
+            # Local staleness fail-open: if we haven't applied a good update
+            # for too long, drop cache (avoid using stale tightening signals).
+            if self._last_apply_ok_ms and (now_ms() - self._last_apply_ok_ms) > self.cfg.stale_fail_open_ms:
+                self.cache.apply_map({}, now_ms())
+                self._last_apply_ok_ms = 0
+
+            # Sleep with jitter.
+            delay_ms = self.cfg.poll_ms + (random.randint(0, self.cfg.jitter_ms) if self.cfg.jitter_ms else 0)
+            dt = now_ms() - t0
+            sleep_ms = max(10, delay_ms - dt)
+            try:
+                await asyncio.wait_for(self._stop.wait(), timeout=sleep_ms / 1000.0)
+            except asyncio.TimeoutError:
+                pass
+
+
+# --- Minimal singleton helpers (optional) ---
+
+_SINGLETON: Optional[NewsRecoReader] = None
+_SINGLETON_LOCK = asyncio.Lock()
+
+
+async def ensure_started(cfg: Optional[ReaderConfig] = None) -> NewsRecoReader:
+    """Get singleton reader and ensure its polling task is running."""
+    global _SINGLETON
+    async with _SINGLETON_LOCK:
+        if _SINGLETON is None:
+            _SINGLETON = NewsRecoReader(cfg)
+        await _SINGLETON.start()
+        return _SINGLETON
+
+
+def get_reco(symbol: str) -> Optional[NewsRecoSnapshot]:
+    """Hot-path getter.
+
+    NOTE: This does NOT start the reader automatically because startup should
+    be explicit (determinism). If you want auto-start, call ensure_started()
+    during process init.
+    """
+    if _SINGLETON is None:
+        return None
+    return _SINGLETON.get(symbol)
+
+
+__all__ = ["ReaderConfig", "NewsRecoReader", "NewsRecoSnapshot", "ensure_started", "get_reco"]
+
