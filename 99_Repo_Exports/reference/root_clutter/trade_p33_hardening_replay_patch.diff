+from pathlib import Path
+import importlib.util
+import sys
+
+mod_path = Path(__file__).resolve().parent / 'execution_state_replay.py'
+spec = importlib.util.spec_from_file_location('execution_state_replay', mod_path)
+mod = importlib.util.module_from_spec(spec)
+sys.modules[spec.name] = mod
+spec.loader.exec_module(mod)
+
+
+class FakeRedis:
+    def __init__(self, rows):
+        self.rows = rows
+        self.kv = {}
+
+    def xrevrange(self, _stream, end, start, count=1000):
+        return list(self.rows)[:count]
+
+    def set(self, key, value, ex=None):
+        self.kv[key] = value
+
+
+def test_rebuild_uses_sql_fallback_when_stream_empty(monkeypatch):
+    fake = FakeRedis([])
+    monkeypatch.setattr(mod, '_load_sql_state_snapshot', lambda dsn, sid: {'sid': sid, 'fsm_state': 'PROTECTED', 'status': 'open'})
+    res = mod.rebuild_state_with_fallback(fake, exec_stream='orders:exec', sid='s1', sql_dsn='postgres://x')
+    assert res.source == 'sql'
+    assert res.state_doc['sid'] == 's1'
+
+
+def test_persist_state_snapshot_writes_checkpoint():
+    fake = FakeRedis([])
+    ok = mod.persist_state_snapshot(fake, state_key='orders:state:s1', state_doc={'sid': 's1', 'stream_last_id': '100-1'}, checkpoint_key='orders:exec:replay:cursor:s1')
+    assert ok is True
+    assert 'orders:exec:replay:cursor:s1' in fake.kv
