+    rules:
+      - alert: TradeExecutionReplaySqlFallbackSpike
+        expr: increase(trade_execution_replay_sql_fallback_total{result="ok"}[15m]) > 5
+        for: 5m
+        labels:
+          severity: warning
+        annotations:
+          summary: "Replay is relying on SQL fallback"
+          description: "Redis orders:exec replay window is insufficient or checkpoints are stale; SQL-backed recovery is being used repeatedly."
+      - alert: TradeExecutionReplayMismatchCritical
+        expr: increase(execution_replay_mismatch_total{severity="critical"}[10m]) > 0
+        for: 1m
+        labels:
+          severity: critical
+        annotations:
+          summary: "Critical replay mismatch detected"
+          description: "Hot Redis state diverged from replayed/SQL-backed execution state and the sid may have been quarantined."
+      - alert: TradeExecutionRehydrateFailures
+        expr: increase(execution_rehydrate_total{result="fail"}[10m]) > 0
+        for: 2m
+        labels:
+          severity: warning
+        annotations:
+          summary: "Execution rehydrate failures detected"
+          description: "Executor failed to recover missing orders:state from stream or SQL fallback."
+      - alert: TradeExecutionReplayTruncated
+        expr: increase(trade_execution_replay_truncated_total[30m]) > 0
+        for: 5m
+        labels:
+          severity: warning
+        annotations:
+          summary: "Replay window truncated"
+          description: "Bounded replay window hit the checkpoint boundary before locating all sid events; consider rebuild/checkpoint review."
