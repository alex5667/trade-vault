@@ -0,0 +1,146 @@
+from types import SimpleNamespace
+
+from services.binance_executor import BinanceExecutor
+from services.binance_futures_client import BinanceFuturesClient
+
+
+class DummyClient:
+    def __init__(self):
+        self.cancel_all_calls = []
+        self.cancel_plain_calls = []
+        self.cancel_algo_calls = []
+        self.open_orders = [{"orderId": 101, "clientOrderId": "cid-1"}]
+        self.algo_orders = [{"algoId": 202, "clientAlgoId": "acid-1"}]
+
+    def get_open_orders(self, symbol=None):
+        return list(self.open_orders)
+
+    def get_open_algo_orders(self, symbol=None):
+        return list(self.algo_orders)
+
+    def cancel_all_orders(self, symbol):
+        self.cancel_all_calls.append(symbol)
+        self.open_orders = []
+        self.algo_orders = []
+        return {"symbol": symbol}
+
+    def cancel_plain_order(self, symbol, order_id=None, client_order_id=None):
+        self.cancel_plain_calls.append((symbol, order_id, client_order_id))
+        return {"symbol": symbol, "orderId": order_id, "clientOrderId": client_order_id}
+
+    def cancel_algo_order(self, symbol, algo_id=None, client_algo_id=None):
+        self.cancel_algo_calls.append((symbol, algo_id, client_algo_id))
+        return {"symbol": symbol, "algoId": algo_id, "clientAlgoId": client_algo_id}
+
+
+
+def _make_exec():
+    ex = BinanceExecutor.__new__(BinanceExecutor)
+    ex.position_mode = "oneway"
+    ex.dust_notional_usdt = 3.0
+    ex.dust_margin_usdt = 1.0
+    ex.dust_close_retries = 3
+    ex.dust_verify_timeout_ms = 100
+    ex.dust_verify_poll_ms = 10
+    ex._position_qty_tolerance = lambda symbol, *, filters: 0.0001
+    ex._save_order_state = lambda *args, **kwargs: None
+    ex._derive_audit_chain_fields = lambda payload, sid: {}
+    ex._new_closed_trade_id = lambda sid, exit_order_ref='': f'closed::{sid}'
+    ex._format_order_ref = lambda venue, kind, order_id=None, client_id=None: f'{venue}:{kind}:{order_id or client_id}'
+    return ex
+
+
+def test_force_flatten_symbol_exact_retries_dust_tail():
+    ex = _make_exec()
+    client = DummyClient()
+    filters = SimpleNamespace()
+
+    live_sequence = [
+        {"abs_qty": 0.1, "logical_side": "LONG", "notional_usdt": 0.12, "margin_usdt": 0.01, "is_flat": False},
+        {"abs_qty": 0.1, "logical_side": "LONG", "notional_usdt": 0.12, "margin_usdt": 0.01, "is_flat": False},
+        {"abs_qty": 0.1, "logical_side": "LONG", "notional_usdt": 0.12, "margin_usdt": 0.01, "is_flat": False},
+    ]
+    verify_sequence = [
+        {"abs_qty": 0.1, "logical_side": "LONG", "notional_usdt": 0.12, "margin_usdt": 0.01, "open_plain_orders": 0, "open_algo_orders": 0, "is_flat": False},
+        {"abs_qty": 0.0, "logical_side": "LONG", "notional_usdt": 0.0, "margin_usdt": 0.0, "open_plain_orders": 0, "open_algo_orders": 0, "is_flat": True},
+    ]
+    submitted_qty = []
+
+    ex._get_live_symbol_exposure = lambda *args, **kwargs: live_sequence.pop(0)
+    ex._verify_symbol_flat = lambda *args, **kwargs: verify_sequence.pop(0)
+    ex._cancel_all_symbol_orders_best_effort = lambda **kwargs: {"plain_canceled": 1, "algo_canceled": 1}
+    ex._submit_reduce_only_market_exit = lambda **kwargs: submitted_qty.append(kwargs["qty"]) or {
+        "close_order_id": 900 + len(submitted_qty),
+        "close_client_id": f"close-{len(submitted_qty)}",
+        "close_reason_tag": kwargs["reason_tag"],
+        "exit_order_ref": f"binance:close:{len(submitted_qty)}",
+    }
+
+    out = ex._force_flatten_symbol_exact(
+        sid="sid-1",
+        symbol="APTUSDT",
+        client=client,
+        filters=filters,
+        logical_side="LONG",
+        reason_tag="close",
+    )
+
+    assert submitted_qty == [0.1, 0.1]
+    assert out["status"] == "closed"
+    assert out["residual_qty"] == 0.0
+    assert len(out["attempts"]) == 2
+    assert out["attempts"][0]["verify"]["is_dust"] is True
+
+
+def test_handle_cancel_uses_exact_flatten_and_surfaces_residuals():
+    ex = _make_exec()
+    client = DummyClient()
+    filters = SimpleNamespace()
+    ex._resolve_client = lambda payload: (client, filters)
+    ex.allowlist = set()
+    ex._cancel_by_token = lambda symbol, sid, *, client: 3
+    ex._force_flatten_symbol_exact = lambda **kwargs: {
+        "status": "closed",
+        "close_order_id": 501,
+        "close_client_id": "cid-close",
+        "exit_order_ref": "binance:close_market:501",
+        "residual_qty": 0.0,
+        "residual_notional_usdt": 0.0,
+        "residual_margin_usdt": 0.0,
+    }
+    saved = {}
+    ex._save_order_state = lambda sid, state: saved.update(state)
+
+    class RiskClient(DummyClient):
+        def get_position_risk(self):
+            return [{"symbol": "APTUSDT", "positionAmt": "0.1"}]
+
+    risk_client = RiskClient()
+    ex._resolve_client = lambda payload: (risk_client, filters)
+
+    out = ex.handle_cancel({"sid": "sid-1", "symbol": "APTUSDT"})
+
+    assert out["closed"] == "true"
+    assert out["close_order_id"] == 501
+    assert out["residual_qty"] == 0.0
+    assert saved["status"] == "closed"
+    assert saved["residual_margin_usdt"] == 0.0
+
+
+class ClientForRisk(BinanceFuturesClient):
+    def __init__(self):
+        pass
+
+
+def test_get_symbol_position_risk_matches_symbol_and_side():
+    client = ClientForRisk.__new__(ClientForRisk)
+    client.get_position_risk = lambda: [
+        {"symbol": "BTCUSDT", "positionAmt": "0.01", "positionSide": "LONG"},
+        {"symbol": "BTCUSDT", "positionAmt": "-0.02", "positionSide": "SHORT"},
+    ]
+
+    long_row = client.get_symbol_position_risk("BTCUSDT", position_side="LONG")
+    short_row = client.get_symbol_position_risk("BTCUSDT", position_side="SHORT")
+
+    assert long_row["positionAmt"] == "0.01"
+    assert short_row["positionAmt"] == "-0.02"
