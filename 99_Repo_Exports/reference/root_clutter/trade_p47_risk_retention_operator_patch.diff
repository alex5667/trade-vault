+-- P4.7: retention + partitioning for risk decision audit hot tables.
+
+create table if not exists risk_decision_audit_archive (
+  like risk_decision_audit including all
+) partition by range (created_ts_ms);
+
+create table if not exists risk_snapshot_archive (
+  like risk_snapshot including all
+) partition by range (updated_ts_ms);
+
+create or replace function ensure_monthly_range_partition_risk(parent_table text, partition_prefix text, ts_ms bigint)
+returns void language plpgsql as $$
+declare
+  start_ts timestamptz;
+  end_ts timestamptz;
+  part_name text;
+  from_ms bigint;
+  to_ms bigint;
+begin
+  start_ts := date_trunc('month', to_timestamp(ts_ms / 1000.0) at time zone 'utc');
+  end_ts := start_ts + interval '1 month';
+  part_name := partition_prefix || to_char(start_ts, 'YYYYMM');
+  from_ms := (extract(epoch from start_ts) * 1000)::bigint;
+  to_ms := (extract(epoch from end_ts) * 1000)::bigint;
+  execute format('create table if not exists %I partition of %I for values from (%s) to (%s)', part_name, parent_table, from_ms, to_ms);
+end$$;
+
+create or replace function purge_risk_audit_hot_tables(cutoff_ts_ms bigint)
+returns table(purged_decisions bigint, purged_snapshots bigint) language plpgsql as $$
+declare
+  d_count bigint := 0;
+  s_count bigint := 0;
+begin
+  perform ensure_monthly_range_partition_risk('risk_decision_audit_archive', 'risk_decision_audit_archive_', cutoff_ts_ms);
+  perform ensure_monthly_range_partition_risk('risk_snapshot_archive', 'risk_snapshot_archive_', cutoff_ts_ms);
+
+  insert into risk_decision_audit_archive
+  select * from risk_decision_audit where created_ts_ms < cutoff_ts_ms;
+  get diagnostics d_count = row_count;
+  delete from risk_decision_audit where created_ts_ms < cutoff_ts_ms;
+
+  insert into risk_snapshot_archive
+  select * from risk_snapshot where updated_ts_ms < cutoff_ts_ms;
+  get diagnostics s_count = row_count;
+  delete from risk_snapshot where updated_ts_ms < cutoff_ts_ms;
+
+  return query select d_count, s_count;
+end$$;
