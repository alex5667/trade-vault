+def apply_liqmap_tp_sl_adjustment(
+    *,
+    # Backward-compatible parameter aliases:
+    #   - old callers: direction + entry_price
+    #   - new callers/tests: side + entry
+    direction: Optional[str] = None,
+    entry_price: Optional[float] = None,
+    side: Optional[str] = None,
+    entry: Optional[float] = None,
+    base_sl: float,
+    base_tp1: float,
+    indicators: Dict[str, Any],
+    window: str = "1h",
+    min_usd: float = 250_000.0,
+    buffer_bps: float = 5.0,
+    max_sl_widen_bps: float = 25.0,
+    enable_tp1: bool = True,
+    enable_sl: bool = True,
+) -> Tuple[float, float, Dict[str, float]]:
+    """Apply LiqMap anchors to TP1/SL.
+
+    This is a lightweight utility used by strategy/engine wiring.
+    Unit tests focus on SL widening being capped.
+
+    Inputs:
+      indicators may contain (recommended):
+        liqmap_<w>_peak_up1_usd, liqmap_<w>_peak_dn1_usd
+        liqmap_<w>_peak_up_price, liqmap_<w>_peak_dn_price
+      (legacy aliases without "1" are accepted too).
+
+    Outputs:
+      returns (new_sl, new_tp1, extra_indicators)
+      extra_indicators include liqmap_tp1_adj_bps / liqmap_sl_adj_bps etc.
+    """
+
+    out: Dict[str, float] = {}
+    side = str(direction or side or "").upper()
+    if side not in ("LONG", "SHORT"):
+        return float(base_sl), float(base_tp1), out
+
+    entry_px = float(entry_price if entry_price is not None else entry if entry is not None else 0.0)
+    if entry_px <= 0.0:
+        return float(base_sl), float(base_tp1), out
+
+    base_sl_px = float(base_sl)
+    base_tp1_px = float(base_tp1)
+
+    w = str(window)
+    up_usd = float(indicators.get(f"liqmap_{w}_peak_up1_usd") or indicators.get(f"liqmap_{w}_peak_up_usd") or 0.0)
+    dn_usd = float(indicators.get(f"liqmap_{w}_peak_dn1_usd") or indicators.get(f"liqmap_{w}_peak_dn_usd") or 0.0)
+    up_px = float(indicators.get(f"liqmap_{w}_peak_up_price") or 0.0)
+    dn_px = float(indicators.get(f"liqmap_{w}_peak_dn_price") or 0.0)
+
+    min_usd_f = float(min_usd)
+    buf = float(buffer_bps) / 10000.0
+    max_widen = float(max_sl_widen_bps)
+
+    def _tp_bps(tp: float) -> float:
+        if side == "LONG":
+            return max(0.0, (tp - entry_px) / entry_px * 10000.0)
+        return max(0.0, (entry_px - tp) / entry_px * 10000.0)
+
+    def _sl_bps(sl: float) -> float:
+        if side == "LONG":
+            return max(0.0, (entry_px - sl) / entry_px * 10000.0)
+        return max(0.0, (sl - entry_px) / entry_px * 10000.0)
+
+    base_tp_bps = _tp_bps(base_tp1_px)
+    base_sl_bps = _sl_bps(base_sl_px)
+
+    new_tp1_px = base_tp1_px
+    new_sl_px = base_sl_px
+    cap_applied = False
+    reasons: List[str] = []
+
+    # TP1 anchoring (optional)
+    if enable_tp1:
+        if side == "LONG" and up_usd >= min_usd_f and up_px > entry_px > 0.0:
+            new_tp1_px = up_px
+            out["liqmap_tp1_anchor_price"] = float(up_px)
+            out["liqmap_tp1_anchor_usd"] = float(up_usd)
+            reasons.append("tp1_to_peak")
+        elif side == "SHORT" and dn_usd >= min_usd_f and 0.0 < dn_px < entry_px:
+            new_tp1_px = dn_px
+            out["liqmap_tp1_anchor_price"] = float(dn_px)
+            out["liqmap_tp1_anchor_usd"] = float(dn_usd)
+            reasons.append("tp1_to_peak")
+
+    # SL hide behind adverse peak (optional, capped)
+    if enable_sl:
+        if side == "LONG" and dn_usd >= min_usd_f and 0.0 < dn_px < entry_px:
+            cand = dn_px * (1.0 - buf)
+            cand_sl_bps = _sl_bps(cand)
+            if cand_sl_bps - base_sl_bps > max_widen:
+                target_sl_bps = base_sl_bps + max_widen
+                new_sl_px = entry_px * (1.0 - target_sl_bps / 10000.0)
+                cap_applied = True
+            else:
+                new_sl_px = cand
+            out["liqmap_sl_anchor_price"] = float(dn_px)
+            out["liqmap_sl_anchor_usd"] = float(dn_usd)
+            reasons.append("sl_behind_peak")
+        elif side == "SHORT" and up_usd >= min_usd_f and up_px > entry_px > 0.0:
+            cand = up_px * (1.0 + buf)
+            cand_sl_bps = _sl_bps(cand)
+            if cand_sl_bps - base_sl_bps > max_widen:
+                target_sl_bps = base_sl_bps + max_widen
+                new_sl_px = entry_px * (1.0 + target_sl_bps / 10000.0)
+                cap_applied = True
+            else:
+                new_sl_px = cand
+            out["liqmap_sl_anchor_price"] = float(up_px)
+            out["liqmap_sl_anchor_usd"] = float(up_usd)
+            reasons.append("sl_behind_peak")
+
+    # Export adjustments
+    new_tp_bps = _tp_bps(new_tp1_px)
+    new_sl_bps = _sl_bps(new_sl_px)
+
+    if abs(new_tp1_px - base_tp1_px) > 1e-12:
+        out["liqmap_tp1_adj_bps"] = float(new_tp_bps - base_tp_bps)
+    if abs(new_sl_px - base_sl_px) > 1e-12:
+        out["liqmap_sl_adj_bps"] = float(new_sl_bps - base_sl_bps)
+
+    applied = (abs(new_tp1_px - base_tp1_px) > 1e-12) or (abs(new_sl_px - base_sl_px) > 1e-12)
+    out["liqmap_levels_applied"] = 1.0 if applied else 0.0
+
+    if cap_applied:
+        out["liqmap_levels_reason"] = "cap_sl_widen"
+    elif applied and len(reasons) >= 2:
+        out["liqmap_levels_reason"] = "tp1_sl"
+    elif applied and len(reasons) == 1:
+        out["liqmap_levels_reason"] = reasons[0]
+    else:
+        out["liqmap_levels_reason"] = "no_peak"
+
+    return new_sl_px, new_tp1_px, out
