--- p5x/binance_execution/test_execution_journal_p5_contract_v1.py	1970-01-01 00:00:00.000000000 +0000
+++ p5x_mod/binance_execution/test_execution_journal_p5_contract_v1.py	2026-03-07 09:07:05.041730117 +0000
@@ -0,0 +1,56 @@
+from pathlib import Path
+import importlib.util
+import sys
+
+mod_path = Path(__file__).resolve().parent / 'execution_journal.py'
+spec = importlib.util.spec_from_file_location('execution_journal_p5', mod_path)
+mod = importlib.util.module_from_spec(spec)
+sys.modules[spec.name] = mod
+spec.loader.exec_module(mod)
+
+
+class _Cursor:
+    def __init__(self, executed):
+        self.executed = executed
+    def __enter__(self):
+        return self
+    def __exit__(self, *args):
+        return False
+    def execute(self, sql, params):
+        self.executed.append((sql, params))
+
+
+class _Conn:
+    def __init__(self, executed):
+        self.executed = executed
+    def __enter__(self):
+        return self
+    def __exit__(self, *args):
+        return False
+    def cursor(self):
+        return _Cursor(self.executed)
+
+
+def test_order_snapshot_contains_chain_columns():
+    executed = []
+    sink = mod.ExecutionJournalSink(dsn='postgres://x', connect_factory=lambda dsn: _Conn(executed))
+    ok = sink.upsert_order_snapshot({
+        'sid': 's1', 'symbol': 'BTCUSDT', 'signal_id': 'sig-1', 'execution_plan_id': 'plan-1',
+        'entry_order_ref': 'binance|entry|oid=1|cid=abc', 'exit_order_ref': 'binance|exit|oid=2',
+        'closed_trade_id': 'closed:s1:abc', 'entry_policy': 'ENTRY_MARKET', 'exit_policy': 'EXIT_SAFE',
+    })
+    assert ok is True
+    sql, params = executed[0]
+    assert 'entry_policy' in sql and 'closed_trade_id' in sql
+    assert params[8] == 'sig-1'
+    assert params[9] == 'plan-1'
+
+
+def test_watchdog_event_insert_exists():
+    executed = []
+    sink = mod.ExecutionJournalSink(dsn='postgres://x', connect_factory=lambda dsn: _Conn(executed))
+    ok = sink.record_watchdog_event({'sid': 's1', 'symbol': 'BTCUSDT', 'tp_level': 1, 'tp_state': 'TP1_TRIGGERED'})
+    assert ok is True
+    sql, params = executed[0]
+    assert 'execution_watchdog_events' in sql
+    assert params[4] == 1
