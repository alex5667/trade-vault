+@pytest.mark.asyncio
+async def test_record_and_trip_sets_cfg_and_auto_apply_keys():
+    r = FakeAsyncRedis()
+    sym = "BTCUSDT"
+    now = 1_000_000
+    r.set_now_ms(now)
+
+    # 1st / 2nd do not trip
+    res1 = await record_downgrade_and_maybe_trip(
