+    ctx, cancel := context.WithCancel(context.Background())
+    defer cancel()
+
+    coins := []string{"BTC", "ETH", "SOL"}
+    c.reconcile(ctx, coins)
+    require.Equal(t, 3, len(c.currentCoins))
+
+    got := sortedStrings(c.currentCoins)
+    want := []string{"BTC", "ETH", "SOL"}
+    for i := range want {
+        assert.Equal(t, want[i], got[i])
+    }
+    cancel()
+}
+
+func TestUpdateSubscriptions_NoConn(t *testing.T) {
+    m := NewHyperliquidFuturesManager([]string{"BTC"}, log.New(os.Stdout, "", 0))
+    err := m.UpdateSubscriptions([]string{"ETH"}, nil)
+    assert.Error(t, err)
+    assert.Contains(t, err.Error(), "no active connection")
+}
+
+func TestLoadBaseCoins_FromSymbols(t *testing.T) {
+    coins := LoadBaseCoins([]string{"BTCUSDT", "ETHUSDT", "1000PEPEUSDT"})
+    require.Equal(t, []string{"1000PEPE", "BTC", "ETH"}, coins)
+}
+
+func TestAssignSyntheticBookIDs_MonotonicPerSymbol(t *testing.T) {
+    c := newTestController()
+
+    b1 := NormalizedDepth{Symbol: "BTCUSDT"}
+    c.assignSyntheticBookIDs(&b1)
+    require.Equal(t, int64(0), b1.PrevFinal)
+    require.Equal(t, int64(1), b1.FinalID)
+    require.Equal(t, int64(1), b1.FirstID)
+
+    b2 := NormalizedDepth{Symbol: "BTCUSDT"}
+    c.assignSyntheticBookIDs(&b2)
+    require.Equal(t, int64(1), b2.PrevFinal)
+    require.Equal(t, int64(2), b2.FinalID)
+
+    // Separate symbol has its own counter.
+    b3 := NormalizedDepth{Symbol: "ETHUSDT"}
+    c.assignSyntheticBookIDs(&b3)
+    require.Equal(t, int64(0), b3.PrevFinal)
+    require.Equal(t, int64(1), b3.FinalID)
+}
