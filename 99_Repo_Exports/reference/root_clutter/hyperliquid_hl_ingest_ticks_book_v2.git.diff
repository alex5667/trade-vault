@@ -0,0 +1,733 @@
+package hyperliquid
+
+import (
+    "context"
+    "errors"
+    "fmt"
+    "log"
+    "net"
+    "os"
+    "sort"
+    "strings"
+    "sync"
+    "sync/atomic"
+    "time"
+
+    "go-worker/internal/metrics"
+    "go-worker/internal/monitoring"
+    "go-worker/internal/orderflow"
+    internalredis "go-worker/internal/redis"
+    "go-worker/internal/wsconn"
+
+    "github.com/go-redis/redis/v8"
+    "github.com/gorilla/websocket"
+)
+
+// HyperliquidFuturesManager manages one WS connection to Hyperliquid.
+// Differences vs Binance:
+//  - Subscriptions are sent after connect (subscribe/unsubscribe).
+//  - Hyperliquid requires application-level heartbeat: {"method":"ping"}.
+//    We send it periodically.
+//
+// WS docs:
+//  - https://hyperliquid.gitbook.io/hyperliquid-docs/for-developers/api/websocket
+//  - https://hyperliquid.gitbook.io/hyperliquid-docs/for-developers/api/websocket/timeouts-and-heartbeats
+type HyperliquidFuturesManager struct {
+    coins []string
+    conn  *websocket.Conn
+    log   *log.Logger
+
+    mu      sync.Mutex
+    writeMu sync.Mutex // Gorilla WS requires single writer
+
+    tradesEnabled bool
+    bookEnabled   bool
+}
+
+type subscription struct {
+    Type string `json:"type"`
+    Coin string `json:"coin"`
+}
+
+type wsCommand struct {
+    Method       string        `json:"method"`
+    Subscription *subscription `json:"subscription,omitempty"`
+}
+
+func NewHyperliquidFuturesManager(coins []string, logger *log.Logger) *HyperliquidFuturesManager {
+    return &HyperliquidFuturesManager{
+        coins:         coins,
+        log:           logger,
+        tradesEnabled: getEnvBool("HYPERLIQUID_TRADES_ENABLED", true),
+        bookEnabled:   getEnvBool("HYPERLIQUID_L2BOOK_ENABLED", true),
+    }
+}
+
+func (m *HyperliquidFuturesManager) Connect(ctx context.Context) error {
+    m.mu.Lock()
+    defer m.mu.Unlock()
+
+    if m.conn != nil {
+        _ = m.conn.Close()
+        m.conn = nil
+    }
+
+    wsURL := getEnv("HYPERLIQUID_WS_URL", "wss://api.hyperliquid.xyz/ws")
+
+    cfg := wsconn.DefaultConfig()
+    cfg.HandshakeTimeout = getEnvDuration("HYPERLIQUID_WS_HANDSHAKE_TIMEOUT", cfg.HandshakeTimeout)
+    cfg.DialTimeout = getEnvDuration("HYPERLIQUID_WS_DIAL_TIMEOUT", cfg.DialTimeout)
+    cfg.TCPKeepAlive = getEnvDuration("HYPERLIQUID_WS_TCP_KEEPALIVE", cfg.TCPKeepAlive)
+    cfg.ReadTimeout = getEnvDuration("HYPERLIQUID_WS_READ_TIMEOUT", 90*time.Second)
+    cfg.PingPeriod = getEnvDuration("HYPERLIQUID_WS_PING_PERIOD", 20*time.Second)
+    cfg.WriteWait = getEnvDuration("HYPERLIQUID_WS_WRITE_WAIT", cfg.WriteWait)
+    cfg.MsgChanCapacity = getEnvInt("HYPERLIQUID_WS_MSG_CHAN", cfg.MsgChanCapacity)
+
+    conn, err := wsconn.Dial(ctx, wsURL, cfg)
+    if err != nil {
+        return err
+    }
+
+    // Transport-level ping/pong handlers.
+    wsconn.SetupPingPong(conn, cfg.ReadTimeout, cfg.WriteWait, func(msg []byte) error {
+        m.writeMu.Lock()
+        defer m.writeMu.Unlock()
+        return conn.WriteControl(websocket.PongMessage, msg, time.Now().Add(cfg.WriteWait))
+    })
+
+    m.conn = conn
+
+    if err := m.subscribeCoinsLocked(m.coins); err != nil {
+        _ = conn.Close()
+        m.conn = nil
+        return err
+    }
+    return nil
+}
+
+func (m *HyperliquidFuturesManager) ReadLoop(ctx context.Context, handler func(msg []byte)) error {
+    m.mu.Lock()
+    conn := m.conn
+    m.mu.Unlock()
+    if conn == nil {
+        return errors.New("websocket connection is nil")
+    }
+
+    readTimeout := getEnvDuration("HYPERLIQUID_WS_READ_TIMEOUT", 90*time.Second)
+    _ = conn.SetReadDeadline(time.Now().Add(readTimeout))
+
+    lastMessageTime := time.Now()
+    msgChanCap := getEnvInt("HYPERLIQUID_WS_MSG_CHAN", wsconn.DefaultConfig().MsgChanCapacity)
+    msgChan := make(chan []byte, msgChanCap)
+
+    handlerDone := make(chan struct{})
+    go func() {
+        defer close(handlerDone)
+        for msg := range msgChan {
+            handler(msg)
+        }
+    }()
+
+    pingCtx, cancel := context.WithCancel(ctx)
+    defer cancel()
+
+    errCh := make(chan error, 1)
+    go func() {
+        ticker := time.NewTicker(getEnvDuration("HYPERLIQUID_WS_PING_PERIOD", 20*time.Second))
+        defer ticker.Stop()
+        for {
+            select {
+            case <-pingCtx.Done():
+                return
+            case <-ticker.C:
+                if err := m.sendAppPing(); err != nil {
+                    errCh <- err
+                    return
+                }
+                _ = conn.SetReadDeadline(time.Now().Add(readTimeout))
+            }
+        }
+    }()
+
+    defer func() {
+        close(msgChan)
+        <-handlerDone
+    }()
+
+    for {
+        select {
+        case err := <-errCh:
+            return err
+        case <-ctx.Done():
+            return ctx.Err()
+        default:
+        }
+
+        _, msg, err := conn.ReadMessage()
+        if err != nil {
+            if netErr, ok := err.(net.Error); ok && netErr.Timeout() {
+                if time.Since(lastMessageTime) > readTimeout {
+                    return fmt.Errorf("read timeout: %w", err)
+                }
+                continue
+            }
+            return fmt.Errorf("read error: %w", err)
+        }
+
+        lastMessageTime = time.Now()
+        select {
+        case msgChan <- msg:
+        default:
+            // load-shed instead of reconnect; same policy as Binance futures.
+            monitoring.RecordFuturesMessageDropped("HYPERLIQUID")
+        }
+    }
+}
+
+func (m *HyperliquidFuturesManager) sendAppPing() error {
+    m.mu.Lock()
+    conn := m.conn
+    m.mu.Unlock()
+    if conn == nil {
+        return nil
+    }
+    m.writeMu.Lock()
+    defer m.writeMu.Unlock()
+    return conn.WriteJSON(wsCommand{Method: "ping"})
+}
+
+// UpdateSubscriptions updates subscriptions without reconnect.
+func (m *HyperliquidFuturesManager) UpdateSubscriptions(addCoins, removeCoins []string) error {
+    m.mu.Lock()
+    conn := m.conn
+    m.mu.Unlock()
+    if conn == nil {
+        return errors.New("no active connection")
+    }
+
+    m.writeMu.Lock()
+    defer m.writeMu.Unlock()
+
+    if len(removeCoins) > 0 {
+        for _, coin := range removeCoins {
+            coin = strings.ToUpper(strings.TrimSpace(coin))
+            if coin == "" {
+                continue
+            }
+            if m.tradesEnabled {
+                if err := conn.WriteJSON(wsCommand{Method: "unsubscribe", Subscription: &subscription{Type: "trades", Coin: coin}}); err != nil {
+                    return fmt.Errorf("unsubscribe trades(%s): %w", coin, err)
+                }
+            }
+            if m.bookEnabled {
+                if err := conn.WriteJSON(wsCommand{Method: "unsubscribe", Subscription: &subscription{Type: "l2Book", Coin: coin}}); err != nil {
+                    return fmt.Errorf("unsubscribe l2Book(%s): %w", coin, err)
+                }
+            }
+        }
+        monitoring.RecordHyperliquidLiveSubscription("UNSUBSCRIBE")
+    }
+
+    if len(addCoins) > 0 {
+        for _, coin := range addCoins {
+            coin = strings.ToUpper(strings.TrimSpace(coin))
+            if coin == "" {
+                continue
+            }
+            if m.tradesEnabled {
+                if err := conn.WriteJSON(wsCommand{Method: "subscribe", Subscription: &subscription{Type: "trades", Coin: coin}}); err != nil {
+                    return fmt.Errorf("subscribe trades(%s): %w", coin, err)
+                }
+            }
+            if m.bookEnabled {
+                if err := conn.WriteJSON(wsCommand{Method: "subscribe", Subscription: &subscription{Type: "l2Book", Coin: coin}}); err != nil {
+                    return fmt.Errorf("subscribe l2Book(%s): %w", coin, err)
+                }
+            }
+        }
+        monitoring.RecordHyperliquidLiveSubscription("SUBSCRIBE")
+    }
+
+    // Update internal list.
+    m.mu.Lock()
+    defer m.mu.Unlock()
+    if len(addCoins) > 0 {
+        m.coins = append(m.coins, addCoins...)
+    }
+    if len(removeCoins) > 0 {
+        removeSet := map[string]struct{}{}
+        for _, c := range removeCoins {
+            removeSet[strings.ToUpper(c)] = struct{}{}
+        }
+        out := make([]string, 0, len(m.coins))
+        for _, c := range m.coins {
+            if _, ok := removeSet[strings.ToUpper(c)]; !ok {
+                out = append(out, c)
+            }
+        }
+        m.coins = out
+    }
+    return nil
+}
+
+func (m *HyperliquidFuturesManager) subscribeCoinsLocked(coins []string) error {
+    conn := m.conn
+    if conn == nil {
+        return errors.New("no active connection")
+    }
+
+    // Dedup + sort (determinism).
+    out := make([]string, 0, len(coins))
+    seen := map[string]struct{}{}
+    for _, c := range coins {
+        c = strings.ToUpper(strings.TrimSpace(c))
+        if c == "" {
+            continue
+        }
+        if _, ok := seen[c]; ok {
+            continue
+        }
+        seen[c] = struct{}{}
+        out = append(out, c)
+    }
+    sort.Strings(out)
+
+    // Each coin consumes up to 2 subscriptions.
+    maxSubs := getEnvInt("HYPERLIQUID_MAX_SUBSCRIPTIONS", 900)
+    needed := 0
+    if m.tradesEnabled {
+        needed += len(out)
+    }
+    if m.bookEnabled {
+        needed += len(out)
+    }
+    if needed > maxSubs {
+        return fmt.Errorf("hyperliquid subscriptions requested=%d exceeds limit=%d (reduce HYPERLIQUID_COINS)", needed, maxSubs)
+    }
+
+    m.writeMu.Lock()
+    defer m.writeMu.Unlock()
+    for _, coin := range out {
+        if m.tradesEnabled {
+            if err := conn.WriteJSON(wsCommand{Method: "subscribe", Subscription: &subscription{Type: "trades", Coin: coin}}); err != nil {
+                return fmt.Errorf("subscribe trades(%s): %w", coin, err)
+            }
+        }
+        if m.bookEnabled {
+            if err := conn.WriteJSON(wsCommand{Method: "subscribe", Subscription: &subscription{Type: "l2Book", Coin: coin}}); err != nil {
+                return fmt.Errorf("subscribe l2Book(%s): %w", coin, err)
+            }
+        }
+    }
+    monitoring.RecordHyperliquidLiveSubscription("SUBSCRIBE")
+    return nil
+}
+
+func (m *HyperliquidFuturesManager) Close() {
+    m.mu.Lock()
+    defer m.mu.Unlock()
+    if m.conn != nil {
+        _ = m.conn.Close()
+        m.conn = nil
+    }
+}
+
+// --- Controller (similar to Binance FuturesStreamController) ---
+
+type FuturesStreamController struct {
+    client          *redis.Client
+    publisher       internalredis.Publisher
+    logger          *log.Logger
+    coinsKey        string
+    refreshInterval time.Duration
+    healthMetrics   *metrics.HealthMetrics
+    stalenessConfig orderflow.StalenessConfig
+
+    symbolMap     map[string]string
+    symbolSuffix  string
+    maxBookLevels int
+
+    // Synthetic book ids (monotonic per SYMBOL)
+    // Why:
+    // - Python worker has DQ / monitoring code that expects first_id/final_id/prev_final fields.
+    // - Hyperliquid l2Book does not provide exchange update ids.
+    // - Using timestamp(ms) as final_id would create enormous "missing seq" gaps.
+    // Therefore we generate local monotonic ids per symbol: 1,2,3,...
+    bookMu       sync.Mutex
+    bookSeq      map[string]int64
+    lastBookFinal map[string]int64
+
+    mu                  sync.Mutex
+    currentCoins        []string
+    activeManagerCancel context.CancelFunc
+    activeManager       *HyperliquidFuturesManager
+    errorCount          int64
+}
+
+func NewFuturesStreamController(
+    client *redis.Client,
+    publisher internalredis.Publisher,
+    logger *log.Logger,
+    coinsKey string,
+    refreshInterval time.Duration,
+    healthMetrics *metrics.HealthMetrics,
+    stalenessConfig orderflow.StalenessConfig,
+) *FuturesStreamController {
+    suffix := getEnv("HYPERLIQUID_SYMBOL_SUFFIX", "USDT")
+    if getEnvBool("HYPERLIQUID_KEEP_COIN_SYMBOL", false) {
+        suffix = ""
+    }
+
+    return &FuturesStreamController{
+        client:          client,
+        publisher:       publisher,
+        logger:          logger,
+        coinsKey:        coinsKey,
+        refreshInterval: refreshInterval,
+        healthMetrics:   healthMetrics,
+        stalenessConfig: stalenessConfig,
+        symbolMap:       parseSymbolMap(getEnv("HYPERLIQUID_SYMBOL_MAP", "")),
+        symbolSuffix:    suffix,
+        maxBookLevels:   getEnvInt("HYPERLIQUID_BOOK_MAX_LEVELS", 20),
+        bookSeq:         map[string]int64{},
+        lastBookFinal:   map[string]int64{},
+    }
+}
+
+func (c *FuturesStreamController) Run(ctx context.Context, baseCoins []string) {
+    c.logger.Printf("Hyperliquid futures controller start. Redis key: %s", c.coinsKey)
+
+    desired := c.loadCoins(ctx, baseCoins)
+    c.reconcile(ctx, desired)
+
+    ticker := time.NewTicker(c.refreshInterval)
+    defer ticker.Stop()
+
+    for {
+        select {
+        case <-ctx.Done():
+            c.logger.Println("Hyperliquid controller stop by ctx")
+            c.Stop()
+            return
+        case <-ticker.C:
+            desired = c.loadCoins(ctx, baseCoins)
+            c.reconcile(ctx, desired)
+        }
+    }
+}
+
+func (c *FuturesStreamController) Stop() {
+    c.mu.Lock()
+    defer c.mu.Unlock()
+    if c.activeManagerCancel != nil {
+        c.activeManagerCancel()
+        c.activeManagerCancel = nil
+    }
+}
+
+func (c *FuturesStreamController) loadCoins(ctx context.Context, base []string) []string {
+    set := make(map[string]struct{}, len(base))
+    for _, s := range base {
+        s = strings.ToUpper(strings.TrimSpace(s))
+        if s == "" {
+            continue
+        }
+        set[s] = struct{}{}
+    }
+    if c.client != nil && c.coinsKey != "" {
+        coins, err := c.client.SMembers(ctx, c.coinsKey).Result()
+        if err != nil && err != redis.Nil {
+            c.logger.Printf("Error reading Redis key %s: %v", c.coinsKey, err)
+        } else {
+            for _, s := range coins {
+                s = strings.ToUpper(strings.TrimSpace(s))
+                if s == "" {
+                    continue
+                }
+                set[s] = struct{}{}
+            }
+        }
+    }
+    out := make([]string, 0, len(set))
+    for s := range set {
+        out = append(out, s)
+    }
+    sort.Strings(out)
+    return out
+}
+
+func (c *FuturesStreamController) reconcile(ctx context.Context, coins []string) {
+    c.mu.Lock()
+    defer c.mu.Unlock()
+
+    if len(coins) == len(c.currentCoins) {
+        currSet := map[string]struct{}{}
+        for _, s := range c.currentCoins {
+            currSet[strings.ToUpper(s)] = struct{}{}
+        }
+        match := true
+        for _, s := range coins {
+            if _, ok := currSet[strings.ToUpper(s)]; !ok {
+                match = false
+                break
+            }
+        }
+        if match {
+            return
+        }
+    }
+
+    currSet := map[string]struct{}{}
+    for _, s := range c.currentCoins {
+        currSet[strings.ToUpper(s)] = struct{}{}
+    }
+    newSet := map[string]struct{}{}
+    for _, s := range coins {
+        newSet[strings.ToUpper(s)] = struct{}{}
+    }
+
+    var toAdd, toRemove []string
+    for s := range newSet {
+        if _, ok := currSet[s]; !ok {
+            toAdd = append(toAdd, s)
+        }
+    }
+    for s := range currSet {
+        if _, ok := newSet[s]; !ok {
+            toRemove = append(toRemove, s)
+        }
+    }
+    sort.Strings(toAdd)
+    sort.Strings(toRemove)
+
+    if c.activeManager != nil {
+        c.logger.Printf("Hyperliquid Live Update: add=%d remove=%d", len(toAdd), len(toRemove))
+        if err := c.activeManager.UpdateSubscriptions(toAdd, toRemove); err == nil {
+            c.currentCoins = append([]string{}, coins...)
+            return
+        } else {
+            c.logger.Printf("⚠️ Hyperliquid live update failed, fallback to reconnect: %v", err)
+        }
+    }
+
+    c.logger.Printf("Hyperliquid coins changed (%d -> %d), reconnect", len(c.currentCoins), len(coins))
+    if c.activeManagerCancel != nil {
+        c.activeManagerCancel()
+    }
+    c.currentCoins = append([]string{}, coins...)
+
+    runCtx, cancel := context.WithCancel(ctx)
+    c.activeManagerCancel = cancel
+    go c.runWS(runCtx, c.currentCoins)
+}
+
+func (c *FuturesStreamController) runWS(ctx context.Context, coins []string) {
+    if len(coins) == 0 {
+        return
+    }
+    backoff := wsconn.DefaultReconnectBackoff
+    for {
+        if ctx.Err() != nil {
+            return
+        }
+
+        manager := NewHyperliquidFuturesManager(coins, c.logger)
+        c.mu.Lock()
+        c.activeManager = manager
+        c.mu.Unlock()
+
+        if err := manager.Connect(ctx); err != nil {
+            c.logger.Printf("Hyperliquid connect error: %v", err)
+            monitoring.RecordHyperliquidReconnect("connect_error")
+            select {
+            case <-ctx.Done():
+                return
+            case <-time.After(backoff):
+            }
+            backoff = wsconn.NextBackoff(backoff)
+            continue
+        }
+
+        backoff = wsconn.DefaultReconnectBackoff
+        c.logger.Printf("✅ Hyperliquid WS connected for %d coins", len(coins))
+
+        err := manager.ReadLoop(ctx, func(msg []byte) {
+            c.processMessage(ctx, msg)
+        })
+
+        if err != nil {
+            if err == context.Canceled {
+                return
+            }
+            currentErrorCount := atomic.AddInt64(&c.errorCount, 1)
+            isConnReset := wsconn.IsConnectionReset(err)
+            isTimeout := wsconn.IsTimeout(err)
+            isCtx := wsconn.IsContextError(err)
+
+            monitoring.RecordHyperliquidReconnect("read_error")
+            if isCtx {
+                return
+            }
+            if isConnReset || isTimeout {
+                if currentErrorCount <= 5 || currentErrorCount%1000 == 0 {
+                    reason := "connection reset"
+                    if isTimeout {
+                        reason = "timeout"
+                    }
+                    c.logger.Printf("⚠️ Hyperliquid WS %s (count=%d): %v", reason, currentErrorCount, err)
+                }
+            } else {
+                if currentErrorCount <= 5 || currentErrorCount%100 == 0 {
+                    c.logger.Printf("❌ Hyperliquid WS error (count=%d): %v", currentErrorCount, err)
+                }
+            }
+        }
+
+        select {
+        case <-ctx.Done():
+            return
+        case <-time.After(backoff):
+        }
+        backoff = wsconn.NextBackoff(backoff)
+    }
+}
+
+func (c *FuturesStreamController) assignSyntheticBookIDs(book *NormalizedDepth) {
+    if book == nil {
+        return
+    }
+    sym := strings.ToUpper(strings.TrimSpace(book.Symbol))
+    if sym == "" {
+        return
+    }
+
+    c.bookMu.Lock()
+    defer c.bookMu.Unlock()
+
+    prev := c.lastBookFinal[sym]
+    next := c.bookSeq[sym] + 1
+    c.bookSeq[sym] = next
+    c.lastBookFinal[sym] = next
+
+    book.PrevFinal = prev
+    book.FirstID = next
+    book.FinalID = next
+}
+
+func (c *FuturesStreamController) processMessage(ctx context.Context, payload []byte) {
+    ticks, books, err := NormalizeFuturesMessage(payload, c.symbolMap, c.symbolSuffix, c.maxBookLevels)
+    if err != nil {
+        monitoring.RecordHyperliquidParseError()
+        return
+    }
+    nowMs := time.Now().UnixMilli()
+
+    for _, tick := range ticks {
+        monitoring.RecordHyperliquidMessage(tick.Symbol, "trades")
+        if c.healthMetrics != nil {
+            // Same pattern as Binance futures controller (bookTsMs approximated by nowMs).
+            ofCtx := orderflow.NewOrderflowCtx(tick.Symbol, tick.Ts, nowMs)
+            ofCtx.ComputeStaleness(c.stalenessConfig)
+            c.healthMetrics.OnTick(metrics.TickMetricsInput{
+                Symbol:       tick.Symbol,
+                L2AgeMs:      ofCtx.L2AgeMsNow,
+                L2AgeMsTick:  ofCtx.L2AgeMsTick,
+                L2IsStale:    ofCtx.L2IsStale,
+                L2IsStaleNow: ofCtx.L2IsStaleNow,
+                EtaFillMs:    nil,
+                BurstRatio:   nil,
+                ImbalanceMin: nil,
+            })
+        }
+
+        if err := c.publisher.PublishTick(ctx, tick.Symbol, tick.RedisValues()); err != nil {
+            if err == context.Canceled {
+                return
+            }
+            c.logger.Printf("Hyperliquid publish tick error: %v", err)
+        }
+    }
+
+    for i := range books {
+        // Fill synthetic ids to keep downstream safe.
+        c.assignSyntheticBookIDs(&books[i])
+
+        monitoring.RecordHyperliquidMessage(books[i].Symbol, "l2Book")
+        if c.healthMetrics != nil {
+            // Same pattern as Binance: tickTsMs approximated by nowMs.
+            ofCtx := orderflow.NewOrderflowCtx(books[i].Symbol, nowMs, books[i].Ts)
+            ofCtx.ComputeStaleness(c.stalenessConfig)
+            c.healthMetrics.OnTick(metrics.TickMetricsInput{
+                Symbol:       books[i].Symbol,
+                L2AgeMs:      ofCtx.L2AgeMsNow,
+                L2AgeMsTick:  ofCtx.L2AgeMsTick,
+                L2IsStale:    ofCtx.L2IsStale,
+                L2IsStaleNow: ofCtx.L2IsStaleNow,
+                EtaFillMs:    nil,
+                BurstRatio:   nil,
+                ImbalanceMin: nil,
+            })
+        }
+
+        if err := c.publisher.PublishBook(ctx, books[i].Symbol, books[i].RedisValues()); err != nil {
+            if err == context.Canceled {
+                return
+            }
+            c.logger.Printf("Hyperliquid publish book error: %v", err)
+        }
+    }
+}
+
+// parseCoinsFromSymbols converts Binance-style symbols to Hyperliquid coins.
+// Examples:
+//  BTCUSDT -> BTC
+//  1000PEPEUSDT -> 1000PEPE
+func parseCoinsFromSymbols(symbols []string) []string {
+    out := make([]string, 0, len(symbols))
+    for _, s := range symbols {
+        s = strings.ToUpper(strings.TrimSpace(s))
+        if s == "" {
+            continue
+        }
+        s = strings.TrimSuffix(s, "USDT")
+        s = strings.TrimSuffix(s, "USDC")
+        if s != "" {
+            out = append(out, s)
+        }
+    }
+    if len(out) == 0 {
+        return []string{"BTC", "ETH"}
+    }
+    // Dedup.
+    seen := map[string]struct{}{}
+    uniq := make([]string, 0, len(out))
+    for _, c := range out {
+        if _, ok := seen[c]; ok {
+            continue
+        }
+        seen[c] = struct{}{}
+        uniq = append(uniq, c)
+    }
+    sort.Strings(uniq)
+    return uniq
+}
+
+// LoadBaseCoins reads HYPERLIQUID_COINS or derives coins from FUTURES_SYMBOLS.
+func LoadBaseCoins(futuresSymbols []string) []string {
+    raw := strings.TrimSpace(os.Getenv("HYPERLIQUID_COINS"))
+    if raw != "" {
+        parts := strings.Split(raw, ",")
+        out := make([]string, 0, len(parts))
+        for _, p := range parts {
+            c := strings.ToUpper(strings.TrimSpace(p))
+            if c != "" {
+                out = append(out, c)
+            }
+        }
+        if len(out) > 0 {
+            sort.Strings(out)
+            return out
+        }
+    }
+    return parseCoinsFromSymbols(futuresSymbols)
+}
