+      - alert: OFInputsQuarantineNonZero
+        expr: of_inputs_dlq_len{stream="quarantine:signals:of:inputs"} > 0
+        for: 30m
+        labels:
+          severity: info
+          component: of_inputs
+        annotations:
+          summary: "OFInputs quarantine contains entries"
+          description: "Quarantine length={{ $value }} (downgrades/missing LOB fields). Investigate dq_code and book_state quality."
+
+      - alert: OFInputsPublisherErrors
+        expr: increase(of_inputs_publish_error_total[5m]) > 0
+        for: 2m
+        labels:
+          severity: critical
+          component: of_inputs
+        annotations:
+          summary: "OFInputs publish errors detected"
+          description: "increase(of_inputs_publish_error_total[5m])={{ $value }}. DLQ likely growing; check Redis health and payload serialization."
+
+      - alert: OFInputsV3DowngradeRateHigh
+        # Tune this threshold per symbol count / tick rate.
+        expr: increase(of_inputs_downgrade_total{from_version="3",to_version="2"}[15m]) > 100
+        for: 10m
+        labels:
+          severity: warning
+          component: of_inputs
+        annotations:
+          summary: "High OFInputs V3→V2 downgrade rate"
+          description: "increase(of_inputs_downgrade_total{from_version=3,to_version=2}[15m])={{ $value }}. Likely book lag or missing LOB fields."
