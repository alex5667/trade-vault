+def _norm_mode(x: Any) -> str:
+    """Normalize liqmap gate mode to a minimal production set.
+
+    Supported modes (case-insensitive): OFF | SHADOW | ENFORCE.
+
+    Legacy/experimental strings (e.g. "penalty", "both", "boost") are mapped to
+    SHADOW (observe-only) for safety, to avoid accidentally introducing new hard-veto
+    policy before it is stabilized.
+
+    Unknown strings are also mapped to SHADOW (observe-only).
+    """
+    s = str(x or "").strip().lower()
+    if s in ("", "off", "0", "false", "no", "disabled", "none"):
+        return "OFF"
+    if s in ("shadow", "observe", "observed", "dryrun", "dry-run"):
+        return "SHADOW"
+    if s in ("enforce", "veto", "hard", "block"):
+        return "ENFORCE"
+
+    if s in ("penalty", "both", "boost", "pen", "soft", "score", "score_only"):
+        return "SHADOW"
+
+    return "SHADOW"
+
+
