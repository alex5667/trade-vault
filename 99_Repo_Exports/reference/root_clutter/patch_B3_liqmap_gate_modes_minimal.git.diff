--- a/tick_flow_full/tests/core/test_liqmap_gate_v1.py
+++ b/tick_flow_full/tests/core/test_liqmap_gate_v1.py
@@ -76,3 +76,20 @@
     res = evaluate_liqmap_gate_v1(indicators=ind, direction="LONG", cfg2=cfg2)
     assert res.shadow_veto == 0
     assert res.veto == 0
+def test_liqmap_gate_legacy_modes_mapped_to_shadow():
+    ind = _base_indicators()
+    for legacy in ("penalty", "both", "boost", "score_only"):
+        cfg2 = _base_cfg(legacy)
+        res = evaluate_liqmap_gate_v1(indicators=ind, direction="LONG", cfg2=cfg2)
+        # Production minimal set: any legacy/unknown mode must normalize to SHADOW (observe-only).
+        assert res.mode == "SHADOW"
+        assert res.shadow_veto in (0, 1)
+        assert res.veto == 0
+
+
+def test_liqmap_gate_unknown_mode_defaults_to_shadow_not_enforce():
+    ind = _base_indicators()
+    cfg2 = _base_cfg("enfocre")  # typo should not accidentally enforce
+    res = evaluate_liqmap_gate_v1(indicators=ind, direction="LONG", cfg2=cfg2)
+    assert res.mode == "SHADOW"
+    assert res.veto == 0

