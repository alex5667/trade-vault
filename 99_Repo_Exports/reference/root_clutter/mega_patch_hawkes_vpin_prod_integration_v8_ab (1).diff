+"""ML feature schema v7 (OrderFlow).
+
+v7_of = v6_of + Hawkes-like split intensities + VPIN-like toxicity + limit-add proxies.
+
+Design: keep extensions cheap (O(1) per bucket) and low-latency.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from typing import List
+
+from core.ml_feature_schema_v6_of import MLFeatureSchemaV6OF
+
+
+@dataclass
+class MLFeatureSchemaV7OF(MLFeatureSchemaV6OF):
+    """v7_of = v6_of + Hawkes-like split intensities + VPIN-like toxicity + limit-add proxies."""
+
+    def __post_init__(self) -> None:  # noqa: D401
+        super().__post_init__()
+
+        extra_num: List[str] = [
+            # limit-add (liquidity replenishment proxy)
+            "limit_add_total_rate_ema",
+            "limit_add_imb",
+
+            # VPIN-like toxicity proxy
+            "vpin_tox_ema",
+            "vpin_tox_z",
+
+            # derived aliases (experiment-friendly)
+            "lambda_trade_buy",
+            "lambda_trade_sell",
+            "lambda_limit_add",
+            "liquidity_pressure",
+            "info_flow",
+
+            # Hawkes-like split intensities
+            "hawkes_taker_buy_lam",
+            "hawkes_taker_sell_lam",
+            "hawkes_cancel_bid_lam",
+            "hawkes_cancel_ask_lam",
+            "hawkes_limit_add_lam",
+        ]
+
+        for k in extra_num:
+            if k not in self.num_keys:
+                self.num_keys.append(k)
