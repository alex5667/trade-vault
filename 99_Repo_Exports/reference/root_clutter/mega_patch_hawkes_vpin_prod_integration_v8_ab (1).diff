+"""Hawkes-like online intensities (cheap burst features).
+
+Goal
+----
+Provide O(1) recursion that approximates Hawkes clustering without heavyweight event-history.
+We keep an exponentially-decaying accumulator S for each stream:
+
+    S <- exp(-beta*dt) * S + rate * dt
+    lambda <- mu + alpha * S
+
+Where `rate` is an EMA proxy (events/sec) coming from L3-lite / microstructure trackers.
+
+Design constraints
+------------------
+- Deterministic time: caller passes ts_ms.
+- Fail-open: safe to skip on errors.
+- Backward compatible: keep aggregated taker/cancel/churn lambdas.
+"""
+
+from __future__ import annotations
+
+import math
+from typing import Any, Dict, Mapping, Optional, Tuple
+
+
+def _get_float(cfg: Mapping[str, Any], key: str, default: float) -> float:
+    v = cfg.get(key, default)
+    try:
+        return float(v)
+    except Exception:
+        return float(default)
+
+
+def update_hawkes_like(
+    state: Optional[Dict[str, Any]],
+    *,
+    ts_ms: int,
+    rates: Mapping[str, float],
+    cfg: Mapping[str, Any],
+) -> Tuple[Dict[str, Any], Dict[str, float]]:
+    """Update Hawkes-like state and return (state, snapshot).
+
+    Parameters
+    ----------
+    state:
+        Mutable dict stored on runtime (or None for init).
+    ts_ms:
+        Current timestamp in epoch ms.
+    rates:
+        Mapping with keys:
+          - taker_buy_rate
+          - taker_sell_rate
+          - cancel_bid_rate
+          - cancel_ask_rate
+          - limit_add_rate
+        All values are expected to be non-negative (events/sec proxy).
+    cfg:
+        Runtime config mapping. Supports:
+          hawkes_beta
+          hawkes_alpha_taker / hawkes_mu_taker
+          hawkes_alpha_cancel / hawkes_mu_cancel
+          hawkes_alpha_churn / hawkes_mu_churn
+          hawkes_alpha_taker_buy / hawkes_mu_taker_buy
+          hawkes_alpha_taker_sell / hawkes_mu_taker_sell
+          hawkes_alpha_cancel_bid / hawkes_mu_cancel_bid
+          hawkes_alpha_cancel_ask / hawkes_mu_cancel_ask
+          hawkes_alpha_limit_add / hawkes_mu_limit_add
+
+    Returns
+    -------
+    (state, snapshot)
+        snapshot is a flat dict of floats suitable to be merged into indicators.
+    """
+
+    t_now = int(ts_ms)
+    if state is None:
+        state = {"ts_ms": t_now}
+
+    prev_ts = int(state.get("ts_ms", t_now))
+    dt_s = max(0.0, (t_now - prev_ts) / 1000.0)
+    state["ts_ms"] = t_now
+
+    # Rates (proxy events/sec)
+    tb = max(0.0, float(rates.get("taker_buy_rate", 0.0) or 0.0))
+    tsell = max(0.0, float(rates.get("taker_sell_rate", 0.0) or 0.0))
+    cb = max(0.0, float(rates.get("cancel_bid_rate", 0.0) or 0.0))
+    ca = max(0.0, float(rates.get("cancel_ask_rate", 0.0) or 0.0))
+    la = max(0.0, float(rates.get("limit_add_rate", 0.0) or 0.0))
+
+    taker_rate = tb + tsell
+    cancel_rate = cb + ca
+    churn_rate = taker_rate + cancel_rate
+
+    beta = _get_float(cfg, "hawkes_beta", 1.8)
+
+    # Base params (used as fallbacks)
+    alpha_t = _get_float(cfg, "hawkes_alpha_taker", 0.9)
+    mu_t = _get_float(cfg, "hawkes_mu_taker", 0.1)
+
+    alpha_c = _get_float(cfg, "hawkes_alpha_cancel", 0.7)
+    mu_c = _get_float(cfg, "hawkes_mu_cancel", 0.1)
+
+    alpha_h = _get_float(cfg, "hawkes_alpha_churn", 0.5)
+    mu_h = _get_float(cfg, "hawkes_mu_churn", 0.1)
+
+    alpha_tb = _get_float(cfg, "hawkes_alpha_taker_buy", alpha_t)
+    mu_tb = _get_float(cfg, "hawkes_mu_taker_buy", mu_t)
+
+    alpha_ts = _get_float(cfg, "hawkes_alpha_taker_sell", alpha_t)
+    mu_ts = _get_float(cfg, "hawkes_mu_taker_sell", mu_t)
+
+    alpha_cb = _get_float(cfg, "hawkes_alpha_cancel_bid", alpha_c)
+    mu_cb = _get_float(cfg, "hawkes_mu_cancel_bid", mu_c)
+
+    alpha_ca = _get_float(cfg, "hawkes_alpha_cancel_ask", alpha_c)
+    mu_ca = _get_float(cfg, "hawkes_mu_cancel_ask", mu_c)
+
+    alpha_la = _get_float(cfg, "hawkes_alpha_limit_add", 0.6)
+    mu_la = _get_float(cfg, "hawkes_mu_limit_add", 0.05)
+
+    if dt_s > 0.0:
+        decay = math.exp(-beta * dt_s)
+
+        # Keep legacy aggregates
+        state["S_taker"] = decay * float(state.get("S_taker", 0.0)) + taker_rate * dt_s
+        state["S_cancel"] = decay * float(state.get("S_cancel", 0.0)) + cancel_rate * dt_s
+        state["S_churn"] = decay * float(state.get("S_churn", 0.0)) + churn_rate * dt_s
+
+        # Split streams
+        state["S_taker_buy"] = decay * float(state.get("S_taker_buy", 0.0)) + tb * dt_s
+        state["S_taker_sell"] = decay * float(state.get("S_taker_sell", 0.0)) + tsell * dt_s
+        state["S_cancel_bid"] = decay * float(state.get("S_cancel_bid", 0.0)) + cb * dt_s
+        state["S_cancel_ask"] = decay * float(state.get("S_cancel_ask", 0.0)) + ca * dt_s
+        state["S_limit_add"] = decay * float(state.get("S_limit_add", 0.0)) + la * dt_s
+
+    snap: Dict[str, float] = {
+        "hawkes_dt_s": float(dt_s),
+
+        # legacy
+        "hawkes_taker_lam": float(mu_t + alpha_t * float(state.get("S_taker", 0.0))),
+        "hawkes_cancel_lam": float(mu_c + alpha_c * float(state.get("S_cancel", 0.0))),
+        "hawkes_churn_lam": float(mu_h + alpha_h * float(state.get("S_churn", 0.0))),
+
+        # split
+        "hawkes_taker_buy_lam": float(mu_tb + alpha_tb * float(state.get("S_taker_buy", 0.0))),
+        "hawkes_taker_sell_lam": float(mu_ts + alpha_ts * float(state.get("S_taker_sell", 0.0))),
+        "hawkes_cancel_bid_lam": float(mu_cb + alpha_cb * float(state.get("S_cancel_bid", 0.0))),
+        "hawkes_cancel_ask_lam": float(mu_ca + alpha_ca * float(state.get("S_cancel_ask", 0.0))),
+        "hawkes_limit_add_lam": float(mu_la + alpha_la * float(state.get("S_limit_add", 0.0))),
+    }
+
+    return state, snap
