+      STRATEGY_RESEARCH_STATS_ALERT_POLICY_DEFAULT_PSR_DSR_LOW_DELTA_VS_7D: ${STRATEGY_RESEARCH_STATS_ALERT_POLICY_DEFAULT_PSR_DSR_LOW_DELTA_VS_7D:-0.15}
+      STRATEGY_RESEARCH_STATS_ALERT_POLICY_EXPORTER_PORT: ${STRATEGY_RESEARCH_STATS_ALERT_POLICY_EXPORTER_PORT:-9838}
