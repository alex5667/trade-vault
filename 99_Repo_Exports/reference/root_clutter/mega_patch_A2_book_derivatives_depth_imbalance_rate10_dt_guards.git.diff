new file mode 100644
index 0000000..83aa78b
--- /dev/null
+++ b/tick_flow_full/core/book_derivatives_v1.py
@@ -0,0 +1,79 @@
+from __future__ import annotations
+
+"""Book derivative features.
+
+These helpers are intentionally dependency-free so they can be unit-tested without
+bringing up the full runtime stack (redis/asyncpg/etc.).
+
+Naming:
+  - `*_rate_*` features are expressed in 1/sec.
+
+Time determinism:
+  - `*_ts_ms` are epoch milliseconds.
+  - dt guards must treat non-monotonic timestamps as bad_time (fail-open).
+"""
+
+import math
+from typing import Optional
+
+
+def compute_book_imbalance_rate_10(
+    prev_imb10: Optional[float],
+    prev_ts_ms: Optional[int],
+    cur_imb10: float,
+    cur_ts_ms: int,
+    *,
+    clip_abs_per_s: float = 50.0,
+) -> tuple[float, int]:
+    """Compute book_imbalance_rate_10 = d(depth_imbalance_10)/dt (1/sec), guarded.
+
+    Args:
+        prev_imb10: Previous depth_imbalance_10 snapshot value.
+        prev_ts_ms: Previous book timestamp (epoch ms) for that snapshot.
+        cur_imb10: Current depth_imbalance_10 snapshot value.
+        cur_ts_ms: Current book timestamp (epoch ms).
+        clip_abs_per_s: Hard safety clip for the derivative, absolute units of 1/sec.
+
+    Returns:
+        (rate_per_s, bad_dt_flag)
+
+    Guard policy:
+        - If there is no previous value -> rate=0.0, bad_dt=0.
+        - If dt_ms <= 0 (out-of-order / non-monotonic book_ts_ms) -> rate=0.0, bad_dt=1.
+        - Otherwise rate = (cur_imb10 - prev_imb10)/dt_sec, clipped to [-clip_abs_per_s, +clip_abs_per_s].
+
+    Rationale:
+        Book timestamps can be non-monotonic in real systems (reconnects, partial snapshots,
+        exchange quirks). We must fail-open and avoid exploding derivatives that would
+        pollute ML inputs and SRE dashboards.
+    """
+
+    if prev_ts_ms is None or prev_imb10 is None:
+        return 0.0, 0
+
+    try:
+        dt_ms = int(cur_ts_ms) - int(prev_ts_ms)
+    except Exception:
+        return 0.0, 1
+
+    if dt_ms <= 0:
+        return 0.0, 1
+
+    dt_sec = float(dt_ms) / 1000.0
+    if dt_sec <= 0.0:
+        return 0.0, 1
+
+    try:
+        rate = (float(cur_imb10) - float(prev_imb10)) / dt_sec
+    except Exception:
+        return 0.0, 0
+
+    if not math.isfinite(rate):
+        return 0.0, 0
+
+    if rate > clip_abs_per_s:
+        rate = clip_abs_per_s
+    elif rate < -clip_abs_per_s:
+        rate = -clip_abs_per_s
+
+    return float(rate), 0
