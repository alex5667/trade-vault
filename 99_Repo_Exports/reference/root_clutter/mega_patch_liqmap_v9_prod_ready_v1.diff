+            if max_bps > 0 and dist_bps > max_bps:
+                return tps
+            if peak_usd < min_peak_usd:
+                return tps
+
+            eff_bps = max(dist_bps - max(front_run_bps, 0.0), 0.0)
+            if eff_bps <= 0:
