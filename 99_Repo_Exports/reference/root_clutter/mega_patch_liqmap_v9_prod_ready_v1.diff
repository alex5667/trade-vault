+            indicators["tp1_anchor_src"] = "liqmap"
+            indicators["tp1_anchor_window"] = w
+            indicators["tp1_anchor_dist_bps"] = float(eff_bps)
+            indicators["tp1_anchor_peak_usd"] = float(peak_usd)
+
+            return tps2
