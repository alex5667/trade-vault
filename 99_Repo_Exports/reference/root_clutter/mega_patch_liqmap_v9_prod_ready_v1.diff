+    def _maybe_anchor_tp1_by_liqmap(
+        self,
+        *,
+        entry: float,
+        side: str,
+        indicators: Dict[str, Any],
+        tps: List[float],
+    ) -> List[float]:
+        """Optionally anchor TP1 to the nearest LiqMap "magnet" cluster.
+
+        Safety:
+          - Default OFF (LIQMAP_TP_ANCHOR_ENABLE=0).
+          - Never expands SL (risk). If LiqMap implies adverse cluster inside SL band,
+            the liqmap gate is expected to veto earlier (ENFORCE mode).
+
+        Behavior:
+          - LONG: use liqmap_<w>_dist_up_bps + liqmap_<w>_peak_up1_usd
+          - SHORT: use liqmap_<w>_dist_dn_bps + liqmap_<w>_peak_dn1_usd
+          - If dist is within [min_bps, max_bps] and peak_usd >= min_peak_usd,
+            set TP1 near that level (with optional front-run).
+        """
+        try:
+            if str(os.getenv("LIQMAP_TP_ANCHOR_ENABLE", "0") or "0").strip().lower() not in ("1", "true", "yes", "on"):
+                return tps
+
+            w = str(os.getenv("LIQMAP_TP_ANCHOR_WINDOW", "5m") or "5m").strip()
+            max_bps = float(os.getenv("LIQMAP_TP_ANCHOR_MAX_BPS", "250") or 250.0)
+            min_bps = float(os.getenv("LIQMAP_TP_ANCHOR_MIN_BPS", "5") or 5.0)
+            min_peak_usd = float(os.getenv("LIQMAP_TP_ANCHOR_MIN_PEAK_USD", "0") or 0.0)
+            front_run_bps = float(os.getenv("LIQMAP_TP_ANCHOR_FRONT_RUN_BPS", "2") or 2.0)
+
+            if not tps:
+                return tps
+            if entry <= 0:
+                return tps
+
+            side_u = str(side or "").upper()
+            if side_u not in ("LONG", "SHORT"):
+                return tps
+
+            if side_u == "LONG":
+                dist_bps = float(indicators.get(f"liqmap_{w}_dist_up_bps", 0.0) or 0.0)
+                peak_usd = float(indicators.get(f"liqmap_{w}_peak_up1_usd", 0.0) or 0.0)
+                sgn = +1.0
+            else:
+                dist_bps = float(indicators.get(f"liqmap_{w}_dist_dn_bps", 0.0) or 0.0)
+                peak_usd = float(indicators.get(f"liqmap_{w}_peak_dn1_usd", 0.0) or 0.0)
+                sgn = -1.0
+
+            if dist_bps <= 0:
+                return tps
+            if dist_bps < min_bps:
