+"""Nightly slippage calibrator (compat wrapper).
+
+The timers worker calls:
+  python -m ml_analysis.tools.nightly_slippage_calibrator_v1
+
+Canonical implementation lives in:
+  tick_flow_full.tools.nightly_slippage_calibrator_v1
+
+This shim keeps stable import paths for orchestrators.
+"""
+
+from __future__ import annotations
+
+import asyncio
+
+
+def main() -> int:
+    try:
+        from tick_flow_full.tools.nightly_slippage_calibrator_v1 import run  # type: ignore
+    except Exception as e:
+        # Missing dependencies or module path issues
+        raise SystemExit(2) from e
+
+    ok = asyncio.run(run())
+    return 0 if ok else 2
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
