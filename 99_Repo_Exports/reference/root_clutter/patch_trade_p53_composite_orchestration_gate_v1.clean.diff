@@ -0,0 +1,55 @@
+from __future__ import annotations
+
+from pathlib import Path
+
+
+def _read(path: str) -> str:
+    return Path(path).read_text(encoding='utf-8')
+
+
+def test_wrapper_uses_composite_preflight() -> None:
+    txt = _read('orderflow_services/integrations/run_with_latency_contract_rollout_preflight_v1.sh')
+    assert 'orchestration_composite_preflight_v1' in txt
+    assert 'strategy_research_guard_rollout_preflight_v1' in txt  # legacy grep safety
+    assert 'latency_contract_rollout_preflight_v1' in txt  # legacy grep safety
+
+
+def test_host_wrapper_uses_composite_preflight() -> None:
+    txt = _read('orderflow_services/deploy/systemd/run_trade_latency_gated_compose_job_v1.sh')
+    assert 'latency_contract_deploy_lint_v1' in txt
+    assert 'orchestration_composite_preflight_v1' in txt
+
+
+def test_compose_files_expose_composite_gate_env() -> None:
+    for rel in [
+        'orderflow_services/deploy/compose/docker-compose.conf-score-guardrails-apply-v1.yml',
+        'orderflow_services/deploy/compose/docker-compose.conf-score-guardrails-promote-v1.yml',
+        'orderflow_services/deploy/compose/docker-compose.conf-score-guardrails-autopromo-controller-v1.yml',
+        'orderflow_services/deploy/compose/docker-compose.meta-cov-rollout-controller-v1.yml',
+    ]:
+        txt = _read(rel)
+        assert 'ENABLE_ORCHESTRATION_COMPOSITE_PREFLIGHT' in txt
+        assert 'ENABLE_LATENCY_CONTRACT_DEPLOY_LINT_PREFLIGHT' in txt
+        assert 'ORCHESTRATION_PREFLIGHT_OPS_EVENT_STREAM' in txt
+
+
+def test_direct_entrypoints_use_composite_assert() -> None:
+    for rel in [
+        'orderflow_services/conf_score_guardrails_apply_v1.py',
+        'orderflow_services/conf_score_guardrails_promote_v1.py',
+        'orderflow_services/conf_score_guardrails_autopromo_controller_v1.py',
+        'orderflow_services/meta_cov_rollout_controller_v1.py',
+    ]:
+        txt = _read(rel)
+        assert 'assert_composite_orchestration_gate_open' in txt
+
+
+def test_env_examples_include_composite_settings() -> None:
+    for rel in [
+        'orderflow_services/deploy/env/latency-contract-sensitive-jobs.staging.env.example',
+        'orderflow_services/deploy/env/latency-contract-sensitive-jobs.prod.env.example',
+    ]:
+        txt = _read(rel)
+        assert 'ENABLE_ORCHESTRATION_COMPOSITE_PREFLIGHT=1' in txt
+        assert 'ENABLE_LATENCY_CONTRACT_DEPLOY_LINT_PREFLIGHT=1' in txt
+        assert 'ORCHESTRATION_PREFLIGHT_OPS_EVENT_STREAM=' in txt
