+#!/usr/bin/env python3
+from __future__ import annotations
+
+"""Composite orchestration preflight for rollout-sensitive jobs (P5.3).
+
+Combines three independent safety sources behind one deterministic decision:
+  - deploy-lint persistent drift gate
+  - latency-contract rollout gate
+  - strategy research guard
+
+Design goals:
+  - one preflight command for both host-wrapper and in-container paths
+  - deterministic reason-code priority when multiple sources disagree
+  - unified ops-event audit trail for every orchestration decision
+  - safe defense-in-depth helper for direct/manual Python entrypoints
+"""
+
+import argparse
+import json
+import os
+import time
+from typing import Any, Dict, Mapping
+
+from services.observability.latency_deploy_lint_state import gate_key as deploy_lint_gate_key
+from services.observability.latency_deploy_lint_state import state_key as deploy_lint_state_key
+from orderflow_services.research_guard_blocker_v1 import evaluate_research_guard_gate
+
+try:
+    import redis  # type: ignore
+except Exception:  # pragma: no cover
+    redis = None  # type: ignore
+
+ALLOWED_PURPOSES = {
+    'latency_contract_sensitive_apply',
+    'conf_score_guardrails_apply',
+    'conf_score_guardrails_promote',
+    'meta_cov_rollout_controller',
+    'conf_score_guardrails_autopromo_controller',
+}
+
+STATUS_PRIORITY = {
+    'block': 0,
+    'invalid': 1,
+    'ok': 2,
+}
+
+SOURCE_PRIORITY = {
+    'deploy_lint': 0,
+    'latency_contract': 1,
+    'research_guard': 2,
+}
+
+
+def _env(name: str, default: str = '') -> str:
+    return (os.getenv(name) or default).strip()
+
+
+def _i(v: Any, d: int = 0) -> int:
+    try:
+        return int(float(v))
+    except Exception:
+        return d
+
+
+def _read_hash(client: Any, key: str) -> Dict[str, str]:
+    if client is None or not key:
+        return {}
+    try:
+        raw = client.hgetall(key)
+        return raw if isinstance(raw, dict) else {}
+    except Exception:
+        return {}
+
+
+def _state_key(prefix: str, purpose: str) -> str:
+    return f'{prefix.rstrip(":")}:{purpose}'
+
+
+def _stage_allowed_for_research(purpose: str, stage_mode: bool) -> bool:
+    if not stage_mode:
+        return False
+    if purpose != 'conf_score_guardrails_apply':
+        return False
+    return _env('STRATEGY_RESEARCH_GUARD_PREFLIGHT_ALLOW_STAGE', '1') == '1'
+
+
+def evaluate_latency_contract_gate(
+    redis_url: str,
+    *,
+    state_key: str,
+    gate_key: str,
+    client: Any | None = None,
+) -> Dict[str, Any]:
+    if client is None:
+        if redis is None:
+            return {'source': 'latency_contract', 'status': 'invalid', 'reason': 'redis_unavailable', 'blocked': True, 'raw': {}}
+        try:
+            client = redis.Redis.from_url(redis_url, decode_responses=True)
+        except Exception:
+            return {'source': 'latency_contract', 'status': 'invalid', 'reason': 'redis_connect_failed', 'blocked': True, 'raw': {}}
+
+    raw = _read_hash(client, gate_key) or _read_hash(client, state_key)
+    if not raw:
+        return {'source': 'latency_contract', 'status': 'invalid', 'reason': 'state_missing', 'blocked': True, 'raw': {}}
+    if _i(raw.get('gate_active'), 0) > 0:
+        reason = str(raw.get('gate_reason_codes') or raw.get('gate_reason_code') or 'latency_contract_gate').strip()
+        return {'source': 'latency_contract', 'status': 'block', 'reason': reason, 'blocked': True, 'raw': raw}
+    return {'source': 'latency_contract', 'status': 'ok', 'reason': 'ok', 'blocked': False, 'raw': raw}
+
+
+def evaluate_deploy_lint_gate(
+    redis_url: str,
+    *,
+    purpose: str,
+    state_prefix: str,
+    gate_prefix: str,
+    fail_closed_missing: int,
+    client: Any | None = None,
+) -> Dict[str, Any]:
+    if client is None:
+        if redis is None:
+            return {'source': 'deploy_lint', 'status': 'invalid', 'reason': 'redis_unavailable', 'blocked': True, 'raw': {}}
+        try:
+            client = redis.Redis.from_url(redis_url, decode_responses=True)
+        except Exception:
+            return {'source': 'deploy_lint', 'status': 'invalid', 'reason': 'redis_connect_failed', 'blocked': True, 'raw': {}}
+
+    gkey = deploy_lint_gate_key(gate_prefix, purpose)
+    skey = deploy_lint_state_key(state_prefix, purpose)
+    raw = _read_hash(client, gkey) or _read_hash(client, skey)
+    if not raw:
+        status = 'invalid' if int(fail_closed_missing) == 1 else 'ok'
+        reason = 'state_missing' if status == 'invalid' else 'ok'
+        return {'source': 'deploy_lint', 'status': status, 'reason': reason, 'blocked': status != 'ok', 'raw': {}}
+    if _i(raw.get('gate_active'), 0) > 0:
+        reason = str(raw.get('gate_reason_code') or 'persistent_config_drift').strip()
+        return {'source': 'deploy_lint', 'status': 'block', 'reason': reason, 'blocked': True, 'raw': raw}
+    return {'source': 'deploy_lint', 'status': 'ok', 'reason': 'ok', 'blocked': False, 'raw': raw}
+
+
+def _priority_tuple(item: Mapping[str, Any]) -> tuple[int, int]:
+    return (
+        STATUS_PRIORITY.get(str(item.get('status') or 'invalid'), 99),
+        SOURCE_PRIORITY.get(str(item.get('source') or ''), 99),
+    )
+
+
+def _select_reason(sources: list[Dict[str, Any]]) -> Dict[str, Any]:
+    bad = [src for src in sources if str(src.get('status')) != 'ok']
+    if not bad:
+        return {'source': 'none', 'status': 'ok', 'reason': 'ok', 'priority_rank': 999}
+    chosen = sorted(bad, key=_priority_tuple)[0]
+    status_rank = STATUS_PRIORITY.get(str(chosen.get('status') or 'invalid'), 9)
+    source_rank = SOURCE_PRIORITY.get(str(chosen.get('source') or ''), 9)
+    chosen = dict(chosen)
+    chosen['priority_rank'] = status_rank * 10 + source_rank
+    return chosen
+
+
+def _emit_audit_event(client: Any, composite: Mapping[str, Any], now_ms: int) -> None:
+    stream = _env('ORCHESTRATION_PREFLIGHT_OPS_EVENT_STREAM', 'ops:orchestration:preflight:v1')
+    fields = {
+        'ts_ms': str(now_ms),
+        'kind': f'orchestration_preflight_{composite.get("status") or "invalid"}',
+        'source': 'orchestration_composite_preflight_v1',
+        'purpose': str(composite.get('purpose') or 'unknown'),
+        'decision_status': str(composite.get('status') or 'invalid'),
+        'selected_source': str(composite.get('selected_source') or 'none'),
+        'selected_reason': str(composite.get('selected_reason') or 'ok'),
+        'selected_reason_code': str(composite.get('selected_reason_code') or 'ok'),
+        'selected_priority_rank': str(composite.get('selected_priority_rank') if composite.get('selected_priority_rank') is not None else 999),
+        'deploy_lint_status': str(composite.get('deploy_lint_status') or 'unknown'),
+        'deploy_lint_reason': str(composite.get('deploy_lint_reason') or 'unknown'),
+        'latency_contract_status': str(composite.get('latency_contract_status') or 'unknown'),
+        'latency_contract_reason': str(composite.get('latency_contract_reason') or 'unknown'),
+        'research_guard_status': str(composite.get('research_guard_status') or 'unknown'),
+        'research_guard_reason': str(composite.get('research_guard_reason') or 'unknown'),
+        'sources_json': json.dumps(dict(composite.get('sources') or {}), sort_keys=True),
+    }
+    client.xadd(stream, fields, maxlen=200000, approximate=True)
+
+
+def _persist_state(client: Any, composite: Mapping[str, Any], now_ms: int) -> None:
+    prefix = _env('ORCHESTRATION_PREFLIGHT_STATE_PREFIX', 'metrics:orchestration:preflight:last')
+    ttl_s = max(600, _i(_env('ORCHESTRATION_PREFLIGHT_STATE_TTL_S', '172800'), 172800))
+    skey = _state_key(prefix, str(composite.get('purpose') or 'unknown'))
+    mapping = {
+        'schema_version': '1',
+        'updated_ts_ms': str(now_ms),
+        'purpose': str(composite.get('purpose') or 'unknown'),
+        'status': str(composite.get('status') or 'invalid'),
+        'selected_source': str(composite.get('selected_source') or 'none'),
+        'selected_reason': str(composite.get('selected_reason') or 'ok'),
+        'selected_reason_code': str(composite.get('selected_reason_code') or 'ok'),
+        'selected_priority_rank': str(composite.get('selected_priority_rank') if composite.get('selected_priority_rank') is not None else 999),
+        'deploy_lint_status': str(composite.get('deploy_lint_status') or 'unknown'),
+        'deploy_lint_reason': str(composite.get('deploy_lint_reason') or 'unknown'),
+        'latency_contract_status': str(composite.get('latency_contract_status') or 'unknown'),
+        'latency_contract_reason': str(composite.get('latency_contract_reason') or 'unknown'),
+        'research_guard_status': str(composite.get('research_guard_status') or 'unknown'),
+        'research_guard_reason': str(composite.get('research_guard_reason') or 'unknown'),
+        'sources_json': json.dumps(dict(composite.get('sources') or {}), sort_keys=True),
+    }
+    client.hset(skey, mapping=mapping)
+    try:
+        client.expire(skey, ttl_s)
+    except Exception:
+        pass
+
+
+def evaluate_composite_gate(
+    redis_url: str,
+    *,
+    purpose: str,
+    stage_mode: bool = False,
+    client: Any | None = None,
+    emit_audit: bool = False,
+) -> Dict[str, Any]:
+    if client is None:
+        if redis is None:
+            sources = {
+                'deploy_lint': {'status': 'invalid', 'reason': 'redis_unavailable'},
+                'latency_contract': {'status': 'invalid', 'reason': 'redis_unavailable'},
+                'research_guard': {'status': 'invalid', 'reason': 'redis_unavailable'},
+            }
+            selected = _select_reason([
+                {'source': 'deploy_lint', **sources['deploy_lint']},
+                {'source': 'latency_contract', **sources['latency_contract']},
+                {'source': 'research_guard', **sources['research_guard']},
+            ])
+            return {
+                'purpose': purpose,
+                'status': str(selected['status']),
+                'selected_source': str(selected['source']),
+                'selected_reason': str(selected['reason']),
+                'selected_reason_code': f"{selected['source']}:{selected['reason']}",
+                'selected_priority_rank': int(selected['priority_rank']),
+                'sources': sources,
+                'deploy_lint_status': 'invalid',
+                'deploy_lint_reason': 'redis_unavailable',
+                'latency_contract_status': 'invalid',
+                'latency_contract_reason': 'redis_unavailable',
+                'research_guard_status': 'invalid',
+                'research_guard_reason': 'redis_unavailable',
+            }
+        client = redis.Redis.from_url(redis_url, decode_responses=True)
+
+    deploy = evaluate_deploy_lint_gate(
+        redis_url,
+        purpose=purpose,
+        state_prefix=_env('LATENCY_CONTRACT_DEPLOY_LINT_STATE_PREFIX', 'metrics:latency_contract:deploy_lint:last'),
+        gate_prefix=_env('LATENCY_CONTRACT_DEPLOY_LINT_GATE_PREFIX', 'cfg:orderflow:latency_contract:deploy_lint_gate'),
+        fail_closed_missing=_i(_env('LATENCY_CONTRACT_DEPLOY_LINT_PREFLIGHT_FAIL_CLOSED_MISSING', '1'), 1),
+        client=client,
+    ) if _env('ENABLE_LATENCY_CONTRACT_DEPLOY_LINT_PREFLIGHT', '1') == '1' else {
+        'source': 'deploy_lint', 'status': 'ok', 'reason': 'disabled', 'blocked': False, 'raw': {}
+    }
+
+    latency = evaluate_latency_contract_gate(
+        redis_url,
+        state_key=_env('LATENCY_CONTRACT_ROLLOUT_GATE_STATE_KEY', 'metrics:latency_contract:rollout_gate:last'),
+        gate_key=_env('LATENCY_CONTRACT_ROLLOUT_GATE_KEY', 'cfg:orderflow:latency_contract:rollout_gate:v1'),
+        client=client,
+    )
+
+    if _env('ENABLE_STRATEGY_RESEARCH_GUARD_HARD_GATE', '0') != '1':
+        research = {'source': 'research_guard', 'status': 'ok', 'reason': 'disabled', 'blocked': False, 'raw': {}}
+    elif _stage_allowed_for_research(purpose, stage_mode):
+        research = {'source': 'research_guard', 'status': 'ok', 'reason': 'stage_allowed', 'blocked': False, 'raw': {}}
+    else:
+        research = dict(
+            source='research_guard',
+            **evaluate_research_guard_gate(
+                redis_url,
+                _env('STRATEGY_RESEARCH_GUARD_BLOCKER_KEY', 'cfg:research_guard:blocker:v1'),
+                _env('STRATEGY_RESEARCH_GUARD_SUMMARY_KEY', 'metrics:strategy_research_guard:last'),
+                max_age_sec=float(_env('STRATEGY_RESEARCH_GUARD_MAX_AGE_SEC', '129600') or 129600),
+                fail_closed_missing=_i(_env('STRATEGY_RESEARCH_GUARD_FAIL_CLOSED_MISSING', '1'), 1),
+                client=client,
+            ),
+        )
+
+    selected = _select_reason([deploy, latency, research])
+    sources = {
+        'deploy_lint': {'status': str(deploy.get('status') or 'invalid'), 'reason': str(deploy.get('reason') or 'unknown')},
+        'latency_contract': {'status': str(latency.get('status') or 'invalid'), 'reason': str(latency.get('reason') or 'unknown')},
+        'research_guard': {'status': str(research.get('status') or 'invalid'), 'reason': str(research.get('reason') or 'unknown')},
+    }
+    composite = {
+        'purpose': purpose,
+        'status': str(selected.get('status') or 'invalid'),
+        'selected_source': str(selected.get('source') or 'none'),
+        'selected_reason': str(selected.get('reason') or 'ok'),
+        'selected_reason_code': 'ok' if str(selected.get('source') or 'none') == 'none' else f"{selected.get('source')}:{selected.get('reason')}",
+        'selected_priority_rank': int(selected['priority_rank']) if 'priority_rank' in selected else 999,
+        'deploy_lint_status': sources['deploy_lint']['status'],
+        'deploy_lint_reason': sources['deploy_lint']['reason'],
+        'latency_contract_status': sources['latency_contract']['status'],
+        'latency_contract_reason': sources['latency_contract']['reason'],
+        'research_guard_status': sources['research_guard']['status'],
+        'research_guard_reason': sources['research_guard']['reason'],
+        'sources': sources,
+    }
+    if emit_audit:
+        now_ms = int(time.time() * 1000)
+        _persist_state(client, composite, now_ms)
+        _emit_audit_event(client, composite, now_ms)
+    return composite
+
+
+def assert_composite_orchestration_gate_open(
+    redis_url: str,
+    *,
+    purpose: str,
+    stage_mode: bool = False,
+    exit_code_blocked: int = 24,
+    exit_code_invalid: int = 25,
+) -> None:
+    state = evaluate_composite_gate(redis_url, purpose=purpose, stage_mode=stage_mode, emit_audit=True)
+    status = str(state.get('status') or 'invalid')
+    reason_code = str(state.get('selected_reason_code') or 'unknown')
+    if status == 'ok':
+        return
+    if status == 'block':
+        print(f'ORCHESTRATION_PREFLIGHT_BLOCK purpose={purpose} reason={reason_code}')
+        raise SystemExit(int(exit_code_blocked))
+    print(f'ORCHESTRATION_PREFLIGHT_INVALID purpose={purpose} reason={reason_code}')
+    raise SystemExit(int(exit_code_invalid))
+
+
+def main() -> int:
+    ap = argparse.ArgumentParser(description='Composite orchestration preflight gate check')
+    ap.add_argument('--purpose', default='latency_contract_sensitive_apply')
+    ap.add_argument('--stage-mode', default='0')
+    ns = ap.parse_args()
+
+    if ns.purpose not in ALLOWED_PURPOSES:
+        print(f'ORCHESTRATION_PREFLIGHT_INVALID purpose={ns.purpose} reason=unknown_purpose')
+        return 64
+
+    if _env('ENABLE_ORCHESTRATION_COMPOSITE_PREFLIGHT', '1') != '1':
+        print(f'ORCHESTRATION_PREFLIGHT_DISABLED purpose={ns.purpose}')
+        return 0
+
+    try:
+        state = evaluate_composite_gate(
+            _env('REDIS_URL', 'redis://redis-worker-1:6379/0'),
+            purpose=ns.purpose,
+            stage_mode=_i(ns.stage_mode, 0) == 1,
+            emit_audit=True,
+        )
+    except Exception as exc:
+        print(f'ORCHESTRATION_PREFLIGHT_INVALID purpose={ns.purpose} reason=exception:{type(exc).__name__}')
+        return 25
+
+    status = str(state.get('status') or 'invalid')
+    reason_code = str(state.get('selected_reason_code') or 'unknown')
+    if status == 'ok':
+        print(f'ORCHESTRATION_PREFLIGHT_OK purpose={ns.purpose} reason={reason_code}')
+        return 0
+    if status == 'block':
+        print(f'ORCHESTRATION_PREFLIGHT_BLOCK purpose={ns.purpose} reason={reason_code}')
+        return 24
+    print(f'ORCHESTRATION_PREFLIGHT_INVALID purpose={ns.purpose} reason={reason_code}')
+    return 25
+
+
+if __name__ == '__main__':
+    raise SystemExit(main())
