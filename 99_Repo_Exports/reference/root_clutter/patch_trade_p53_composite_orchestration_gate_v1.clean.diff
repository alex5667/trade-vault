--- a/orderflow_services/tests/test_orchestration_composite_preflight_v1.py
+++ b/orderflow_services/tests/test_orchestration_composite_preflight_v1.py
@@ -0,0 +1,94 @@
+from __future__ import annotations
+
+from orderflow_services.orchestration_composite_preflight_v1 import evaluate_composite_gate
+
+
+class FakeRedis:
+    def __init__(self, hashes=None):
+        self.hashes = dict(hashes or {})
+        self.streams = []
+        self.exp = {}
+
+    def hgetall(self, key):
+        return dict(self.hashes.get(key, {}))
+
+    def hset(self, key, mapping=None, **kwargs):
+        cur = self.hashes.setdefault(key, {})
+        cur.update(mapping or kwargs)
+
+    def expire(self, key, ttl):
+        self.exp[key] = ttl
+
+    def xadd(self, stream, fields, maxlen=None, approximate=None):
+        self.streams.append((stream, dict(fields)))
+        return '1-0'
+
+
+def test_priority_prefers_block_over_invalid_and_latency_over_research(monkeypatch) -> None:
+    monkeypatch.setenv('ENABLE_STRATEGY_RESEARCH_GUARD_HARD_GATE', '1')
+    r = FakeRedis(
+        {
+            'metrics:latency_contract:rollout_gate:last': {'gate_active': '1', 'gate_reason_code': 'external_missing'},
+            'cfg:research_guard:blocker:v1': {'blocked': '1', 'report_only': '0', 'reason': 'pbo_high'},
+            'metrics:strategy_research_guard:last': {'updated_ts_ms': '9999999999999'},
+        }
+    )
+    state = evaluate_composite_gate('redis://unused', purpose='conf_score_guardrails_promote', client=r)
+    assert state['status'] == 'block'
+    assert state['selected_source'] == 'latency_contract'
+    assert state['selected_reason_code'] == 'latency_contract:external_missing'
+
+
+def test_priority_prefers_deploy_lint_block_when_multiple_blocks(monkeypatch) -> None:
+    monkeypatch.setenv('ENABLE_STRATEGY_RESEARCH_GUARD_HARD_GATE', '1')
+    r = FakeRedis(
+        {
+            'cfg:orderflow:latency_contract:deploy_lint_gate:conf_score_guardrails_promote:v1': {
+                'gate_active': '1',
+                'gate_reason_code': 'persistent_config_drift',
+            },
+            'metrics:latency_contract:rollout_gate:last': {'gate_active': '1', 'gate_reason_code': 'external_missing'},
+            'cfg:research_guard:blocker:v1': {'blocked': '1', 'report_only': '0', 'reason': 'pbo_high'},
+            'metrics:strategy_research_guard:last': {'updated_ts_ms': '9999999999999'},
+        }
+    )
+    state = evaluate_composite_gate('redis://unused', purpose='conf_score_guardrails_promote', client=r)
+    assert state['selected_source'] == 'deploy_lint'
+    assert state['selected_reason_code'] == 'deploy_lint:persistent_config_drift'
+    assert state['selected_priority_rank'] == 0
+
+
+def test_stage_mode_bypasses_research_only(monkeypatch) -> None:
+    monkeypatch.setenv('ENABLE_STRATEGY_RESEARCH_GUARD_HARD_GATE', '1')
+    monkeypatch.setenv('STRATEGY_RESEARCH_GUARD_PREFLIGHT_ALLOW_STAGE', '1')
+    r = FakeRedis(
+        {
+            'metrics:latency_contract:deploy_lint:last:conf_score_guardrails_apply': {'gate_active': '0', 'ok': '1'},
+            'metrics:latency_contract:rollout_gate:last': {'gate_active': '0'},
+            'cfg:research_guard:blocker:v1': {'blocked': '1', 'report_only': '0', 'reason': 'pbo_high'},
+            'metrics:strategy_research_guard:last': {'updated_ts_ms': '9999999999999'},
+        }
+    )
+    state = evaluate_composite_gate('redis://unused', purpose='conf_score_guardrails_apply', stage_mode=True, client=r)
+    assert state['status'] == 'ok'
+    assert state['research_guard_reason'] == 'stage_allowed'
+
+
+def test_emit_audit_persists_state_and_event(monkeypatch) -> None:
+    monkeypatch.setenv('ENABLE_STRATEGY_RESEARCH_GUARD_HARD_GATE', '0')
+    monkeypatch.setenv('ORCHESTRATION_PREFLIGHT_OPS_EVENT_STREAM', 'ops:orchestration:preflight:v1')
+    monkeypatch.setenv('ORCHESTRATION_PREFLIGHT_STATE_PREFIX', 'metrics:orchestration:preflight:last')
+    r = FakeRedis(
+        {
+            'metrics:latency_contract:deploy_lint:last:conf_score_guardrails_promote': {'gate_active': '0', 'ok': '1'},
+            'metrics:latency_contract:rollout_gate:last': {'gate_active': '0'},
+        }
+    )
+    state = evaluate_composite_gate('redis://unused', purpose='conf_score_guardrails_promote', client=r, emit_audit=True)
+    assert state['status'] == 'ok'
+    assert r.streams
+    stream, payload = r.streams[0]
+    assert stream == 'ops:orchestration:preflight:v1'
+    assert payload['decision_status'] == 'ok'
+    skey = 'metrics:orchestration:preflight:last:conf_score_guardrails_promote'
+    assert r.hashes[skey]['selected_reason_code'] == 'ok'
