@@ -0,0 +1,62 @@
+import unittest
+
+
+# Repo layouts differ across environments. Prefer the canonical import used by the
+# python-worker runtime (usually `services.*`). Fall back to alternative namespace
+# if a monorepo wrapper is used.
+try:
+    from services.orderflow.decision_ctx_fields import ensure_decision_ctx_fields  # type: ignore
+except Exception:  # pragma: no cover
+    from python_worker.services.orderflow.decision_ctx_fields import ensure_decision_ctx_fields  # type: ignore
+
+
+class TestDecisionCtxFields(unittest.TestCase):
+    def test_happy_path_computes_mid_and_spread(self):
+        ctx = {
+            "symbol": "BTCUSDT",
+            "ts_emit_ms": 1700000000123,
+            "best_bid": 100.0,
+            "best_ask": 100.2,
+            "depth_bid_5": 12345.0,
+            "depth_ask_5": 12000.0,
+        }
+        ensure_decision_ctx_fields(ctx)
+
+        self.assertEqual(ctx["decision_ts_ms"], 1700000000123)
+        self.assertAlmostEqual(ctx["decision_mid"], 100.1, places=10)
+        # spread = (0.2 / 100.1) * 10000 ≈ 19.98 bps
+        self.assertAlmostEqual(ctx["decision_spread_bps"], (0.2 / 100.1) * 10000.0, places=6)
+        self.assertTrue(ctx["tca_ready"])
+        self.assertIsInstance(ctx["book_sanity_flags"], list)
+        self.assertNotIn("crossed_bbo", ctx["book_sanity_flags"])
+
+        # decision_price defaults to mid
+        self.assertAlmostEqual(ctx["decision_price"], ctx["decision_mid"], places=10)
+
+    def test_missing_bbo_sets_flags_and_tca_ready_false(self):
+        ctx = {
+            "symbol": "BTCUSDT",
+            "ts_emit_ms": 1700000000123,
+            "best_bid": 100.0,
+            # best_ask missing
+        }
+        ensure_decision_ctx_fields(ctx)
+
+        self.assertFalse(ctx["tca_ready"])
+        self.assertIn("missing_bbo", ctx["book_sanity_flags"])
+
+    def test_crossed_bbo_flag(self):
+        ctx = {
+            "symbol": "BTCUSDT",
+            "ts_emit_ms": 1700000000123,
+            "best_bid": 100.5,
+            "best_ask": 100.4,
+        }
+        ensure_decision_ctx_fields(ctx)
+        self.assertIn("crossed_bbo", ctx["book_sanity_flags"])
+        # Still can be tca_ready (mid computable), but flagged for later BookSanityGate.
+        self.assertTrue(ctx["tca_ready"])
+
+
+if __name__ == "__main__":
+    unittest.main()
