@@ -0,0 +1,27 @@
+# Runtime rules-loaded probe alerts
+#
+# These alerts rely on exporter gauges populated from Redis keys written by:
+#   orderflow_services/prom_rules_loaded_probe_v1.py
+
+groups:
+  - name: of_prom_rules_loaded_probe
+    rules:
+      - alert: OF_PromRulesFilesMissing_Crit
+        expr: rules_files_missing > 0
+        for: 10m
+        labels:
+          severity: crit
+          component: observability
+        annotations:
+          summary: "Prometheus rules bundle: expected files are NOT loaded"
+          description: "rules_files_missing > 0 (see rules_files_expected / rules_files_loaded / rules_files_missing)."
+
+      - alert: OF_PromRulesLoadedProbeStale_Warn
+        expr: rules_loaded_probe_last_run_age_sec > 10800
+        for: 10m
+        labels:
+          severity: warn
+          component: observability
+        annotations:
+          summary: "Prometheus rules-loaded probe is stale"
+          description: "No probe run in >3h. Check of_timers_worker schedule and prom_rules_loaded_probe_v1 logs."
