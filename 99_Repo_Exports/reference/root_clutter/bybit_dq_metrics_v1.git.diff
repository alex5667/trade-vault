@@ -0,0 +1,58 @@
+package bybit
+
+import (
+	"testing"
+	"time"
+)
+
+func TestBookSeqEMA_SnapshotDoesNotPenalize(t *testing.T) {
+	// Small tau to keep the math stable in tests.
+	b := newBookSeqEMA(1000 * time.Millisecond)
+
+	ema, missing, reason := b.observe(1000, 0, 10, true)
+	if reason != "reset" {
+		t.Fatalf("expected reset, got %q", reason)
+	}
+	if missing != 0 {
+		t.Fatalf("expected missing=0 on reset, got %d", missing)
+	}
+	if ema != 0 {
+		t.Fatalf("expected ema=0 on first reset, got %v", ema)
+	}
+
+	// Next delta: prev=10 final=15 => missing=4
+	ema, missing, reason = b.observe(2000, 10, 15, false)
+	if reason != "" {
+		t.Fatalf("expected no reason, got %q", reason)
+	}
+	if missing != 4 {
+		t.Fatalf("expected missing=4, got %d", missing)
+	}
+	if ema <= 0 {
+		t.Fatalf("expected ema>0, got %v", ema)
+	}
+}
+
+func TestTickGapWindow_P95(t *testing.T) {
+	w := newTickGapWindow(10, 5, 0)
+
+	// First tick sets lastTs.
+	_, _, computed, _ := w.observe(1000, 1000)
+	if computed {
+		t.Fatalf("unexpected computed on first tick")
+	}
+
+	// Gaps: 1,2,3,4,5 ms
+	for i := int64(1); i <= 5; i++ {
+		_, _, _, _ = w.observe(1000+i, 1000+i)
+	}
+
+	// After enough samples, compute should happen.
+	_, p95, computed, _ := w.observe(1010, 1010)
+	if !computed {
+		t.Fatalf("expected computed=true")
+	}
+	if p95 <= 0 {
+		t.Fatalf("expected p95>0")
+	}
+}
