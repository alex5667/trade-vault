index 0000000..541c426
--- /dev/null
+++ b/internal/monitoring/dq_metrics.go
@@ -0,0 +1,146 @@
+package monitoring
+
+import (
+	"strings"
+
+	"github.com/prometheus/client_golang/prometheus"
+	"github.com/prometheus/client_golang/prometheus/promauto"
+)
+
+// DQ metrics (shared naming across venues).
+//
+// IMPORTANT:
+// - Metric names intentionally match the stack's dashboards/alerts:
+//   tick_gap_p95_ms, tick_gap_n, book_missing_seq_ema, ...
+// - To avoid ambiguity across exchanges, metrics include the `venue` label.
+
+const (
+	dqLabelVenue  = "venue"
+	dqLabelSymbol = "symbol"
+)
+
+var (
+	// tick_gap_p95_ms — p95 по гэпам между соседними тиками (event-time), миллисекунды.
+	TickGapP95MsGauge = promauto.NewGaugeVec(
+		prometheus.GaugeOpts{
+			Name: "tick_gap_p95_ms",
+			Help: "p95 gap between consecutive ticks (event-time), milliseconds",
+		},
+		[]string{dqLabelVenue, dqLabelSymbol},
+	)
+
+	// tick_gap_n — количество samples (gap>0).
+	TickGapNSamplesTotal = promauto.NewCounterVec(
