+func normVenueSymbol(venue, symbol string) (string, string) {
+	v := strings.ToLower(strings.TrimSpace(venue))
+	if v == "" {
+		v = "unknown"
+	}
+	s := strings.ToUpper(strings.TrimSpace(symbol))
+	return v, s
+}
+
+func RecordTickGapSample(venue, symbol string) {
+	v, s := normVenueSymbol(venue, symbol)
+	if s == "" {
+		return
+	}
+	TickGapNSamplesTotal.WithLabelValues(v, s).Inc()
+}
+
+func RecordTickGapOutOfOrder(venue, symbol string) {
+	v, s := normVenueSymbol(venue, symbol)
+	if s == "" {
+		return
+	}
+	TickGapOutOfOrderTotal.WithLabelValues(v, s).Inc()
+}
