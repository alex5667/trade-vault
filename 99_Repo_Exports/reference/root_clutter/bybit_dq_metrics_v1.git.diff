diff --git a/internal/bybit/dq_tracker.go b/internal/bybit/dq_tracker.go
new file mode 100644
index 0000000..480403d
--- /dev/null
+++ b/internal/bybit/dq_tracker.go
@@ -0,0 +1,379 @@
+package bybit
+
+import (
+	"math"
+	"sort"
+	"strconv"
+	"strings"
+	"sync"
+	"time"
+
+	"go-worker/internal/monitoring"
+	"go-worker/pkg/timeutil"
+)
+
+// DQTracker computes lightweight in-process data-quality metrics for Bybit.
+//
+// It is intentionally decoupled from the Python EvidenceContract layer:
+// - We only observe raw market data (ticks/books) and export Prometheus metrics.
+// - Any extra fields we add to Redis values are safe for Python raw-ingestion
+//   (extra keys are ignored there).
+//
+// Metrics emitted (with venue="bybit"):
+// - tick_gap_p95_ms{venue,symbol}
+// - tick_gap_n{venue,symbol}
+// - book_missing_seq_ema{venue,symbol}
+// - book_missing_seq_events_total{venue,symbol}
+// plus OOO/reset counters.
+
+type DQTracker struct {
+	enabled bool
+	venue   string
+
+	tickCfg tickGapConfig
+	bookCfg bookSeqConfig
+
+	muTicks sync.Mutex
+	ticks   map[string]*tickGapWindow
+
+	muBooks sync.Mutex
+	books   map[string]*bookSeqEMA
+}
+
+type tickGapConfig struct {
+	windowSize      int
+	minSamples      int
+	computeInterval time.Duration
+}
+
+type bookSeqConfig struct {
+	emaTau time.Duration
+}
+
+func NewDQTracker() *DQTracker {
+	enabled := getEnvBool("BYBIT_DQ_ENABLED", true)
+	t := &DQTracker{
+		enabled: enabled,
+		venue:   "bybit",
+		tickCfg: tickGapConfig{
+			windowSize:      getEnvInt("BYBIT_TICK_GAP_WINDOW", 512),
+			minSamples:      getEnvInt("BYBIT_TICK_GAP_MIN_SAMPLES", 50),
+			computeInterval: getEnvDuration("BYBIT_TICK_GAP_P95_INTERVAL", 2*time.Second),
+		},
+		bookCfg: bookSeqConfig{
+			emaTau: getEnvDuration("BYBIT_BOOK_MISSING_SEQ_EMA_TAU", 30*time.Second),
+		},
+		ticks: map[string]*tickGapWindow{},
+		books: map[string]*bookSeqEMA{},
+	}
+	// Guard rails.
+	if t.tickCfg.windowSize < 64 {
+		t.tickCfg.windowSize = 64
+	}
+	if t.tickCfg.minSamples < 10 {
+		t.tickCfg.minSamples = 10
+	}
+	if t.tickCfg.minSamples > t.tickCfg.windowSize {
+		t.tickCfg.minSamples = t.tickCfg.windowSize
+	}
+	if t.tickCfg.computeInterval <= 0 {
+		t.tickCfg.computeInterval = 2 * time.Second
+	}
+	if t.bookCfg.emaTau <= 0 {
+		t.bookCfg.emaTau = 30 * time.Second
+	}
+	return t
+}
+
+func (t *DQTracker) ObserveTick(symbol string, values map[string]any) {
+	if !t.enabled {
+		return
+	}
+	ts, ok := getInt64(values["ts"])
+	if !ok || ts <= 0 {
+		return
+	}
+	sym := strings.ToUpper(strings.TrimSpace(symbol))
+	if sym == "" {
+		sym = strings.ToUpper(strings.TrimSpace(getString(values["symbol"])))
+	}
+	if sym == "" {
+		return
+	}
+
+	t.muTicks.Lock()
+	w := t.ticks[sym]
+	if w == nil {
+		w = newTickGapWindow(t.tickCfg.windowSize, t.tickCfg.minSamples, t.tickCfg.computeInterval)
+		t.ticks[sym] = w
+	}
+	t.muTicks.Unlock()
+
+	nowMs := timeutil.GetCurrentTimestampMs()
+	gap, p95, computed, ooo := w.observe(ts, nowMs)
+	if ooo {
+		monitoring.RecordTickGapOutOfOrder(t.venue, sym)
+		return
+	}
+	if gap <= 0 {
+		return
+	}
+	monitoring.RecordTickGapSample(t.venue, sym)
+	if computed {
+		monitoring.SetTickGapP95Ms(t.venue, sym, p95)
+	}
+}
+
+func (t *DQTracker) ObserveBook(symbol string, values map[string]any) {
+	if !t.enabled {
+		return
+	}
+	sym := strings.ToUpper(strings.TrimSpace(symbol))
+	if sym == "" {
+		sym = strings.ToUpper(strings.TrimSpace(getString(values["symbol"])))
+	}
+	if sym == "" {
+		return
+	}
+
+	finalID, ok := getInt64(values["final_id"])
+	if !ok || finalID <= 0 {
+		return
+	}
+	prevID, _ := getInt64(values["prev_final"])
+	isSnapshot := getBool(values["is_snapshot"])
+
+	t.muBooks.Lock()
+	b := t.books[sym]
+	if b == nil {
+		b = newBookSeqEMA(t.bookCfg.emaTau)
+		t.books[sym] = b
+	}
+	t.muBooks.Unlock()
+
+	nowMs := timeutil.GetCurrentTimestampMs()
+	ema, missing, reason := b.observe(nowMs, prevID, finalID, isSnapshot)
+	switch reason {
+	case "reset":
+		monitoring.RecordBookSeqReset(t.venue, sym)
+		monitoring.SetBookMissingSeqEMA(t.venue, sym, ema)
+		return
+	case "ooo":
+		monitoring.RecordBookSeqOutOfOrder(t.venue, sym)
+		monitoring.SetBookMissingSeqEMA(t.venue, sym, ema)
+		return
+	default:
+	}
+
+	if missing > 0 {
+		monitoring.RecordBookMissingSeqEvent(t.venue, sym)
+	}
+	monitoring.SetBookMissingSeqEMA(t.venue, sym, ema)
+}
+
+// --- internals ---
+
+type tickGapWindow struct {
+	mu sync.Mutex
+
+	lastTs int64
+
+	buf  []int64
+	idx  int
+	full bool
+
+	minSamples int
+
+	lastComputeMs     int64
+	computeIntervalMs int64
+}
+
+func newTickGapWindow(windowSize, minSamples int, computeInterval time.Duration) *tickGapWindow {
+	return &tickGapWindow{
+		buf:               make([]int64, windowSize),
+		minSamples:        minSamples,
+		computeIntervalMs: computeInterval.Milliseconds(),
+	}
+}
+
+// observe returns: gapMs, p95Ms, computed, outOfOrder.
+func (w *tickGapWindow) observe(tsMs, nowMs int64) (int64, float64, bool, bool) {
+	w.mu.Lock()
+	defer w.mu.Unlock()
+
+	if w.lastTs == 0 {
+		w.lastTs = tsMs
+		return 0, 0, false, false
+	}
+	gap := tsMs - w.lastTs
+	if gap <= 0 {
+		// duplicates / out-of-order ticks
+		w.lastTs = max64(w.lastTs, tsMs)
+		return 0, 0, false, true
+	}
+	w.lastTs = tsMs
+
+	w.buf[w.idx] = gap
+	w.idx++
+	if w.idx >= len(w.buf) {
+		w.idx = 0
+		w.full = true
+	}
+
+	// Compute p95 not more often than computeInterval.
+	if w.computeIntervalMs > 0 && w.lastComputeMs > 0 && nowMs-w.lastComputeMs < w.computeIntervalMs {
+		return gap, 0, false, false
+	}
+	samples := w.samplesUnsafe()
+	if len(samples) < w.minSamples {
+		return gap, 0, false, false
+	}
+	p95 := p95Int64(samples)
+	w.lastComputeMs = nowMs
+	return gap, p95, true, false
+}
+
+func (w *tickGapWindow) samplesUnsafe() []int64 {
+	if w.full {
+		out := make([]int64, 0, len(w.buf))
+		for _, v := range w.buf {
+			if v > 0 {
+				out = append(out, v)
+			}
+		}
+		return out
+	}
+	out := make([]int64, 0, w.idx)
+	for i := 0; i < w.idx; i++ {
+		if w.buf[i] > 0 {
+			out = append(out, w.buf[i])
+		}
+	}
+	return out
+}
+
+func p95Int64(samples []int64) float64 {
+	if len(samples) == 0 {
+		return 0
+	}
+	tmp := make([]int64, len(samples))
+	copy(tmp, samples)
+	sort.Slice(tmp, func(i, j int) bool { return tmp[i] < tmp[j] })
+	// p95 index: ceil(0.95*n)-1
+	idx := int(math.Ceil(0.95*float64(len(tmp)))) - 1
+	if idx < 0 {
+		idx = 0
+	}
+	if idx >= len(tmp) {
+		idx = len(tmp) - 1
+	}
+	return float64(tmp[idx])
+}
+
+type bookSeqEMA struct {
+	mu sync.Mutex
+
+	ema        float64
+	lastUpdate int64
+	tauMs      float64
+}
+
+func newBookSeqEMA(tau time.Duration) *bookSeqEMA {
+	return &bookSeqEMA{tauMs: float64(tau.Milliseconds())}
+}
+
+// observe returns: ema, missingCount, reason ("reset"|"ooo"|"").
+func (b *bookSeqEMA) observe(nowMs, prevID, finalID int64, isSnapshot bool) (float64, int64, string) {
+	b.mu.Lock()
+	defer b.mu.Unlock()
+
+	if isSnapshot || prevID <= 0 {
+		b.lastUpdate = nowMs
+		// Do not penalize missing on snapshots (reconnects / first sync).
+		return b.ema, 0, "reset"
+	}
+	if finalID <= prevID {
+		// Duplicates / OOO.
+		return b.ema, 0, "ooo"
+	}
+	missing := finalID - prevID - 1
+	if missing < 0 {
+		missing = 0
+	}
+
+	// Time-based EMA: alpha = 1-exp(-dt/tau).
+	dt := float64(nowMs - b.lastUpdate)
+	if dt < 0 {
+		dt = 0
+	}
+	alpha := 1.0
+	if b.tauMs > 0 {
+		alpha = 1 - math.Exp(-dt/b.tauMs)
+		if alpha < 0 {
+			alpha = 0
+		}
+		if alpha > 1 {
+			alpha = 1
+		}
+	}
+	b.ema = b.ema*(1-alpha) + float64(missing)*alpha
+	b.lastUpdate = nowMs
+	return b.ema, missing, ""
+}
+
+func getInt64(v any) (int64, bool) {
+	switch t := v.(type) {
+	case int64:
+		return t, true
+	case int:
+		return int64(t), true
+	case float64:
+		return int64(t), true
+	case string:
+		s := strings.TrimSpace(t)
+		if s == "" {
+			return 0, false
+		}
+		n, err := strconv.ParseInt(s, 10, 64)
+		if err != nil {
+			return 0, false
+		}
+		return n, true
+	default:
+		return 0, false
+	}
+}
+
+func getString(v any) string {
+	switch t := v.(type) {
+	case string:
+		return t
+	default:
+		return ""
+	}
+}
+
+func getBool(v any) bool {
+	switch t := v.(type) {
+	case bool:
+		return t
+	case string:
+		s := strings.ToLower(strings.TrimSpace(t))
+		return s == "1" || s == "true" || s == "yes" || s == "on"
+	case int:
+		return t != 0
+	case int64:
+		return t != 0
+	case float64:
+		return t != 0
+	default:
+		return false
+	}
+}
+
+func max64(a, b int64) int64 {
+	if a > b {
+		return a
+	}
+	return b
+}
