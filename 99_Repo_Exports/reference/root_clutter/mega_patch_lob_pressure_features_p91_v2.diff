+# -*- coding: utf-8 -*-

+"""LOB Pressure features (P91).

+

+Designed for low-latency / deterministic runtime:

+- Pure Python, no numpy/pandas.

+- Bounded depth (default top-5).

+- Fail-open: if inputs are incomplete/invalid -> returns zeros.

+

+Features:

+1) Queue imbalance per level (L1..L5) + aggregates (mean, max_abs, slope)

+2) Microprice divergence vs mid (bps) + microprice shift (bps)

+3) Book slope/convexity (by cumulative depth) per side + imbalance

+4) Depth-weighted OBI (weights 1/(level)) for stronger near-touch emphasis

+"""

+

+from __future__ import annotations

+

+from typing import Any, Dict, List, Optional, Tuple

+import math

+

+

+def _sf(x: Any, default: float = 0.0) -> float:

+    try:

+        v = float(x)

+        if math.isnan(v) or math.isinf(v):

+            return float(default)

+        return v

+    except Exception:

+        return float(default)

+

+

+def _lin_slope(y: List[float]) -> float:

+    """Slope of y over x=1..n (least squares), fail-open."""

+    n = len(y)

+    if n <= 1:

+        return 0.0

+    x_mean = (n + 1) * 0.5

+    y_mean = sum(y) / float(n)

+    num = 0.0

+    den = 0.0

+    for i, yi in enumerate(y, 1):

+        dx = float(i) - x_mean

+        dy = float(yi) - y_mean

+        num += dx * dy

+        den += dx * dx

+    if den <= 0:

+        return 0.0

+    return num / den

+

+

+def _microprice(best_bid_px: float, best_bid_qty: float, best_ask_px: float, best_ask_qty: float) -> float:

+    denom = best_bid_qty + best_ask_qty

+    if denom <= 0:

+        return 0.0

+    return (best_ask_px * best_bid_qty + best_bid_px * best_ask_qty) / denom

+

+

+def compute_lob_pressure(

+    *,

+    bids: List[Tuple[float, float]],

+    asks: List[Tuple[float, float]],

+    prev_bids: Optional[List[Tuple[float, float]]] = None,

+    prev_asks: Optional[List[Tuple[float, float]]] = None,

+    depth: int = 5,

+) -> Dict[str, float]:

+    """Compute LOB pressure features from top-of-book levels."""

+    depth = int(max(1, min(10, depth)))

+    eps = 1e-12

+

+    # Normalize levels

+    bq: List[float] = []

+    aq: List[float] = []

+    bp: List[float] = []

+    ap: List[float] = []

+    for i in range(depth):

+        if i < len(bids):

+            bp.append(_sf(bids[i][0], 0.0))

+            bq.append(max(0.0, _sf(bids[i][1], 0.0)))

+        else:

+            bp.append(0.0)

+            bq.append(0.0)

+        if i < len(asks):

+            ap.append(_sf(asks[i][0], 0.0))

+            aq.append(max(0.0, _sf(asks[i][1], 0.0)))

+        else:

+            ap.append(0.0)

+            aq.append(0.0)

+

+    # --- Queue imbalance per level ---

+    qi_levels: List[float] = []

+    for i in range(depth):

+        # Require both sides to be present to avoid extreme (1/-1) on partial snapshots.

+        if bq[i] <= 0.0 or aq[i] <= 0.0:

+            qi = 0.0

+        else:

+            denom = bq[i] + aq[i]

+            qi = (bq[i] - aq[i]) / denom if denom > 0.0 else 0.0

+        qi_levels.append(float(qi))

+

+    qi_mean = sum(qi_levels) / float(max(1, len(qi_levels)))

+    qi_max_abs = 0.0

+    for q in qi_levels:

+        qi_max_abs = max(qi_max_abs, abs(float(q)))

+    qi_slope = _lin_slope(qi_levels)

+

+    out: Dict[str, float] = {

+        "qi_mean": float(qi_mean),

+        "qi_max_abs": float(qi_max_abs),

+        "qi_slope": float(qi_slope),

+    }

+    for i, q in enumerate(qi_levels, 1):

+        out[f"qi_l{i}"] = float(q)

+

+    # --- Microprice divergence + shift ---

+    best_bid_px = bp[0] if bp else 0.0

+    best_ask_px = ap[0] if ap else 0.0

+    best_bid_qty = bq[0] if bq else 0.0

+    best_ask_qty = aq[0] if aq else 0.0

+

+    mid = 0.0

+    if best_bid_px > 0.0 and best_ask_px > 0.0:

+        mid = 0.5 * (best_bid_px + best_ask_px)

+

+    mp = 0.0

+    if best_bid_px > 0.0 and best_ask_px > 0.0 and (best_bid_qty + best_ask_qty) > 0.0:

+        mp = _microprice(best_bid_px, best_bid_qty, best_ask_px, best_ask_qty)

+

+    mp_mid_div_bps = 0.0

+    if mid > 0.0 and mp > 0.0:

+        mp_mid_div_bps = ((mp - mid) / mid) * 10_000.0

+

+    mp_shift_bps = 0.0

+    if prev_bids and prev_asks and len(prev_bids) > 0 and len(prev_asks) > 0:

+        pbid_px = _sf(prev_bids[0][0], 0.0)

+        pask_px = _sf(prev_asks[0][0], 0.0)

+        pbid_qty = max(0.0, _sf(prev_bids[0][1], 0.0))

+        pask_qty = max(0.0, _sf(prev_asks[0][1], 0.0))

+        pmid = 0.0

+        if pbid_px > 0.0 and pask_px > 0.0:

+            pmid = 0.5 * (pbid_px + pask_px)

+        pmp = 0.0

+        if pbid_px > 0.0 and pask_px > 0.0 and (pbid_qty + pask_qty) > 0.0:

+            pmp = _microprice(pbid_px, pbid_qty, pask_px, pask_qty)

+        if pmid > 0.0 and mp > 0.0 and pmp > 0.0:

+            mp_shift_bps = ((mp - pmp) / pmid) * 10_000.0

+

+    out["micro_mid_div_bps"] = float(mp_mid_div_bps)

+    out["micro_shift_bps"] = float(mp_shift_bps)

+

+    # --- Depth curve slope/convexity ---

+    # Cumulative depth is more stable than raw per-level sizes.

+    cum_bid: List[float] = []

+    cum_ask: List[float] = []

+    s = 0.0

+    for q in bq:

+        s += float(q)

+        cum_bid.append(float(s))

+    s = 0.0

+    for q in aq:

+        s += float(q)

+        cum_ask.append(float(s))

+

+    def _slope(cum: List[float]) -> float:

+        n = len(cum)

+        if n <= 1:

+            return 0.0

+        return (cum[-1] - cum[0]) / float(n - 1)

+

+    def _convexity(cum: List[float]) -> float:

+        n = len(cum)

+        if n < 3:

+            return 0.0

+        mid_i = n // 2  # for 5 -> 2 (L3)

+        a = cum[0]

+        m = cum[mid_i]

+        z = cum[-1]

+        # second difference around mid (normalized)

+        return ((z - m) - (m - a)) / float(max(eps, abs(z)))

+

+    slope_bid = _slope(cum_bid)

+    slope_ask = _slope(cum_ask)

+    conv_bid = _convexity(cum_bid)

+    conv_ask = _convexity(cum_ask)

+

+    out["depth_slope_bid"] = float(slope_bid)

+    out["depth_slope_ask"] = float(slope_ask)

+    out["depth_slope_imb"] = float(slope_bid - slope_ask)

+

+    out["depth_convexity_bid"] = float(conv_bid)

+    out["depth_convexity_ask"] = float(conv_ask)

+    out["depth_convexity_imb"] = float(conv_bid - conv_ask)

+

+    # --- Depth-weighted OBI (1/level weights) ---

+    wb = 0.0

+    wa = 0.0

+    for i in range(depth):

+        w = 1.0 / float(i + 1)

+        wb += w * float(bq[i])

+        wa += w * float(aq[i])

+    denom = wb + wa

+    dw_obi = (wb - wa) / denom if denom > eps else 0.0

+    out["dw_obi"] = float(dw_obi)

+

+    return out


