+# -*- coding: utf-8 -*-

+import os

+import sys

+import math

+

+# Ensure `core.*` resolves to tick_flow_full/core in this repo layout.

+_TFF_ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__), "..", "..", "..", "tick_flow_full"))

+if _TFF_ROOT not in sys.path:

+    sys.path.insert(0, _TFF_ROOT)

+

+from core.lob_pressure import compute_lob_pressure

+

+

+def _approx(a, b, tol=1e-6):

+    return abs(float(a) - float(b)) <= float(tol)

+

+

+def test_compute_lob_pressure_basic():

+    bids = [(100.0, 10.0), (99.0, 20.0), (98.0, 30.0), (97.0, 40.0), (96.0, 50.0)]

+    asks = [(101.0, 5.0), (102.0, 5.0), (103.0, 5.0), (104.0, 5.0), (105.0, 5.0)]

+

+    out = compute_lob_pressure(bids=bids, asks=asks, depth=5)

+

+    # L1 queue imbalance: (10-5)/(10+5)=1/3

+    assert _approx(out["qi_l1"], 1.0 / 3.0, tol=1e-6)

+    # L2: (20-5)/25 = 0.6

+    assert _approx(out["qi_l2"], 0.6, tol=1e-6)

+

+    # Microprice divergence should be positive (hidden bid pressure)

+    assert out["micro_mid_div_bps"] > 0.0

+

+    # Depth-weighted OBI should be positive

+    assert out["dw_obi"] > 0.0

+

+    # Slope should be positive (imbalance grows deeper)

+    assert out["qi_slope"] > 0.0

+

+

+def test_compute_lob_pressure_fail_open_on_partial():

+    # Missing ask levels -> qi should not explode to 1; we require both sides -> 0.

+    bids = [(100.0, 10.0)]

+    asks = [(101.0, 0.0)]

+    out = compute_lob_pressure(bids=bids, asks=asks, depth=5)

+    assert _approx(out["qi_l1"], 0.0)

+    assert _approx(out["qi_mean"], 0.0)


