+from __future__ import annotations
+
+"""Deterministic rolling robust z-score tracker (median/MAD)."""
+
+from collections import deque
+from typing import Deque
+import math
+import numpy as np
+
+
+class RollingRobustZ:
+    def __init__(self, window: int = 120) -> None:
+        self.window = max(3, int(window))
+        self.values: Deque[float] = deque(maxlen=self.window)
+
+    def update(self, value: float) -> float:
+        try:
+            v = float(value)
+        except Exception:
+            v = 0.0
+        if not math.isfinite(v):
+            v = 0.0
+        self.values.append(v)
+        if len(self.values) < 3:
+            return 0.0
+        a = np.asarray(list(self.values), dtype=np.float64)
+        med = float(np.median(a))
+        mad = float(np.median(np.abs(a - med)))
+        if mad <= 0.0 or not math.isfinite(mad):
+            return 0.0
+        return float((v - med) / (1.4826 * mad))
