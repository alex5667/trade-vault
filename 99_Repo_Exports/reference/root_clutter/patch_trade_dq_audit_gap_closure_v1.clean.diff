+from __future__ import annotations
+
+"""Minimal EMA tracker for sparse stream-integrity events."""
+
+from dataclasses import dataclass
+
+
+@dataclass
+class GapEmaTracker:
+    tau_ms: int = 10_000
+    ema: float = 0.0
+    last_ts_ms: int = 0
+
+    def update(self, *, is_gap: bool, ts_ms: int) -> float:
+        t = int(ts_ms)
+        if self.last_ts_ms <= 0:
+            self.last_ts_ms = t
+            self.ema = 1.0 if bool(is_gap) else 0.0
+            return float(self.ema)
+        dt = max(1, t - int(self.last_ts_ms))
+        tau = max(1, int(self.tau_ms))
+        alpha = min(1.0, dt / float(tau))
+        x = 1.0 if bool(is_gap) else 0.0
+        self.ema = float((1.0 - alpha) * float(self.ema) + alpha * x)
+        self.last_ts_ms = t
+        return float(self.ema)
