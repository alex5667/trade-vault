@@ -0,0 +1,44 @@
+import { parseSnapshotJson } from '../liqmap.parse';
+
+describe('liqmap.parse', () => {
+  test('parseSnapshotJson rejects huge payload', () => {
+    const json = JSON.stringify({ ts_ms: 1, symbol: 'BTCUSDT', window: '1h', bucket_mode: 'log_bps', levels: [] });
+    expect(parseSnapshotJson(json, 10)).toBeNull();
+  });
+
+  test('parseSnapshotJson accepts valid payload', () => {
+    const json = JSON.stringify({
+      ts_ms: 123,
+      symbol: 'BTCUSDT',
+      window: '1h',
+      bucket_mode: 'log_bps',
+      levels: [{ price: '100', bucket: '1', long_usd: '1', short_usd: '2', total_usd: '3' }],
+    });
+    const out = parseSnapshotJson(json, 100000);
+    expect(out).not.toBeNull();
+    expect(out?.symbol).toBe('BTCUSDT');
+  });
+});
+
