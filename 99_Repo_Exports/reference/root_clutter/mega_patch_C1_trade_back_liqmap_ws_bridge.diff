+import {
+  WebSocketGateway,
+  WebSocketServer,
+  OnGatewayConnection,
+} from '@nestjs/websockets';
+import { Server, Socket } from 'socket.io';
+import { Logger } from '@nestjs/common';
+import { LiqmapSnapshotV1 } from './liqmap.types';
+
+@WebSocketGateway({ namespace: '/signals', cors: { origin: '*', credentials: true } })
+export class LiqmapGateway implements OnGatewayConnection {
+  private readonly logger = new Logger('LiqmapGateway');
+
+  @WebSocketServer()
+  server!: Server;
+
+  // latest snapshot cache (symbol|window -> payload)
+  private latest = new Map<string, LiqmapSnapshotV1>();
+
+  handleConnection(client: Socket) {
+    // Best-effort: on connect, emit last known snapshots.
+    try {
+      for (const s of this.latest.values()) {
+        client.emit('liqmap_snapshot', { schema: 1, payload: s });
+      }
+    } catch (e) {
+      this.logger.debug(`handleConnection emit failed: ${(e as Error).message}`);
+    }
+  }
+
+  publish(snapshot: LiqmapSnapshotV1) {
+    const key = `${snapshot.symbol}|${snapshot.window}`;
+    this.latest.set(key, snapshot);
+    this.server.emit('liqmap_snapshot', { schema: 1, payload: snapshot });
+  }
+}
+
diff --git a/src/modules/liqmap/liqmap.bridge.service.ts b/src/modules/liqmap/liqmap.bridge.service.ts
new file mode 100644
index 0000000..4453ff9
--- /dev/null
+++ b/src/modules/liqmap/liqmap.bridge.service.ts
@@ -0,0 +1,293 @@
+import { Injectable, Logger, OnModuleDestroy, OnModuleInit } from '@nestjs/common';
+import type { RedisClient } from './liqmap.redis';
+import { createRedisClient } from './liqmap.redis';
+import { loadLiqmapConfig } from './liqmap.config';
+import { LiqmapGateway } from './liqmap.gateway';
+import { parseSnapshotJson, snapshotKey, snapshotStream } from './liqmap.parse';
+
+type StreamMsg = [string, Array<[string, Record<string, string>]>];
+
+@Injectable()
+export class LiqmapBridgeService implements OnModuleInit, OnModuleDestroy {
+  private readonly logger = new Logger('LiqmapBridgeService');
+
+  private r!: RedisClient;
+  private stop = false;
+  private pollTimer: NodeJS.Timeout | null = null;
+
+  private lastTsByKey = new Map<string, number>();
+
+  constructor(private readonly gw: LiqmapGateway) {}
+
+  async onModuleInit() {
+    const cfg = loadLiqmapConfig();
+    this.r = createRedisClient(cfg.redisUrl);
+    await this.r.connect();
+
+    if (!cfg.symbols.length) {
+      this.logger.warn('LIQMAP_SYMBOLS is empty: bridge is idle (safe).');
+      return;
+    }
+
+    if (cfg.source === 'key') {
+      this.startKeyPolling(cfg);
+    } else {
+      await this.startStreamLoop(cfg);
+    }
+  }
+
+  async onModuleDestroy() {
+    this.stop = true;
+    if (this.pollTimer) {
+      clearInterval(this.pollTimer);
+      this.pollTimer = null;
+    }
+    try {
+      if (this.r) await this.r.quit();
+    } catch {
+      // ignore
+    }
+  }
+
+  private keysToTrack(cfg: ReturnType<typeof loadLiqmapConfig>) {
+    const out: Array<{ sym: string; win: string; key: string }> = [];
+    for (const sym of cfg.symbols) {
+      for (const w of cfg.windows) {
+        out.push({ sym, win: w, key: snapshotKey(cfg.snapshotKeyPrefix, sym, w) });
+      }
+    }
+    return out;
+  }
+
+  private streamsToTrack(cfg: ReturnType<typeof loadLiqmapConfig>) {
+    const out: string[] = [];
+    for (const sym of cfg.symbols) {
+      for (const w of cfg.windows) {
+        out.push(snapshotStream(cfg.snapshotStreamPrefix, sym, w));
+      }
+    }
+    return out;
+  }
+
+  private startKeyPolling(cfg: ReturnType<typeof loadLiqmapConfig>) {
+    const tracked = this.keysToTrack(cfg);
+    this.logger.log(`LIQMAP key polling enabled: keys=${tracked.length} interval=${cfg.pollIntervalMs}ms`);
+
+    this.pollTimer = setInterval(async () => {
+      if (this.stop) return;
+      try {
+        const keys = tracked.map((t) => t.key);
+        const vals = await this.r.mget(...keys);
+        for (let i = 0; i < keys.length; i++) {
+          const key = keys[i];
+          const json = vals[i];
+          if (!json) continue;
+          const snap = parseSnapshotJson(json, cfg.maxPayloadBytes);
+          if (!snap) continue;
+          const last = this.lastTsByKey.get(key) || 0;
+          if (snap.ts_ms <= last) continue;
+          this.lastTsByKey.set(key, snap.ts_ms);
+          this.gw.publish(snap);
+        }
+      } catch (e) {
+        this.logger.warn(`key polling error: ${(e as Error).message}`);
+      }
+    }, cfg.pollIntervalMs);
+  }
+
+  private async ensureGroups(cfg: ReturnType<typeof loadLiqmapConfig>, streams: string[]) {
+    for (const s of streams) {
+      try {
+        // XGROUP CREATE <key> <groupname> $ MKSTREAM
+        // ioredis: xgroup('CREATE', key, group, '$', 'MKSTREAM')
+        await this.r.xgroup('CREATE', s, cfg.streamGroup, '$', 'MKSTREAM');
+      } catch (e) {
+        const msg = (e as Error).message || '';
+        if (msg.includes('BUSYGROUP')) {
+          continue;
+        }
+        // In case the stream doesn't exist yet, MKSTREAM should create it.
+        // Other errors should be visible.
+        this.logger.warn(`xgroup create failed stream=${s}: ${msg}`);
+      }
+    }
+  }
+
+  private async startStreamLoop(cfg: ReturnType<typeof loadLiqmapConfig>) {
+    const streams = this.streamsToTrack(cfg);
+    this.logger.log(
+      `LIQMAP stream mode enabled: streams=${streams.length} group=${cfg.streamGroup} consumer=${cfg.streamConsumer}`,
+    );
+
+    await this.ensureGroups(cfg, streams);
+
+    // Start background loop (non-blocking for Nest init): fire and forget
+    // NOTE: OnModuleInit allows async, but we don't want to block the app start forever.
+    void this.streamLoop(cfg, streams);
+  }
+
+  private async streamLoop(cfg: ReturnType<typeof loadLiqmapConfig>, streams: string[]) {
+    // We use XREADGROUP to read from ALL streams in one blocking call.
+    // Format: XREADGROUP GROUP g c COUNT N BLOCK ms STREAMS k1 k2 ... > > ...
+    const ids = streams.map(() => '>');
+
+    while (!this.stop) {
+      try {
+        const resp = (await this.r.xreadgroup(
+          'GROUP',
+          cfg.streamGroup,
+          cfg.streamConsumer,
+          'COUNT',
+          cfg.streamCount,
+          'BLOCK',
+          cfg.streamBlockMs,
+          'STREAMS',
+          ...streams,
+          ...ids,
+        )) as unknown as StreamMsg[] | null;
+
+        if (!resp || !resp.length) continue;
+
+        for (const [stream, entries] of resp) {
+          for (const [id, fields] of entries) {
+            const json = fields?.data;
+            if (typeof json === 'string' && json) {
+              const snap = parseSnapshotJson(json, cfg.maxPayloadBytes);
+              if (snap) {
+                this.gw.publish(snap);
+              }
+            }
+            // Always ACK to prevent PEL growth (UI is best-effort).
+            try {
+              await this.r.xack(stream, cfg.streamGroup, id);
+            } catch (e) {
+              this.logger.debug(`xack failed stream=${stream} id=${id}: ${(e as Error).message}`);
+            }
+          }
+        }
+      } catch (e) {
+        this.logger.warn(`stream loop error: ${(e as Error).message}`);
+        // bounded backoff
+        await new Promise((r) => setTimeout(r, 250));
+      }
+    }
+  }
+}
+
