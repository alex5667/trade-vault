@@ -0,0 +1,74 @@
+export type LiqmapWindow = string; // e.g. "1h"|"4h"|"24h"
+
+export type LiqmapLevelV1 = {
+  price: string; // decimal-as-string
+  bucket: string; // abs: bucket price string; log_*: integer index string
+  long_usd: string; // decimal-as-string
+  short_usd: string; // decimal-as-string
+  total_usd: string; // decimal-as-string
+};
+
+export type LiqmapSnapshotV1 = {
+  ts_ms: number;
+  symbol: string;
+  window: LiqmapWindow;
+
+  bucket_mode: 'log_bps' | 'log_pct' | 'abs' | string;
+  bucket_bps?: number | null;
+  bucket_pct?: number | null;
+  bucket_abs?: string | null;
+  range_pct?: number | null;
+
+  levels: LiqmapLevelV1[];
+};
+
+export type LiqmapWsEnvelope = {
+  event: 'liqmap_snapshot';
+  schema: 1;
+  payload: LiqmapSnapshotV1;
+};
+
+export function isLiqmapSnapshotV1(x: unknown): x is LiqmapSnapshotV1 {
+  if (!x || typeof x !== 'object') return false;
+  const o = x as any;
+  return (
+    typeof o.ts_ms === 'number' &&
+    typeof o.symbol === 'string' &&
+    typeof o.window === 'string' &&
+    typeof o.bucket_mode === 'string' &&
+    Array.isArray(o.levels)
+  );
+}
+
diff --git a/src/modules/liqmap/liqmap.parse.ts b/src/modules/liqmap/liqmap.parse.ts
