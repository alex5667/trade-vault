@@ -0,0 +1,148 @@
+/* eslint-disable @typescript-eslint/no-non-null-assertion */
+
+export type LiqmapSource = 'stream' | 'key';
+
+export type LiqmapConfig = {
+  redisUrl: string;
+
+  source: LiqmapSource;
+  symbols: string[];
+  windows: string[];
+
+  snapshotKeyPrefix: string;
+  snapshotStreamPrefix: string;
+
+  // stream mode
+  streamGroup: string;
+  streamConsumer: string;
+  streamBlockMs: number;
+  streamCount: number;
+
+  // key mode
+  pollIntervalMs: number;
+
+  // safety
+  maxPayloadBytes: number;
+};
+
+function splitCsv(v: string | undefined): string[] {
+  if (!v) return [];
+  return v
+    .split(',')
+    .map((s) => s.trim())
+    .filter(Boolean);
+}
+
+function envInt(name: string, def: number): number {
+  const v = process.env[name];
+  if (!v) return def;
+  const n = Number(v);
+  return Number.isFinite(n) ? Math.trunc(n) : def;
+}
+
+export function loadLiqmapConfig(): LiqmapConfig {
+  const redisUrl =
+    process.env.REDIS_URL ||
+    process.env.REDIS_WORKER_URL ||
+    process.env.REDIS_URI ||
+    'redis://localhost:6379';
+
+  const source = (process.env.LIQMAP_WS_SOURCE || 'stream').toLowerCase() as LiqmapSource;
+  const symbols = splitCsv(process.env.LIQMAP_SYMBOLS);
+  const windows = splitCsv(process.env.LIQMAP_WINDOWS);
+
+  return {
+    redisUrl,
+    source: source === 'key' ? 'key' : 'stream',
+
+    // If user didn't pass symbols/windows, we still keep the module alive.
+    // It will log warnings and do nothing (safe).
+    symbols: symbols.map((s) => s.toUpperCase()),
+    windows: windows.length ? windows : ['1h', '4h', '24h'],
+
+    snapshotKeyPrefix: process.env.LIQMAP_SNAPSHOT_KEY_PREFIX || 'liqmap:snapshot',
+    snapshotStreamPrefix: process.env.LIQMAP_SNAPSHOT_STREAM_PREFIX || 'stream:liqmap_snapshot',
+
+    streamGroup: process.env.LIQMAP_STREAM_GROUP || 'tb_liqmap',
+    streamConsumer: process.env.LIQMAP_STREAM_CONSUMER || `tb-${process.pid}`,
+    streamBlockMs: envInt('LIQMAP_STREAM_BLOCK_MS', 1000),
+    streamCount: envInt('LIQMAP_STREAM_COUNT', 200),
+
+    pollIntervalMs: envInt('LIQMAP_POLL_INTERVAL_MS', 500),
+
+    maxPayloadBytes: envInt('LIQMAP_MAX_PAYLOAD_BYTES', 262144),
+  };
+}
+
