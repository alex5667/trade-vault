@@ -0,0 +1,56 @@
+import { isLiqmapSnapshotV1, LiqmapSnapshotV1 } from './liqmap.types';
+
+export function parseSnapshotJson(json: string, maxBytes: number): LiqmapSnapshotV1 | null {
+  if (!json) return null;
+  // Safety: avoid parsing huge payloads.
+  if (Buffer.byteLength(json, 'utf8') > maxBytes) return null;
+
+  let obj: unknown;
+  try {
+    obj = JSON.parse(json);
+  } catch {
+    return null;
+  }
+  if (!isLiqmapSnapshotV1(obj)) return null;
+  return obj;
+}
+
+export function snapshotKey(prefix: string, symbol: string, window: string): string {
+  return `${prefix}:${symbol}:${window}`;
+}
+
+export function snapshotStream(prefix: string, symbol: string, window: string): string {
+  return `${prefix}:${symbol}:${window}`;
+}
+
