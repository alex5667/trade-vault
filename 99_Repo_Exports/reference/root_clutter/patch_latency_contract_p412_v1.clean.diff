+groups:
+  - name: latency-contract-p412
+    rules:
+      - alert: OF_LatencyDeployLint_DualControlBindingMismatch_Warn
+        expr: latency_contract_deploy_lint_summary_dual_control_binding_mismatch_total > 0
+        for: 10m
+        labels: {severity: warn}
+        annotations:
+          summary: "Latency deploy-lint override approval drift binding no longer matches"
+          description: "At least one latest dual-control override approval is still present, but the bound deploy-lint drift snapshot no longer matches the current error_codes / active_purposes_hash. A fresh prepare/approve cycle is required before final ack."
+      - alert: OF_LatencyDeployLint_DualControlApprovalInvalidated_Crit
+        expr: latency_contract_deploy_lint_summary_dual_control_invalidated_gate_active_total > 0
+        for: 5m
+        labels: {severity: crit}
+        annotations:
+          summary: "Latency deploy-lint override approval was invalidated by drift change"
+          description: "A final long-override ack was denied because deploy-lint drift changed after approval was prepared/approved. The approval request is invalidated and operators must repeat the workflow on the fresh drift snapshot."

