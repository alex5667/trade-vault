+# Fixed namespace UUID for deterministic event IDs.
+# This makes replay tests and idempotency trivial while remaining a valid UUID type
+# for Postgres schemas that declare event_id UUID.
+_NEWS_EVENT_NAMESPACE = uuid.UUID("2b8fd6d1-25ae-4a04-8ed1-2e3b1d1b0b8a")
+
+
+def stable_event_uuid(doc_id: str, prompt_ver: str, model_id: str) -> str:
+    """Deterministic UUID for an extracted event.
+
+    Key design points:
+    - Deterministic by (doc_id, prompt_ver, model_id) → no duplicates on replay.
+    - Does NOT include provider: provider may change on fallback/repair, but
+      semantically it's the same extraction for the same prompt/model.
+
+    Why UUIDv5:
+    - Valid UUID type for Postgres schemas.
+    - Deterministic (unlike uuid4).
+    """
+    name = f"{doc_id}|{prompt_ver}|{model_id}"
+    return str(uuid.uuid5(_NEWS_EVENT_NAMESPACE, name))
+
