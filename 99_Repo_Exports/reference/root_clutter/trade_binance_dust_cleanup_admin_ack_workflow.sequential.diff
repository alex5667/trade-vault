+groups:
+  - name: binance-dust-cleanup-admin-ack
+    rules:
+      - alert: BinanceDustAdminOldDenylistWithoutAck
+        expr: execution_dust_admin_unacked_items_total{kind="old_denylist"} > 0
+        for: 15m
+        labels:
+          severity: warning
+        annotations:
+          summary: "Dust admin has old denylist entries without operator acknowledgement"
+
+      - alert: BinanceDustAdminCooldownLoopWithoutAck
+        expr: execution_dust_admin_unacked_items_total{kind="cooldown_loop"} > 0
+        for: 15m
+        labels:
+          severity: warning
+        annotations:
+          summary: "Dust admin has cooldown loop reminders without operator acknowledgement"
+
+      - alert: BinanceDustAdminAckRenewReminderEmitted
+        expr: increase(execution_dust_admin_ack_renew_reminder_total{result="sent"}[30m]) > 0
+        for: 0m
+        labels:
+          severity: info
+        annotations:
+          summary: "Dust admin ACK renewal reminder was emitted"
+
+      - alert: BinanceDustAdminAckActionFailures
+        expr: increase(execution_dust_admin_ack_action_total{result!="ok"}[15m]) > 0
+        for: 0m
+        labels:
+          severity: warning
