--- /dev/null
+++ b/internal/hyperliquid/utils.go
@@ -0,0 +1,108 @@
+package hyperliquid
+
+import (
+	"os"
+	"strconv"
+	"strings"
+	"time"
+)
+
+// getEnv returns env value or defaultValue.
+func getEnv(key, defaultValue string) string {
+	v := strings.TrimSpace(os.Getenv(key))
+	if v == "" {
+		return defaultValue
+	}
+	return v
+}
+
+// getEnvDuration reads time.Duration from env (e.g. "250ms", "2s").
+// If parsing fails — returns defaultValue.
+func getEnvDuration(key string, defaultValue time.Duration) time.Duration {
+	v := strings.TrimSpace(os.Getenv(key))
+	if v == "" {
+		return defaultValue
+	}
+	d, err := time.ParseDuration(v)
+	if err != nil {
+		return defaultValue
+	}
+	return d
+}
+
+// getEnvInt reads int from env, otherwise defaultValue.
+func getEnvInt(key string, defaultValue int) int {
+	v := strings.TrimSpace(os.Getenv(key))
+	if v == "" {
+		return defaultValue
+	}
+	n, err := strconv.Atoi(v)
+	if err != nil {
+		return defaultValue
+	}
+	return n
+}
+
+// getEnvBool reads bool from env.
+// Empty value => defaultValue.
+func getEnvBool(key string, defaultValue bool) bool {
+	v := strings.TrimSpace(os.Getenv(key))
+	if v == "" {
+		return defaultValue
+	}
+	switch strings.ToLower(v) {
+	case "1", "true", "yes", "on":
+		return true
+	case "0", "false", "no", "off":
+		return false
+	default:
+		return defaultValue
+	}
+}
+
+// parseSymbolMap reads COIN->SYMBOL mapping from env.
+// Format: "BTC:BTCUSDT,ETH:ETHUSDT,1000PEPE:1000PEPEUSDT".
+func parseSymbolMap(raw string) map[string]string {
+	out := map[string]string{}
+	raw = strings.TrimSpace(raw)
+	if raw == "" {
+		return out
+	}
+	parts := strings.Split(raw, ",")
+	for _, p := range parts {
+		p = strings.TrimSpace(p)
+		if p == "" {
+			continue
+		}
+		kv := strings.SplitN(p, ":", 2)
+		if len(kv) != 2 {
+			continue
+		}
+		k := strings.ToUpper(strings.TrimSpace(kv[0]))
+		v := strings.ToUpper(strings.TrimSpace(kv[1]))
+		if k == "" || v == "" {
+			continue
+		}
+		out[k] = v
+	}
+	return out
+}
+
+// normalizeSymbol maps Hyperliquid coin -> internal Symbol.
+// Strict policy to match Python worker contract:
+//   - if explicit map has coin, use it
+//   - else coin + suffix (default "USDT") to match Binance-style symbols
+//   - suffix can be disabled by setting HYPERLIQUID_SYMBOL_SUFFIX="" (symbol=coin)
+func normalizeSymbol(coin string, symbolMap map[string]string, suffix string) string {
+	c := strings.ToUpper(strings.TrimSpace(coin))
+	if c == "" {
+		return ""
+	}
+	if v, ok := symbolMap[c]; ok {
+		return strings.ToUpper(v)
+	}
+	if strings.TrimSpace(suffix) == "" {
+		return c
+	}
+	return c + strings.ToUpper(strings.TrimSpace(suffix))
+}
