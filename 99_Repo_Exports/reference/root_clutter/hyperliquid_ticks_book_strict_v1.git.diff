diff --git a/internal/hyperliquid/futures_normalizer.go b/internal/hyperliquid/futures_normalizer.go
new file mode 100644
index 0000000..c87b141
--- /dev/null
+++ b/internal/hyperliquid/futures_normalizer.go
@@ -0,0 +1,249 @@
+package hyperliquid
+
+import (
+	"bytes"
+	"encoding/json"
+	"errors"
+	"fmt"
+	"strings"
+
+	"go-worker/pkg/timeutil"
+)
+
+// Hyperliquid WS message formats (official docs):
+//   - WS endpoint: wss://api.hyperliquid.xyz/ws
+//   - subscribe: {"method":"subscribe","subscription":{"type":"trades"|"l2Book","coin":"BTC"}}
+//   - server sends: {"channel":"trades","data":[...]}
+//                   {"channel":"l2Book","data":{...}}
+//   - keepalive: client may send {"method":"ping"}, server responds {"channel":"pong"}
+// Docs:
+//   https://hyperliquid.gitbook.io/hyperliquid-docs/for-developers/api/websocket
+//   https://hyperliquid.gitbook.io/hyperliquid-docs/for-developers/api/websocket/subscriptions
+
+type envelope struct {
+	Channel string          `json:"channel"`
+	Data    json.RawMessage `json:"data"`
+}
+
+// WsTrade (subscription type: trades)
+type WsTrade struct {
+	Coin string `json:"coin"`
+	Side string `json:"side"` // typically "B" (buy) / "A" (sell)
+	Px   string `json:"px"`
+	Sz   string `json:"sz"`
+	Time int64  `json:"time"` // ms (sometimes seconds in ecosystem) — normalize
+	TID  int64  `json:"tid"`
+}
+
+type WsLevel struct {
+	Px string `json:"px"`
+	Sz string `json:"sz"`
+	N  int    `json:"n"`
+}
+
+// WsBook (subscription type: l2Book) — aggregated L2 snapshot.
+// levels: [bids, asks]
+type WsBook struct {
+	Coin   string      `json:"coin"`
+	Levels [][]WsLevel `json:"levels"`
+	Time   int64       `json:"time"`
+}
+
+// NormalizedTick matches internal/binance.NormalizedTick schema (strict keys).
+// Redis fields:
+//
+//	symbol, ts, price, qty, side, source, market, trade_id, written_at
+type NormalizedTick struct {
+	Symbol  string
+	Ts      int64
+	Price   string
+	Qty     string
+	Side    string
+	Source  string
+	Market  string
+	TradeID int64
+}
+
+func (t NormalizedTick) RedisValues() map[string]any {
+	return map[string]any{
+		"symbol":     strings.ToUpper(t.Symbol),
+		"ts":         t.Ts,
+		"price":      t.Price,
+		"qty":        t.Qty,
+		"side":       t.Side,
+		"source":     t.Source,
+		"market":     t.Market,
+		"trade_id":   t.TradeID,
+		"written_at": timeutil.GetCurrentTimestampMs(),
+	}
+}
+
+// NormalizedDepth matches internal/binance.NormalizedDepth schema (strict keys).
+// Redis fields:
+//
+//	symbol, ts, first_id, final_id, prev_final, bids, asks, source, market, written_at
+type NormalizedDepth struct {
+	Symbol    string
+	Ts        int64
+	FirstID   int64
+	FinalID   int64
+	PrevFinal int64
+	Bids      [][]string
+	Asks      [][]string
+	Source    string
+	Market    string
+}
+
+func (d NormalizedDepth) RedisValues() map[string]any {
+	bidsJSON, err := json.Marshal(d.Bids)
+	if err != nil {
+		bidsJSON = []byte("[]")
+	}
+	asksJSON, err := json.Marshal(d.Asks)
+	if err != nil {
+		asksJSON = []byte("[]")
+	}
+	return map[string]any{
+		"symbol":     strings.ToUpper(d.Symbol),
+		"ts":         d.Ts,
+		"first_id":   d.FirstID,
+		"final_id":   d.FinalID,
+		"prev_final": d.PrevFinal,
+		"bids":       string(bidsJSON),
+		"asks":       string(asksJSON),
+		"source":     d.Source,
+		"market":     d.Market,
+		"written_at": timeutil.GetCurrentTimestampMs(),
+	}
+}
+
+var errEmptyPayload = errors.New("empty hyperliquid payload")
+
+// normalizeEpochMs tries to detect seconds vs millis.
+// If value is below ~2001 in ms-scale, treat it as seconds and convert to ms.
+func normalizeEpochMs(v int64) int64 {
+	if v > 0 && v < 1_000_000_000_000 {
+		return v * 1000
+	}
+	return v
+}
+
+func normalizeSide(raw string) string {
+	s := strings.ToUpper(strings.TrimSpace(raw))
+	switch s {
+	case "B", "BUY":
+		return "BUY"
+	case "A", "SELL":
+		return "SELL"
+	default:
+		if s == "" {
+			return "UNKNOWN"
+		}
+		return s
+	}
+}
+
+func levelsToPairs(levels [][]WsLevel, maxLevels int) (bids [][]string, asks [][]string) {
+	if maxLevels <= 0 {
+		maxLevels = 20
+	}
+	if len(levels) < 2 {
+		return [][]string{}, [][]string{}
+	}
+	for _, lv := range levels[0] {
+		if lv.Px == "" || lv.Sz == "" {
+			continue
+		}
+		bids = append(bids, []string{lv.Px, lv.Sz})
+		if len(bids) >= maxLevels {
+			break
+		}
+	}
+	for _, lv := range levels[1] {
+		if lv.Px == "" || lv.Sz == "" {
+			continue
+		}
+		asks = append(asks, []string{lv.Px, lv.Sz})
+		if len(asks) >= maxLevels {
+			break
+		}
+	}
+	if bids == nil {
+		bids = [][]string{}
+	}
+	if asks == nil {
+		asks = [][]string{}
+	}
+	return bids, asks
+}
+
+// NormalizeWSMessage converts raw WS payload to normalized ticks/books.
+// Output is designed to be compatible with Python worker reading:
+//   - stream:tick_{SYMBOL}
+//   - stream:book_{SYMBOL}
+func NormalizeWSMessage(raw []byte, symbolMap map[string]string, suffix string, maxBookLevels int) (ticks []NormalizedTick, books []NormalizedDepth, err error) {
+	if len(raw) == 0 {
+		return nil, nil, errEmptyPayload
+	}
+
+	var env envelope
+	dec := json.NewDecoder(bytes.NewReader(raw))
+	dec.UseNumber()
+	if err := dec.Decode(&env); err != nil {
+		return nil, nil, fmt.Errorf("decode envelope: %w", err)
+	}
+
+	switch env.Channel {
+	case "trades":
+		var wsTrades []WsTrade
+		if err := json.Unmarshal(env.Data, &wsTrades); err != nil {
+			return nil, nil, fmt.Errorf("decode trades: %w", err)
+		}
+		for _, tr := range wsTrades {
+			sym := normalizeSymbol(tr.Coin, symbolMap, suffix)
+			if sym == "" {
+				continue
+			}
+			ticks = append(ticks, NormalizedTick{
+				Symbol:  sym,
+				Ts:      normalizeEpochMs(tr.Time),
+				Price:   tr.Px,
+				Qty:     tr.Sz,
+				Side:    normalizeSide(tr.Side),
+				Source:  "hyperliquid",
+				Market:  "USDC-PERP",
+				TradeID: tr.TID,
+			})
+		}
+		return ticks, nil, nil
+
+	case "l2Book":
+		var book WsBook
+		if err := json.Unmarshal(env.Data, &book); err != nil {
+			return nil, nil, fmt.Errorf("decode l2Book: %w", err)
+		}
+		sym := normalizeSymbol(book.Coin, symbolMap, suffix)
+		if sym == "" {
+			return nil, nil, nil
+		}
+		bids, asks := levelsToPairs(book.Levels, maxBookLevels)
+		books = append(books, NormalizedDepth{
+			Symbol:    sym,
+			Ts:        normalizeEpochMs(book.Time),
+			FirstID:   0,
+			FinalID:   0,
+			PrevFinal: 0,
+			Bids:      bids,
+			Asks:      asks,
+			Source:    "hyperliquid",
+			Market:    "USDC-PERP",
+		})
+		return nil, books, nil
+
+	case "pong", "subscriptionResponse":
+		return nil, nil, nil
+
+	default:
+		return nil, nil, nil
+	}
+}
