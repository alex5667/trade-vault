+package hyperliquid
+
+import (
+	"os"
+	"reflect"
+	"testing"
+)
+
+func TestParseBaseCoins_FromEnv(t *testing.T) {
+	t.Setenv("HYPERLIQUID_COINS", "btc, ETH ,")
+	got := ParseBaseCoins([]string{"BTCUSDT"})
+	want := []string{"BTC", "ETH"}
+	if !reflect.DeepEqual(got, want) {
+		t.Fatalf("got %v want %v", got, want)
+	}
+}
+
+func TestParseBaseCoins_FromSymbols(t *testing.T) {
+	_ = os.Unsetenv("HYPERLIQUID_COINS")
+	got := ParseBaseCoins([]string{"BTCUSDT", "ETHUSDC", "1000PEPEUSDT"})
+	want := []string{"1000PEPE", "BTC", "ETH"}
+	if !reflect.DeepEqual(got, want) {
+		t.Fatalf("got %v want %v", got, want)
+	}
+}
