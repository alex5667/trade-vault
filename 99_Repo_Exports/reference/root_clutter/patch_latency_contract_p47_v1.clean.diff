+    rules:
+      - alert: OF_LatencyDeployLint_PersistentDriftUnsilenced_Crit
+        expr: latency_contract_deploy_lint_summary_unsilenced_gate_active_total > 0 and latency_contract_deploy_lint_notifier_active > 0
