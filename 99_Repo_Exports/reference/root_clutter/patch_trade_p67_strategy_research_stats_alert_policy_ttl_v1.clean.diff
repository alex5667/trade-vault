+        {
+            'purpose': purpose,
+            'family': family,
+            'ticket': ticket,
+            'operator': operator,
+            'reason': reason,
+            'previous_ticket': existing.get('ticket', ''),
+            'previous_operator': existing.get('operator', ''),
+            'previous_reason': existing.get('reason', ''),
+            'previous_expire_ts_ms': existing.get('expire_ts_ms', ''),
