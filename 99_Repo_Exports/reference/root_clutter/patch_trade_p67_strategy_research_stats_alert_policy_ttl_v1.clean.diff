+    return (os.getenv(name) or default).strip()
+
+
+def _to_int(v: Any, default: int = 0) -> int:
+    try:
+        return int(float(v))
+    except Exception:
+        return default
+
+
+def _now_ms() -> int:
+    return int(time.time() * 1000)
+
+
