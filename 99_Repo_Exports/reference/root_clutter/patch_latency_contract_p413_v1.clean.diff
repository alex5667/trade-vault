@@ -0,0 +1,31 @@
+# P4.13 Semantic approval binding
+
+P4.13 extends deploy-lint override approval binding beyond `error_codes` and
+`active_purposes_hash`.
+
+Additional semantic binding keys:
+- `gate_reason_code`
+- `errors_count`
+- canonical `details_json` fingerprint
+
+`details_json` is built deterministically from the current deploy-lint state:
+- `compose_file`
+- `wrapper_file`
+- `unit_file`
+- `env_file`
+- `missing_runtime_env`
+- `missing_env_file_vars`
+- `warning_codes`
+- `warnings_count`
+
+Operational effect:
+- even fresh dual-control approval is denied at final `ack` if semantic drift
+  changed after prepare/approve
+- approval transitions to `invalidated`
+- operators must run a fresh prepare/approve cycle against the new snapshot
+
+Primary metrics:
+- `latency_contract_deploy_lint_silence_approval_binding_match`
+- `latency_contract_deploy_lint_silence_approval_details_fingerprint_match`
+- `latency_contract_deploy_lint_silence_approval_binding_schema_version`
+- `latency_contract_deploy_lint_summary_dual_control_semantic_binding_mismatch_total`
--- orderflow_services/tests/test_latency_contract_p413_silence_approval_semantic_binding_v1.py
+++ orderflow_services/tests/test_latency_contract_p413_silence_approval_semantic_binding_v1.py
@@ -0,0 +1,159 @@
+
+from orderflow_services import latency_contract_deploy_lint_silence_v1 as mod
+
+
+class FakeRedis:
+    def __init__(self):
+        self.h = {}
+        self.exp = {}
+        self.stream = []
+        self.kv = {}
+    def hgetall(self, k):
+        return dict(self.h.get(k, {}))
+    def hset(self, k, mapping=None, **kwargs):
+        cur = self.h.setdefault(k, {})
+        cur.update(mapping or kwargs)
+    def expire(self, k, ttl):
+        self.exp[k] = ttl
+    def xadd(self, stream, fields, maxlen=None, approximate=None):
+        self.stream.append((stream, dict(fields)))
+        return f"{len(self.stream)}-0"
+    def get(self, k):
+        return self.kv.get(k)
+    def set(self, k, v, ex=None):
+        self.kv[k] = v
+        if ex is not None:
+            self.exp[k] = ex
+
+
+def _cfg() -> mod.Cfg:
+    return mod.Cfg(
+        redis_url='redis://unused',
+        state_prefix='metrics:latency_contract:deploy_lint:last',
+        silence_prefix='cfg:orderflow:latency_contract:deploy_lint:silence',
+        approval_prefix='cfg:orderflow:latency_contract:deploy_lint:silence_approval',
+        ops_stream='ops:latency_contract:events:v1',
+        silence_ttl_s=3600,
+        approval_ttl_s=3600,
+        approval_prepared_freshness_s=60,
+        approval_approved_freshness_s=60,
+        default_minutes=60,
+        policy_window_s=168 * 3600,
+        policy_max_budget_minutes=60,
+        policy_max_acks=1,
+        policy_denied_exit_code=27,
+        dual_control_minutes=45,
+    )
+
+
+def _lint_key(purpose: str) -> str:
+    return f'metrics:latency_contract:deploy_lint:last:{purpose}'
+
+
+def _approve_ready_request(r: FakeRedis, cfg: mod.Cfg, purpose: str) -> str:
+    r.h[_lint_key(purpose)] = {
+        'gate_active': '1',
+        'gate_reason_code': 'persistent_config_drift',
+        'error_codes': 'compose_missing_preflight_wrapper',
+        'errors_count': '1',
+        'warnings_count': '0',
+        'warning_codes': 'none',
+        'compose_file': '/opt/scanner/docker-compose.yml',
+        'wrapper_file': '/opt/scanner/run-wrapper.sh',
+        'unit_file': 'trade.service',
+        'env_file': '/etc/trade.env',
+        'missing_runtime_env': 'none',
+        'missing_env_file_vars': 'none',
+    }
+    mod.cmd_ack(r, cfg, purpose=purpose, operator='alex', ticket='INC-1', reason='known', minutes=30, now_ms=1000)
+    prep = mod.cmd_prepare_override(
+        r,
+        cfg,
+        purpose=purpose,
+        operator='alex',
+        ticket='INC-1',
+        escalation_ticket='SEV-9',
+        reason='need long silence',
+        minutes=45,
+        now_ms=2000,
+    )
+    req_id = prep['request_id']
+    mod.cmd_approve_override(r, cfg, request_id=req_id, operator='bob', reason='approved', now_ms=3000)
+    return req_id
+
+
+def test_ack_invalidates_approval_when_gate_reason_changes() -> None:
+    r = FakeRedis()
+    cfg = _cfg()
+    purpose = 'meta_cov_rollout_controller'
+    req_id = _approve_ready_request(r, cfg, purpose)
+    approval_key = f'cfg:orderflow:latency_contract:deploy_lint:silence_approval:req:{req_id}'
+    r.h[_lint_key(purpose)]['gate_reason_code'] = 'transient_config_drift'
+    out = mod.cmd_ack(
+        r,
+        cfg,
+        purpose=purpose,
+        operator='alex',
+        ticket='INC-1',
+        escalation_ticket='SEV-9',
+        approval_request_id=req_id,
+        reason='bridge approved',
+        minutes=45,
+        now_ms=4000,
+    )
+    assert out['ok'] is False
+    assert out['policy']['denied_reason'] == 'dual_control_drift_binding_mismatch:gate_reason_code'
+    assert r.h[approval_key]['status'] == 'invalidated'
+    assert r.h[approval_key]['invalidated_gate_reason_code'] == 'transient_config_drift'
+
+
+def test_ack_invalidates_approval_when_errors_count_changes() -> None:
+    r = FakeRedis()
+    cfg = _cfg()
+    purpose = 'meta_cov_rollout_controller'
+    req_id = _approve_ready_request(r, cfg, purpose)
+    approval_key = f'cfg:orderflow:latency_contract:deploy_lint:silence_approval:req:{req_id}'
+    r.h[_lint_key(purpose)]['errors_count'] = '2'
+    out = mod.cmd_ack(
+        r,
+        cfg,
+        purpose=purpose,
+        operator='alex',
+        ticket='INC-1',
+        escalation_ticket='SEV-9',
+        approval_request_id=req_id,
+        reason='bridge approved',
+        minutes=45,
+        now_ms=4000,
+    )
+    assert out['ok'] is False
+    assert out['policy']['denied_reason'] == 'dual_control_drift_binding_mismatch:errors_count'
+    assert r.h[approval_key]['status'] == 'invalidated'
+    assert r.h[approval_key]['invalidated_errors_count'] == '2'
+
+
+def test_ack_invalidates_approval_when_details_fingerprint_changes() -> None:
+    r = FakeRedis()
+    cfg = _cfg()
+    purpose = 'meta_cov_rollout_controller'
+    req_id = _approve_ready_request(r, cfg, purpose)
+    approval_key = f'cfg:orderflow:latency_contract:deploy_lint:silence_approval:req:{req_id}'
+    r.h[_lint_key(purpose)]['missing_runtime_env'] = 'BINANCE_API_KEY'
+    out = mod.cmd_ack(
+        r,
+        cfg,
+        purpose=purpose,
+        operator='alex',
+        ticket='INC-1',
+        escalation_ticket='SEV-9',
+        approval_request_id=req_id,
+        reason='bridge approved',
+        minutes=45,
+        now_ms=4000,
+    )
+    assert out['ok'] is False
+    assert out['policy']['denied_reason'] == 'dual_control_drift_binding_mismatch:details_fingerprint'
+    assert r.h[approval_key]['status'] == 'invalidated'
+    status = mod.cmd_status(r, cfg, purpose=purpose, now_ms=4000)['rows'][0]
+    assert status['latest_approval_binding_match'] is False
+    assert status['latest_approval_binding_mismatch_fields'] == ['details_fingerprint']
