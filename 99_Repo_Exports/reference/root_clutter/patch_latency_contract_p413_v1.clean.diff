+def _csv_tokens(value: Any, *, default: str = 'none') -> str:
+    if isinstance(value, (list, tuple)):
+        items = [str(x).strip() for x in value if str(x).strip() and str(x).strip() != 'none']
+    else:
+        raw = _s(value, default)
