+groups:
+  - name: feature_schema_compare_p104
+    rules:
+      - alert: FeatureSchemaCompareExporterDown
+        expr: absent(feature_schema_compare_exporter_up) OR (feature_schema_compare_exporter_up == 0)
+        for: 5m
+        labels:
+          severity: page
+          tier: P104
+          owner: ML
+        annotations:
+          summary: "Feature schema compare exporter is down"
+          description: "Prometheus cannot scrape feature schema compare metrics (feature_schema_compare_exporter_up)."
+
+      - alert: FeatureSchemaCompareStale
+        expr: feature_schema_compare_age_seconds > 129600
+        for: 30m
+        labels:
+          severity: page
+          tier: P104
+          owner: ML
+        annotations:
+          summary: "Feature schema compare report is stale"
+          description: "No successful schema compare update for >36h. Check of_timers_worker schedule and bundle logs."
+
+      - alert: FeatureSchemaCompareFailed
+        expr: (feature_schema_compare_last_success == 0) AND (feature_schema_compare_age_seconds < 21600)
+        for: 15m
+        labels:
+          severity: page
+          tier: P104
+          owner: ML
+        annotations:
+          summary: "Feature schema compare failed"
+          description: "Nightly schema compare bundle failed recently. Inspect metrics:feature_schema_compare:last and report_path."
+
+      - alert: FeatureSchemaCompareAUCRegression
+        expr: (feature_schema_compare_delta_auc < -0.010) AND (feature_schema_compare_age_seconds < 21600)
+        for: 30m
+        labels:
+          severity: warn
+          tier: P104
+          owner: ML
+        annotations:
+          summary: "Schema compare shows AUC regression (delta_auc < -0.010)"
+          description: "schema_b underperforms schema_a on the same window. Do not promote schema_b; review top new features + stability tables."
+
+      - alert: FeatureSchemaCompareBrierRegression
+        expr: (feature_schema_compare_delta_brier > 0.000500) AND (feature_schema_compare_age_seconds < 21600)
+        for: 30m
+        labels:
+          severity: warn
+          tier: P104
+          owner: ML
+        annotations:
+          summary: "Schema compare shows Brier regression (delta_brier > 0.0005)"
+          description: "schema_b increases Brier error vs schema_a (worse calibration). Consider pruning/regularizing new features or increasing min_group_rows."
+
+      - alert: FeatureSchemaCompareNoiseHigh
+        expr: (feature_schema_compare_noise_share{schema=~".*"} > 0.60)
+        for: 2h
+        labels:
+          severity: warn
+          tier: P104
+          owner: ML
+        annotations:
+          summary: "High noise share in schema compare"
+          description: "A large fraction of features are flagged as low-importance or unstable across regimes/hours. Review report.md and stability_table.csv."
