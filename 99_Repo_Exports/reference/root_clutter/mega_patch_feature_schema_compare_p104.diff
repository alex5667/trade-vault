diff -ruN --no-dereference /mnt/data/repo_p104_base/ml_analysis/tools/feature_schema_compare_exporter_v1.py /mnt/data/repo/ml_analysis/tools/feature_schema_compare_exporter_v1.py
--- /mnt/data/repo_p104_base/ml_analysis/tools/feature_schema_compare_exporter_v1.py	1970-01-01 00:00:00.000000000 +0000
+++ /mnt/data/repo/ml_analysis/tools/feature_schema_compare_exporter_v1.py	2026-02-26 10:09:50.696814658 +0000
@@ -0,0 +1,144 @@
+from __future__ import annotations
+
+import os
+import time
+from typing import Dict, Tuple
+
+from fastapi import FastAPI
+from fastapi.responses import PlainTextResponse
+import uvicorn
+
+
+def _env(name: str, default: str = "") -> str:
+    return (os.getenv(name) or default).strip()
+
+
+REDIS_URL = _env("REDIS_URL", "")
+METRICS_KEY = _env("FEATURE_SCHEMA_COMPARE_METRICS_KEY", "metrics:feature_schema_compare:last")
+PORT = int(_env("FEATURE_SCHEMA_COMPARE_EXPORTER_PORT", "9822"))
+
+app = FastAPI()
+
+
+def _read_redis() -> Dict[str, str]:
+    if not REDIS_URL:
+        return {}
+    try:
+        import redis  # type: ignore
+
+        r = redis.Redis.from_url(REDIS_URL)
+        d = r.hgetall(METRICS_KEY)
+        out: Dict[str, str] = {}
+        for k, v in d.items():
+            try:
+                out[k.decode("utf-8")] = v.decode("utf-8")
+            except Exception:
+                pass
+        return out
+    except Exception:
+        return {}
+
+
+def _f(d: Dict[str, str], k: str, default: float = 0.0) -> float:
+    try:
+        return float(d.get(k, str(default)) or default)
+    except Exception:
+        return float(default)
+
+
+def _schema_pair(d: Dict[str, str]) -> Tuple[str, str]:
+    a = (d.get("schema_a") or "v5_of").strip() or "v5_of"
+    b = (d.get("schema_b") or "v6_of").strip() or "v6_of"
+    return a, b
+
+
+@app.get("/metrics")
+def metrics() -> PlainTextResponse:
+    d = _read_redis()
+
+    success = 0.0
+    updated_ts = 0.0
+    age_s = 0.0
+    if d:
+        success = 1.0 if _f(d, "success", 0.0) > 0 else 0.0
+        updated_ts = _f(d, "updated_ts_ms", 0.0)
+    if updated_ts > 0:
+        age_s = max(0.0, (time.time() * 1000.0 - updated_ts) / 1000.0)
+
+    schema_a, schema_b = _schema_pair(d)
+
+    # metrics
+    auc_a = _f(d, "auc_a", 0.0)
+    auc_b = _f(d, "auc_b", 0.0)
+    brier_a = _f(d, "brier_a", 0.0)
+    brier_b = _f(d, "brier_b", 0.0)
+    noise_share_a = _f(d, "noise_share_a", 0.0)
+    noise_share_b = _f(d, "noise_share_b", 0.0)
+    delta_auc = _f(d, "delta_auc", 0.0)
+    delta_brier = _f(d, "delta_brier", 0.0)
+    n_rows = _f(d, "n_rows", 0.0)
+    new_features_n = _f(d, "new_features_n", 0.0)
+    top_new_mean_auc_drop = _f(d, "top_new_mean_auc_drop", 0.0)
+
+    lines = []
+    lines.append("# HELP feature_schema_compare_exporter_up Exporter up")
+    lines.append("# TYPE feature_schema_compare_exporter_up gauge")
+    lines.append("feature_schema_compare_exporter_up 1")
+
+    lines.append("# HELP feature_schema_compare_last_success Last compare bundle success (1/0)")
+    lines.append("# TYPE feature_schema_compare_last_success gauge")
+    lines.append(f"feature_schema_compare_last_success {success}")
+
+    lines.append("# HELP feature_schema_compare_last_updated_ts_ms Last updated timestamp (ms)")
+    lines.append("# TYPE feature_schema_compare_last_updated_ts_ms gauge")
+    lines.append(f"feature_schema_compare_last_updated_ts_ms {updated_ts}")
+
+    lines.append("# HELP feature_schema_compare_age_seconds Age since last update (s)")
+    lines.append("# TYPE feature_schema_compare_age_seconds gauge")
+    lines.append(f"feature_schema_compare_age_seconds {age_s}")
+
+    lines.append("# HELP feature_schema_compare_rows Number of joined rows used")
+    lines.append("# TYPE feature_schema_compare_rows gauge")
+    lines.append(f"feature_schema_compare_rows {n_rows}")
+
+    lines.append("# HELP feature_schema_compare_auc Validation AUC by schema")
+    lines.append("# TYPE feature_schema_compare_auc gauge")
+    lines.append(f'feature_schema_compare_auc{{schema="{schema_a}"}} {auc_a}')
+    lines.append(f'feature_schema_compare_auc{{schema="{schema_b}"}} {auc_b}')
+
+    lines.append("# HELP feature_schema_compare_brier Validation Brier score by schema")
+    lines.append("# TYPE feature_schema_compare_brier gauge")
+    lines.append(f'feature_schema_compare_brier{{schema="{schema_a}"}} {brier_a}')
+    lines.append(f'feature_schema_compare_brier{{schema="{schema_b}"}} {brier_b}')
+
+    lines.append("# HELP feature_schema_compare_noise_share Share of noisy candidates (0..1) by schema")
+    lines.append("# TYPE feature_schema_compare_noise_share gauge")
+    lines.append(f'feature_schema_compare_noise_share{{schema="{schema_a}"}} {noise_share_a}')
+    lines.append(f'feature_schema_compare_noise_share{{schema="{schema_b}"}} {noise_share_b}')
+
+    lines.append("# HELP feature_schema_compare_delta_auc AUC(schema_b) - AUC(schema_a)")
+    lines.append("# TYPE feature_schema_compare_delta_auc gauge")
+    lines.append(f"feature_schema_compare_delta_auc {delta_auc}")
+
+    lines.append("# HELP feature_schema_compare_delta_brier Brier(schema_b) - Brier(schema_a) (negative is good)")
+    lines.append("# TYPE feature_schema_compare_delta_brier gauge")
+    lines.append(f"feature_schema_compare_delta_brier {delta_brier}")
+
+    lines.append("# HELP feature_schema_compare_new_features_n Number of features present in schema_b but not in schema_a")
+    lines.append("# TYPE feature_schema_compare_new_features_n gauge")
+    lines.append(f"feature_schema_compare_new_features_n {new_features_n}")
+
+    lines.append("# HELP feature_schema_compare_top_new_mean_auc_drop Mean perm AUC drop for top new features")
+    lines.append("# TYPE feature_schema_compare_top_new_mean_auc_drop gauge")
+    lines.append(f"feature_schema_compare_top_new_mean_auc_drop {top_new_mean_auc_drop}")
+
+    return PlainTextResponse("\n".join(lines) + "\n", media_type="text/plain; version=0.0.4")
+
+
+@app.get("/healthz")
+def healthz() -> Dict[str, str]:
+    return {"ok": "1"}
+
+
+if __name__ == "__main__":
+    uvicorn.run(app, host="0.0.0.0", port=PORT)
diff -ruN --no-dereference /mnt/data/repo_p104_base/ml_analysis/tools/nightly_feature_schema_compare_bundle_v1.py /mnt/data/repo/ml_analysis/tools/nightly_feature_schema_compare_bundle_v1.py
