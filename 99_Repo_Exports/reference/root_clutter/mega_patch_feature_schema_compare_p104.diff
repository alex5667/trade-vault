+"""Nightly bundle: compare two ML feature schemas via minimal feature-selection loop.
+
+Purpose
+  - Быстро и детерминированно сравнить качество (AUC/Brier) и стабильность фич
+    между schema_a и schema_b (по режимам + по часам UTC).
+  - Используется как smoke/guardrail перед расширением фич-пула (например v5_of -> v6_of).
+
+Pipeline
+  1) Build one dataset window from Redis using *schema_b* (superset expected)
+  2) Run ml_analysis.tools.feature_selection_loop_v1 twice:
+       - on schema_a (subset)
+       - on schema_b
+  3) Compute deltas + "new features" summary
+  4) Publish low-cardinality summary to Redis hash (metrics:feature_schema_compare:last)
+
+Outputs (out_dir)
+  <out_dir>/runs/<run_id>/edge_train.jsonl
+  <out_dir>/runs/<run_id>/schema_a/*
+  <out_dir>/runs/<run_id>/schema_b/*
+  <out_dir>/runs/<run_id>/schema_compare/report.md
+  <out_dir>/runs/<run_id>/schema_compare/compare_summary.json
+
+Redis fields (low-cardinality)
+  success, status, reason, run_id, schema_a, schema_b,
+  n_rows, auc_a, auc_b, brier_a, brier_b,
+  noise_n_a, noise_n_b, noise_share_a, noise_share_b,
+  delta_auc, delta_brier,
+  new_features_n, top_new_mean_auc_drop,
+  out_dir, run_dir, report_path
+"""
+
+from __future__ import annotations
+
+import argparse
+import csv
+import json
+import logging
+import os
+import subprocess
+import sys
+from datetime import datetime
+from typing import Any, Dict, List, Optional, Tuple
+
+from ml_analysis.tools.edge_stack_train_bundle_utils_p59 import atomic_write_json, now_ms, write_train_metrics
+
+
+logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(levelname)s] %(name)s: %(message)s")
+logger = logging.getLogger("nightly_feature_schema_compare_bundle_v1")
+
+
+def _run(module: str, args: list, timeout: int = 3600) -> Tuple[bool, int]:
+    cmd = [sys.executable, "-m", module] + list(args)
+    logger.info("Running: %s", " ".join(cmd))
+    p = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
+    if p.returncode != 0:
+        logger.error("Command failed code=%s\nSTDOUT:%s\nSTDERR:%s", p.returncode, p.stdout, p.stderr)
+    return p.returncode == 0, int(p.returncode)
+
+
+def _load_json(path: str) -> Dict[str, Any]:
+    try:
+        with open(path, "r", encoding="utf-8") as f:
+            obj = json.load(f)
+        return obj if isinstance(obj, dict) else {}
+    except Exception:
+        return {}
+
+
+def _read_stability_table(path: str) -> List[Dict[str, Any]]:
+    rows: List[Dict[str, Any]] = []
+    try:
+        with open(path, "r", encoding="utf-8", newline="") as f:
+            r = csv.DictReader(f)
+            for row in r:
+                if not row:
+                    continue
+                rows.append(dict(row))
+    except Exception:
+        return []
+    return rows
+
+
+def _count_noise(stab_rows: List[Dict[str, Any]]) -> int:
+    n = 0
+    for r in stab_rows:
+        try:
+            if int(float(r.get("flag_noise", "0") or 0)) == 1:
+                n += 1
+        except Exception:
+            continue
+    return int(n)
+
+
+def _top_new_features(
+    *,
+    stab_b: List[Dict[str, Any]],
+    feats_a: set[str],
+    top_k: int = 10,
+) -> Tuple[int, float, List[Tuple[str, float]]]:
+    items: List[Tuple[str, float]] = []
+    for r in stab_b:
+        f = str(r.get("feature") or "").strip()
+        if not f or f in feats_a:
+            continue
+        try:
+            auc_drop = float(r.get("global_perm_auc_drop", "0") or 0.0)
+        except Exception:
+            auc_drop = 0.0
+        items.append((f, float(auc_drop)))
+    items.sort(key=lambda x: (-float(x[1]), x[0]))
+    top = items[: int(top_k)]
+    mean_top = float(sum([x[1] for x in top]) / max(1, len(top)))
+    return int(len(items)), float(mean_top), top
+
+
+def _write_metrics(redis_url: str, metrics_key: str, mapping: Dict[str, Any]) -> None:
+    try:
+        write_train_metrics(str(redis_url), str(metrics_key), mapping)
+    except Exception:
+        return
+
+
+def _fail(
+    *,
+    redis_url: str,
+    metrics_key: str,
+    run_id: str,
+    out_dir: str,
+    run_dir: str,
+    status: str,
+    reason: str,
+    exit_code: int,
+    latest_json: str,
+    version_json: str,
+) -> int:
+    mapping: Dict[str, Any] = {
+        "status": status,
+        "reason": reason,
+        "success": 0,
+        "run_id": run_id,
+        "exit_code": int(exit_code),
+        "updated_ts_ms": now_ms(),
+        "out_dir": str(out_dir),
+        "run_dir": str(run_dir),
+    }
+    _write_metrics(redis_url, metrics_key, mapping)
+    atomic_write_json(version_json, mapping)
+    atomic_write_json(latest_json, mapping)
+    return 2
+
+
+def main(argv: Optional[list] = None) -> int:
+    ap = argparse.ArgumentParser(description="Nightly feature schema compare bundle (P104)")
+    ap.add_argument("--redis_url", default=os.environ.get("REDIS_URL", "redis://redis-worker-1:6379/0"))
+    ap.add_argument(
+        "--metrics_key",
+        default=os.environ.get("FEATURE_SCHEMA_COMPARE_METRICS_KEY", "metrics:feature_schema_compare:last"),
+    )
+
+    ap.add_argument(
+        "--out_dir",
+        default=os.environ.get("FEATURE_SCHEMA_COMPARE_OUT_DIR", "/var/lib/trade/ml_models/feature_schema_compare_p104"),
+    )
+    ap.add_argument("--signals_stream", default=os.environ.get("EDGE_STACK_SIGNALS_STREAM", "signals:of:inputs"))
+    ap.add_argument("--closed_stream", default=os.environ.get("EDGE_STACK_CLOSED_STREAM", "trades:closed"))
+    ap.add_argument("--window_hours", type=int, default=int(os.environ.get("FEATURE_SCHEMA_COMPARE_WINDOW_HOURS", "168")))
+    ap.add_argument("--signals_count", type=int, default=int(os.environ.get("FEATURE_SCHEMA_COMPARE_SIGNALS_COUNT", "250000")))
+    ap.add_argument("--closes_count", type=int, default=int(os.environ.get("FEATURE_SCHEMA_COMPARE_CLOSES_COUNT", "250000")))
+    ap.add_argument("--y_min_r", type=float, default=float(os.environ.get("Y_MIN_R", "0.10")))
+
+    ap.add_argument("--schema_a", default=os.environ.get("FEATURE_SCHEMA_COMPARE_SCHEMA_A", "v5_of"))
+    ap.add_argument("--schema_b", default=os.environ.get("FEATURE_SCHEMA_COMPARE_SCHEMA_B", "v6_of"))
+
+    ap.add_argument("--scenario_prefix", default=os.environ.get("EDGE_STACK_SCENARIO_PREFIX", "bucket:"))
+    ap.add_argument("--include_time_onehot", type=int, default=int(os.environ.get("EDGE_STACK_INCLUDE_TIME_ONEHOT", "1")))
+    ap.add_argument("--strict_feature_cols", type=int, default=int(os.environ.get("ML_STRICT_FEATURE_COLS", "0")))
+    ap.add_argument("--forbid_scenario_v4_onehot", type=int, default=int(os.environ.get("ML_FORBID_SCENARIO_V4_ONEHOT", "0")))
+
+    ap.add_argument("--model", default=os.environ.get("FEATURE_SCHEMA_COMPARE_MODEL", "lr"), choices=["lr", "gbdt"])
+    ap.add_argument("--min_rows", type=int, default=int(os.environ.get("FEATURE_SCHEMA_COMPARE_MIN_ROWS", "4000")))
+    ap.add_argument("--min_group_rows", type=int, default=int(os.environ.get("FEATURE_SCHEMA_COMPARE_MIN_GROUP_ROWS", "300")))
+    ap.add_argument("--n_repeats", type=int, default=int(os.environ.get("FEATURE_SCHEMA_COMPARE_N_REPEATS", "3")))
+    ap.add_argument("--seed", type=int, default=int(os.environ.get("FEATURE_SCHEMA_COMPARE_SEED", "7")))
+    ap.add_argument("--top_new_k", type=int, default=int(os.environ.get("FEATURE_SCHEMA_COMPARE_TOP_NEW_K", "10")))
+
+    args = ap.parse_args(argv)
+
+    run_id = datetime.utcnow().strftime("%Y%m%d_%H%M%S")
+    out_dir = os.path.abspath(str(args.out_dir))
+    run_dir = os.path.join(out_dir, "runs", run_id)
+    os.makedirs(run_dir, exist_ok=True)
+    os.makedirs(os.path.join(out_dir, "versions"), exist_ok=True)
+
+    latest_json = os.path.join(out_dir, "feature_schema_compare_latest.json")
+    version_json = os.path.join(out_dir, "versions", f"feature_schema_compare_{run_id}.json")
+
+    dataset_jsonl = os.path.join(run_dir, "edge_train.jsonl")
+    dataset_report = os.path.join(run_dir, "edge_dataset_report.json")
+    quarantine_jsonl = os.path.join(run_dir, "edge_quarantine.jsonl")
+    feature_cols_json = os.path.join(run_dir, "feature_cols.json")
+
+    a_dir = os.path.join(run_dir, "schema_a")
+    b_dir = os.path.join(run_dir, "schema_b")
+    cmp_dir = os.path.join(run_dir, "schema_compare")
+    os.makedirs(a_dir, exist_ok=True)
+    os.makedirs(b_dir, exist_ok=True)
+    os.makedirs(cmp_dir, exist_ok=True)
+
+    end_ms = now_ms()
+    start_ms = end_ms - int(args.window_hours) * 3600 * 1000
+
+    # Build once using schema_b (expected superset) so schema_a can reuse a subset of columns.
+    build_args = [
+        "--redis_url",
+        str(args.redis_url),
+        "--signal_stream",
+        str(args.signals_stream),
+        "--closed_stream",
+        str(args.closed_stream),
+        "--signals_count",
+        str(args.signals_count),
+        "--closes_count",
+        str(args.closes_count),
+        "--since_ms",
+        str(start_ms),
+        "--until_ms",
+        str(end_ms),
+        "--y_min_r",
+        str(args.y_min_r),
+        "--out_jsonl",
+        dataset_jsonl,
+        "--out_report_json",
+        dataset_report,
+        "--out_quarantine_jsonl",
+        quarantine_jsonl,
+        "--emit_feature_cols_json",
+        feature_cols_json,
+        "--feature_schema_ver",
+        str(args.schema_b).strip(),
+        "--scenario_prefix",
+        str(args.scenario_prefix),
+        "--include_time_onehot",
+        str(int(args.include_time_onehot)),
+        "--strict_feature_cols",
+        str(int(args.strict_feature_cols)),
+        "--forbid_scenario_v4_onehot",
+        str(int(args.forbid_scenario_v4_onehot)),
+    ]
+    ok_build, rc_build = _run("ml_analysis.tools.build_edge_stack_dataset_from_redis", build_args, timeout=3600)
+    if (not ok_build) or (not os.path.exists(dataset_report)):
+        return _fail(
+            redis_url=str(args.redis_url),
+            metrics_key=str(args.metrics_key),
+            run_id=run_id,
+            out_dir=out_dir,
+            run_dir=run_dir,
+            status="fail_build",
+            reason="dataset_build_failed",
+            exit_code=rc_build,
+            latest_json=latest_json,
+            version_json=version_json,
+        )
+
+    rep = _load_json(dataset_report)
+    joined = int(rep.get("joined", 0) or 0)
+    if joined < int(args.min_rows):
+        return _fail(
+            redis_url=str(args.redis_url),
+            metrics_key=str(args.metrics_key),
+            run_id=run_id,
+            out_dir=out_dir,
+            run_dir=run_dir,
+            status="fail_validate",
+            reason=f"too_few_rows joined={joined} min_rows={int(args.min_rows)}",
+            exit_code=3,
+            latest_json=latest_json,
+            version_json=version_json,
+        )
+
+    def _run_loop(schema_ver: str, out_dir_loop: str) -> Tuple[bool, int, str, str]:
+        loop_args = [
+            "--data_path",
+            dataset_jsonl,
+            "--schema_ver",
+            str(schema_ver),
+            "--out_dir",
+            out_dir_loop,
+            "--model",
+            str(args.model),
+            "--min_group_rows",
+            str(int(args.min_group_rows)),
+            "--n_repeats",
+            str(int(args.n_repeats)),
+            "--seed",
+            str(int(args.seed)),
+        ]
+        ok, rc = _run("ml_analysis.tools.feature_selection_loop_v1", loop_args, timeout=3600)
+        return ok, rc, os.path.join(out_dir_loop, "summary.json"), os.path.join(out_dir_loop, "stability_table.csv")
+
+    ok_a, rc_a, summary_a_path, stab_a_path = _run_loop(str(args.schema_a).strip(), a_dir)
+    if (not ok_a) or (not os.path.exists(summary_a_path)):
+        return _fail(
+            redis_url=str(args.redis_url),
+            metrics_key=str(args.metrics_key),
+            run_id=run_id,
+            out_dir=out_dir,
+            run_dir=run_dir,
+            status="fail_loop_a",
+            reason="feature_selection_loop_failed schema_a",
+            exit_code=rc_a,
+            latest_json=latest_json,
+            version_json=version_json,
+        )
+
+    ok_b, rc_b, summary_b_path, stab_b_path = _run_loop(str(args.schema_b).strip(), b_dir)
+    if (not ok_b) or (not os.path.exists(summary_b_path)):
+        return _fail(
+            redis_url=str(args.redis_url),
+            metrics_key=str(args.metrics_key),
+            run_id=run_id,
+            out_dir=out_dir,
+            run_dir=run_dir,
+            status="fail_loop_b",
+            reason="feature_selection_loop_failed schema_b",
+            exit_code=rc_b,
+            latest_json=latest_json,
+            version_json=version_json,
+        )
+
+    s_a = _load_json(summary_a_path)
+    s_b = _load_json(summary_b_path)
+
+    stab_a = _read_stability_table(stab_a_path)
+    stab_b = _read_stability_table(stab_b_path)
+    feats_a = set([str(r.get("feature") or "") for r in stab_a if str(r.get("feature") or "").strip()])
+
+    noise_n_a = _count_noise(stab_a)
+    noise_n_b = _count_noise(stab_b)
+
+    n_feat_a = int(s_a.get("n_features", 0) or 0)
+    n_feat_b = int(s_b.get("n_features", 0) or 0)
+    auc_a = float(s_a.get("auc_val", 0.0) or 0.0)
+    auc_b = float(s_b.get("auc_val", 0.0) or 0.0)
+    brier_a = float(s_a.get("brier_val", 0.0) or 0.0)
+    brier_b = float(s_b.get("brier_val", 0.0) or 0.0)
+
+    noise_share_a = float(noise_n_a) / float(max(1, n_feat_a))
+    noise_share_b = float(noise_n_b) / float(max(1, n_feat_b))
+
+    new_n, top_new_mean, top_new = _top_new_features(stab_b=stab_b, feats_a=feats_a, top_k=int(args.top_new_k))
+
+    delta_auc = float(auc_b - auc_a)
+    delta_brier = float(brier_b - brier_a)
+
+    report_path = os.path.join(cmp_dir, "report.md")
+    compare_json = os.path.join(cmp_dir, "compare_summary.json")
+
+    compare_summary: Dict[str, Any] = {
+        "ts": int(now_ms()),
+        "run_id": run_id,
+        "schema_a": str(args.schema_a),
+        "schema_b": str(args.schema_b),
+        "n_rows": int(joined),
+        "auc_a": float(auc_a),
+        "auc_b": float(auc_b),
+        "brier_a": float(brier_a),
+        "brier_b": float(brier_b),
+        "delta_auc": float(delta_auc),
+        "delta_brier": float(delta_brier),
+        "n_features_a": int(n_feat_a),
+        "n_features_b": int(n_feat_b),
+        "noise_n_a": int(noise_n_a),
+        "noise_n_b": int(noise_n_b),
+        "noise_share_a": float(noise_share_a),
+        "noise_share_b": float(noise_share_b),
+        "new_features_n": int(new_n),
+        "top_new_mean_auc_drop": float(top_new_mean),
+        "top_new_features": [{"feature": k, "auc_drop": float(v)} for (k, v) in top_new],
+        "schema_hash_a": str(s_a.get("schema_hash", "")),
+        "schema_hash_b": str(s_b.get("schema_hash", "")),
+        "summary_a_path": summary_a_path,
+        "summary_b_path": summary_b_path,
+        "report_a_path": os.path.join(a_dir, "report.md"),
+        "report_b_path": os.path.join(b_dir, "report.md"),
+    }
+    atomic_write_json(compare_json, compare_summary)
+
+    with open(report_path, "w", encoding="utf-8") as f:
+        f.write("# Feature schema compare (P104)\n\n")
+        f.write(f"schema_a=**{args.schema_a}**  hash={str(s_a.get('schema_hash',''))[:16]}…\n\n")
+        f.write(f"schema_b=**{args.schema_b}**  hash={str(s_b.get('schema_hash',''))[:16]}…\n\n")
+        f.write(f"Rows(joined): **{joined}**\n\n")
+        f.write("## Quality (val)\n\n")
+        f.write("|schema|AUC|Brier|noise_n|noise_share|\n|---|---:|---:|---:|---:|\n")
+        f.write(
+            f"|{args.schema_a}|{auc_a:.4f}|{brier_a:.6f}|{noise_n_a}|{noise_share_a:.3f}|\n"
+        )
+        f.write(
+            f"|{args.schema_b}|{auc_b:.4f}|{brier_b:.6f}|{noise_n_b}|{noise_share_b:.3f}|\n\n"
+        )
+        f.write(f"Delta: **delta_auc={delta_auc:+.4f}**, **delta_brier={delta_brier:+.6f}** (neg brier is good)\n\n")
+
+        f.write("## New features in schema_b\n\n")
+        f.write(f"count={new_n}  top{int(args.top_new_k)} mean_auc_drop={top_new_mean:.6f}\n\n")
+        f.write("|rank|feature|perm_auc_drop|\n|---:|---|---:|\n")
+        for i, (k, v) in enumerate(top_new, start=1):
+            f.write(f"|{i}|{k}|{float(v):.6f}|\n")
+        f.write("\n")
+        f.write("## Detailed reports\n\n")
+        f.write(f"- schema_a report: `{os.path.join(a_dir, 'report.md')}`\n")
+        f.write(f"- schema_b report: `{os.path.join(b_dir, 'report.md')}`\n")
+        f.write(f"- compare summary: `{compare_json}`\n")
+
+    mapping: Dict[str, Any] = {
+        "status": "ok",
+        "reason": "ok",
+        "success": 1,
+        "run_id": run_id,
+        "schema_a": str(args.schema_a),
+        "schema_b": str(args.schema_b),
+        "n_rows": int(joined),
+        "auc_a": float(auc_a),
+        "auc_b": float(auc_b),
+        "brier_a": float(brier_a),
+        "brier_b": float(brier_b),
+        "noise_n_a": int(noise_n_a),
+        "noise_n_b": int(noise_n_b),
+        "noise_share_a": float(noise_share_a),
+        "noise_share_b": float(noise_share_b),
+        "delta_auc": float(delta_auc),
+        "delta_brier": float(delta_brier),
+        "new_features_n": int(new_n),
+        "top_new_mean_auc_drop": float(top_new_mean),
+        "out_dir": str(out_dir),
+        "run_dir": str(run_dir),
+        "report_path": str(report_path),
+    }
+    _write_metrics(str(args.redis_url), str(args.metrics_key), mapping)
+    atomic_write_json(version_json, mapping)
+    atomic_write_json(latest_json, mapping)
+    logger.info("OK: wrote metrics_key=%s", str(args.metrics_key))
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
