+from pathlib import Path
+import importlib.util
+import sys
+
+root = Path(__file__).resolve().parents[2]
+if str(root) not in sys.path:
+    sys.path.insert(0, str(root))
+
+mod_path = root / "services" / "binance_executor.py"
+spec = importlib.util.spec_from_file_location("services.binance_executor_p3", mod_path)
+mod = importlib.util.module_from_spec(spec)
+sys.modules[spec.name] = mod
+assert spec.loader is not None
+spec.loader.exec_module(mod)
+
+
+class DummyFilters:
+    def get(self, symbol):
+        return type("F", (), {"step_size": 0.001, "tick_size": 0.1})()
+
+
+class DummyPolicy:
+    name = "SAFETY_FIRST"
+    reason = "test"
+    tp_watchdog_enabled = False
+    tp_working_type = "MARK_PRICE"
+    tp_limit_time_in_force = "GTX"
+
+
+class DummyClient:
+    def __init__(self):
+        self.cancelled = []
+    def cancel_all_orders(self, symbol):
+        self.cancelled.append((symbol, "all"))
+    def get_mark_price(self, symbol):
+        return 100.0
+
+
+def _mk_exec_for_replace(repair_result):
+    ex = mod.BinanceExecutor.__new__(mod.BinanceExecutor)
+    ex.position_mode = "oneway"
+    ex.protection_replace_max_naked_ms = 5000
+    ex.exec_modify_resize_strict_replace = True
+    ex._transition_log = []
+    ex._transition_state = lambda sid, **kwargs: ex._transition_log.append(kwargs["next_state"]) or {"fsm_state": kwargs["next_state"]}
+    ex._cancel_expected_protection_refs = lambda **kwargs: [mod._make_cid(kwargs["sid"], "sl")]
+    ex._repair_open_protection = lambda **kwargs: dict(repair_result)
+    ex._read_live_position = lambda **kwargs: {"is_open": True, "qty": 2.0, "logical_side": "LONG", "position_amt": 2.0}
+    ex._maybe_start_trailing_after_tp1 = lambda **kwargs: {}
+    ex._emit_protection_incident = lambda *args, **kwargs: None
+    ex._emergency_flatten_position = lambda **kwargs: {"emergency_order_id": 91, "emergency_reason": kwargs.get("reason", "")}
+    return ex
+
+
+def test_replace_position_protection_transitions_via_replacing_then_protected():
+    ex = _mk_exec_for_replace({"is_complete": True, "sl_algo_id": 11, "tp1_algo_id": 12, "repair_actions": ["replace_sl", "replace_tp1"]})
+    out = ex._replace_position_protection(
+        sid="sid-p3-ok",
+        symbol="BTCUSDT",
+        action="modify",
+        logical_side="LONG",
+        live_qty=2.0,
+        sl=95.0,
+        tps=[110.0],
+        payload={"trail_after_tp1": False},
+        policy=DummyPolicy(),
+        client=DummyClient(),
+        filters=DummyFilters(),
+        ref_price=100.0,
+    )
+    assert out["protection_replaced"] is True
+    assert mod.FSM_PROTECTION_REPLACING in ex._transition_log
+    assert mod.FSM_PROTECTED in ex._transition_log
+    assert mod.FSM_EMERGENCY_FLATTENED not in ex._transition_log
+
+
+def test_replace_position_protection_flattens_when_verify_incomplete():
