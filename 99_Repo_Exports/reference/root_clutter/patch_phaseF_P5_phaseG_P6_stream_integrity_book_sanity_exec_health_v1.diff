+import unittest
+
+from services.orderflow.book_sanity import check_book_sanity, trade_outside_bbo
+
+
+class TestBookSanityP5(unittest.TestCase):
+    def test_ok_book(self):
+        book = {
+            "best_bid_px": 100.0,
+            "best_ask_px": 101.0,
+            "bids": [[100.0, 1.0], [99.5, 2.0]],
+            "asks": [[101.0, 1.5], [101.5, 3.0]],
+        }
+        res = check_book_sanity(book=book)
+        self.assertTrue(res.ok)
+        self.assertEqual(res.flags, [])
+
+    def test_crossed_book(self):
+        book = {
+            "best_bid_px": 101.0,
+            "best_ask_px": 101.0,
+            "bids": [[101.0, 1.0]],
+            "asks": [[101.0, 1.0]],
+        }
+        res = check_book_sanity(book=book)
+        self.assertFalse(res.ok)
+        self.assertIn("crossed_bbo", res.flags)
+
+    def test_trade_outside_bbo(self):
+        outside, dist = trade_outside_bbo(trade_px=103.0, best_bid=100.0, best_ask=101.0, eps_bps=1.0)
+        self.assertTrue(outside)
+        self.assertGreater(dist, 0.0)
+
+        outside2, dist2 = trade_outside_bbo(trade_px=101.0, best_bid=100.0, best_ask=101.0, eps_bps=1.0)
+        self.assertFalse(outside2)
+        self.assertEqual(dist2, 0.0)
+
+
+if __name__ == "__main__":
+    unittest.main()
