+import unittest
+
+from services.orderflow.execution_health_gate import (
+    ExecHealthThresholds,
+    decide_execution_health,
+    apply_exec_health_to_indicators,
+)
+
+
+class TestExecutionHealthGateP6(unittest.TestCase):
+    def test_monitor_mode_flags(self):
+        thr = ExecHealthThresholds(max_is_p95_bps=5.0, max_perm_impact_p95_bps=3.0, min_realized_spread_p50_bps=-1.0)
+        roll = {"is_p95_bps": 6.0, "perm_impact_p95_bps_1": 4.0, "realized_spread_p50_bps_1": -2.0}
+
+        # Force monitor via env by not touching env; decision uses _mode() which defaults to auto.
+        # We only assert flags are present and decision is applied.
+        dec = decide_execution_health(rollups=roll, thr=thr)
+        self.assertTrue(dec.apply)
+        self.assertTrue(len(dec.flags) >= 1)
+
+    def test_apply_tighten_adds_slippage(self):
+        thr = ExecHealthThresholds(max_is_p95_bps=5.0, max_perm_impact_p95_bps=3.0)
+        roll = {"is_p95_bps": 10.0, "perm_impact_p95_bps_1": 6.0}
+        dec = decide_execution_health(rollups=roll, thr=thr)
+
+        ind = {"expected_slippage_bps": 2.0}
+        apply_exec_health_to_indicators(indicators=ind, dec=dec)
+        self.assertIn("exec_health_apply", ind)
+        self.assertIn("exec_health_veto", ind)
+        self.assertIn("exec_health_flags", ind)
+        self.assertGreaterEqual(ind.get("expected_slippage_bps", 0.0), 2.0)
+
+
+if __name__ == "__main__":
+    unittest.main()
