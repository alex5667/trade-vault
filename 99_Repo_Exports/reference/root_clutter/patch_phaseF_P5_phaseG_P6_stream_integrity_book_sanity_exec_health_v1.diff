+
+        # Gap
+        s_gap = tr.update_seq(seq=10, ts_ms=2000)
+        self.assertEqual(s_gap.gap_last, 10 - 5 - 1)
+        self.assertGreaterEqual(s_gap.gap_max_window, 4)
+        self.assertTrue(0.0 <= s_gap.gap_rate_ema <= 1.0)
+
+        # Duplicate
+        s_dup = tr.update_seq(seq=10, ts_ms=3000)
+        self.assertTrue(0.0 <= s_dup.dup_rate_ema <= 1.0)
+
