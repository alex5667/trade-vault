+        dq_veto=1,
+        dq_reason_bucket="tick_seq",
+        dq_reasons=["tick_seq_hard"],
+        uptime_sec=0,
+        cfg={},
+    )
+    assert out.dq_veto == 1
+    assert out.suppressed is False
