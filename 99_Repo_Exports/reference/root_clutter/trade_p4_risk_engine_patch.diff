+    rules:
+      - alert: TradeRiskForceFlatten
+        expr: increase(trade_risk_force_flatten_total[5m]) > 0
+        for: 0m
+        labels:
+          severity: critical
+        annotations:
+          summary: Trade risk engine requested force flatten
+      - alert: TradeRiskDenySpike
+        expr: increase(trade_risk_deny_total[10m]) > 10
+        for: 5m
+        labels:
+          severity: warning
+        annotations:
+          summary: Trade risk engine denials are spiking
+      - alert: TradePortfolioExposureHigh
+        expr: trade_portfolio_total_exposure_ratio > 2.0
+        for: 5m
+        labels:
+          severity: warning
