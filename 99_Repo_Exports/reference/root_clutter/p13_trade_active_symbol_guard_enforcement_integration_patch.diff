+from pathlib import Path
+import sys
+ROOT = Path(__file__).resolve().parents[2]
+if str(ROOT) not in sys.path:
+    sys.path.insert(0, str(ROOT))
+
+from services.active_symbol_guard_incident_notifier import ActiveSymbolGuardIncidentNotifier
+
+
+class FakeRedis:
+    def __init__(self):
+        self.events = []
+    def xadd(self, stream, fields, maxlen=None, approximate=True):
+        self.events.append((stream, fields))
+        return '1-0'
+    def set(self, key, value, ex=None):
+        return True
+
+
+class StubDiag:
+    def snapshot(self):
+        return {'guards': [{'symbol': 'BTCUSDT', 'classification': 'pending_release'}], 'heatmap': {'top_hot_symbols': {'5m': [], '1h': []}}, 'cas_conflict_hot_symbols': [], 'resurrection_hot_symbols': []}
+    def operator_dashboard(self, limit=100):
+        return {'active_holds': [], 'active_acks': []}
+
+
+class StubPolicy:
+    def triage_symbol(self, symbol, include_exchange=True):
+        return {'summary': {'symbol': symbol, 'severity': 'warning'}, 'policy': {'decision': 'renew_reminder', 'should_notify': True, 'fingerprint': 'fp-1'}, 'telegram_text': 'renew me'}
+    def telegram_stream_fields(self, triaged):
+        return {'symbol': triaged['summary']['symbol'], 'text': triaged['telegram_text']}
+    def mark_notified(self, triaged, channel, result='sent'):
+        pass
+
+
+def test_notifier_sends_renew_reminder_incident():
+    r = FakeRedis()
+    notifier = ActiveSymbolGuardIncidentNotifier(r, StubDiag(), StubPolicy())
+    result = notifier.run_once()
+    assert result['sent'][0]['decision'] == 'renew_reminder'
+    assert r.events[0][0] == 'notify:telegram'
