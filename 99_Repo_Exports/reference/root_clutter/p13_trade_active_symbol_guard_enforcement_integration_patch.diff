@@ -0,0 +1,55 @@
+from pathlib import Path
+import sys
+ROOT = Path(__file__).resolve().parents[2]
+if str(ROOT) not in sys.path:
+    sys.path.insert(0, str(ROOT))
+
+import json
+
+from services.active_symbol_guard_diagnostics import ActiveSymbolGuardDiagnostics
+from services.active_symbol_guard_runbook import ActiveSymbolGuardRunbookExecutor
+
+
+class FakeRedis:
+    def __init__(self):
+        self.kv = {}
+        self.streams = {}
+        self._id = 0
+    def get(self, key):
+        return self.kv.get(key)
+    def set(self, key, value, ex=None):
+        self.kv[key] = value
+        return True
+    def delete(self, key):
+        return 1 if self.kv.pop(key, None) is not None else 0
+    def keys(self, pattern):
+        prefix = pattern[:-1] if pattern.endswith('*') else pattern
+        return [k for k in self.kv if str(k).startswith(prefix)]
+    def scan_iter(self, pattern):
+        for k in self.keys(pattern):
+            yield k
+    def xadd(self, stream, fields, maxlen=None, approximate=True):
+        self._id += 1
+        sid = f'{self._id}-0'
+        self.streams.setdefault(stream, []).append((sid, dict(fields)))
+        return sid
+    def xrevrange(self, stream, count=10):
+        return list(reversed(self.streams.get(stream, [])))[:count]
+    def xrange(self, stream, count=10):
+        return self.streams.get(stream, [])[:count]
+
+
+def test_runbook_dashboard_and_ticket_history_are_linked():
+    r = FakeRedis()
+    # active guard doc for symbol so diagnostics has something to read
+    r.set('orders:active_symbol_sid:BTCUSDT', json.dumps({'symbol': 'BTCUSDT', 'sid': 'sid-1', 'guard_status': 'active', 'updated_at_ms': 1}))
+    diag = ActiveSymbolGuardDiagnostics(r)
+    rb = ActiveSymbolGuardRunbookExecutor(r, diagnostics=diag)
+    rb.apply_hold_symbol(symbol='BTCUSDT', operator='alice', ticket='INC-77', reason='investigate', ttl_sec=600)
+    rb.escalation_ack(symbol='BTCUSDT', fingerprint='fp-1', operator='alice', ticket='INC-77', reason='owned', ttl_sec=600)
+    dash = rb.runbook_dashboard()
+    assert dash['active_holds'][0]['symbol'] == 'BTCUSDT'
+    assert dash['active_acks'][0]['ticket'] == 'INC-77'
+    state = rb.runbook_state_symbol('BTCUSDT')
+    assert state['ticket_history'][0]['ticket'] == 'INC-77'
+    assert len(state['runbook_history']) >= 2
