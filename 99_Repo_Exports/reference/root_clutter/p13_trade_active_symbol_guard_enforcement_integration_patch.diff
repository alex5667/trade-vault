+from __future__ import annotations
+
+import json
+import os
+import time
+from collections import Counter
+from typing import Any, Dict, Iterable, List, Optional
+
+try:  # pragma: no cover
+    from services.active_symbol_guard_diagnostics import ActiveSymbolGuardDiagnostics
+    from services.active_symbol_guard_incident_policy import ActiveSymbolGuardIncidentPolicyEngine
+    from services.active_symbol_guard_semantics import guard_view
+    from services.active_symbol_guard_store import ActiveSymbolGuardStore
+    from services.binance_futures_client import BinanceFuturesClient
+    from services.execution_metrics import (
+        EXECUTION_ACTIVE_SYMBOL_GUARD_RUNBOOK_ACTION_TOTAL,
+        EXECUTION_ACTIVE_SYMBOL_GUARD_RUNBOOK_AUDIT_TOTAL,
+        EXECUTION_ACTIVE_SYMBOL_GUARD_RUNBOOK_STATE_TOTAL,
+    )
+except Exception:  # pragma: no cover
+    from active_symbol_guard_diagnostics import ActiveSymbolGuardDiagnostics  # type: ignore
+    from active_symbol_guard_incident_policy import ActiveSymbolGuardIncidentPolicyEngine  # type: ignore
+    from active_symbol_guard_semantics import guard_view  # type: ignore
+    from active_symbol_guard_store import ActiveSymbolGuardStore  # type: ignore
+    from binance_futures_client import BinanceFuturesClient  # type: ignore
+    from execution_metrics import (  # type: ignore
+        EXECUTION_ACTIVE_SYMBOL_GUARD_RUNBOOK_ACTION_TOTAL,
+        EXECUTION_ACTIVE_SYMBOL_GUARD_RUNBOOK_AUDIT_TOTAL,
+        EXECUTION_ACTIVE_SYMBOL_GUARD_RUNBOOK_STATE_TOTAL,
+    )
+
+
+def _ms_now() -> int:
+    return int(time.time() * 1000)
+
+
+def _i(v: Any, default: int = 0) -> int:
+    try:
+        return int(float(v))
+    except Exception:
+        return int(default)
+
+
+def _f(v: Any, default: float = 0.0) -> float:
+    try:
+        return float(v)
+    except Exception:
+        return float(default)
+
+
+def _normalize(obj: Any) -> Any:
+    if isinstance(obj, bytes):
+        return obj.decode("utf-8", errors="replace")
+    if isinstance(obj, dict):
+        return {str(_normalize(k)): _normalize(v) for k, v in obj.items()}
+    if isinstance(obj, list):
+        return [_normalize(x) for x in obj]
+    return obj
+
+
+class ActiveSymbolGuardRunbookExecutor:
+    def __init__(
+        self,
+        redis_client: Any,
+        diagnostics: Optional[ActiveSymbolGuardDiagnostics] = None,
+        policy: Optional[ActiveSymbolGuardIncidentPolicyEngine] = None,
+        store: Optional[ActiveSymbolGuardStore] = None,
+        client: Optional[BinanceFuturesClient] = None,
+        *,
+        hold_ttl_sec: Optional[int] = None,
+        escalation_ack_ttl_sec: Optional[int] = None,
+        audit_stream: str = "orders:active_symbol_guard:audit",
+        hold_key_prefix: str = "orders:active_symbol_guard:hold:symbol:",
+        escalation_key_prefix: str = "orders:active_symbol_guard:incident:ack:",
+    ) -> None:
+        self.r = redis_client
+        self.diagnostics = diagnostics
+        self.policy = policy
+        self.store = store or ActiveSymbolGuardStore(redis_client)
+        self.client = client
+        self.hold_ttl_sec = max(int(hold_ttl_sec or os.getenv("ACTIVE_SYMBOL_GUARD_RUNBOOK_HOLD_TTL_SEC", "1800")), 1)
+        self.escalation_ack_ttl_sec = max(int(escalation_ack_ttl_sec or os.getenv("ACTIVE_SYMBOL_GUARD_ESCALATION_ACK_TTL_SEC", "1800")), 1)
+        self.audit_stream = str(audit_stream or "orders:active_symbol_guard:audit")
+        self.hold_key_prefix = str(hold_key_prefix or "orders:active_symbol_guard:hold:symbol:")
+        self.escalation_key_prefix = str(escalation_key_prefix or "orders:active_symbol_guard:incident:ack:")
+
+    def _hold_key(self, symbol: str) -> str:
+        return f"{self.hold_key_prefix}{str(symbol or '').strip().upper()}"
+
+    def _escalation_key(self, fingerprint: str) -> str:
+        return f"{self.escalation_key_prefix}{str(fingerprint or '').strip()}"
+
+    def _json_get(self, key: str) -> Dict[str, Any]:
+        try:
+            raw = self.r.get(key)
+            doc = json.loads(raw) if raw else {}
+            return doc if isinstance(doc, dict) else {}
+        except Exception:
+            return {}
+
+    def _json_set(self, key: str, doc: Dict[str, Any], ttl_sec: int) -> None:
+        self.r.set(key, json.dumps(doc, ensure_ascii=False, default=str), ex=max(int(ttl_sec), 1))
+
+    def _metric(self, *, action: str, result: str) -> None:
+        try:
+            if EXECUTION_ACTIVE_SYMBOL_GUARD_RUNBOOK_ACTION_TOTAL is not None:
+                EXECUTION_ACTIVE_SYMBOL_GUARD_RUNBOOK_ACTION_TOTAL.labels(action=str(action or ""), result=str(result or "")).inc()
+        except Exception:
+            pass
+
+    def _audit(self, **kwargs: Any) -> None:
+        fields = {k: (json.dumps(v, ensure_ascii=False, default=str) if isinstance(v, (dict, list)) else str(v)) for k, v in kwargs.items()}
+        fields["ts_ms"] = str(_ms_now())
+        try:
+            self.r.xadd(self.audit_stream, fields, maxlen=100000, approximate=True)
+        except Exception:
+            try:
+                self.r.xadd(self.audit_stream, fields)
+            except Exception:
+                pass
+        try:
+            if EXECUTION_ACTIVE_SYMBOL_GUARD_RUNBOOK_AUDIT_TOTAL is not None:
+                EXECUTION_ACTIVE_SYMBOL_GUARD_RUNBOOK_AUDIT_TOTAL.labels(action=str(kwargs.get("action") or ""), result=str(kwargs.get("result") or "")).inc()
+        except Exception:
+            pass
+
+    def _iter_prefix_keys(self, prefix: str) -> List[str]:
+        out: List[str] = []
+        pattern = f"{prefix}*"
+        try:
+            if hasattr(self.r, "scan_iter"):
+                out.extend([str(_normalize(k)) for k in self.r.scan_iter(pattern)])
+            elif hasattr(self.r, "keys"):
+                out.extend([str(_normalize(k)) for k in (self.r.keys(pattern) or [])])
+        except Exception:
+            pass
+        return sorted(set([k for k in out if k.startswith(prefix)]))
+
+    def _stream_entries(self, *, limit: int = 50) -> List[Dict[str, Any]]:
+        items: Iterable[Any] = []
+        try:
+            if hasattr(self.r, "xrevrange"):
+                items = self.r.xrevrange(self.audit_stream, count=max(int(limit), 1)) or []
+            elif hasattr(self.r, "xrange"):
+                raw = self.r.xrange(self.audit_stream, count=max(int(limit), 1)) or []
+                items = list(reversed(raw))
+        except Exception:
+            items = []
+        out: List[Dict[str, Any]] = []
+        for item in items:
+            try:
+                entry_id, fields = item
+                doc = _normalize(fields)
+                if not isinstance(doc, dict):
+                    continue
+                doc["stream_id"] = str(_normalize(entry_id))
+                if "payload" in doc and isinstance(doc.get("payload"), str):
+                    try:
+                        doc["payload_json"] = json.loads(str(doc.get("payload") or "{}"))
+                    except Exception:
+                        doc["payload_json"] = {}
+                out.append(doc)
+            except Exception:
+                continue
+        return out
+
+    def audit_history(
+        self,
+        *,
+        symbol: str = "",
+        sid: str = "",
+        ticket: str = "",
+        operator: str = "",
+        action: str = "",
+        limit: int = 50,
+    ) -> List[Dict[str, Any]]:
+        symbol = str(symbol or "").strip().upper()
+        sid = str(sid or "").strip()
+        ticket = str(ticket or "").strip()
+        operator = str(operator or "").strip()
+        action = str(action or "").strip()
+        out: List[Dict[str, Any]] = []
+        for doc in self._stream_entries(limit=max(int(limit or 50) * 5, 50)):
+            payload_json = dict(doc.get("payload_json") or {})
+            doc_symbol = str(doc.get("symbol") or payload_json.get("symbol") or "").strip().upper()
+            doc_sid = str(doc.get("sid") or payload_json.get("sid") or payload_json.get("state", {}).get("sid") or "").strip()
+            doc_ticket = str(doc.get("ticket") or payload_json.get("ticket") or payload_json.get("renew_ticket") or "").strip()
+            doc_operator = str(doc.get("operator") or payload_json.get("operator") or payload_json.get("acked_by") or payload_json.get("renewed_by") or "").strip()
+            doc_action = str(doc.get("action") or "").strip()
+            if symbol and doc_symbol != symbol:
+                continue
+            if sid and doc_sid != sid:
+                continue
+            if ticket and doc_ticket != ticket:
+                continue
+            if operator and doc_operator != operator:
+                continue
+            if action and doc_action != action:
+                continue
+            doc["symbol"] = doc_symbol
+            if doc_sid:
+                doc["sid"] = doc_sid
+            if doc_ticket:
+                doc["ticket"] = doc_ticket
+            if doc_operator:
+                doc["operator"] = doc_operator
+            out.append(doc)
+            if len(out) >= max(int(limit or 50), 1):
+                break
+        return out
+
+    def linked_tickets(self, *, symbol: str = "", sid: str = "", limit: int = 20) -> List[Dict[str, Any]]:
+        counts: Counter[str] = Counter()
+        latest: Dict[str, Dict[str, Any]] = {}
+        for doc in self.audit_history(symbol=symbol, sid=sid, limit=max(int(limit or 20) * 5, 50)):
+            ticket = str(doc.get("ticket") or "").strip()
+            if not ticket:
+                continue
+            counts[ticket] += 1
+            latest[ticket] = {
+                "ticket": ticket,
+                "last_action": str(doc.get("action") or ""),
+                "last_operator": str(doc.get("operator") or ""),
+                "last_ts_ms": _i(doc.get("ts_ms"), 0),
+            }
+        out = []
+        for ticket, count in counts.most_common(max(int(limit or 20), 1)):
+            item = dict(latest.get(ticket) or {})
+            item["count"] = int(count)
+            out.append(item)
+        return out
+
+    def hold_state(self, symbol: str) -> Dict[str, Any]:
+        symbol = str(symbol or "").strip().upper()
+        doc = self._json_get(self._hold_key(symbol))
+        if not doc:
+            return {}
+        exp = _i(doc.get("expires_at_ms"), 0)
+        doc["is_active"] = bool(str(doc.get("hold_status") or "active") == "active" and (exp <= 0 or exp > _ms_now()))
+        return doc
+
+    def active_holds(self, *, limit: int = 100) -> List[Dict[str, Any]]:
+        out: List[Dict[str, Any]] = []
+        for key in self._iter_prefix_keys(self.hold_key_prefix):
+            doc = self._json_get(key)
+            if not doc:
+                continue
+            symbol = str(doc.get("symbol") or key[len(self.hold_key_prefix):] or "").strip().upper()
+            doc["symbol"] = symbol
+            exp = _i(doc.get("expires_at_ms"), 0)
+            doc["is_active"] = bool(str(doc.get("hold_status") or "active") == "active" and (exp <= 0 or exp > _ms_now()))
+            out.append(doc)
+        out = [d for d in out if bool(d.get("is_active"))]
+        out.sort(key=lambda d: (-_i(d.get("updated_at_ms") or d.get("applied_at_ms"), 0), str(d.get("symbol") or "")))
+        try:
+            if EXECUTION_ACTIVE_SYMBOL_GUARD_RUNBOOK_STATE_TOTAL is not None:
+                EXECUTION_ACTIVE_SYMBOL_GUARD_RUNBOOK_STATE_TOTAL.labels(kind="hold", status="active").set(len(out))
+        except Exception:
+            pass
+        return out[: max(int(limit or 100), 1)]
+
+    def apply_hold_symbol(self, *, symbol: str, operator: str, ticket: str, reason: str = "", ttl_sec: Optional[int] = None) -> Dict[str, Any]:
+        if not symbol or not operator or not ticket:
+            raise ValueError("symbol/operator/ticket required")
+        now = _ms_now()
+        ttl = max(int(ttl_sec or self.hold_ttl_sec), 1)
+        symbol = str(symbol or "").strip().upper()
+        guard = self.store.load_view(symbol) if hasattr(self.store, "load_view") else guard_view(self.store.load_raw(symbol))
+        doc = {
+            "symbol": symbol,
+            "sid": str(guard.get("sid") or ""),
+            "hold_status": "active",
+            "reason": str(reason or ""),
+            "ticket": str(ticket or ""),
+            "operator": str(operator or ""),
+            "applied_at_ms": now,
+            "expires_at_ms": now + ttl * 1000,
+            "updated_at_ms": now,
+        }
+        self._json_set(self._hold_key(symbol), doc, ttl)
+        self._metric(action="apply_hold_symbol", result="applied")
+        self._audit(action="apply_hold_symbol", operator=operator, ticket=ticket, symbol=symbol, sid=str(doc.get("sid") or ""), result="applied", reason=reason, payload=doc)
+        return {"ok": True, "action": "apply_hold_symbol", "symbol": symbol, "hold": doc}
+
+    def revoke_hold_symbol(self, *, symbol: str, operator: str, ticket: str, reason: str = "") -> Dict[str, Any]:
+        if not symbol or not operator or not ticket:
+            raise ValueError("symbol/operator/ticket required")
+        symbol = str(symbol or "").strip().upper()
+        prev = self.hold_state(symbol)
+        deleted = int(self.r.delete(self._hold_key(symbol)) or 0)
+        result = "revoked" if deleted else "noop"
+        self._metric(action="revoke_hold_symbol", result=result)
+        self._audit(action="revoke_hold_symbol", operator=operator, ticket=ticket, symbol=symbol, sid=str(prev.get("sid") or ""), result=result, reason=reason, payload={"previous": prev})
+        return {"ok": True, "action": "revoke_hold_symbol", "symbol": symbol, "result": result, "previous_hold": prev}
+
+    def _exchange_truth(self, symbol: str) -> Dict[str, Any]:
+        if self.diagnostics is not None:
+            payload = self.diagnostics.debug_symbol(symbol, include_exchange=True)
+            return dict(payload.get("exchange_truth") or {})
+        return {"symbol": symbol, "position_amt": 0.0, "open_plain_orders": 0, "open_algo_orders": 0, "is_reliable": False}
+
+    def guarded_force_release(
+        self,
+        *,
+        symbol: str,
+        operator: str,
+        ticket: str,
+        expected_sid: str = "",
+        reason: str = "",
+        dry_run: bool = False,
+    ) -> Dict[str, Any]:
+        if not symbol or not operator or not ticket:
+            raise ValueError("symbol/operator/ticket required")
+        symbol = str(symbol or "").strip().upper()
+        raw = self.store.load_raw(symbol)
+        view = guard_view(raw)
+        guard_sid = str(view.get("sid") or raw.get("sid") or "").strip()
+        exchange = self._exchange_truth(symbol)
+        if expected_sid and guard_sid and guard_sid != expected_sid:
+            out = {"ok": False, "action": "guarded_force_release", "symbol": symbol, "reason": "sid_mismatch", "guard_sid": guard_sid, "expected_sid": expected_sid, "exchange_truth": exchange}
+            self._metric(action="guarded_force_release", result="blocked")
+            self._audit(action="guarded_force_release", operator=operator, ticket=ticket, symbol=symbol, sid=guard_sid, result="blocked", reason="sid_mismatch", payload=out)
+            return out
+        safe = bool(
+            exchange.get("is_reliable") and abs(_f(exchange.get("position_amt"), 0.0)) == 0.0 and _i(exchange.get("open_plain_orders"), 0) == 0 and _i(exchange.get("open_algo_orders"), 0) == 0
+        )
+        if not safe:
+            out = {"ok": False, "action": "guarded_force_release", "symbol": symbol, "reason": "exchange_truth_not_safe", "guard": view, "exchange_truth": exchange}
+            self._metric(action="guarded_force_release", result="blocked")
+            self._audit(action="guarded_force_release", operator=operator, ticket=ticket, symbol=symbol, sid=guard_sid, result="blocked", reason="exchange_truth_not_safe", payload=out)
+            return out
+        if dry_run:
+            out = {"ok": True, "action": "guarded_force_release", "symbol": symbol, "result": "dry_run_safe", "guard": view, "exchange_truth": exchange}
+            self._metric(action="guarded_force_release", result="dry_run_safe")
+            self._audit(action="guarded_force_release", operator=operator, ticket=ticket, symbol=symbol, sid=guard_sid, result="dry_run_safe", reason=reason, payload=out)
+            return out
+        released = self.store.mark_released(
+            symbol=symbol,
+            expected_sid=expected_sid or guard_sid,
+            release_reason="runbook_force_release",
+            writer="runbook",
+            extra_patch={"runbook_operator": operator, "runbook_ticket": ticket, "runbook_reason": reason},
+        )
+        out = {
+            "ok": bool(released.get("applied")),
+            "action": "guarded_force_release",
+            "symbol": symbol,
+            "sid": guard_sid,
+            "result": "released" if released.get("applied") else str(released.get("reason") or "rejected"),
+            "released_doc": dict(released.get("doc") or {}),
+            "exchange_truth": exchange,
+        }
+        self._metric(action="guarded_force_release", result=str(out.get("result") or ""))
+        self._audit(action="guarded_force_release", operator=operator, ticket=ticket, symbol=symbol, sid=guard_sid, result=str(out.get("result") or ""), reason=reason, payload=out)
+        return out
+
+    def _resolve_triage(self, *, symbol: str = "", sid: str = "", fingerprint: str = "", include_exchange: bool = True) -> Dict[str, Any]:
+        fp = str(fingerprint or "").strip()
+        if fp:
+            return {"summary": {"symbol": str(symbol or "").upper(), "sid": str(sid or ""), "severity": "info"}, "policy": {"fingerprint": fp}}
+        if self.policy is None:
+            return {"summary": {"symbol": str(symbol or "").upper(), "sid": str(sid or ""), "severity": "info"}, "policy": {"fingerprint": ""}}
+        if symbol:
+            return self.policy.triage_symbol(str(symbol).upper(), include_exchange=bool(include_exchange))
+        if sid:
+            return self.policy.triage_sid(str(sid), include_exchange=bool(include_exchange))
+        return {"summary": {"severity": "info"}, "policy": {"fingerprint": ""}}
+
+    def escalation_state(self, fingerprint: str) -> Dict[str, Any]:
+        if not fingerprint:
+            return {}
+        doc = self._json_get(self._escalation_key(fingerprint))
+        if not doc:
+            return {}
+        exp = _i(doc.get("expires_at_ms"), 0)
+        doc["is_active"] = bool(exp <= 0 or exp > _ms_now())
+        return doc
+
+    def active_acks(self, *, limit: int = 100) -> List[Dict[str, Any]]:
+        out: List[Dict[str, Any]] = []
+        for key in self._iter_prefix_keys(self.escalation_key_prefix):
+            doc = self._json_get(key)
+            if not doc:
+                continue
+            exp = _i(doc.get("expires_at_ms"), 0)
+            doc["is_active"] = bool(exp <= 0 or exp > _ms_now())
+            doc["fingerprint"] = str(doc.get("fingerprint") or key[len(self.escalation_key_prefix):] or "")
+            if doc["is_active"]:
+                out.append(doc)
+        out.sort(key=lambda d: (-_i(d.get("updated_at_ms") or d.get("acked_at_ms"), 0), str(d.get("symbol") or "")))
+        try:
+            if EXECUTION_ACTIVE_SYMBOL_GUARD_RUNBOOK_STATE_TOTAL is not None:
+                EXECUTION_ACTIVE_SYMBOL_GUARD_RUNBOOK_STATE_TOTAL.labels(kind="ack", status="active").set(len(out))
+        except Exception:
+            pass
+        return out[: max(int(limit or 100), 1)]
+
+    def escalation_ack(
+        self,
+        *,
+        symbol: str = "",
+        sid: str = "",
+        fingerprint: str = "",
+        operator: str,
+        ticket: str,
+        reason: str = "",
+        ttl_sec: Optional[int] = None,
+    ) -> Dict[str, Any]:
+        if not operator or not ticket:
+            raise ValueError("operator/ticket required")
+        triaged = self._resolve_triage(symbol=symbol, sid=sid, fingerprint=fingerprint, include_exchange=True)
+        summary = dict(triaged.get("summary") or {})
+        policy = dict(triaged.get("policy") or {})
+        fp = str(policy.get("fingerprint") or fingerprint or "").strip()
+        if not fp:
+            raise ValueError("fingerprint could not be resolved")
+        now = _ms_now()
+        ttl = max(int(ttl_sec or self.escalation_ack_ttl_sec), 1)
+        current = self.escalation_state(fp)
+        doc = dict(current or {})
+        doc.update({
+            "fingerprint": fp,
+            "symbol": str(summary.get("symbol") or symbol or "").upper(),
+            "sid": str(summary.get("sid") or sid or ""),
+            "ack_status": "acked",
+            "acked_by": operator,
+            "ticket": ticket,
+            "ack_reason": reason,
+            "acked_at_ms": _i(doc.get("acked_at_ms"), now) or now,
+            "renew_count": _i(doc.get("renew_count"), 0),
+            "expires_at_ms": now + ttl * 1000,
+            "updated_at_ms": now,
+        })
+        self._json_set(self._escalation_key(fp), doc, ttl)
+        self._metric(action="escalation_ack", result="acked")
+        self._audit(action="escalation_ack", operator=operator, ticket=ticket, symbol=doc["symbol"], sid=doc["sid"], fingerprint=fp, result="acked", reason=reason, payload=doc)
+        return {"ok": True, "action": "escalation_ack", "fingerprint": fp, "state": doc, "triage": triaged}
+
+    def escalation_renew(
+        self,
+        *,
+        symbol: str = "",
+        sid: str = "",
+        fingerprint: str = "",
+        operator: str,
+        ticket: str,
+        reason: str = "",
+        ttl_sec: Optional[int] = None,
+    ) -> Dict[str, Any]:
+        if not operator or not ticket:
+            raise ValueError("operator/ticket required")
+        triaged = self._resolve_triage(symbol=symbol, sid=sid, fingerprint=fingerprint, include_exchange=True)
+        summary = dict(triaged.get("summary") or {})
+        policy = dict(triaged.get("policy") or {})
+        fp = str(policy.get("fingerprint") or fingerprint or "").strip()
+        if not fp:
+            raise ValueError("fingerprint could not be resolved")
+        current = self.escalation_state(fp)
+        if not current:
+            out = {"ok": False, "action": "escalation_renew", "fingerprint": fp, "reason": "ack_missing"}
+            self._metric(action="escalation_renew", result="ack_missing")
+            self._audit(action="escalation_renew", operator=operator, ticket=ticket, symbol=str(summary.get("symbol") or symbol or "").upper(), sid=str(summary.get("sid") or sid or ""), fingerprint=fp, result="ack_missing", reason=reason, payload=out)
+            return out
+        now = _ms_now()
+        ttl = max(int(ttl_sec or self.escalation_ack_ttl_sec), 1)
+        doc = dict(current)
+        doc.update({
+            "fingerprint": fp,
+            "symbol": str(doc.get("symbol") or summary.get("symbol") or symbol or "").upper(),
+            "sid": str(doc.get("sid") or summary.get("sid") or sid or ""),
+            "ack_status": "acked",
+            "renewed_by": operator,
+            "renew_ticket": ticket,
+            "renew_reason": reason,
+            "renew_count": _i(doc.get("renew_count"), 0) + 1,
+            "renewed_at_ms": now,
+            "expires_at_ms": now + ttl * 1000,
+            "updated_at_ms": now,
+        })
+        self._json_set(self._escalation_key(fp), doc, ttl)
+        self._metric(action="escalation_renew", result="renewed")
+        self._audit(action="escalation_renew", operator=operator, ticket=ticket, symbol=doc["symbol"], sid=doc["sid"], fingerprint=fp, result="renewed", reason=reason, payload=doc)
