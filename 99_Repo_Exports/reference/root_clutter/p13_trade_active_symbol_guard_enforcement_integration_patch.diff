+from pathlib import Path
+
+
+def test_exporter_and_cli_have_p13_surface():
+    exporter = Path('services/active_symbol_guard_exporter.py').read_text()
+    cli = Path('services/active_symbol_guard_cli.py').read_text()
+    assert '/api/active-symbol-guard/runbook/dashboard' in exporter
+    assert '/api/active-symbol-guard/runbook/ticket/' in exporter
+    assert '--runbook-dashboard' in cli
+    assert '--ticket-history' in cli
