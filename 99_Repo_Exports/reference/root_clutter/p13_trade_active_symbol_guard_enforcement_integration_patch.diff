+from pathlib import Path
+import sys
+ROOT = Path(__file__).resolve().parents[2]
+if str(ROOT) not in sys.path:
+    sys.path.insert(0, str(ROOT))
+
+import json
+
+from services.active_symbol_guard_incident_policy import ActiveSymbolGuardIncidentPolicyEngine
+
+
+class FakeRedis:
+    def __init__(self):
+        self.kv = {}
+    def get(self, key):
+        return self.kv.get(key)
+    def set(self, key, value, ex=None):
+        self.kv[key] = value
+        return True
+
+
+class StubDiagnostics:
+    def incident_bundle_symbol(self, symbol, include_exchange=False):
+        return {
+            'summary': {'symbol': symbol, 'sid': 'sid-1', 'classification': 'pending_release', 'severity': 'warning', 'hotness': {'5m': 1, '1h': 2}, 'race_chain_count': 0},
+            'exchange_truth': {'is_reliable': True, 'is_flat': False, 'has_live_position': False, 'has_open_orders': False},
+            'suspicious_writer_race_chains': [],
+            'telegram_text': f'incident {symbol}',
+        }
+    def incident_bundle_sid(self, sid, include_exchange=False):
+        b = self.incident_bundle_symbol('BTCUSDT', include_exchange=include_exchange)
+        b['summary']['sid'] = sid
+        return b
+
+
+def test_triage_is_hold_aware_and_ack_aware():
+    r = FakeRedis()
+    now_ms = 9_999_999_999_999
+    hold = {'symbol': 'BTCUSDT', 'hold_status': 'active', 'ticket': 'INC-1', 'operator': 'alice', 'expires_at_ms': now_ms + 600_000}
+    r.set('orders:active_symbol_guard:hold:symbol:BTCUSDT', json.dumps(hold))
+    engine = ActiveSymbolGuardIncidentPolicyEngine(r, StubDiagnostics())
+    triaged = engine.triage_symbol('BTCUSDT', include_exchange=True)
+    fp = triaged['policy']['fingerprint']
+    ack = {'fingerprint': fp, 'symbol': 'BTCUSDT', 'ticket': 'INC-1', 'acked_by': 'alice', 'expires_at_ms': now_ms + 120_000}
+    r.set(f'orders:active_symbol_guard:incident:ack:{fp}', json.dumps(ack))
+    triaged = engine.triage_symbol('BTCUSDT', include_exchange=True)
+    assert triaged['summary']['hold_active'] is True
+    assert triaged['policy']['hold_state']['ticket'] == 'INC-1'
+    assert triaged['policy']['ack_state']['is_active'] is True
+    actions = {a['action']: a for a in triaged['runbook_actions']}
+    assert 'revoke_hold' in actions
+    assert 'renew_ack' in actions
+    assert triaged['policy']['decision'] in {'acked', 'renew_reminder'}
