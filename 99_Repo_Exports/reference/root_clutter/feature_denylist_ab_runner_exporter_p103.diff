+# P103: Feature denylist actionable output guardrails
+# Alerts are intentionally low-cardinality.
+
+groups:
+- name: feature_denylist_p103
+  rules:
+
+  - alert: FeatureDenylistPendingABStale
+    expr: feature_denylist_oldest_pending_age_seconds > 72*3600
+    for: 30m
+    labels:
+      severity: warning
+      tier: P103
+      owner: ml
+    annotations:
+      summary: "Feature denylist proposal pending AB is stale"
+      description: "Oldest pending_ab proposal age {{ $value }}s (>72h). Run nightly_feature_denylist_ab_runner_v1 or investigate AB failures."
+
+  - alert: FeatureDenylistABRunnerStale
+    expr: feature_denylist_ab_runner_age_seconds > 6*3600
+    for: 30m
+    labels:
+      severity: warning
+      tier: P103
+      owner: ml
+    annotations:
+      summary: "Feature denylist AB runner hasn't reported recently"
+      description: "AB runner last tick age {{ $value }}s (>6h). Timers worker may be disabled or exporter not updating."
+
+  - alert: FeatureDenylistABRunnerFailing
+    expr: feature_denylist_ab_runner_fail > 0
+    for: 10m
+    labels:
+      severity: warning
+      tier: P103
+      owner: ml
+    annotations:
+      summary: "Feature denylist AB runner had failures"
+      description: "AB runner processed failures count={{ $value }}. Check logs; proposal manifests may be stuck in pending_ab."
