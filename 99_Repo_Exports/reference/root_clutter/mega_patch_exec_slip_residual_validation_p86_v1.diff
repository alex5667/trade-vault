--- /dev/null	2026-02-24 19:02:04.353820025 +0000
+++ /mnt/data/tradeproj/orderflow_services/prometheus_alerts_exec_slip_residual_validation_p86.yml	2026-02-24 19:10:31.698724291 +0000
@@ -0,0 +1,31 @@
+# P86: Alerts for DB-based residual validation (regime buckets)
+
+groups:
+  - name: of_exec_slip_residuals_p86
+    rules:
+      - alert: ExecSlipResidualDBDown
+        expr: of_exec_slip_stats_db_up == 0
+        for: 10m
+        labels:
+          severity: warn
+        annotations:
+          summary: "Residual validation DB query failing"
+          description: "enforce_bucket_state_exporter DB stats query failing (of_exec_slip_stats_db_up=0). Check ANALYTICS_DB_DSN and exporter logs."
+
+      - alert: ExecSlipResidualP99High
+        expr: (of_exec_slip_db_n > 80) and on(sym,bucket) (of_exec_slip_resid_p99_bps > 20)
+        for: 30m
+        labels:
+          severity: page
+        annotations:
+          summary: "Slippage residual P99 is high"
+          description: "DB-based residual P99 > 20 bps for sym/bucket with enough samples. Inspect mv_exec_slippage_eval_1h_stats and runbook_slippage_qa_p77.md."
+
+      - alert: ExecSlipEdgeNegShareHigh
+        expr: (of_exec_slip_db_n > 80) and on(sym,bucket) (of_exec_slip_edge_neg_share > 0.55)
+        for: 30m
+        labels:
+          severity: page
+        annotations:
+          summary: "Edge negative share is high"
+          description: "edge_minus_expected_bps < 0 share > 0.55 for sym/bucket with enough samples. Investigate slippage decomp calibration and enforcement."
