+from pathlib import Path
+import importlib.util
+import sys
+
+mod_path = Path(__file__).with_name("atomic_outbox.py")
+spec = importlib.util.spec_from_file_location("atomic_outbox", mod_path)
+mod = importlib.util.module_from_spec(spec)
+sys.modules[spec.name] = mod
+assert spec.loader is not None
+spec.loader.exec_module(mod)
+
+
+class FakeRedis:
+    def __init__(self):
+        self.args = None
+    def eval(self, *args):
+        self.args = args
+        return [1, '1741-0']
+
+
+def test_atomic_xadd_adds_exec_event_and_contract_fields(monkeypatch):
+    monkeypatch.setenv('OUTBOX_EVENT_STREAM_ENABLE', '1')
+    monkeypatch.setenv('OUTBOX_EVENT_STREAM_KEY', 'orders:exec')
+    r = FakeRedis()
+    entry_id = mod.atomic_xadd_sync(
+        r,
+        stream_key='signals:crypto:raw',
+        signal_id='sid-1',
+        payload_obj={'symbol': 'BTCUSDT'},
+        kind='flow',
+        symbol='BTCUSDT',
+        meta_obj={'risk_snapshot': {'risk_level': 'ok'}},
+    )
+    assert entry_id == '1741-0'
+    assert r.args is not None
+    assert r.args[1] == 5
+    assert r.args[6] == 'orders:exec'
+    payload_json = r.args[-7]
+    event_json = r.args[-1]
+    assert 'execution_intent:v1' in payload_json
+    assert 'ts_publish_ms' in payload_json
