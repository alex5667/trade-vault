+)
+mods['common.outbox_contract'] = types.SimpleNamespace(
+    contract_check_best_effort=lambda **kwargs: None,
+    strip_forbidden_keys=lambda obj, forbidden: obj,
+    FORBIDDEN_TARGET_KEYS=set(),
