+from pathlib import Path
+import importlib.util
+import sys
+
+mod_path = Path(__file__).with_name("redis_dq_policy.py")
+spec = importlib.util.spec_from_file_location("redis_dq_policy", mod_path)
+mod = importlib.util.module_from_spec(spec)
+sys.modules[spec.name] = mod
+assert spec.loader is not None
+spec.loader.exec_module(mod)
+
+
+def test_hard_veto_on_tick_and_timeouts():
+    snap = mod.RedisDQSnapshot(symbol="BTCUSDT", tick_staleness_ms=9000, redis_timeout_events=7)
+    decision = mod.evaluate_redis_dq(snap)
+    assert decision.level == 2
+    assert decision.allow_trade_publish is False
+    assert "tick_staleness" in decision.reasons
+    assert "redis_timeout_events" in decision.reasons
+
+
+def test_soft_veto_tightens_without_blocking():
+    snap = mod.RedisDQSnapshot(symbol="ETHUSDT", queue_lag_ms=2500, outbox_backlog=120)
+    decision = mod.evaluate_redis_dq(snap)
+    assert decision.level == 1
+    assert decision.allow_trade_publish is True
+    assert decision.tightened_mode is True
