diff -ruN /mnt/data/proj_base/services/prom_rules_bundle_smoke_runner_v1.py /mnt/data/proj/services/prom_rules_bundle_smoke_runner_v1.py
--- /mnt/data/proj_base/services/prom_rules_bundle_smoke_runner_v1.py	1970-01-01 00:00:00.000000000 +0000
+++ /mnt/data/proj/services/prom_rules_bundle_smoke_runner_v1.py	2026-02-25 18:43:53.761948952 +0000
@@ -0,0 +1,24 @@
+"""Minimal entry-point to run only the Prometheus rules bundle smoke-check.
+
+Rationale
+- In prod you may not run the full `services.of_timers_worker` loop in this compose.
+- This runner reuses the already-prod-hardened logic (dedup/cooldown + auto-apply block) from `of_timers_worker`.
+
+Exit codes
+- 0: OK
+- 2: FAILED (and side-effects already applied: notify + block keys)
+"""
+
+from __future__ import annotations
+
+
+def main() -> int:
+    # Import lazily to avoid side effects during module import.
+    from services.of_timers_worker import run_prom_rules_bundle_smoke_check
+
+    ok = bool(run_prom_rules_bundle_smoke_check())
+    return 0 if ok else 2
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
