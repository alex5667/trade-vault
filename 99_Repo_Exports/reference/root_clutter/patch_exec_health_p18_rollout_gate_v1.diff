+class RolloutGateController:
+    def __init__(self, redis_url: str | None = None) -> None:
+        if redis is None:
+            raise RuntimeError('redis dependency missing')
+        self.redis_url = redis_url or os.getenv('EXEC_HEALTH_REDIS_BOOTSTRAP_URL') or os.getenv('REDIS_URL', 'redis://redis-worker-1:6379/0')
+        self.r = redis.Redis.from_url(self.redis_url, decode_responses=True)
+        ensure_service_identity_sync(self.r, DEFAULT_ACK_SERVICE)
+        heal_service_identity_sync(self.r, DEFAULT_ACK_SERVICE, force=True)
+
+    def status(self) -> Dict[str, Any]:
