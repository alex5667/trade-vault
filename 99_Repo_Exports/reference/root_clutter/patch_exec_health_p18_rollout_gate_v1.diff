+        out = get_rollout_gate_state(self.r)
+        out['service'] = DEFAULT_ACK_SERVICE
+        return out
+
+    def ack(self, *, operator: str, reason: str, ticket: str = '') -> Dict[str, Any]:
+        heal_service_identity_sync(self.r, DEFAULT_ACK_SERVICE)
+        return manual_ack_rollout_gate(self.r, operator=operator, reason=reason, ticket=ticket)
+
+
+def main(argv: List[str] | None = None) -> int:
+    ap = argparse.ArgumentParser(description='ExecHealth reconnect nightly rollout gate controller')
