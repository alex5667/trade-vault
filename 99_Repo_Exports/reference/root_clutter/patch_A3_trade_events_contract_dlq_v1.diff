+"""Trade events (events:trades) contract helpers.
+
+Purpose
+-------
+This module defines a *strict-but-safe* validator/sanitizer for Redis Stream events
+produced by executors and trade monitors. The main consumer is the ML/label joiner
+pipeline, which requires a stable join-key (`sid`) and deterministic time semantics
+(epoch-ms).
+
+Design goals
+------------
+- Deterministic time: `ts` and `exit_ts_ms` are epoch-ms UTC, encoded as strings
+  because Redis Streams store string fields.
+- Idempotency: `event_id` is expected to be SHA1 hex (40 chars). We validate format.
+- Fail-open for optional fields: we never invent PnL/risk numbers, but we will
+  normalize types and fill `exit_ts_ms` from `ts` if missing (safe default).
+- Low-cardinality: do NOT put `event_id`/`sid` into Prometheus labels. Use logs.
+
+How to use
+----------
+Producers (trade_events_logger.py, executors):
+  evt = normalize_position_closed_event(evt)
+  ok, err = validate_position_closed_event(evt)
+  if not ok: publish to DLQ and ACK (poison-pill) OR raise in strict environments.
+
+Consumers:
+  Use `validate_position_closed_event` early and quarantine invalid events.
+"""
+
+from __future__ import annotations
+
+import json
+import re
+from dataclasses import dataclass
+from typing import Any, Dict, Iterable, List, Optional, Tuple
+
+# ---------------------------------------------------------------------
+# Contract
+# ---------------------------------------------------------------------
+
+POSITION_CLOSED_REQUIRED_FIELDS: Tuple[str, ...] = (
+    "event_type",
+    "event_id",
+    "sid",
+    "symbol",
+    "ts",
+    "source",
+    "price",
+    "pnl",
+    "risk_usd",
+    "r_mult",
+    "exit_ts_ms",
+    "ab_arm",
+    "regime",
+)
+
+# Heavy fields must never be emitted into Redis Streams.
+# They belong in Postgres or a per-sid blob list key.
+HEAVY_FIELDS: Tuple[str, ...] = (
+    "config_snapshot",
+    "calibrated_specs",
+    "indicators_snapshot",
+    "trail_profile_config",
+    "evidence",
+    "feature_vector",
+    "trail_profile",
+    "raw_signal",
+    "signal_payload",
+)
+
+_SHA1_RE = re.compile(r"^[0-9a-f]{40}$")
+_EPOCH_MS_RE = re.compile(r"^[0-9]{13,}$")  # allow >=13 digits to tolerate ms+ns trunc.
+
+@dataclass(frozen=True)
+class ValidationError:
+    field: str
+    reason: str
+
+    def __str__(self) -> str:
+        return f"{self.field}: {self.reason}"
+
+
+def _as_str(x: Any) -> str:
+    """Convert to Redis Stream safe string."""
+    if x is None:
+        return ""
+    if isinstance(x, (bytes, bytearray)):
+        try:
+            return x.decode("utf-8", errors="replace")
+        except Exception:
+            return str(x)
+    if isinstance(x, (dict, list)):
+        return json.dumps(x, separators=(",", ":"), ensure_ascii=False)
+    return str(x)
+
+
+def strip_heavy_fields(evt: Dict[str, Any]) -> Dict[str, Any]:
+    """Remove heavy fields from a trade event dict (in-place copy)."""
+    out = dict(evt)
+    for k in HEAVY_FIELDS:
+        out.pop(k, None)
+    return out
+
+
+def normalize_position_closed_event(evt: Dict[str, Any]) -> Dict[str, str]:
+    """Normalize event values to strings (Redis Stream contract).
+
+    Notes:
+    - We preserve both 'metadata' and 'meta' if present. If only one exists,
+      we mirror into the other for backwards compatibility.
+    - If exit_ts_ms missing, we default it to ts (safe and deterministic).
+    """
+    e: Dict[str, Any] = strip_heavy_fields(evt)
+
+    # Mirror meta/metadata for compatibility
+    meta = e.get("meta")
+    metadata = e.get("metadata")
+    if meta is None and metadata is not None:
+        e["meta"] = metadata
+    if metadata is None and meta is not None:
+        e["metadata"] = meta
+
+    # Default exit_ts_ms to ts if missing
+    if e.get("exit_ts_ms") in (None, ""):
+        if e.get("ts") not in (None, ""):
+            e["exit_ts_ms"] = e.get("ts")
+
+    # Convert everything to strings
+    out: Dict[str, str] = {}
+    for k, v in e.items():
+        out[k] = _as_str(v)
+    return out
+
+
+def validate_position_closed_event(evt: Dict[str, Any]) -> Tuple[bool, List[ValidationError]]:
+    """Validate a POSITION_CLOSED event. Returns (ok, errors)."""
+    errors: List[ValidationError] = []
+
+    def miss(field: str, reason: str) -> None:
+        errors.append(ValidationError(field=field, reason=reason))
+
+    # Required fields
+    for f in POSITION_CLOSED_REQUIRED_FIELDS:
+        v = evt.get(f)
+        if v is None or str(v).strip() == "":
+            miss(f, "missing")
+    if errors:
+        return False, errors
+
+    # event_type strict
+    if str(evt.get("event_type")) != "POSITION_CLOSED":
+        miss("event_type", "must be POSITION_CLOSED")
+
+    # event_id SHA1 hex
+    eid = str(evt.get("event_id") or "").strip().lower()
+    if not _SHA1_RE.match(eid):
+        miss("event_id", "must be sha1 hex (40 chars)")
+
+    # epoch ms checks
+    for f in ("ts", "exit_ts_ms"):
+        v = str(evt.get(f) or "").strip()
+        if not _EPOCH_MS_RE.match(v):
+            miss(f, "must be epoch ms as digits")
+
+    # price/pnl/risk/r_mult must parse as float
+    for f in ("price", "pnl", "risk_usd", "r_mult"):
+        v = str(evt.get(f) or "").strip()
+        try:
+            float(v)
+        except Exception:
+            miss(f, "must be float")
+
+    # Soft sanity: regime must be non-empty (allow 'na')
+    if str(evt.get("regime") or "").strip() == "":
+        miss("regime", "missing")
+
+    return (len(errors) == 0), errors
