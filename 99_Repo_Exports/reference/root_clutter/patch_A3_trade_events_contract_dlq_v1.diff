+"""DLQ helper for Redis Streams.
+
+We use a dedicated DLQ stream for poison-pill events, so the main consumer group
+doesn't get stuck on invalid messages.
+
+DLQ entry schema (fields are strings):
+  - reason: short machine-readable code
+  - error:  human-readable error summary (short)
+  - stream: original stream name
+  - entry_id: original stream entry id
+  - payload: JSON string (possibly truncated)
+"""
+
+from __future__ import annotations
+
+import json
+from typing import Any, Dict, Optional
+
+def _truncate(s: str, max_bytes: int = 16_000) -> str:
+    b = s.encode("utf-8", errors="replace")
+    if len(b) <= max_bytes:
+        return s
+    return b[:max_bytes].decode("utf-8", errors="replace")
+
+def publish_dlq(
+    redis_client: Any,
+    *,
+    dlq_stream: str,
+    reason: str,
+    error: str,
+    stream: str,
+    entry_id: str,
+    payload: Dict[str, Any],
+    maxlen: int = 200_000,
+) -> None:
+    # NOTE: Redis Streams require field-values to be strings/bytes.
+    body = {
+        "reason": str(reason),
+        "error": _truncate(str(error), 2000),
+        "stream": str(stream),
+        "entry_id": str(entry_id),
+        "payload": _truncate(json.dumps(payload, ensure_ascii=False, separators=(",", ":"))),
+    }
+    redis_client.xadd(dlq_stream, body, maxlen=maxlen, approximate=True)
diff --git a/python-worker/tests/test_trade_events_contract.py b/python-worker/tests/test_trade_events_contract.py
new file mode 100644
index 0000000..1111111
--- /dev/null
+++ b/python-worker/tests/test_trade_events_contract.py
@@ -0,0 +1,103 @@
+import unittest
+import time
+
+from python_worker.services.posttrade.trade_events_contract import (
+    normalize_position_closed_event,
+    validate_position_closed_event,
+)
+
+def _ms_now():
+    return int(time.time() * 1000)
+
+class TestTradeEventsContract(unittest.TestCase):
+    def test_valid_position_closed(self):
+        ts = str(_ms_now())
+        evt = {
+            "event_type": "POSITION_CLOSED",
+            "event_id": "a" * 40,
+            "sid": "sig-BTCUSDT-1",
+            "symbol": "BTCUSDT",
+            "ts": ts,
+            "source": "binance",
+            "price": "85400.5",
+            "pnl": "127.35",
+            "risk_usd": "18.45",
+            "r_mult": "6.91",
+            "exit_ts_ms": ts,
+            "ab_arm": "A",
+            "regime": "trending",
+            "meta": {"close_reason": "SL_HIT"},
+        }
+        norm = normalize_position_closed_event(evt)
+        ok, errs = validate_position_closed_event(norm)
+        self.assertTrue(ok, str(errs))
+        self.assertIn("metadata", norm)  # mirrored
+
+    def test_missing_sid_fails(self):
+        ts = str(_ms_now())
+        evt = {
+            "event_type": "POSITION_CLOSED",
+            "event_id": "a" * 40,
+            "sid": "",
+            "symbol": "BTCUSDT",
+            "ts": ts,
+            "source": "binance",
+            "price": "1",
+            "pnl": "1",
+            "risk_usd": "1",
+            "r_mult": "1",
+            "exit_ts_ms": ts,
+            "ab_arm": "A",
+            "regime": "na",
+        }
+        norm = normalize_position_closed_event(evt)
+        ok, errs = validate_position_closed_event(norm)
+        self.assertFalse(ok)
+        self.assertTrue(any(e.field == "sid" for e in errs))
+
+    def test_bad_ts_fails(self):
+        evt = {
+            "event_type": "POSITION_CLOSED",
+            "event_id": "a" * 40,
+            "sid": "sig-1",
+            "symbol": "BTCUSDT",
+            "ts": "not_ms",
+            "source": "binance",
+            "price": "1",
+            "pnl": "1",
+            "risk_usd": "1",
+            "r_mult": "1",
+            "exit_ts_ms": "not_ms",
+            "ab_arm": "A",
+            "regime": "na",
+        }
+        norm = normalize_position_closed_event(evt)
+        ok, errs = validate_position_closed_event(norm)
+        self.assertFalse(ok)
+        self.assertTrue(any(e.field == "ts" for e in errs))
+        self.assertTrue(any(e.field == "exit_ts_ms" for e in errs))
+
+    def test_exit_ts_defaulted(self):
+        ts = str(_ms_now())
+        evt = {
+            "event_type": "POSITION_CLOSED",
+            "event_id": "a" * 40,
+            "sid": "sig-1",
+            "symbol": "BTCUSDT",
+            "ts": ts,
+            "source": "binance",
+            "price": "1",
+            "pnl": "1",
+            "risk_usd": "1",
+            "r_mult": "1",
+            "exit_ts_ms": "",
+            "ab_arm": "A",
+            "regime": "na",
+        }
+        norm = normalize_position_closed_event(evt)
+        self.assertEqual(norm["exit_ts_ms"], ts)
+        ok, errs = validate_position_closed_event(norm)
+        self.assertTrue(ok, str(errs))
+
+if __name__ == "__main__":
+    unittest.main()
