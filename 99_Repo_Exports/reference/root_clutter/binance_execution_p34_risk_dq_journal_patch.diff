diff -ruN '--exclude=__pycache__' '--exclude=.pytest_cache' /mnt/data/p2work/p2/binance_execution/execution_journal.py /mnt/data/p34work/binance_execution/execution_journal.py
--- /mnt/data/p2work/p2/binance_execution/execution_journal.py	1970-01-01 00:00:00.000000000 +0000
+++ /mnt/data/p34work/binance_execution/execution_journal.py	2026-03-06 18:42:43.107758824 +0000
@@ -0,0 +1,162 @@
+from __future__ import annotations
+
+"""Best-effort execution journal sink for Postgres."""
+
+from dataclasses import dataclass
+from typing import Any, Dict
+import json
+import os
+import time
+
+try:
+    from prometheus_client import Counter, REGISTRY
+except Exception:  # pragma: no cover
+    Counter = None  # type: ignore
+    REGISTRY = None  # type: ignore
+
+
+def _metric(factory, name: str, *args, **kwargs):
+    if factory is None:
+        return None
+    try:
+        return factory(name, *args, **kwargs)
+    except ValueError:
+        return getattr(REGISTRY, "_names_to_collectors", {}).get(name) if REGISTRY is not None else None
+
+
+TRADE_EXECUTION_JOURNAL_WRITE_FAIL_TOTAL = _metric(
+    Counter,
+    'trade_execution_journal_write_fail_total',
+    'Number of execution journal DB write failures.',
+    ['kind'],
+)
+
+try:  # pragma: no cover
+    import psycopg  # type: ignore
+except Exception:  # pragma: no cover
+    psycopg = None
+    try:
+        import psycopg2 as psycopg  # type: ignore
+    except Exception:  # pragma: no cover
+        psycopg = None
+
+
+@dataclass
+class ExecutionJournalSink:
+    dsn: str = ''
+    connect_factory: Any = None
+
+    def __post_init__(self) -> None:
+        self.dsn = self.dsn or os.getenv('EXECUTION_JOURNAL_DSN', '')
+        if self.connect_factory is None and self.dsn and psycopg is not None:
+            self.connect_factory = psycopg.connect
+
+    @property
+    def enabled(self) -> bool:
+        return bool(self.dsn and self.connect_factory)
+
+    def _connect(self):
+        if not self.enabled:
+            return None
+        return self.connect_factory(self.dsn)
+
+    def record_event(self, event: Dict[str, Any]) -> bool:
+        if not self.enabled:
+            return False
+        sql = (
+            "INSERT INTO execution_order_events (sid, symbol, event_type, event_ts_ms, payload_jsonb) "
+            "VALUES (%s, %s, %s, %s, %s::jsonb)"
+        )
+        payload = dict(event or {})
+        try:
+            conn = self._connect()
+            with conn:
+                with conn.cursor() as cur:
+                    cur.execute(sql, (
+                        str(payload.get('sid') or ''),
+                        str(payload.get('symbol') or ''),
+                        str(payload.get('event_type') or payload.get('action') or 'event'),
+                        int(payload.get('ts_ms') or int(time.time() * 1000)),
+                        json.dumps(payload, ensure_ascii=False, default=str),
+                    ))
+            return True
+        except Exception:
+            if TRADE_EXECUTION_JOURNAL_WRITE_FAIL_TOTAL:
+                TRADE_EXECUTION_JOURNAL_WRITE_FAIL_TOTAL.labels(kind='event').inc()
+            return False
+
+    def upsert_order_snapshot(self, state: Dict[str, Any]) -> bool:
+        if not self.enabled:
+            return False
+        sql = (
+            "INSERT INTO execution_orders (sid, symbol, action, status, fsm_state, execution_policy, venue, "
+            "position_mode, position_side, working_type_policy, state_jsonb, created_at_ms, updated_at_ms) "
+            "VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s::jsonb, %s, %s) "
+            "ON CONFLICT (sid) DO UPDATE SET "
+            "symbol = EXCLUDED.symbol, action = EXCLUDED.action, status = EXCLUDED.status, fsm_state = EXCLUDED.fsm_state, "
+            "execution_policy = EXCLUDED.execution_policy, venue = EXCLUDED.venue, position_mode = EXCLUDED.position_mode, "
+            "position_side = EXCLUDED.position_side, working_type_policy = EXCLUDED.working_type_policy, "
+            "state_jsonb = EXCLUDED.state_jsonb, updated_at_ms = EXCLUDED.updated_at_ms"
+        )
+        doc = dict(state or {})
+        now_ms = int(doc.get('ts_ms') or int(time.time() * 1000))
+        try:
+            conn = self._connect()
+            with conn:
+                with conn.cursor() as cur:
+                    cur.execute(sql, (
+                        str(doc.get('sid') or ''),
+                        str(doc.get('symbol') or ''),
+                        str(doc.get('action') or ''),
+                        str(doc.get('status') or ''),
+                        str(doc.get('fsm_state') or ''),
+                        str(doc.get('execution_policy') or ''),
+                        str(doc.get('venue') or 'binance'),
+                        str(doc.get('position_mode') or ''),
+                        str(doc.get('position_side') or ''),
+                        str(doc.get('working_type_policy') or ''),
+                        json.dumps(doc, ensure_ascii=False, default=str),
+                        int(doc.get('created_at_ms') or now_ms),
+                        int(doc.get('updated_at_ms') or now_ms),
+                    ))
+            return True
+        except Exception:
+            if TRADE_EXECUTION_JOURNAL_WRITE_FAIL_TOTAL:
+                TRADE_EXECUTION_JOURNAL_WRITE_FAIL_TOTAL.labels(kind='order_snapshot').inc()
+            return False
+
+    def upsert_protection_refs(self, state: Dict[str, Any]) -> bool:
+        if not self.enabled:
+            return False
+        sid = str((state or {}).get('sid') or '')
+        if not sid:
+            return False
+        sql = (
+            "INSERT INTO execution_protection_refs (sid, symbol, sl_algo_id, sl_client_algo_id, tp1_algo_id, tp2_algo_id, tp3_algo_id, trail_algo_id, trail_client_algo_id, updated_at_ms) "
+            "VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s) "
+            "ON CONFLICT (sid) DO UPDATE SET symbol = EXCLUDED.symbol, sl_algo_id = EXCLUDED.sl_algo_id, sl_client_algo_id = EXCLUDED.sl_client_algo_id, "
+            "tp1_algo_id = EXCLUDED.tp1_algo_id, tp2_algo_id = EXCLUDED.tp2_algo_id, tp3_algo_id = EXCLUDED.tp3_algo_id, "
+            "trail_algo_id = EXCLUDED.trail_algo_id, trail_client_algo_id = EXCLUDED.trail_client_algo_id, updated_at_ms = EXCLUDED.updated_at_ms"
+        )
+        s = state or {}
+        try:
+            conn = self._connect()
+            with conn:
+                with conn.cursor() as cur:
+                    cur.execute(sql, (
+                        sid,
+                        str(s.get('symbol') or ''),
+                        s.get('sl_algo_id'),
+                        s.get('sl_client_algo_id'),
+                        s.get('tp1_algo_id'),
+                        s.get('tp2_algo_id'),
+                        s.get('tp3_algo_id'),
+                        s.get('trail_algo_id'),
+                        s.get('trail_client_algo_id'),
+                        int(s.get('updated_at_ms') or int(time.time() * 1000)),
+                    ))
+            return True
+        except Exception:
+            if TRADE_EXECUTION_JOURNAL_WRITE_FAIL_TOTAL:
+                TRADE_EXECUTION_JOURNAL_WRITE_FAIL_TOTAL.labels(kind='protection_refs').inc()
+            return False
