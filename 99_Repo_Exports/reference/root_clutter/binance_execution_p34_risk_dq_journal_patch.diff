+
+RISK_ALLOW = "ALLOW"
+RISK_ALLOW_TIGHTENED = "ALLOW_TIGHTENED"
+RISK_DENY_SOFT = "DENY_SOFT"
+RISK_DENY_HARD = "DENY_HARD"
+RISK_FORCE_FLATTEN = "FORCE_FLATTEN"
+
+
+@dataclass(frozen=True)
+class PortfolioRiskLimits:
+    max_daily_loss_pct: float = 2.0
+    max_total_exposure_ratio: float = 2.5
+    max_symbol_exposure_ratio: float = 0.75
+    max_cluster_exposure_ratio: float = 1.25
+    tier_a_max_leverage: float = 10.0
+    tier_b_max_leverage: float = 5.0
+    tier_c_max_leverage: float = 3.0
+    tier_c_block_when_infra_degraded: bool = True
+    soft_spread_bps_cap: float = 12.0
+    hard_spread_bps_cap: float = 30.0
+    soft_slippage_bps_cap: float = 20.0
+    hard_slippage_bps_cap: float = 60.0
+
+    @classmethod
+    def from_env(cls) -> "PortfolioRiskLimits":
+        def _f(name: str, default: float) -> float:
+            try:
+                return float(os.getenv(name, str(default)))
+            except Exception:
+                return float(default)
+        def _b(name: str, default: bool) -> bool:
+            v = os.getenv(name)
+            if v is None:
+                return default
+            return str(v).strip().lower() in {"1", "true", "yes", "on"}
+        return cls(
+            max_daily_loss_pct=_f("RISK_MAX_DAILY_LOSS_PCT", cls.max_daily_loss_pct),
+            max_total_exposure_ratio=_f("RISK_MAX_TOTAL_EXPOSURE_RATIO", cls.max_total_exposure_ratio),
+            max_symbol_exposure_ratio=_f("RISK_MAX_SYMBOL_EXPOSURE_RATIO", cls.max_symbol_exposure_ratio),
+            max_cluster_exposure_ratio=_f("RISK_MAX_CLUSTER_EXPOSURE_RATIO", cls.max_cluster_exposure_ratio),
+            tier_a_max_leverage=_f("RISK_TIER_A_MAX_LEVERAGE", cls.tier_a_max_leverage),
+            tier_b_max_leverage=_f("RISK_TIER_B_MAX_LEVERAGE", cls.tier_b_max_leverage),
+            tier_c_max_leverage=_f("RISK_TIER_C_MAX_LEVERAGE", cls.tier_c_max_leverage),
+            tier_c_block_when_infra_degraded=_b("RISK_TIER_C_BLOCK_WHEN_INFRA_DEGRADED", cls.tier_c_block_when_infra_degraded),
+            soft_spread_bps_cap=_f("RISK_SOFT_SPREAD_BPS_CAP", cls.soft_spread_bps_cap),
+            hard_spread_bps_cap=_f("RISK_HARD_SPREAD_BPS_CAP", cls.hard_spread_bps_cap),
+            soft_slippage_bps_cap=_f("RISK_SOFT_SLIPPAGE_BPS_CAP", cls.soft_slippage_bps_cap),
+            hard_slippage_bps_cap=_f("RISK_HARD_SLIPPAGE_BPS_CAP", cls.hard_slippage_bps_cap),
+        )
+
+
+@dataclass(frozen=True)
+class PortfolioPosition:
+    symbol: str
+    notional_usd: float
+    side: str = "LONG"
+    cluster: str = "default"
+    tier: str = "B"
+
+
+@dataclass(frozen=True)
+class PortfolioRiskInput:
+    symbol: str
+    cluster: str
+    tier: str
+    requested_notional_usd: float
+    current_positions: List[PortfolioPosition] = field(default_factory=list)
+    equity_usd: float = 0.0
+    daily_pnl_pct: float = 0.0
+    spread_bps: float = 0.0
+    slippage_bps: float = 0.0
+    infra_degraded: bool = False
+    high_vol: bool = False
+
+
+@dataclass(frozen=True)
+class PortfolioRiskDecision:
+    level: str
+    allow_trade_publish: bool
+    adjusted_notional_usd: float
+    leverage_cap: float
+    risk_multiplier: float
+    reasons: List[str]
+    snapshot: Dict[str, Any]
+
+    def to_dict(self) -> Dict[str, Any]:
+        return {
+            "level": self.level,
+            "allow_trade_publish": bool(self.allow_trade_publish),
+            "adjusted_notional_usd": float(self.adjusted_notional_usd),
+            "leverage_cap": float(self.leverage_cap),
+            "risk_multiplier": float(self.risk_multiplier),
+            "reasons": list(self.reasons),
+            "snapshot": dict(self.snapshot),
+        }
+
+
+def _f(v: Any, default: float = 0.0) -> float:
+    try:
+        return float(v)
+    except Exception:
+        return float(default)
+
+
+def _tier(v: Any) -> str:
+    s = str(v or "B").strip().upper()
+    return s if s in {"A", "B", "C"} else "B"
+
+
+def _level_num(level: str) -> int:
+    return {
+        RISK_ALLOW: 0,
+        RISK_ALLOW_TIGHTENED: 1,
+        RISK_DENY_SOFT: 2,
+        RISK_DENY_HARD: 3,
+        RISK_FORCE_FLATTEN: 4,
+    }.get(level, 3)
+
+
+def evaluate_portfolio_risk(inp: PortfolioRiskInput, limits: Optional[PortfolioRiskLimits] = None) -> PortfolioRiskDecision:
+    lim = limits or PortfolioRiskLimits()
+    symbol = str(inp.symbol or "UNKNOWN").upper()
+    tier = _tier(inp.tier)
+    cluster = str(inp.cluster or symbol)
+    equity = max(0.0, _f(inp.equity_usd))
+    req = max(0.0, _f(inp.requested_notional_usd))
+    positions = list(inp.current_positions or [])
+
+    total_exposure = sum(abs(_f(p.notional_usd)) for p in positions)
+    symbol_exposure = sum(abs(_f(p.notional_usd)) for p in positions if str(p.symbol).upper() == symbol)
+    cluster_exposure = sum(abs(_f(p.notional_usd)) for p in positions if str(p.cluster or "") == cluster)
+
+    total_ratio = (total_exposure / equity) if equity > 0 else 0.0
+    symbol_ratio = (symbol_exposure / equity) if equity > 0 else 0.0
+    cluster_ratio = (cluster_exposure / equity) if equity > 0 else 0.0
+
+    if TRADE_PORTFOLIO_TOTAL_EXPOSURE_RATIO:
+        TRADE_PORTFOLIO_TOTAL_EXPOSURE_RATIO.set(total_ratio)
+    if TRADE_PORTFOLIO_SYMBOL_EXPOSURE_RATIO:
+        TRADE_PORTFOLIO_SYMBOL_EXPOSURE_RATIO.labels(symbol=symbol).set(symbol_ratio)
+    if TRADE_PORTFOLIO_CLUSTER_EXPOSURE_RATIO:
+        TRADE_PORTFOLIO_CLUSTER_EXPOSURE_RATIO.labels(cluster=cluster).set(cluster_ratio)
+
+    leverage_cap = {"A": lim.tier_a_max_leverage, "B": lim.tier_b_max_leverage, "C": lim.tier_c_max_leverage}[tier]
+
+    reasons: List[str] = []
+    level = RISK_ALLOW
+    allow = True
+    risk_multiplier = 1.0
+
+    if _f(inp.daily_pnl_pct) <= -abs(lim.max_daily_loss_pct):
+        level = RISK_FORCE_FLATTEN
+        allow = False
+        reasons.append("daily_loss_limit")
+    elif tier == "C" and inp.infra_degraded and lim.tier_c_block_when_infra_degraded:
+        level = RISK_DENY_HARD
+        allow = False
+        reasons.append("tier_c_infra_degraded")
+    elif equity <= 0 or req <= 0:
+        level = RISK_ALLOW_TIGHTENED
+        reasons.append("insufficient_risk_context")
+        risk_multiplier = 0.5
+    else:
+        projected_total_ratio = (total_exposure + req) / equity
+        projected_symbol_ratio = (symbol_exposure + req) / equity
+        projected_cluster_ratio = (cluster_exposure + req) / equity
+
+        if projected_total_ratio > lim.max_total_exposure_ratio:
+            level = RISK_DENY_HARD
+            allow = False
+            reasons.append("total_exposure_cap")
+        if projected_symbol_ratio > lim.max_symbol_exposure_ratio:
+            level = RISK_DENY_HARD
+            allow = False
+            reasons.append("symbol_exposure_cap")
+        if projected_cluster_ratio > lim.max_cluster_exposure_ratio:
+            level = RISK_DENY_HARD
+            allow = False
+            reasons.append("cluster_exposure_cap")
+
+        spread_bps = _f(inp.spread_bps)
+        slippage_bps = _f(inp.slippage_bps)
+        if allow and (spread_bps > lim.hard_spread_bps_cap or slippage_bps > lim.hard_slippage_bps_cap):
+            level = RISK_DENY_SOFT
+            allow = False
+            reasons.append("market_cost_hard_cap")
+        elif allow and (spread_bps > lim.soft_spread_bps_cap or slippage_bps > lim.soft_slippage_bps_cap or inp.high_vol):
+            level = RISK_ALLOW_TIGHTENED
+            allow = True
+            risk_multiplier = 0.5 if tier != "A" else 0.65
+            reasons.append("market_cost_or_regime_soft_cap")
+
+    adjusted = req * risk_multiplier if allow else 0.0
+
+    if TRADE_RISK_LEVEL:
+        TRADE_RISK_LEVEL.labels(symbol=symbol).set(_level_num(level))
+    if level in {RISK_DENY_SOFT, RISK_DENY_HARD} and TRADE_RISK_DENY_TOTAL:
+        for reason in sorted(set(reasons)):
+            TRADE_RISK_DENY_TOTAL.labels(symbol=symbol, reason=reason, level=level).inc()
+    if level == RISK_FORCE_FLATTEN and TRADE_RISK_FORCE_FLATTEN_TOTAL:
+        for reason in sorted(set(reasons)):
+            TRADE_RISK_FORCE_FLATTEN_TOTAL.labels(symbol=symbol, reason=reason).inc()
+
+    snapshot = {
+        "symbol": symbol,
+        "cluster": cluster,
+        "tier": tier,
+        "equity_usd": equity,
+        "requested_notional_usd": req,
+        "total_exposure_usd": total_exposure,
+        "symbol_exposure_usd": symbol_exposure,
+        "cluster_exposure_usd": cluster_exposure,
+        "total_exposure_ratio": total_ratio,
+        "symbol_exposure_ratio": symbol_ratio,
+        "cluster_exposure_ratio": cluster_ratio,
+        "daily_pnl_pct": _f(inp.daily_pnl_pct),
+        "spread_bps": _f(inp.spread_bps),
+        "slippage_bps": _f(inp.slippage_bps),
+        "infra_degraded": bool(inp.infra_degraded),
+        "high_vol": bool(inp.high_vol),
+    }
+
+    return PortfolioRiskDecision(
+        level=level,
+        allow_trade_publish=allow,
+        adjusted_notional_usd=adjusted,
+        leverage_cap=leverage_cap,
+        risk_multiplier=risk_multiplier,
+        reasons=sorted(set(reasons)),
+        snapshot=snapshot,
+    )
