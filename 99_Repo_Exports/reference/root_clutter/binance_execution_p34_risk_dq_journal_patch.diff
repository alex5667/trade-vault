@@ -0,0 +1,52 @@
+from pathlib import Path
+import importlib.util
+import sys
+
+mod_path = Path(__file__).with_name("execution_journal.py")
+spec = importlib.util.spec_from_file_location("execution_journal", mod_path)
+mod = importlib.util.module_from_spec(spec)
+sys.modules[spec.name] = mod
+assert spec.loader is not None
+spec.loader.exec_module(mod)
+
+
+class FakeCursor:
+    def __init__(self, log):
+        self.log = log
+
+    def __enter__(self):
+        return self
+
+    def __exit__(self, exc_type, exc, tb):
+        return False
+
+    def execute(self, sql, params):
+        self.log.append((sql, params))
+
+
+class FakeConn:
+    def __init__(self, log):
+        self.log = log
+
+    def __enter__(self):
+        return self
+
+    def __exit__(self, exc_type, exc, tb):
+        return False
+
+    def cursor(self):
+        return FakeCursor(self.log)
+
+
+def _factory(log):
+    return lambda dsn: FakeConn(log)
+
+
+def test_record_event_and_snapshot_use_sql_sink():
+    log = []
+    sink = mod.ExecutionJournalSink(dsn="postgres://unit-test", connect_factory=_factory(log))
+    assert sink.record_event({"sid": "sid-1", "symbol": "BTCUSDT", "event_type": "state_transition", "ts_ms": 1}) is True
+    assert sink.upsert_order_snapshot({"sid": "sid-1", "symbol": "BTCUSDT", "fsm_state": "PROTECTED", "ts_ms": 2}) is True
+    assert len(log) == 2
+    assert "execution_order_events" in log[0][0]
+    assert "execution_orders" in log[1][0]
