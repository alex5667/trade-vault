+from pathlib import Path
+import importlib.util
+import sys
+
+mod_path = Path(__file__).with_name("portfolio_risk_engine.py")
+spec = importlib.util.spec_from_file_location("portfolio_risk_engine", mod_path)
+mod = importlib.util.module_from_spec(spec)
+sys.modules[spec.name] = mod
+assert spec.loader is not None
+spec.loader.exec_module(mod)
+
+
+def test_force_flatten_on_daily_loss_limit():
+    inp = mod.PortfolioRiskInput(
+        symbol="BTCUSDT",
+        cluster="majors",
+        tier="A",
+        requested_notional_usd=10_000,
+        equity_usd=5_000,
+        daily_pnl_pct=-3.0,
+    )
+    decision = mod.evaluate_portfolio_risk(inp)
+    assert decision.level == mod.RISK_FORCE_FLATTEN
+    assert decision.allow_trade_publish is False
+    assert "daily_loss_limit" in decision.reasons
+
+
+def test_cluster_exposure_hard_deny():
+    positions = [
+        mod.PortfolioPosition(symbol="BTCUSDT", notional_usd=4_000, cluster="majors"),
+        mod.PortfolioPosition(symbol="ETHUSDT", notional_usd=3_000, cluster="majors"),
+    ]
+    inp = mod.PortfolioRiskInput(
+        symbol="SOLUSDT",
+        cluster="majors",
+        tier="B",
+        requested_notional_usd=2_000,
+        current_positions=positions,
+        equity_usd=5_000,
+    )
+    decision = mod.evaluate_portfolio_risk(inp)
+    assert decision.level == mod.RISK_DENY_HARD
+    assert decision.allow_trade_publish is False
+    assert "cluster_exposure_cap" in decision.reasons
