+    out = (stdout or "").strip()
+    err = (stderr or "").strip()
+    blob = "
+".join([out, err]).strip()
+
+    for line in reversed(blob.splitlines()):
+        line = line.strip()
+        if not line:
+            continue
+        if line.startswith("{") and line.endswith("}"):
+            try:
+                d = json.loads(line)
+                if isinstance(d, dict):
