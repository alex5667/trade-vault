+
+    Exit codes:
+      - 0 -> OK (or no_data)
+      - 2 -> ALERT (missing/invalid/stuck above thresholds)
+      - other -> ERROR
+
+    Dedup/cooldown by signature (issues + key shares).
+    """
+    enabled = os.getenv("ENABLE_WORLD_PRACTICE_SMOKE")
