diff --git a/docker-compose-timers.yml b/docker-compose-timers.yml
index 1b3217a1..c9edfd13 100644
--- a/docker-compose-timers.yml
+++ b/docker-compose-timers.yml
@@ -3347,6 +3347,541 @@ services:
     networks:
       - scanner-network
 
+  # P5.6 Execution Audit Chain Checker Timer
+  # Periodically validates execution linkage across all downstream tables:
+  # execution_orders → signals / signal_execution_plan / trades_closed /
+  # position_events / entry_policy_audit / decision_snapshot
+  # Writes JSON report + Prometheus textfile at EXEC_AUDIT_REPORT_STALE_SECONDS cadence
+  exec-audit-chain-timer:
+    build:
+      context: .
+      dockerfile: python-worker/Dockerfile.gpu
+    container_name: scanner-exec-audit-chain-timer
+    restart: unless-stopped
+    environment:
+      # Database DSN — reuses the analytics DB used by other risk scripts
+      - TRADES_DB_DSN=postgresql://trading:trading_password@scanner-postgres:5432/scanner_analytics
+      # Lookback window for execution_orders seed rows
+      - EXEC_AUDIT_LOOKBACK_HOURS=${EXEC_AUDIT_LOOKBACK_HOURS:-24}
+      # Max number of seed rows to evaluate per run
+      - EXEC_AUDIT_LIMIT=${EXEC_AUDIT_LIMIT:-1000}
+      # Output paths for JSON report and Prometheus textfile exporter
+      - EXEC_AUDIT_REPORT_JSON=/var/lib/trade/exec_audit/latest_execution_audit_chain.json
+      - EXEC_AUDIT_REPORT_PROM=/var/lib/node_exporter/textfile_collector/latest_execution_audit_chain.prom
+      # Stale threshold for the report freshness metric (seconds)
+      - EXEC_AUDIT_REPORT_STALE_SECONDS=${EXEC_AUDIT_REPORT_STALE_SECONDS:-900}
+      # Run cadence: sleep seconds between check iterations
+      - EXEC_AUDIT_CHAIN_INTERVAL_SEC=${EXEC_AUDIT_CHAIN_INTERVAL_SEC:-3600}
+      - PYTHONPATH=.:/app
+      - PYTHONUNBUFFERED=1
+    working_dir: /app
+    volumes:
+      - ./python-worker:/app
+      # Reports directory readable by runbook server
+      - /var/lib/trade/exec_audit:/var/lib/trade/exec_audit
+      # Node exporter textfile collector directory
+      - /var/lib/node_exporter/textfile_collector:/var/lib/node_exporter/textfile_collector
+    command: >
+      sh -c "sleep 30 && while true; do
+        echo '[exec-audit-chain] Running P5.6 execution audit chain check...';
+        python3 scripts/check_execution_audit_chain.py \
+          --dsn \"$$TRADES_DB_DSN\" \
+          --lookback-hours \"$$EXEC_AUDIT_LOOKBACK_HOURS\" \
+          --limit \"$$EXEC_AUDIT_LIMIT\" \
+          --report-json \"$$EXEC_AUDIT_REPORT_JSON\" \
+          --report-prom \"$$EXEC_AUDIT_REPORT_PROM\" && \
+          echo '[exec-audit-chain] Check complete.' || \
+          echo '[exec-audit-chain] Check failed (non-fatal).';
+        echo \"[exec-audit-chain] Sleeping $$EXEC_AUDIT_CHAIN_INTERVAL_SEC seconds...\";
+        sleep \"$$EXEC_AUDIT_CHAIN_INTERVAL_SEC\";
+      done"
+    networks:
+      - scanner-network
+
+  # P4 ExecHealth SLO Checker
+  # Scans metrics:exec_health:scope_state:* keys and writes summary to metrics:exec_health:slo:last
+  # Runs every 30 seconds.
+  exec-health-slo-checker:
+    build:
+      context: .
+      dockerfile: python-worker/Dockerfile.gpu
+    image: scanner-python-worker:latest
+    container_name: scanner-exec-health-slo-checker
+    restart: unless-stopped
+    environment:
+      - REDIS_URL=redis://redis-worker-1:6379/0
+      # P4 SLO: scope-state prefix and flush config
+      - EXEC_HEALTH_SCOPE_STATE_PREFIX=${EXEC_HEALTH_SCOPE_STATE_PREFIX:-metrics:exec_health:scope_state}
+      - EXEC_HEALTH_STATE_FLUSH_INTERVAL_MS=${EXEC_HEALTH_STATE_FLUSH_INTERVAL_MS:-5000}
+      - EXEC_HEALTH_STATE_TTL_S=${EXEC_HEALTH_STATE_TTL_S:-900}
+      # P4 SLO: summary key and staleness budget for the checker
+      - EXEC_HEALTH_SLO_SUMMARY_KEY=${EXEC_HEALTH_SLO_SUMMARY_KEY:-metrics:exec_health:slo:last}
+      - EXEC_HEALTH_SLO_STALE_MS=${EXEC_HEALTH_SLO_STALE_MS:-90000}
+      # P4 SLO: instance / deploy identity (used in scope-state hash)
+      - EXEC_HEALTH_INSTANCE_ID=${EXEC_HEALTH_INSTANCE_ID:-${HOSTNAME:-}}
+      - EXEC_HEALTH_DEPLOY_ID=${EXEC_HEALTH_DEPLOY_ID:-}
+      - PYTHONPATH=.:/app
+      - PYTHONUNBUFFERED=1
+    working_dir: /app
+    volumes:
+      - ./python-worker:/app
+    command: >
+      sh -c "sleep 15 && while true; do
+        python3 -m orderflow_services.exec_health_slo_checker_v1;
+        sleep 30;
+      done"
+    networks:
+      - scanner-network
+
+  # P4 ExecHealth SLO Exporter
+  # Reads metrics:exec_health:slo:last and exposes Prometheus metrics on port 9824
+  exec-health-slo-exporter:
+    build:
+      context: .
+      dockerfile: python-worker/Dockerfile.gpu
+    image: scanner-python-worker:latest
+    container_name: scanner-exec-health-slo-exporter
+    restart: unless-stopped
+    environment:
+      - REDIS_URL=redis://redis-worker-1:6379/0
+      # P4 SLO: summary key (must match checker)
+      - EXEC_HEALTH_SLO_SUMMARY_KEY=${EXEC_HEALTH_SLO_SUMMARY_KEY:-metrics:exec_health:slo:last}
+      - EXEC_HEALTH_SLO_STALE_MS=${EXEC_HEALTH_SLO_STALE_MS:-90000}
+      # P4 SLO: scope-state config (informational, not read by exporter directly)
+      - EXEC_HEALTH_SCOPE_STATE_PREFIX=${EXEC_HEALTH_SCOPE_STATE_PREFIX:-metrics:exec_health:scope_state}
+      - EXEC_HEALTH_STATE_FLUSH_INTERVAL_MS=${EXEC_HEALTH_STATE_FLUSH_INTERVAL_MS:-5000}
+      - EXEC_HEALTH_STATE_TTL_S=${EXEC_HEALTH_STATE_TTL_S:-900}
+      # P4 SLO: exporter port and poll config
+      - EXEC_HEALTH_SLO_EXPORTER_PORT=${EXEC_HEALTH_SLO_EXPORTER_PORT:-9824}
+      - EXEC_HEALTH_SLO_EXPORTER_INTERVAL_S=${EXEC_HEALTH_SLO_EXPORTER_INTERVAL_S:-10}
+      - EXEC_HEALTH_SLO_EXPORTER_STALE_S=${EXEC_HEALTH_SLO_EXPORTER_STALE_S:-180}
+      # P4 SLO: instance / deploy identity (passed through for reference)
+      - EXEC_HEALTH_INSTANCE_ID=${EXEC_HEALTH_INSTANCE_ID:-${HOSTNAME:-}}
+      - EXEC_HEALTH_DEPLOY_ID=${EXEC_HEALTH_DEPLOY_ID:-}
+      - PYTHONPATH=.:/app
+      - PYTHONUNBUFFERED=1
+    working_dir: /app
+    ports:
+      - "9824:9824"
+    volumes:
+      - ./python-worker:/app
+    command: ["python3", "-m", "orderflow_services.exec_health_slo_exporter_v1"]
+    networks:
+      - scanner-network
+
+  # ─────────────────────────────────────────────────────────────────────────────
+  # P5 ExecHealth SLO AutoGuard
+  #
+  # exec-health-slo-autoguard
+  #   Reads metrics:exec_health:slo:last (written by exec-health-slo-checker, P4)
+  #   and applies auto-freeze / optional rollback when either condition is sustained:
+  #     - cross_scope_mode_distinct > 1  (for EXEC_HEALTH_AUTOGUARD_MODE_MISMATCH_MINUTES)
+  #     - rollout_drift_instances_total >= threshold (for EXEC_HEALTH_AUTOGUARD_DRIFT_MINUTES)
+  #   Freeze key: cfg:orderflow:exec_health:auto_freeze:v1
+  #   Rollback:   cfg:orderflow:overrides:v1:active_sid → prev_sid (if enabled)
+  #   Runs every EXEC_HEALTH_AUTOGUARD_CHECK_EVERY_S seconds (default: 30).
+  #   Fail-open: if P4 summary key is missing, no action is taken.
+  # ─────────────────────────────────────────────────────────────────────────────
+  exec-health-slo-autoguard:
+    build:
+      context: .
+      dockerfile: python-worker/Dockerfile
+    image: scanner-python-worker:latest
+    container_name: scanner-exec-health-slo-autoguard
+    restart: unless-stopped
+    environment:
+      - REDIS_URL=${REDIS_URL:-redis://redis-worker-1:6379/0}
+      # P4 summary key — single source of truth for SLO state
+      - EXEC_HEALTH_SLO_SUMMARY_KEY=${EXEC_HEALTH_SLO_SUMMARY_KEY:-metrics:exec_health:slo:last}
+      # P5 state key written by this service
+      - EXEC_HEALTH_SLO_AUTOGUARD_STATE_KEY=${EXEC_HEALTH_SLO_AUTOGUARD_STATE_KEY:-metrics:exec_health:slo:autoguard:state}
+      # Freeze key consumed by downstream services
+      - EXEC_HEALTH_AUTO_FREEZE_KEY=${EXEC_HEALTH_AUTO_FREEZE_KEY:-cfg:orderflow:exec_health:auto_freeze:v1}
+      # P7: latched control hash (thaw requires explicit operator ack)
+      - EXEC_HEALTH_FREEZE_CONTROL_KEY=${EXEC_HEALTH_FREEZE_CONTROL_KEY:-cfg:orderflow:exec_health:freeze_control:v1}
+      # Telegram notification stream (optional)
+      - EXEC_HEALTH_AUTOGUARD_NOTIFY_STREAM=${EXEC_HEALTH_AUTOGUARD_NOTIFY_STREAM:-notify:telegram}
+      # Set to 0 to disable autoguard entirely without stopping the container
+      - EXEC_HEALTH_AUTOGUARD_ENABLE=${EXEC_HEALTH_AUTOGUARD_ENABLE:-1}
+      # Check loop cadence in seconds (min 5)
+      - EXEC_HEALTH_AUTOGUARD_CHECK_EVERY_S=${EXEC_HEALTH_AUTOGUARD_CHECK_EVERY_S:-30}
+      # Minutes cross_scope_mode_distinct > 1 must be sustained before firing
+      - EXEC_HEALTH_AUTOGUARD_MODE_MISMATCH_MINUTES=${EXEC_HEALTH_AUTOGUARD_MODE_MISMATCH_MINUTES:-5}
+      # Minutes rollout_drift must be sustained before firing
+      - EXEC_HEALTH_AUTOGUARD_DRIFT_MINUTES=${EXEC_HEALTH_AUTOGUARD_DRIFT_MINUTES:-10}
+      # Minimum number of drift instances to count as drift (default 1)
+      - EXEC_HEALTH_AUTOGUARD_DRIFT_INSTANCES_MIN=${EXEC_HEALTH_AUTOGUARD_DRIFT_INSTANCES_MIN:-1}
+      # Freeze duration in minutes
+      - EXEC_HEALTH_AUTOGUARD_FREEZE_MINUTES=${EXEC_HEALTH_AUTOGUARD_FREEZE_MINUTES:-30}
+      # Cooldown: no re-trigger for this many minutes after a trigger
+      - EXEC_HEALTH_AUTOGUARD_COOLDOWN_MINUTES=${EXEC_HEALTH_AUTOGUARD_COOLDOWN_MINUTES:-30}
+      # Master rollback switch — set to 0 to disable all rollback actions
+      - EXEC_HEALTH_AUTOGUARD_ROLLBACK_ENABLE=${EXEC_HEALTH_AUTOGUARD_ROLLBACK_ENABLE:-1}
+      # Enable rollback on mode mismatch trigger
+      - EXEC_HEALTH_AUTOGUARD_ROLLBACK_ON_MODE_MISMATCH=${EXEC_HEALTH_AUTOGUARD_ROLLBACK_ON_MODE_MISMATCH:-1}
+      # Enable rollback on rollout drift trigger (default off — conservative)
+      - EXEC_HEALTH_AUTOGUARD_ROLLBACK_ON_DRIFT=${EXEC_HEALTH_AUTOGUARD_ROLLBACK_ON_DRIFT:-0}
+      # P8: event stream for signed ack audit events
+      - EXEC_HEALTH_FREEZE_EVENT_STREAM=${EXEC_HEALTH_FREEZE_EVENT_STREAM:-ops:exec_health:freeze_events:v1}
+      # P8: HMAC signing secret for autoguard latch nonce (must match operator thaw CLI)
+      - EXEC_HEALTH_ACK_SIGNING_SECRET=${EXEC_HEALTH_ACK_SIGNING_SECRET:-}
+      - PYTHONPATH=.:/app
+      - PYTHONUNBUFFERED=1
+    working_dir: /app
+    volumes:
+      - ./python-worker:/app
+    command: ["python3", "-m", "orderflow_services.exec_health_slo_autoguard_v1"]
+    networks:
+      - scanner-network
+
+  # ─────────────────────────────────────────────────────────────────────────────
+  # P5 ExecHealth SLO AutoGuard Exporter
+  #
+  # exec-health-slo-autoguard-exporter
+  #   Reads metrics:exec_health:slo:autoguard:state (written by exec-health-slo-autoguard)
+  #   and exposes Prometheus metrics on port 9825.
+  #   Metrics exposed:
+  #     exec_health_slo_autoguard_exporter_up
+  #     exec_health_slo_autoguard_freeze_active
+  #     exec_health_slo_autoguard_freeze_remaining_seconds
+  #     exec_health_slo_autoguard_mode_mismatch_active
+  #     exec_health_slo_autoguard_rollout_drift_active
+  #     exec_health_slo_autoguard_last_trigger_ts_ms
+  #     exec_health_slo_autoguard_last_rollback_ts_ms
+  #     exec_health_slo_autoguard_rollback_total
+  #     exec_health_slo_autoguard_state_age_seconds
+  # ─────────────────────────────────────────────────────────────────────────────
+  exec-health-slo-autoguard-exporter:
+    build:
+      context: .
+      dockerfile: python-worker/Dockerfile
+    image: scanner-python-worker:latest
+    container_name: scanner-exec-health-slo-autoguard-exporter
+    restart: unless-stopped
+    environment:
+      - REDIS_URL=${REDIS_URL:-redis://redis-worker-1:6379/0}
+      - EXEC_HEALTH_SLO_AUTOGUARD_STATE_KEY=${EXEC_HEALTH_SLO_AUTOGUARD_STATE_KEY:-metrics:exec_health:slo:autoguard:state}
+      - EXEC_HEALTH_SLO_AUTOGUARD_EXPORTER_PORT=${EXEC_HEALTH_SLO_AUTOGUARD_EXPORTER_PORT:-9825}
+      - EXEC_HEALTH_SLO_AUTOGUARD_EXPORTER_INTERVAL_S=${EXEC_HEALTH_SLO_AUTOGUARD_EXPORTER_INTERVAL_S:-10}
+      - PYTHONPATH=.:/app
+      - PYTHONUNBUFFERED=1
+    working_dir: /app
+    ports:
+      - "9825:9825"
+    volumes:
+      - ./python-worker:/app
+    command: ["python3", "-m", "orderflow_services.exec_health_slo_autoguard_exporter_v1"]
+    networks:
+      - scanner-network
+
+
+  # ─────────────────────────────────────────────────────────────────────────────
+  # P7 ExecHealth Freeze Control Exporter
+  #
+  # exec-health-freeze-control-exporter
+  #   Reads cfg:orderflow:exec_health:freeze_control:v1 (latched P7 control hash)
+  #   and exposes Prometheus metrics on port 9827.
+  #
+  #   P7 adds a latched control layer over the P5 raw freeze key so that a
+  #   simple key deletion can no longer bypass the auto-freeze. Thawing requires
+  #   an explicit operator ack with operator / reason / ticket fields.
+  #
+  #   Metrics exposed:
+  #     exec_health_freeze_control_exporter_up
+  #     exec_health_freeze_control_effective_active
+  #     exec_health_freeze_control_manual_ack_required
+  #     exec_health_freeze_control_manual_override_active
+  #     exec_health_freeze_control_state_age_seconds
+  #     exec_health_freeze_control_manual_ack_age_seconds
+  #     exec_health_freeze_control_trigger_total
+  #     exec_health_freeze_control_thaw_total
+  #     exec_health_freeze_control_manual_freeze_total
+  #     exec_health_freeze_control_source{source=...}
+  # ─────────────────────────────────────────────────────────────────────────────
+  exec-health-freeze-control-exporter:
+    build:
+      context: .
+      dockerfile: python-worker/Dockerfile
+    image: scanner-python-worker:latest
+    container_name: scanner-exec-health-freeze-control-exporter
+    restart: unless-stopped
+    environment:
+      - REDIS_URL=${REDIS_URL:-redis://redis-worker-1:6379/0}
+      # P7 latched control hash key (must match exec-health-slo-autoguard)
+      - EXEC_HEALTH_FREEZE_CONTROL_KEY=${EXEC_HEALTH_FREEZE_CONTROL_KEY:-cfg:orderflow:exec_health:freeze_control:v1}
+      # Exporter port (9827: distinct from SLO=9824, autoguard=9825)
+      - EXEC_HEALTH_FREEZE_CONTROL_EXPORTER_PORT=${EXEC_HEALTH_FREEZE_CONTROL_EXPORTER_PORT:-9827}
+      # Poll interval in seconds
+      - EXEC_HEALTH_FREEZE_CONTROL_EXPORTER_INTERVAL_S=${EXEC_HEALTH_FREEZE_CONTROL_EXPORTER_INTERVAL_S:-10}
+      - PYTHONPATH=.:/app
+      - PYTHONUNBUFFERED=1
+    working_dir: /app
+    ports:
+      - "9827:9827"
+    volumes:
+      - ./python-worker:/app
+    command: ["python3", "-m", "orderflow_services.exec_health_freeze_control_exporter_v1"]
+    networks:
+      - scanner-network
+
+
+  # ─────────────────────────────────────────────────────────────────────────────
+  # P8 ExecHealth Freeze Integrity Exporter
+  #
+  # exec-health-freeze-integrity-exporter
+  #   Reads the P7 control hash, autoguard state hash, and P8 audit event stream
+  #   and evaluates whether any tamper / unsigned-thaw violation has occurred.
+  #   Port 9828 (distinct from SLO=9824, autoguard=9825, freeze-control=9827).
+  #
+  #   Violations detected:
+  #     control_missing_pending_ack, state_missing_pending_ack,
+  #     control_state_missing_without_valid_ack, thaw_without_valid_ack_event,
+  #     invalid_ack_event_signature, invalid_control_ack_signature
+  #
+  #   Requires: EXEC_HEALTH_ACK_SIGNING_SECRET (same secret used by autoguard
+  #             and exec_health_freeze_override_v1.py thaw command).
+  # ─────────────────────────────────────────────────────────────────────────────
+  exec-health-freeze-integrity-exporter:
+    build:
+      context: .
+      dockerfile: python-worker/Dockerfile
+    image: scanner-python-worker:latest
+    container_name: scanner-exec-health-freeze-integrity-exporter
+    restart: unless-stopped
+    environment:
+      - REDIS_URL=${REDIS_URL:-redis://redis-worker-1:6379/0}
+      # P7 control hash key (must match autoguard and override service)
+      - EXEC_HEALTH_FREEZE_CONTROL_KEY=${EXEC_HEALTH_FREEZE_CONTROL_KEY:-cfg:orderflow:exec_health:freeze_control:v1}
+      # P5 autoguard state hash key (fallback path)
+      - EXEC_HEALTH_SLO_AUTOGUARD_STATE_KEY=${EXEC_HEALTH_SLO_AUTOGUARD_STATE_KEY:-metrics:exec_health:slo:autoguard:state}
+      # P8 audit event stream key
+      - EXEC_HEALTH_FREEZE_EVENT_STREAM=${EXEC_HEALTH_FREEZE_EVENT_STREAM:-ops:exec_health:freeze_events:v1}
+      # P8 HMAC signing secret (must match exec-health-slo-autoguard and operator thaw CLI)
+      - EXEC_HEALTH_ACK_SIGNING_SECRET=${EXEC_HEALTH_ACK_SIGNING_SECRET:-}
+      # Exporter port (9828)
+      - EXEC_HEALTH_FREEZE_INTEGRITY_EXPORTER_PORT=${EXEC_HEALTH_FREEZE_INTEGRITY_EXPORTER_PORT:-9828}
+      # Poll interval in seconds
+      - EXEC_HEALTH_FREEZE_INTEGRITY_EXPORTER_INTERVAL_S=${EXEC_HEALTH_FREEZE_INTEGRITY_EXPORTER_INTERVAL_S:-10}
+      # Number of recent stream events to scan for ack verification
+      - EXEC_HEALTH_FREEZE_INTEGRITY_EVENT_COUNT=${EXEC_HEALTH_FREEZE_INTEGRITY_EVENT_COUNT:-100}
+      - PYTHONPATH=.:/app
+      - PYTHONUNBUFFERED=1
+    working_dir: /app
+    ports:
+      - "9828:9828"
+    volumes:
+      - ./python-worker:/app
+    command: ["python3", "-m", "orderflow_services.exec_health_freeze_integrity_exporter_v1"]
+    networks:
+      - scanner-network
+
+
+  # ─────────────────────────────────────────────────────────────────────────────
+  # P9 ExecHealth Freeze Dual-Control Exporter
+  #
+  # exec-health-freeze-dual-control-exporter
+  #   Reads the P7 control hash, autoguard state hash, and P8 audit event stream
+  #   and evaluates whether the dual-control thaw chain (prepare → approve → commit)
+  #   is consistent, signed, and free of same-operator violations.
+  #   Port 9829 (distinct from SLO=9824, autoguard=9825, freeze-control=9827, integrity=9828).
+  #
+  #   Violations detected:
+  #     same_operator_dual_control_violation, commit_without_approval,
+  #     commit_without_prepare, invalid_commit_signature,
+  #     invalid_control_commit_signature
+  #
+  #   Requires: EXEC_HEALTH_ACK_SIGNING_SECRET (same secret used by autoguard
+  #             and exec_health_freeze_override_v1.py commit-thaw command).
+  # ─────────────────────────────────────────────────────────────────────────────
+  exec-health-freeze-dual-control-exporter:
+    build:
+      context: .
+      dockerfile: python-worker/Dockerfile
+    image: scanner-python-worker:latest
+    container_name: scanner-exec-health-freeze-dual-control-exporter
+    restart: unless-stopped
+    environment:
+      - REDIS_URL=${REDIS_URL:-redis://redis-worker-1:6379/0}
+      # P7 control hash key (must match autoguard and override service)
+      - EXEC_HEALTH_FREEZE_CONTROL_KEY=${EXEC_HEALTH_FREEZE_CONTROL_KEY:-cfg:orderflow:exec_health:freeze_control:v1}
+      # P5 autoguard state hash key (fallback path)
+      - EXEC_HEALTH_SLO_AUTOGUARD_STATE_KEY=${EXEC_HEALTH_SLO_AUTOGUARD_STATE_KEY:-metrics:exec_health:slo:autoguard:state}
+      # P8 audit event stream key (contains prepare/approve/commit events)
+      - EXEC_HEALTH_FREEZE_EVENT_STREAM=${EXEC_HEALTH_FREEZE_EVENT_STREAM:-ops:exec_health:freeze_events:v1}
+      # P9 HMAC signing secret (must match exec-health-slo-autoguard and operator commit-thaw CLI)
+      - EXEC_HEALTH_ACK_SIGNING_SECRET=${EXEC_HEALTH_ACK_SIGNING_SECRET:-}
+      # P9: set to 0 to disable dual-control enforcement and allow legacy P8 single-operator thaw
+      - EXEC_HEALTH_REQUIRE_DUAL_CONTROL_ACK=${EXEC_HEALTH_REQUIRE_DUAL_CONTROL_ACK:-1}
+      # Exporter port (9829)
+      - EXEC_HEALTH_FREEZE_DUAL_CONTROL_EXPORTER_PORT=${EXEC_HEALTH_FREEZE_DUAL_CONTROL_EXPORTER_PORT:-9829}
+      # Poll interval in seconds
+      - EXEC_HEALTH_FREEZE_DUAL_CONTROL_EXPORTER_INTERVAL_S=${EXEC_HEALTH_FREEZE_DUAL_CONTROL_EXPORTER_INTERVAL_S:-10}
+      # Number of recent stream events to scan for dual-control verification
+      - EXEC_HEALTH_FREEZE_DUAL_CONTROL_EVENT_COUNT=${EXEC_HEALTH_FREEZE_DUAL_CONTROL_EVENT_COUNT:-100}
+      - PYTHONPATH=.:/app
+      - PYTHONUNBUFFERED=1
+    working_dir: /app
+    ports:
+      - "9829:9829"
+    volumes:
+      - ./python-worker:/app
+    command: ["python3", "-m", "orderflow_services.exec_health_freeze_dual_control_exporter_v1"]
+    networks:
+      - scanner-network
+
+
+  # ─────────────────────────────────────────────────────────────────────────────
+  # P10 ExecHealth Freeze Tamper Guard
+  # Порт 9830. Мониторит request log + control/state хеши. При tamper → автозаморозка.
+  # ─────────────────────────────────────────────────────────────────────────────
+  exec-health-freeze-tamper-guard:
+    build:
+      context: .
+      dockerfile: python-worker/Dockerfile
+    image: scanner-python-worker:latest
+    container_name: scanner-exec-health-freeze-tamper-guard
+    restart: unless-stopped
+    environment:
+      - REDIS_URL=${REDIS_URL:-redis://redis-worker-1:6379/0}
+      - EXEC_HEALTH_FREEZE_CONTROL_KEY=${EXEC_HEALTH_FREEZE_CONTROL_KEY:-cfg:orderflow:exec_health:freeze_control:v1}
+      - EXEC_HEALTH_SLO_AUTOGUARD_STATE_KEY=${EXEC_HEALTH_SLO_AUTOGUARD_STATE_KEY:-metrics:exec_health:slo:autoguard:state}
+      - EXEC_HEALTH_AUTO_FREEZE_KEY=${EXEC_HEALTH_AUTO_FREEZE_KEY:-cfg:orderflow:exec_health:auto_freeze:v1}
+      - EXEC_HEALTH_FREEZE_EVENT_STREAM=${EXEC_HEALTH_FREEZE_EVENT_STREAM:-ops:exec_health:freeze_events:v1}
+      - EXEC_HEALTH_FREEZE_REQUEST_STREAM=${EXEC_HEALTH_FREEZE_REQUEST_STREAM:-ops:exec_health:freeze_requests:v1}
+      - EXEC_HEALTH_ACK_SIGNING_SECRET=${EXEC_HEALTH_ACK_SIGNING_SECRET:-}
+      - EXEC_HEALTH_TAMPER_GUARD_EXPORTER_PORT=${EXEC_HEALTH_TAMPER_GUARD_EXPORTER_PORT:-9830}
+      - EXEC_HEALTH_TAMPER_GUARD_INTERVAL_S=${EXEC_HEALTH_TAMPER_GUARD_INTERVAL_S:-10}
+      - EXEC_HEALTH_TAMPER_GUARD_COOLDOWN_S=${EXEC_HEALTH_TAMPER_GUARD_COOLDOWN_S:-300}
+      - EXEC_HEALTH_TAMPER_GUARD_FREEZE_MINUTES=${EXEC_HEALTH_TAMPER_GUARD_FREEZE_MINUTES:-30}
+      - EXEC_HEALTH_FREEZE_INTEGRITY_EVENT_COUNT=${EXEC_HEALTH_FREEZE_INTEGRITY_EVENT_COUNT:-100}
+      - EXEC_HEALTH_FREEZE_REQUEST_EVENT_COUNT=${EXEC_HEALTH_FREEZE_REQUEST_EVENT_COUNT:-200}
+      - EXEC_HEALTH_AUTOGUARD_NOTIFY_STREAM=${EXEC_HEALTH_AUTOGUARD_NOTIFY_STREAM:-notify:telegram}
+      - PYTHONPATH=.:/app
+      - PYTHONUNBUFFERED=1
+    working_dir: /app
+    ports:
+      - "${EXEC_HEALTH_TAMPER_GUARD_EXPORTER_PORT:-9830}:${EXEC_HEALTH_TAMPER_GUARD_EXPORTER_PORT:-9830}"
+    volumes:
+      - ./python-worker:/app
+    command: ["python3", "-m", "orderflow_services.exec_health_freeze_tamper_guard_v1"]
+    networks:
+      - scanner-network
+
+
+  # ─────────────────────────────────────────────────────────────────────────────
+  # P11 ExecHealth Freeze ACL Audit Exporter
+  #
+  # exec-health-freeze-acl-audit-exporter
+  #   Мониторит Redis ACL LOG на попытки прямых HSET/HDEL/DEL/EVAL на freeze-control ключах.
+  #   Каждое denied attempt = policy violation → Prometheus метрики на порту 9831.
+  #
+  #   Метрики:
+  #     exec_health_freeze_acl_audit_up
+  #     exec_health_freeze_acl_audit_state_age_seconds
+  #     exec_health_freeze_acl_violation_total{user,reason,command}
+  #     exec_health_freeze_acl_violation_active{command}
+  #
+  #   Требует: EXEC_HEALTH_FREEZE_SEAL_SECRET (для sealed writes)
+  # ─────────────────────────────────────────────────────────────────────────────
+  exec-health-freeze-acl-audit-exporter:
+    build:
+      context: .
+      dockerfile: python-worker/Dockerfile
+    image: scanner-python-worker:latest
+    container_name: scanner-exec-health-freeze-acl-audit-exporter
+    restart: unless-stopped
+    environment:
+      - REDIS_URL=${REDIS_URL:-redis://redis-worker-1:6379/0}
+      # P11: seal secret — тот же что у autoguard и override CLI
+      - EXEC_HEALTH_FREEZE_SEAL_SECRET=${EXEC_HEALTH_FREEZE_SEAL_SECRET:-}
+      # 1 = enforce seal (recommended); 0 = disable temporarily during bootstrap
+      - EXEC_HEALTH_FREEZE_SEAL_ENFORCE=${EXEC_HEALTH_FREEZE_SEAL_ENFORCE:-1}
+      # ACL audit state key
+      - EXEC_HEALTH_FREEZE_ACL_AUDIT_STATE_KEY=${EXEC_HEALTH_FREEZE_ACL_AUDIT_STATE_KEY:-metrics:exec_health:freeze_acl_audit:last}
+      # Interval between ACL LOG polls in seconds
+      - EXEC_HEALTH_FREEZE_ACL_AUDIT_INTERVAL_S=${EXEC_HEALTH_FREEZE_ACL_AUDIT_INTERVAL_S:-30}
+      # Exporter port (9831, distinct from tamper-guard=9830)
+      - EXEC_HEALTH_FREEZE_ACL_AUDIT_EXPORTER_PORT=${EXEC_HEALTH_FREEZE_ACL_AUDIT_EXPORTER_PORT:-9831}
+      - PYTHONPATH=.:/app
+      - PYTHONUNBUFFERED=1
+    working_dir: /app
+    ports:
+      - "${EXEC_HEALTH_FREEZE_ACL_AUDIT_EXPORTER_PORT:-9831}:${EXEC_HEALTH_FREEZE_ACL_AUDIT_EXPORTER_PORT:-9831}"
+    volumes:
+      - ./python-worker:/app
+    command: ["python3", "-m", "orderflow_services.exec_health_freeze_acl_audit_exporter_v1"]
+    networks:
+      - scanner-network
+
+
+  # P5.7 Execution audit-chain periodic checker (compose / scheduler wiring)
+  # Long-running service that invokes the P5.6 checker on a configurable interval.
+  # Checker logic is NOT duplicated here—this is a pure orchestration wrapper.
+  # JSON report and .prom textfile are written to bind-mounted runtime dirs so
+  # node_exporter (textfile collector) and the runbook server see the same SoT.
+  execution-audit-chain-checker:
+    build:
+      context: .
+      dockerfile: python-worker/Dockerfile.gpu
+    container_name: scanner-execution-audit-chain-checker
+    image: scanner-python-worker-gpu
+    restart: unless-stopped
+    environment:
+      - PYTHONPATH=.:/app
+      - TRADES_DB_DSN=${TRADES_DB_DSN:-}
+      - EXEC_AUDIT_LOOKBACK_HOURS=${EXEC_AUDIT_LOOKBACK_HOURS:-24}
+      - EXEC_AUDIT_LIMIT=${EXEC_AUDIT_LIMIT:-1000}
+      - EXEC_AUDIT_REPORT_STALE_SECONDS=${EXEC_AUDIT_REPORT_STALE_SECONDS:-900}
+      - EXEC_AUDIT_REPORT_JSON=/var/lib/trade/runbooks/latest_execution_audit_chain.json
+      - EXEC_AUDIT_REPORT_PROM=/var/lib/node_exporter/textfile_collector/latest_execution_audit_chain.prom
+      # Loop orchestration (P5.7 scheduler)
+      - EXEC_AUDIT_LOOP_INTERVAL_SECONDS=${EXEC_AUDIT_LOOP_INTERVAL_SECONDS:-300}
+      - EXEC_AUDIT_LOOP_FAILURE_SLEEP_SECONDS=${EXEC_AUDIT_LOOP_FAILURE_SLEEP_SECONDS:-30}
+      - EXEC_AUDIT_LOOP_INITIAL_DELAY_SECONDS=${EXEC_AUDIT_LOOP_INITIAL_DELAY_SECONDS:-20}
+      - EXEC_AUDIT_LOOP_RUN_ON_START=${EXEC_AUDIT_LOOP_RUN_ON_START:-1}
+      - PYTHONUNBUFFERED=1
+    working_dir: /app
+    volumes:
+      - ./python-worker:/app
+      # Bind-mount runtime dirs so reports are accessible from the host
+      # and shared with the runbook server container.
+      - ./runtime/execution_audit_chain:/var/lib/trade/runbooks
+      - ./runtime/node_exporter_textfile:/var/lib/node_exporter/textfile_collector
+    command: ["python3", "/app/scripts/run_execution_audit_chain_scheduler.py"]
+    networks:
+      - scanner-network
+    profiles: ["ops"]
+
+  # P5.7 Runbook server for latest execution audit-chain report.
+  # Exposes GET /api/audit-chain/latest -> latest_execution_audit_chain.json
+  # Reads the same bind-mount as the checker (read-only).
+  execution-audit-runbook-server:
+    build:
+      context: .
+      dockerfile: python-worker/Dockerfile.gpu
+    container_name: scanner-execution-audit-runbook-server
+    image: scanner-python-worker-gpu
+    restart: unless-stopped
+    environment:
+      - PYTHONPATH=.:/app
+      - EXEC_AUDIT_REPORT_JSON=/var/lib/trade/runbooks/latest_execution_audit_chain.json
+      - RUNBOOK_SERVER_BIND=${RUNBOOK_SERVER_BIND:-0.0.0.0}
+      - RUNBOOK_SERVER_PORT=${RUNBOOK_SERVER_PORT:-8777}
+      - PYTHONUNBUFFERED=1
+    depends_on:
+      - execution-audit-chain-checker
+    working_dir: /app
+    volumes:
+      - ./python-worker:/app
+      # Read-only: server only consumes the report, checker writes it
+      - ./runtime/execution_audit_chain:/var/lib/trade/runbooks:ro
+    ports:
+      - "${RUNBOOK_SERVER_PORT:-8777}:${RUNBOOK_SERVER_PORT:-8777}"
+    command: ["python3", "/app/runbooks/server/runbook_server.py"]
+    networks:
+      - scanner-network
+    profiles: ["ops"]
+
