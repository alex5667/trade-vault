+      - PIPELINE_EXEC_HEALTH_MODE=monitor      # SignalPipeline (pre-publish)
+      - ENTRY_EXEC_HEALTH_MODE=monitor         # EntryPolicyService
+      # Venue / TF для формирования Redis-ключей
+      - EXEC_HEALTH_VENUE=binance
+      - EXEC_HEALTH_TF=all
+      # Kill-switch для EntryPolicy (1=enabled, 0=disable без перезапуска)
+      - EXEC_HEALTH_ENTRY_POLICY_ENABLED=1
+      # Пороги TCA: 0 = порог отключён (gate не срабатывает даже в режиме tighten/veto)
       - EXEC_MAX_IS_P95_BPS=0
       - EXEC_MAX_PERM_IMPACT_P95_BPS=0
       - EXEC_MIN_REALIZED_SPREAD_P50_BPS=-999
-      # Delta list (seconds) for perm_impact and realized_spread rollup keys
+      # Delta-окна (сек) для perm_impact и realized_spread rollup-ключей
       - EXEC_TCA_DELTA_SEC_LIST=1,5
-      # Tighten knobs (bounded add to slippage_bps)
-      - EDGE_EXEC_HEALTH_TIGHTEN_ADD_MULT=1.0
-      - EDGE_EXEC_HEALTH_TIGHTEN_ADD_CAP_BPS=8.0
-      - EDGE_EXEC_HEALTH_TIGHTEN_K_MULT=1.0
-      # Adverse selection veto (opt-in): 0=off, 1=on (combine with IS+impact flags)
-      - EDGE_EXEC_HEALTH_VETO_ON_ADVERSE=0
+      # Параметры tighten: ограниченное добавление к slippage_bps
+      - EXEC_TIGHTEN_ADD_MULT=1.0
+      - EXEC_TIGHTEN_ADD_CAP_BPS=8.0
+      # Множитель K для EdgeCostGate (k_eff *= tighten_k_mult)
+      - EXEC_TIGHTEN_K_MULT=1.0
+      # Adverse selection veto (opt-in): 0=off, 1=on
+      - EXEC_VETO_ON_ADVERSE=0
+      # Требовать оба флага (IS + perm_impact) для veto: 1=да, 0=любого достаточно
+      - EXEC_VETO_REQUIRE_BOTH_IS_AND_IMPACT=1
       - MIN_CONF_DEFAULT=50
       - MIN_CONF_BTCUSDT=75
       - MIN_CONF_ETHUSDT=72
