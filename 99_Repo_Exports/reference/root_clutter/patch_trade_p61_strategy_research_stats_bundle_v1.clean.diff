+from ml_analysis.pbo_cscv import compute_pbo
+
+
+def test_compute_pbo_prefers_consistent_variant():
+    matrix = {
+        'A': [0.30, 0.28, 0.27, 0.29, 0.31, 0.26, 0.28, 0.30],
+        'B': [0.05, 0.02, 0.01, 0.04, 0.03, 0.02, 0.01, 0.00],
+        'C': [-0.02, 0.00, -0.01, -0.03, 0.01, -0.02, 0.00, -0.01],
+    }
+    out = compute_pbo(matrix, n_folds=8)
+    assert out['cscv_splits'] > 0
+    assert 0.0 <= out['pbo'] <= 1.0
+    assert out['pbo'] < 0.5
diff --git a/ml_analysis/tests/test_psr_dsr.py b/ml_analysis/tests/test_psr_dsr.py
new file mode 100644
index 0000000..6f575df
