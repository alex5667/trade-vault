+++ b/ml_analysis/tests/test_psr_dsr.py
@@ -0,0 +1,15 @@
+from ml_analysis.psr_dsr import probabilistic_sharpe_ratio, deflated_sharpe_ratio
+
+
+def test_psr_positive_series_high():
+    xs = [0.3, 0.2, 0.25, 0.18, 0.22, 0.27, 0.19, 0.24]
+    psr = probabilistic_sharpe_ratio(xs)
+    dsr = deflated_sharpe_ratio(xs, n_trials=4)
+    assert psr > 0.5
+    assert 0.0 <= dsr <= psr <= 1.0
+
+
+def test_psr_negative_series_low():
+    xs = [-0.3, -0.2, -0.25, -0.18, -0.22, -0.27, -0.19, -0.24]
+    psr = probabilistic_sharpe_ratio(xs)
+    assert psr < 0.5
