+from orderflow_services.strategy_research_stats_gate_v1 import evaluate_strategy_research_stats_gate
+
+
+class FakeRedis:
+    def __init__(self, hashes):
+        self.hashes = hashes
+
+    def hgetall(self, key):
+        return dict(self.hashes.get(key, {}))
+
+
+def test_hard_block_from_blocker():
+    r = FakeRedis({
+        'blocker': {'gate_mode': 'hard', 'blocked': '1', 'reason': 'psr_low', 'updated_ts_ms': '9999999999999'},
+        'summary': {'gate_mode': 'hard', 'updated_ts_ms': '9999999999999'},
+    })
+    state = evaluate_strategy_research_stats_gate('redis://unused', 'blocker', 'summary', client=r)
+    assert state['status'] == 'block'
+    assert state['reason'] == 'psr_low'
+
+
+def test_soft_block_from_blocker():
+    r = FakeRedis({
+        'blocker': {'gate_mode': 'soft', 'soft_blocked': '1', 'reason': 'pbo_high', 'updated_ts_ms': '9999999999999'},
+        'summary': {'gate_mode': 'soft', 'updated_ts_ms': '9999999999999'},
+    })
+    state = evaluate_strategy_research_stats_gate('redis://unused', 'blocker', 'summary', client=r)
+    assert state['status'] == 'soft'
+    assert state['reason'] == 'pbo_high'
+
+
+def test_missing_state_fail_open_in_report_only():
+    r = FakeRedis({})
+    state = evaluate_strategy_research_stats_gate('redis://unused', 'blocker', 'summary', client=r, fail_closed_missing=1)
+    assert state['status'] in ('ok', 'invalid')
