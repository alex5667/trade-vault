@@ -0,0 +1,77 @@
+import json
+import sys
+from pathlib import Path
+
+from ml_analysis.tools import nightly_strategy_research_stats_bundle_v1 as mod
+
+
+class FakeRedis:
+    def __init__(self):
+        self.data = {}
+
+    def hset(self, key, mapping):
+        self.data[key] = dict(mapping)
+
+
+def _write_rows(path: Path, rows):
+    with path.open('w', encoding='utf-8') as f:
+        for row in rows:
+            f.write(json.dumps(row) + '\n')
+
+
+def test_bundle_report_only_writes_summary_and_blocker(tmp_path, monkeypatch):
+    ds = tmp_path / 'dataset.jsonl'
+    rows = []
+    for period in range(8):
+        for variant, base in [('A', 0.30), ('B', 0.05)]:
+            rows.append({
+                'variant': variant,
+                'period': f'p{period}',
+                'score': 0.9 if variant == 'A' else 0.3,
+                'label': 1 if variant == 'A' else 0,
+                'net_r': base + (period * 0.001),
+                'r': base + (period * 0.001),
+                'cost_bps': 1.0,
+            })
+    _write_rows(ds, rows)
+    fake = FakeRedis()
+    monkeypatch.setattr(mod, '_redis', lambda: fake)
+    old = sys.argv[:]
+    sys.argv = ['bundle', '--dataset-path', str(ds), '--out-dir', str(tmp_path), '--gate-mode', 'report_only']
+    try:
+        rc = mod.main()
+    finally:
+        sys.argv = old
+    assert rc == 0
+    assert 'metrics:strategy_research_stats:last' in fake.data
+    assert 'cfg:strategy_research_stats:blocker:v1' in fake.data
+    assert fake.data['cfg:strategy_research_stats:blocker:v1']['blocked'] == '0'
+
+
+def test_bundle_hard_gate_blocks_bad_metrics(tmp_path, monkeypatch):
+    ds = tmp_path / 'dataset_bad.jsonl'
+    rows = []
+    for period in range(8):
+        for variant, base in [('A', -0.30), ('B', -0.10)]:
+            rows.append({
+                'variant': variant,
+                'period': f'p{period}',
+                'score': 0.4,
+                'label': 0,
+                'net_r': base - (period * 0.001),
+                'r': base - (period * 0.001),
+                'cost_bps': 1.0,
+            })
+    _write_rows(ds, rows)
+    fake = FakeRedis()
+    monkeypatch.setattr(mod, '_redis', lambda: fake)
+    old = sys.argv[:]
+    sys.argv = ['bundle', '--dataset-path', str(ds), '--out-dir', str(tmp_path), '--gate-mode', 'hard', '--min-psr', '0.90', '--min-dsr', '0.90']
+    try:
+        rc = mod.main()
+    finally:
+        sys.argv = old
+    assert rc == 0
+    blocker = fake.data['cfg:strategy_research_stats:blocker:v1']
+    assert blocker['blocked'] == '1'
+    assert 'psr_low' in blocker['reason'] or 'dsr_low' in blocker['reason']
