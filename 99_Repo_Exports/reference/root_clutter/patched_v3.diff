diff --git a/python-worker/orderflow_services/prometheus_alerts_policy_effectiveness_p71.yml b/python-worker/orderflow_services/prometheus_alerts_policy_effectiveness_p71.yml
index 6fbe68f..0752636 100644
--- a/python-worker/orderflow_services/prometheus_alerts_policy_effectiveness_p71.yml
+++ b/python-worker/orderflow_services/prometheus_alerts_policy_effectiveness_p71.yml
@@ -1,35 +1,71 @@
+# Alerts for Policy effectiveness report (P71)
+# Source metrics: ok_rate_logic/signal_quality_exporter_v3.py (reads settings:dynamic_cfg)
+
 groups:
-  - name: policy-effectiveness-p71
+  - name: policy_effectiveness_p71
     rules:
+
       - alert: PolicyEffectivenessReportStale
-        expr: policy_effectiveness_staleness_sec > 7200
+        expr: policy_effectiveness_last_age_seconds > 1800
         for: 30m
         labels:
-          severity: warn
-          component: trade
+          severity: warning
+          component: policy_effectiveness
+          policy: p71
         annotations:
-          summary: "policy effectiveness report is stale"
-          description: "No fresh policy effectiveness snapshot in cfg2 for >2h. The worker may be stopped, crashing, or Redis stream reads may be failing."
-          runbook: "orderflow_services/runbook_policy_effectiveness_p71.md"
+          summary: "Policy effectiveness report is stale"
+          description: "policy_effectiveness_last_age_seconds={{ $value }}s. Check policy_effectiveness_report_worker_v1 and Redis dyn cfg keys."
+          runbook_path: "/runbooks/policy_effectiveness_p71.md"
+          dashboard_path: "/grafana/d/policy_eff_p71/policy-effectiveness-p71?orgId=1"
 
-      - alert: PolicyEffectivenessUnknownShareHigh
-        expr: policy_effectiveness_share_24h{mode="unknown"} > 0.02 and signal_quality_n_24h > 200
+      - alert: PolicyEffectivenessBaselineMissing
+        expr: (policy_effectiveness_baseline_ok_present < 0.5) and on(instance) (policy_effectiveness_total_n_24h > 200)
         for: 1h
         labels:
-          severity: warn
-          component: trade
+          severity: warning
+          component: policy_effectiveness
+          policy: p71
+        annotations:
+          summary: "Policy effectiveness baseline (OK) missing"
+          description: "No OK baseline in last 24h (baseline_ok_present={{ $value }}). Report deltas are not meaningful."
+          runbook_path: "/runbooks/policy_effectiveness_p71.md"
+          dashboard_path: "/grafana/d/policy_eff_p71/policy-effectiveness-p71?orgId=1"
+
+      - alert: PolicyEffectivenessBlockShareHigh
+        expr: (policy_effectiveness_share_24h{mode="block"} > 0.20) and on(instance) (policy_effectiveness_total_n_24h > 200)
+        for: 30m
+        labels:
+          severity: warning
+          component: policy_effectiveness
+          policy: p71
         annotations:
-          summary: "high share of trades with policy mode=unknown"
-          description: "More than 2% of trades in last 24h are missing/unknown policy_effective_mode. This breaks calibration of policy thresholds."
-          runbook: "orderflow_services/runbook_policy_effectiveness_p71.md"
+          summary: "Policy effectiveness: block share is high"
+          description: "block share={{ $value }} (24h). Validate policy thresholds vs regime; check upstream data-quality (bad-time / OF gaps)."
+          runbook_path: "/runbooks/policy_effectiveness_p71.md"
+          dashboard_path: "/grafana/d/policy_eff_p71/policy-effectiveness-p71?orgId=1"
 
-      - alert: PolicyEffectivenessWarnMuchWorseThanOk
-        expr: policy_effectiveness_baseline_ok_present == 1 and signal_quality_n_24h_by_policy_mode{mode="ok"} >= 50 and signal_quality_n_24h_by_policy_mode{mode="warn"} >= 30 and policy_effectiveness_expectancy_r_delta_24h{mode="warn"} < -0.25
-        for: 2h
+      - alert: PolicyEffectivenessWarnExpectancyDrop
+        expr: (policy_effectiveness_expectancy_r_delta_24h{mode="warn"} < -0.20) and on(instance) (policy_effectiveness_total_n_24h > 200) and on(instance) (policy_effectiveness_share_24h{mode="warn"} > 0.05)
+        for: 1h
+        labels:
+          severity: warning
+          component: policy_effectiveness
+          policy: p71
+        annotations:
+          summary: "Policy effectiveness: WARN expectancy is worse than OK"
+          description: "warn expectancy delta vs OK={{ $value }}R (24h). Check selection bias, calibration drift, and policy routing."
+          runbook_path: "/runbooks/policy_effectiveness_p71.md"
+          dashboard_path: "/grafana/d/policy_eff_p71/policy-effectiveness-p71?orgId=1"
+
+      - alert: PolicyEffectivenessWarnCalibrationWorse
+        expr: (policy_effectiveness_ece_delta_24h{mode="warn"} > 0.03) and on(instance) (policy_effectiveness_total_n_24h > 200) and on(instance) (policy_effectiveness_share_24h{mode="warn"} > 0.05)
+        for: 1h
         labels:
-          severity: warn
-          component: trade
+          severity: warning
+          component: policy_effectiveness
+          policy: p71
         annotations:
-          summary: "warn-mode expectancy much worse than ok"
-          description: "Expected return under policy_effective_mode=warn is materially worse than ok (delta < -0.25R). Consider adjusting warn threshold, quarantine behavior, or data-quality gate sensitivity."
-          runbook: "orderflow_services/runbook_policy_effectiveness_p71.md"
+          summary: "Policy effectiveness: WARN calibration (ECE) is worse than OK"
+          description: "warn ECE delta vs OK={{ $value }} (24h). Consider re-calibration / thresholds per regime and verify feature drift."
+          runbook_path: "/runbooks/policy_effectiveness_p71.md"
+          dashboard_path: "/grafana/d/policy_eff_p71/policy-effectiveness-p71?orgId=1"
diff --git a/python-worker/services/orderflow/tools/signal_quality_exporter_v3.py b/python-worker/services/orderflow/tools/signal_quality_exporter_v3.py
index 7935409..dd2d580 100644
--- a/python-worker/services/orderflow/tools/signal_quality_exporter_v3.py
+++ b/python-worker/services/orderflow/tools/signal_quality_exporter_v3.py
@@ -66,6 +66,19 @@ gb_prec   = Gauge("signal_quality_precision_top5p_24h_by_bucket", "Precision@top
 gb_ece    = Gauge("signal_quality_ece_24h_by_bucket", "ECE by cov_bucket,applied", ["cov_bucket","applied"])
 gb_n      = Gauge("signal_quality_n_24h_by_bucket", "N by cov_bucket,applied", ["cov_bucket","applied"])
 
+# Policy effectiveness (P71): computed by orderflow_services/policy_effectiveness_report_worker_v1.py
+# and stored in settings:dynamic_cfg (dyn_cfg_key).
+g_pe_last_ts_ms = Gauge("policy_effectiveness_last_ts_ms", "Last policy effectiveness report timestamp (epoch ms)")
+g_pe_last_age_seconds = Gauge("policy_effectiveness_last_age_seconds", "Age of policy effectiveness report (seconds)")
+g_pe_input_last_ts_ms = Gauge("policy_effectiveness_input_last_ts_ms", "Last input timestamp used by report (epoch ms)")
+g_pe_input_age_seconds = Gauge("policy_effectiveness_input_age_seconds", "Age of last input timestamp used by report (seconds)")
+g_pe_total_n_24h = Gauge("policy_effectiveness_total_n_24h", "Total decisions in last 24h used for policy effectiveness report")
+g_pe_baseline_ok_present = Gauge("policy_effectiveness_baseline_ok_present", "Whether OK baseline was present (1/0)")
+g_pe_share_24h = Gauge("policy_effectiveness_share_24h", "Share of effective_mode in last 24h", ["mode"])
+g_pe_expectancy_r_delta_24h = Gauge("policy_effectiveness_expectancy_r_delta_24h", "Expectancy(R) delta vs OK baseline in last 24h", ["mode"])
+g_pe_precision_top5p_delta_24h = Gauge("policy_effectiveness_precision_top5p_delta_24h", "Precision@top5% delta vs OK baseline in last 24h", ["mode"])
+g_pe_ece_delta_24h = Gauge("policy_effectiveness_ece_delta_24h", "ECE delta vs OK baseline in last 24h (positive = worse calibration)", ["mode"])
+
 def _parse_kv(key: str) -> Dict[str,str]:
     out: Dict[str,str] = {}
     for part in (key or "").split("|"):
@@ -144,6 +157,31 @@ def main() -> None:
                 if obj.get("ece") is not None:
                     gb_ece.labels(b,a).set(float(obj["ece"]))
 
+            # --- Policy effectiveness (P71) ---
+            pe_last = int(float(cfg.get("policy_effectiveness_last_ts_ms") or 0))
+            g_pe_last_ts_ms.set(pe_last)
+            if pe_last > 0:
+                g_pe_last_age_seconds.set(max(0.0, (now_ms - pe_last) / 1000.0))
+            else:
+                g_pe_last_age_seconds.set(0.0)
+
+            pe_in_last = int(float(cfg.get("policy_effectiveness_input_last_ts_ms") or 0))
+            g_pe_input_last_ts_ms.set(pe_in_last)
+            if pe_in_last > 0:
+                g_pe_input_age_seconds.set(max(0.0, (now_ms - pe_in_last) / 1000.0))
+            else:
+                g_pe_input_age_seconds.set(0.0)
+
+            g_pe_total_n_24h.set(int(float(cfg.get("policy_effectiveness_total_n_24h") or 0)))
+            ok_present = str(cfg.get("policy_effectiveness_baseline_ok_present") or "0").lower().strip()
+            g_pe_baseline_ok_present.set(1.0 if ok_present in ("1", "true", "yes", "y") else 0.0)
+
+            for mode in ("ok", "warn", "block", "unknown"):
+                g_pe_share_24h.labels(mode=mode).set(float(cfg.get(f"policy_effectiveness_share_24h_{mode}") or 0.0))
+                g_pe_expectancy_r_delta_24h.labels(mode=mode).set(float(cfg.get(f"policy_effectiveness_expectancy_r_delta_24h_{mode}") or 0.0))
+                g_pe_precision_top5p_delta_24h.labels(mode=mode).set(float(cfg.get(f"policy_effectiveness_precision_top5p_delta_24h_{mode}") or 0.0))
+                g_pe_ece_delta_24h.labels(mode=mode).set(float(cfg.get(f"policy_effectiveness_ece_delta_24h_{mode}") or 0.0))
+
         except Exception:
             pass
         time.sleep(interval_s)
