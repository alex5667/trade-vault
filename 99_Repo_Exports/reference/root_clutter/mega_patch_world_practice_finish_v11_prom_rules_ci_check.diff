+from __future__ import annotations
+
+"""Prometheus rules bundle validator (CI/local) — tick_flow_full mirror.
+
+This file is intentionally kept in sync with:
+  - orderflow_services/validate_prometheus_rules_bundle_v1.py
+
+It validates all `prometheus_alerts_*.yml` files under this package directory.
+If the repo root contains the top-level `orderflow_services/`, it validates those
+as well (useful when running from the mono-tree).
+"""
+
+import argparse
+import shutil
+import subprocess
+from dataclasses import dataclass
+from pathlib import Path
+
+import yaml
+
+
+@dataclass(frozen=True)
