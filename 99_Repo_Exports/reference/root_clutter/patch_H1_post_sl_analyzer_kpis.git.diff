+def _extract_indicators_from_trade(t: Dict[str, Any]) -> Dict[str, Any]:
+    """Best-effort extraction of runtime indicators from a hydrated trade dict.
+
+    Fail-open by design: post-trade analytics must not break on missing / malformed payloads.
+    """
+    ind = t.get("indicators")
+    if isinstance(ind, dict):
+        return ind
+
+    sp = t.get("signal_payload")
+    if isinstance(sp, (bytes, bytearray)):
+        try:
+            sp = sp.decode("utf-8", errors="ignore")
+        except Exception:
+            sp = None
+
+    if isinstance(sp, str) and sp.strip().startswith("{"):
+        try:
+            obj = json.loads(sp)
+            ind = obj.get("indicators")
+            if isinstance(ind, dict):
+                return ind
+            # Some producers might nest indicators
+            runtime = obj.get("runtime")
+            if isinstance(runtime, dict):
+                ind = runtime.get("indicators")
+                if isinstance(ind, dict):
+                    return ind
+        except Exception:
+            return {}
+
+    return {}
+
+def _liqmap_peak_from_indicators(
+    *,
+    indicators: Dict[str, Any],
+    entry_price: float,
+    window: str,
+    direction: str,  # "up" or "dn"
+) -> Tuple[float, float]:
+    """Get (peak_price, peak_usd) for liqmap peak (fail-open).
+
+    Supports both:
+      A) explicit peak price keys:
+         liqmap_<w>_peak_up_price / peak_dn_price
+         liqmap_<w>_peak_up_usd   / peak_dn_usd
+         liqmap_<w>_peak_up_dist_bps / peak_dn_dist_bps
+
+      B) compact core.liqmap_features_v1 keys:
+         liqmap_<w>_dist_up_bps / dist_dn_bps
+         liqmap_<w>_peak_up1_usd / peak_dn1_usd
+         (price will be derived from entry+dist)
+    """
+    w = (window or "1h").strip() or "1h"
+    pref = f"liqmap_{w}_"
+    d = (direction or "").strip().lower()
+    if d not in ("up", "dn"):
+        return 0.0, 0.0
+
+    px = _safe_float(indicators.get(f"{pref}peak_{d}_price", 0.0), 0.0)
+    usd = _safe_float(indicators.get(f"{pref}peak_{d}_usd", 0.0), 0.0)
+    dist = _safe_float(indicators.get(f"{pref}peak_{d}_dist_bps", 0.0), 0.0)
+
+    # v1 compact keys
+    if usd <= 0.0:
+        usd = _safe_float(indicators.get(f"{pref}peak_{d}1_usd", 0.0), 0.0)
+        if d == "up" and usd <= 0.0:
+            usd = _safe_float(indicators.get(f"{pref}peak_up1_usd", 0.0), 0.0)
+        if d == "dn" and usd <= 0.0:
+            usd = _safe_float(indicators.get(f"{pref}peak_dn1_usd", 0.0), 0.0)
+
+    if dist <= 0.0:
+        dist = _safe_float(indicators.get(f"{pref}dist_{d}_bps", 0.0), 0.0)
+        if d == "up" and dist <= 0.0:
+            dist = _safe_float(indicators.get(f"{pref}dist_up_bps", 0.0), 0.0)
+        if d == "dn" and dist <= 0.0:
+            dist = _safe_float(indicators.get(f"{pref}dist_dn_bps", 0.0), 0.0)
+
+    if px <= 0.0 and dist > 0.0 and entry_price > 0.0:
+        if d == "up":
+            px = entry_price * (1.0 + dist / 10000.0)
+        else:
+            px = entry_price * (1.0 - dist / 10000.0)
+
+    if px <= 0.0 or usd <= 0.0:
+        return 0.0, 0.0
+    return float(px), float(usd)
+
+def compute_sl_hit_near_liqmap_peak(
+    *,
+    side: str,
+    entry_price: float,
+    exit_price: float,
+    indicators: Dict[str, Any],
+    window: str,
+    min_usd: float,
+    near_bps: float,
+) -> Tuple[int, float, float]:
+    """KPI: SL hit near a strong liqmap peak.
+
+    Returns (flag, dist_bps, peak_usd_used).
+    """
+    s = _norm_side(side)
+    entry = _safe_float(entry_price, 0.0)
+    exit_px = _safe_float(exit_price, 0.0)
+    if entry <= 0.0 or exit_px <= 0.0 or s not in ("LONG", "SHORT"):
+        return 0, 0.0, 0.0
+
+    direction = "dn" if s == "LONG" else "up"
+    peak_px, peak_usd = _liqmap_peak_from_indicators(indicators=indicators, entry_price=entry, window=window, direction=direction)
+    if peak_px <= 0.0 or peak_usd < float(min_usd):
+        return 0, 0.0, float(peak_usd)
+
+    dist_bps = abs(exit_px - peak_px) / entry * 10000.0
+    flag = 1 if dist_bps <= float(near_bps) else 0
+    return int(flag), float(dist_bps), float(peak_usd)
+
+def is_tp1_anchored_by_liqmap(indicators: Dict[str, Any]) -> int:
+    """Detect whether TP1 overlay was applied due to liqmap anchoring."""
+    try:
+        applied = _safe_float(indicators.get("liqmap_levels_applied", 0.0), 0.0) >= 1.0
+        tp1_adj_bps = abs(_safe_float(indicators.get("liqmap_tp1_adj_bps", 0.0), 0.0))
+        reason = str(indicators.get("liqmap_levels_reason", "") or "")
+        reason_is_tp1 = ("tp1" in reason) or (reason == "tp1_sl")
+        anchor_usd = _safe_float(indicators.get("liqmap_tp1_anchor_usd", 0.0), 0.0)
+        return int(applied and (tp1_adj_bps > 0.01) and (reason_is_tp1 or anchor_usd > 0.0))
+    except Exception:
+        return 0
