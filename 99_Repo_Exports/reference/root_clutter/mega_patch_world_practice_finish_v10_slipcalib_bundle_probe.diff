+from __future__ import annotations
+
+import os
+
+import pytest
+import yaml
+
+
+def _alerts_path(tick_flow_full: bool) -> str:
+    base = os.path.dirname(__file__)  # services/orderflow/tests
+    root = os.path.abspath(os.path.join(base, "..", "..", ".."))
+    if tick_flow_full:
+        return os.path.join(
+            root,
+            "tick_flow_full",
+            "orderflow_services",
+            "prometheus_alerts_slippage_calibrator_health_v1.yml",
+        )
+    return os.path.join(
+        root,
+        "orderflow_services",
+        "prometheus_alerts_slippage_calibrator_health_v1.yml",
+    )
+
+
+@pytest.mark.parametrize("tick_flow_full", [False, True])
+def test_slippage_calib_health_rules_yaml_parses(tick_flow_full: bool) -> None:
+    path = _alerts_path(tick_flow_full)
+    assert os.path.isfile(path), f"missing alerts file: {path}"
+    with open(path, "r", encoding="utf-8") as f:
+        doc = yaml.safe_load(f)
+    assert isinstance(doc, dict)
+    assert "groups" in doc
+    assert isinstance(doc["groups"], list) and len(doc["groups"]) >= 1
+
+
+@pytest.mark.parametrize("tick_flow_full", [False, True])
+def test_slippage_calib_health_rules_have_expected_alerts(tick_flow_full: bool) -> None:
+    path = _alerts_path(tick_flow_full)
+    with open(path, "r", encoding="utf-8") as f:
+        doc = yaml.safe_load(f)
+
+    groups = doc["groups"]
+    rules = []
+    for g in groups:
+        rs = g.get("rules", [])
+        if isinstance(rs, list):
+            rules.extend(rs)
+
+    alert_names = {r.get("alert") for r in rules if isinstance(r, dict) and r.get("alert")}
+    expected = {
+        "OF_SlippageCalibratorStale_Crit",
+        "OF_SlippageCoeffStaleHVLL_Warn",
+        "OF_ExecSlippageEvalRowcountProbeStale_Crit",
+    }
+    missing = expected - alert_names
+    assert not missing, f"missing alerts: {missing}; have={sorted(alert_names)}"
