+- name: of_slippage_calibrator_health_v1
+  interval: 60s
+  rules:
+
+  - alert: OF_SlippageCalibratorStale_Crit
+    expr: of_slippage_calib_last_ok_age_sec > 172800
+    for: 30m
+    labels:
+      severity: critical
+    annotations:
+      summary: "Slippage calibrator stale (last OK > 48h)"
+      description: |
+        Nightly slippage calibrator hasn't reported OK within 48 hours.
+        Check timers (of_timers_worker), DB view v_exec_slippage_eval, and Redis connectivity.
+      runbook_path: /runbooks/runbook_slippage_qa_p77.md
+
+  - alert: OF_SlippageCalibratorNoUpdates_Warn
+    expr: |
+      (of_slippage_calib_last_ok_age_sec < 7200)
+      and (of_slippage_calib_last_groups_total > 0)
+      and (of_slippage_calib_last_updated_groups == 0)
+    for: 15m
+    labels:
+      severity: warning
+    annotations:
+      summary: "Slippage calibrator ran but updated 0 groups"
+      description: |
+        Calibrator OK is recent, but updated_groups==0 despite groups_total>0.
+        Likely ratio/x_min filtering too strict or view returned degenerate rows.
+      runbook_path: /runbooks/runbook_slippage_qa_p77.md
+
+  - alert: OF_SlippageCoeffStaleHVLL_Warn
+    expr: max by (sym) (of_slippage_decomp_impact_coeff_age_sec{bucket="HIGH_VOL_LOW_LIQ"}) > 172800
+    for: 30m
+    labels:
+      severity: warning
+    annotations:
+      summary: "Impact coeff stale for HVLL bucket (>48h)"
+      description: |
+        slippage_decomp_impact_coeff_bps timestamp for HIGH_VOL_LOW_LIQ is stale.
+        Check calibrator state keys and whether v_exec_slippage_eval has sufficient HVLL samples.
+      runbook_path: /runbooks/runbook_slippage_qa_p77.md
+
+  - alert: OF_ExecSlippageEvalRowcountProbeStale_Crit
+    expr: of_exec_slippage_eval_rows_24h_age_sec > 7200
+    for: 30m
+    labels:
+      severity: critical
+    annotations:
+      summary: "Exec slippage eval rowcount probe stale (>2h)"
+      description: |
+        The hourly probe that writes rowcounts for v_exec_slippage_eval is stale.
+        Check of_timers_worker schedule (hourly :13) and DB connectivity.
+      runbook_path: /runbooks/runbook_slippage_qa_p77.md
+
+  - alert: OF_ExecSlippageEvalRowsLow_Warn
+    expr: sum(of_exec_slippage_eval_rows_24h) < 30
+    for: 1h
+    labels:
+      severity: warning
+    annotations:
+      summary: "v_exec_slippage_eval low rows in last 24h"
+      description: |
+        Total rows in v_exec_slippage_eval for last 24h is below threshold.
+        Could indicate: no closed trades, view broken, or ingestion lag.
+      runbook_path: /runbooks/runbook_slippage_qa_p77.md
