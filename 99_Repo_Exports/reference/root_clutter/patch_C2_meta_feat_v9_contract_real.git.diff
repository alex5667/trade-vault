+def test_meta_features_v9_registered_in_meta_schema_registry():
+    """Ensures runtime registry knows about v9 (prevents silent drift)."""
+    from core.meta_schema_registry import get_schema_info
+    vers, cols, h = get_schema_info(META_FEAT_V9_NAME)
+    assert vers == META_FEAT_V9_VERSION
+    assert cols == META_FEAT_V9_COLS
+    assert h == META_FEAT_V9_HASH
+
+
+def test_meta_features_v9_wired_in_of_confirm_engine_schema_builders():
+    """Ensures OFConfirmEngine uses v9 builder when model requests meta_feat_v9."""
+    from core import of_confirm_engine as oce
+    assert META_FEAT_V9_NAME in oce.META_SCHEMA_REGISTRY, "v9 missing in engine META_SCHEMA_REGISTRY"
+    vers, h = oce.META_SCHEMA_REGISTRY[META_FEAT_V9_NAME]
+    assert vers == META_FEAT_V9_VERSION
+    assert h == META_FEAT_V9_HASH
+
+    # Builder wiring: if this breaks, runtime would silently fallback to v1.
+    cfg = oce.get_meta_schema_cfg(META_FEAT_V9_NAME)
+    assert cfg["name"] == META_FEAT_V9_NAME
+    assert int(cfg["version"]) == META_FEAT_V9_VERSION
+    assert str(cfg.get("hash", "")) == META_FEAT_V9_HASH
+    assert cfg["builder"] is build_meta_features_v9
