diff --git a/_b/tick_flow_full/orderflow_services/prometheus_alerts_liqmap_observability_v1.yml b/tick_flow_full/orderflow_services/prometheus_alerts_liqmap_observability_v1.yml
new file mode 100644
index 0000000..574c1dc
--- /dev/null
+++ b/tick_flow_full/orderflow_services/prometheus_alerts_liqmap_observability_v1.yml
@@ -0,0 +1,42 @@
+groups:
+  - name: liqmap_observability_v1
+    rules:
+      - alert: OF_LiqMap_SnapshotAgeHigh_Warn
+        expr: max by (symbol, window) (liqmap_snapshot_age_ms) > 60000
+        for: 2m
+        labels:
+          severity: warning
+          component: liqmap
+        annotations:
+          summary: "LiqMap snapshot is stale (>60s)"
+          description: "liqmap_snapshot_age_ms={{ $value }}ms for symbol={{ $labels.symbol }}, window={{ $labels.window }}. Check liqmap snapshot writer and Redis latency."
+
+      - alert: OF_LiqMap_SnapshotAgeHigh_Crit
+        expr: max by (symbol, window) (liqmap_snapshot_age_ms) > 180000
+        for: 30s
+        labels:
+          severity: critical
+          component: liqmap
+        annotations:
+          summary: "LiqMap snapshot is very stale (>180s)"
+          description: "liqmap_snapshot_age_ms={{ $value }}ms for symbol={{ $labels.symbol }}, window={{ $labels.window }}. Gate/features likely ineffective; check producer health and Redis."
+
+      - alert: OF_LiqMap_ParseErrorsHigh_Warn
+        expr: increase(liqmap_parse_errors_total[5m]) > 5
+        for: 2m
+        labels:
+          severity: warning
+          component: liqmap
+        annotations:
+          summary: "LiqMap parse/compute errors detected"
+          description: "increase(liqmap_parse_errors_total[5m])={{ $value }}. Fail-open path is being used; inspect logs (silent_errors_total{kind=liqmap,where=parse_or_compute})."
+
+      - alert: OF_LiqMap_ParseErrorsHigh_Crit
+        expr: increase(liqmap_parse_errors_total[5m]) > 25
+        for: 2m
+        labels:
+          severity: critical
+          component: liqmap
+        annotations:
+          summary: "High LiqMap parse/compute error rate"
+          description: "increase(liqmap_parse_errors_total[5m])={{ $value }}. Likely schema drift or corrupt snapshot payloads; investigate liqmap snapshot writer and parser expectations."

