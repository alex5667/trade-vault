+class LogSampler:
+    """Lightweight log sampler used by runtime.* (unit-test friendly).
+
+    The project also has a richer sampler in handlers/crypto_orderflow/utils/log_sampler.py.
+    This local implementation keeps services.orderflow.* imports stable even in minimal
+    installs where optional deps are missing.
+    """
+
+    def __init__(self, sample_rate: int = 1000):
+        self.sample_rate = max(1, int(sample_rate) if sample_rate is not None else 1000)
+        self._counter = 0
+
+    def should_log(self, _key: str | None = None) -> bool:
+        self._counter += 1
+        return (self._counter - 1) % self.sample_rate == 0
+
