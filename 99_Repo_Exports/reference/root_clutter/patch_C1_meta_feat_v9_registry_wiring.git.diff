--- /dev/null
+++ b/tick_flow_full/tests/core/test_meta_schema_registry_v9_registered.py
@@ -0,0 +1,10 @@
+from core.meta_features_v9 import META_FEAT_V9_NAME, META_FEAT_V9_VERSION, META_FEAT_V9_HASH, META_FEAT_V9_COLS
+from core.meta_schema_registry import META_SCHEMA_REGISTRY, get_schema_info
+
+
+def test_meta_schema_registry_registers_v9():
+    assert META_FEAT_V9_NAME in META_SCHEMA_REGISTRY
+    vers, cols, h = get_schema_info(META_FEAT_V9_NAME)
+    assert vers == META_FEAT_V9_VERSION
+    assert h == META_FEAT_V9_HASH
+    assert cols == META_FEAT_V9_COLS
diff --git a/mnt/data/trade19/tick_flow_full/tests/core/test_of_confirm_engine_meta_schema_registry_v9.py b/tick_flow_full/tests/core/test_of_confirm_engine_meta_schema_registry_v9.py
new file mode 100644
index 0000000..426c863
--- /dev/null
+++ b/tick_flow_full/tests/core/test_of_confirm_engine_meta_schema_registry_v9.py
@@ -0,0 +1,17 @@
+from core.meta_features_v9 import META_FEAT_V9_NAME, META_FEAT_V9_VERSION, META_FEAT_V9_HASH
+import core.of_confirm_engine as ofe
+
+
+def test_of_confirm_engine_meta_schema_registry_has_v9():
+    assert META_FEAT_V9_NAME in ofe.META_SCHEMA_REGISTRY
+    vers, h = ofe.META_SCHEMA_REGISTRY[META_FEAT_V9_NAME]
+    assert int(vers) == int(META_FEAT_V9_VERSION)
+    assert str(h) == str(META_FEAT_V9_HASH)
+
+
+def test_of_confirm_engine_source_has_v9_builder():
+    # Static guard: ensure v9 builder is actually wired in the schema map.
+    import inspect
+    src = inspect.getsource(ofe)
+    assert "build_meta_features_v9" in src
+    assert "META_FEAT_V9_NAME" in src
