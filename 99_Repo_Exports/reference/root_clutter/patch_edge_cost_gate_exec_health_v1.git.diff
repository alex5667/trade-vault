+        # Prepare Redis rollups that exceed thresholds
+        kv = {
+            "tca:is_p95_bps:BTCUSDT:binance:na:all:all:long": b"20.0",
+            "tca:perm_impact_p95_bps:1:BTCUSDT:binance:na:all:all:long": b"15.0",
