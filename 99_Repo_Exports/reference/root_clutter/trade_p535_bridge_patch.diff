@@ -0,0 +1,33 @@
+from pathlib import Path
+import importlib.util
+import sys
+
+mod_path = Path(__file__).resolve().parent / 'check_execution_audit_chain.py'
+spec = importlib.util.spec_from_file_location('check_execution_audit_chain', mod_path)
+mod = importlib.util.module_from_spec(spec)
+sys.modules[spec.name] = mod
+spec.loader.exec_module(mod)
+
+
+class _Cursor:
+    def __init__(self):
+        self.calls = 0
+    def __enter__(self):
+        return self
+    def __exit__(self, *args):
+        return False
+    def execute(self, sql):
+        self.calls += 1
+    def fetchone(self):
+        return [self.calls]
+
+
+class _Conn:
+    def cursor(self):
+        return _Cursor()
+
+
+def test_collect_summary_runs_all_queries():
+    summary = mod.collect_summary(_Conn())
+    assert summary.execution_orders_missing_signal_id >= 1
+    assert summary.decision_snapshot_missing_chain >= 1
