diff -ruN /tmp/p5orig/scripts/backfill_execution_audit_bridge.py /tmp/p5bridge/scripts/backfill_execution_audit_bridge.py
--- /tmp/p5orig/scripts/backfill_execution_audit_bridge.py	1970-01-01 00:00:00.000000000 +0000
+++ /tmp/p5bridge/scripts/backfill_execution_audit_bridge.py	2026-03-07 09:47:15.586807690 +0000
@@ -0,0 +1,142 @@
+#!/usr/bin/env python3
+from __future__ import annotations
+
+"""Backfill signal/execution/closed-trade bridge fields across analytics tables.
+
+The bridge is intentionally idempotent: every statement can be re-run after new
+execution rows or post-trade analytics arrive.  This lets operators repair the
+chain without mutating the hot-path writer code.
+"""
+
+import argparse
+import json
+import os
+from dataclasses import dataclass, asdict
+from typing import Dict
+
+try:  # pragma: no cover
+    import psycopg  # type: ignore
+except Exception:  # pragma: no cover
+    psycopg = None
+
+
+@dataclass
+class BackfillCounts:
+    signal_execution_plan_execution_plan_id: int = 0
+    execution_orders_from_state: int = 0
+    execution_orders_closed_trade_link: int = 0
+    trades_closed_chain: int = 0
+    position_events_chain: int = 0
+    entry_policy_audit_chain: int = 0
+    decision_snapshot_chain: int = 0
+
+
+def _exec(cur, sql: str) -> int:
+    cur.execute(sql)
+    return int(getattr(cur, 'rowcount', 0) or 0)
+
+
+def run_backfill(conn) -> BackfillCounts:
+    counts = BackfillCounts()
+    with conn.cursor() as cur:
+        counts.signal_execution_plan_execution_plan_id += _exec(cur, """
+            UPDATE signal_execution_plan
+               SET execution_plan_id = signal_id
+             WHERE execution_plan_id IS NULL
+        """)
+        counts.execution_orders_from_state += _exec(cur, """
+            UPDATE execution_orders eo
+               SET signal_id = COALESCE(eo.signal_id, NULLIF(eo.state_jsonb->>'signal_id','')::uuid),
+                   execution_plan_id = COALESCE(eo.execution_plan_id, NULLIF(eo.state_jsonb->>'execution_plan_id','')::uuid),
+                   decision_id = COALESCE(eo.decision_id, NULLIF(eo.state_jsonb->>'decision_id','')),
+                   entry_order_ref = COALESCE(eo.entry_order_ref, NULLIF(eo.state_jsonb->>'entry_order_ref','')),
+                   exit_order_ref = COALESCE(eo.exit_order_ref, NULLIF(eo.state_jsonb->>'exit_order_ref','')),
+                   bridge_status = CASE
+                     WHEN COALESCE(eo.closed_trade_id,0) > 0 THEN 'closed_trade_linked'
+                     WHEN COALESCE(NULLIF(eo.state_jsonb->>'exit_order_ref',''),'') <> '' THEN 'awaiting_trades_closed_link'
+                     ELSE eo.bridge_status
+                   END
+             WHERE (eo.signal_id IS NULL AND eo.state_jsonb ? 'signal_id')
+                OR (eo.execution_plan_id IS NULL AND eo.state_jsonb ? 'execution_plan_id')
+                OR (COALESCE(eo.decision_id,'') = '' AND eo.state_jsonb ? 'decision_id')
+                OR (COALESCE(eo.entry_order_ref,'') = '' AND eo.state_jsonb ? 'entry_order_ref')
+                OR (COALESCE(eo.exit_order_ref,'') = '' AND eo.state_jsonb ? 'exit_order_ref')
+        """)
+        counts.execution_orders_closed_trade_link += _exec(cur, """
+            WITH latest_trade AS (
+                SELECT DISTINCT ON (sid) sid, id AS closed_trade_id, signal_id, execution_plan_id
+                  FROM trades_closed
+                 WHERE sid IS NOT NULL AND sid <> ''
+                 ORDER BY sid, exit_ts_ms DESC, id DESC
+            )
+            UPDATE execution_orders eo
+               SET closed_trade_id = lt.closed_trade_id,
+                   signal_id = COALESCE(eo.signal_id, lt.signal_id),
+                   execution_plan_id = COALESCE(eo.execution_plan_id, lt.execution_plan_id),
+                   bridge_status = 'closed_trade_linked'
+              FROM latest_trade lt
+             WHERE eo.sid = lt.sid
+               AND (eo.closed_trade_id IS DISTINCT FROM lt.closed_trade_id
+                 OR eo.signal_id IS NULL
+                 OR eo.execution_plan_id IS NULL)
+        """)
+        counts.trades_closed_chain += _exec(cur, """
+            UPDATE trades_closed tc
+               SET signal_id = COALESCE(tc.signal_id, eo.signal_id),
+                   execution_plan_id = COALESCE(tc.execution_plan_id, eo.execution_plan_id)
+              FROM execution_orders eo
+             WHERE tc.sid IS NOT NULL AND tc.sid <> ''
+               AND eo.sid = tc.sid
+               AND (tc.signal_id IS NULL OR tc.execution_plan_id IS NULL)
+        """)
+        counts.position_events_chain += _exec(cur, """
+            UPDATE position_events pe
+               SET signal_id = COALESCE(pe.signal_id, eo.signal_id),
+                   execution_plan_id = COALESCE(pe.execution_plan_id, eo.execution_plan_id),
+                   closed_trade_id = COALESCE(pe.closed_trade_id, eo.closed_trade_id)
+              FROM execution_orders eo
+             WHERE pe.sid IS NOT NULL AND pe.sid <> ''
+               AND eo.sid = pe.sid
+               AND (pe.signal_id IS NULL OR pe.execution_plan_id IS NULL OR pe.closed_trade_id IS NULL)
+        """)
+        counts.entry_policy_audit_chain += _exec(cur, """
+            UPDATE entry_policy_audit epa
+               SET signal_id = COALESCE(epa.signal_id, eo.signal_id),
+                   execution_plan_id = COALESCE(epa.execution_plan_id, eo.execution_plan_id),
+                   decision_id = COALESCE(epa.decision_id, eo.decision_id)
+              FROM execution_orders eo
+             WHERE epa.sid IS NOT NULL AND epa.sid <> ''
+               AND eo.sid = epa.sid
+               AND (epa.signal_id IS NULL OR epa.execution_plan_id IS NULL OR COALESCE(epa.decision_id,'') = '')
+        """)
+        counts.decision_snapshot_chain += _exec(cur, """
+            UPDATE decision_snapshot ds
+               SET signal_id = COALESCE(ds.signal_id, eo.signal_id),
+                   execution_plan_id = COALESCE(ds.execution_plan_id, eo.execution_plan_id),
+                   decision_id = COALESCE(ds.decision_id, eo.decision_id)
+              FROM execution_orders eo
+             WHERE eo.sid = ds.sid
+               AND (ds.signal_id IS NULL OR ds.execution_plan_id IS NULL OR COALESCE(ds.decision_id,'') = '')
+        """)
+    return counts
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser(description='Backfill execution analytics bridge fields.')
+    parser.add_argument('--dsn', default=os.getenv('EXECUTION_JOURNAL_DSN', ''))
+    parser.add_argument('--dry-run', action='store_true')
+    args = parser.parse_args()
+    if not args.dsn or psycopg is None:
+        raise RuntimeError('psycopg + EXECUTION_JOURNAL_DSN required')
+    with psycopg.connect(args.dsn) as conn:
+        counts = run_backfill(conn)
+        if args.dry_run:
+            conn.rollback()
+        else:
+            conn.commit()
+    print(json.dumps(asdict(counts), ensure_ascii=False, indent=2))
+    return 0
+
+
+if __name__ == '__main__':  # pragma: no cover
+    raise SystemExit(main())
