@@ -0,0 +1,128 @@
+-- P5.3 bridge migration: align execution journal with existing analytics tables.
+--
+-- Goals:
+-- 1. Introduce a durable `execution_plan_id` bridge on signal_execution_plan.
+-- 2. Add signal/execution/closed-trade linkage to execution journal + audit tables.
+-- 3. Migrate earlier TEXT placeholders to the real schema contract where needed.
+
+ALTER TABLE signal_execution_plan
+  ADD COLUMN IF NOT EXISTS execution_plan_id UUID;
+
+UPDATE signal_execution_plan
+   SET execution_plan_id = signal_id
+ WHERE execution_plan_id IS NULL;
+
+ALTER TABLE entry_policy_audit
+  ADD COLUMN IF NOT EXISTS signal_id UUID,
+  ADD COLUMN IF NOT EXISTS execution_plan_id UUID,
+  ADD COLUMN IF NOT EXISTS decision_id TEXT;
+
+ALTER TABLE position_events
+  ADD COLUMN IF NOT EXISTS signal_id UUID,
+  ADD COLUMN IF NOT EXISTS execution_plan_id UUID,
+  ADD COLUMN IF NOT EXISTS closed_trade_id BIGINT;
+
+ALTER TABLE decision_snapshot
+  ADD COLUMN IF NOT EXISTS signal_id UUID,
+  ADD COLUMN IF NOT EXISTS execution_plan_id UUID,
+  ADD COLUMN IF NOT EXISTS decision_id TEXT;
+
+ALTER TABLE trades_closed
+  ADD COLUMN IF NOT EXISTS signal_id UUID,
+  ADD COLUMN IF NOT EXISTS execution_plan_id UUID;
+
+ALTER TABLE execution_orders
+  ADD COLUMN IF NOT EXISTS decision_id TEXT,
+  ADD COLUMN IF NOT EXISTS bridge_status TEXT NOT NULL DEFAULT '';
+
+ALTER TABLE execution_order_events
+  ADD COLUMN IF NOT EXISTS decision_id TEXT;
+
+CREATE TABLE IF NOT EXISTS execution_watchdog_events (
+  id BIGSERIAL PRIMARY KEY,
+  sid TEXT NOT NULL,
+  symbol TEXT NOT NULL DEFAULT '',
+  signal_id UUID NULL,
+  execution_plan_id UUID NULL,
+  decision_id TEXT NULL,
+  tp_level INTEGER NULL,
+  watchdog_state TEXT NOT NULL DEFAULT '',
+  event_type TEXT NOT NULL,
+  event_ts_ms BIGINT NOT NULL,
+  payload_jsonb JSONB NOT NULL DEFAULT '{}'::jsonb
+);
+
+DO $$
+BEGIN
+  IF EXISTS (
+      SELECT 1 FROM information_schema.columns
+      WHERE table_name='execution_orders' AND column_name='signal_id' AND udt_name <> 'uuid'
+  ) THEN
+    UPDATE execution_orders
+       SET signal_id = NULL
+     WHERE signal_id IS NOT NULL
+       AND signal_id !~* '^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$';
+    ALTER TABLE execution_orders
+      ALTER COLUMN signal_id TYPE UUID USING NULLIF(signal_id,'')::uuid;
+  END IF;
+END $$;
+
+DO $$
+BEGIN
+  IF EXISTS (
+      SELECT 1 FROM information_schema.columns
+      WHERE table_name='execution_orders' AND column_name='execution_plan_id' AND udt_name <> 'uuid'
+  ) THEN
+    UPDATE execution_orders
+       SET execution_plan_id = NULL
+     WHERE execution_plan_id IS NOT NULL
+       AND execution_plan_id !~* '^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$';
+    ALTER TABLE execution_orders
+      ALTER COLUMN execution_plan_id TYPE UUID USING NULLIF(execution_plan_id,'')::uuid;
+  END IF;
+END $$;
+
+DO $$
+BEGIN
+  IF EXISTS (
+      SELECT 1 FROM information_schema.columns
+      WHERE table_name='execution_orders' AND column_name='closed_trade_id' AND udt_name <> 'int8'
+  ) THEN
+    UPDATE execution_orders
+       SET closed_trade_id = NULL
+     WHERE closed_trade_id IS NOT NULL
+       AND closed_trade_id !~ '^[0-9]+$';
+    ALTER TABLE execution_orders
+      ALTER COLUMN closed_trade_id TYPE BIGINT USING NULLIF(closed_trade_id,'')::bigint;
+  END IF;
+END $$;
+
+DO $$
+BEGIN
+  IF EXISTS (
+      SELECT 1 FROM information_schema.columns
+      WHERE table_name='execution_order_events' AND column_name='signal_id' AND udt_name <> 'uuid'
+  ) THEN
+    UPDATE execution_order_events
+       SET signal_id = NULL
+     WHERE signal_id IS NOT NULL
+       AND signal_id !~* '^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$';
+    ALTER TABLE execution_order_events
+      ALTER COLUMN signal_id TYPE UUID USING NULLIF(signal_id,'')::uuid;
+  END IF;
+END $$;
+
+DO $$
+BEGIN
+  IF EXISTS (
+      SELECT 1 FROM information_schema.columns
+      WHERE table_name='execution_order_events' AND column_name='execution_plan_id' AND udt_name <> 'uuid'
+  ) THEN
+    UPDATE execution_order_events
+       SET execution_plan_id = NULL
+     WHERE execution_plan_id IS NOT NULL
+       AND execution_plan_id !~* '^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$';
+    ALTER TABLE execution_order_events
+      ALTER COLUMN execution_plan_id TYPE UUID USING NULLIF(execution_plan_id,'')::uuid;
+  END IF;
+END $$;
