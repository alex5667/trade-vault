+from pathlib import Path
+import importlib.util
+import sys
+
+mod_path = Path(__file__).resolve().parent / 'backfill_execution_audit_bridge.py'
+spec = importlib.util.spec_from_file_location('backfill_execution_audit_bridge', mod_path)
+mod = importlib.util.module_from_spec(spec)
+sys.modules[spec.name] = mod
+spec.loader.exec_module(mod)
+
+
+class _Cursor:
+    def __init__(self):
+        self.rowcount = 1
+        self.sql = []
+    def __enter__(self):
+        return self
+    def __exit__(self, *args):
+        return False
+    def execute(self, sql):
+        self.sql.append(sql)
+        self.rowcount = 1
+
+
+class _Conn:
+    def __init__(self):
+        self.cur = _Cursor()
+    def cursor(self):
+        return self.cur
+
+
+def test_run_backfill_executes_bridge_updates():
+    conn = _Conn()
+    counts = mod.run_backfill(conn)
+    assert counts.signal_execution_plan_execution_plan_id >= 1
+    assert counts.trades_closed_chain >= 1
+    assert counts.position_events_chain >= 1
+    merged_sql = "\n".join(conn.cur.sql)
+    assert 'UPDATE signal_execution_plan' in merged_sql
+    assert 'UPDATE trades_closed' in merged_sql
