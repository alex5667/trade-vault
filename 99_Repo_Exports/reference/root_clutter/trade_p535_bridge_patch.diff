+#!/usr/bin/env python3
+from __future__ import annotations
+
+import argparse
+import json
+import os
+from dataclasses import dataclass, asdict
+
+try:  # pragma: no cover
+    import psycopg  # type: ignore
+except Exception:  # pragma: no cover
+    psycopg = None
+
+
+@dataclass
+class AuditChainSummary:
+    execution_orders_missing_signal_id: int = 0
+    execution_orders_missing_execution_plan_id: int = 0
+    execution_orders_signal_fk_missing: int = 0
+    execution_orders_plan_fk_missing: int = 0
+    execution_orders_closed_trade_missing: int = 0
+    position_events_missing_chain: int = 0
+    trades_closed_missing_chain: int = 0
+    entry_policy_audit_missing_chain: int = 0
+    decision_snapshot_missing_chain: int = 0
+
+
+def collect_summary(conn) -> AuditChainSummary:
+    s = AuditChainSummary()
+    with conn.cursor() as cur:
+        cur.execute("select count(*) from execution_orders where signal_id is null")
+        s.execution_orders_missing_signal_id = int(cur.fetchone()[0])
+        cur.execute("select count(*) from execution_orders where execution_plan_id is null")
+        s.execution_orders_missing_execution_plan_id = int(cur.fetchone()[0])
+        cur.execute("""
+            select count(*)
+              from execution_orders eo
+              left join signals s on s.signal_id = eo.signal_id
+             where eo.signal_id is not null and s.signal_id is null
+        """)
+        s.execution_orders_signal_fk_missing = int(cur.fetchone()[0])
+        cur.execute("""
+            select count(*)
+              from execution_orders eo
+              left join signal_execution_plan sep on sep.execution_plan_id = eo.execution_plan_id
+             where eo.execution_plan_id is not null and sep.execution_plan_id is null
+        """)
+        s.execution_orders_plan_fk_missing = int(cur.fetchone()[0])
+        cur.execute("""
+            select count(*)
+              from execution_orders eo
+         left join trades_closed tc on tc.id = eo.closed_trade_id
+             where eo.closed_trade_id is not null and tc.id is null
+        """)
+        s.execution_orders_closed_trade_missing = int(cur.fetchone()[0])
+        cur.execute("select count(*) from position_events where sid is not null and sid <> '' and (signal_id is null or execution_plan_id is null)")
+        s.position_events_missing_chain = int(cur.fetchone()[0])
+        cur.execute("select count(*) from trades_closed where sid is not null and sid <> '' and (signal_id is null or execution_plan_id is null)")
+        s.trades_closed_missing_chain = int(cur.fetchone()[0])
+        cur.execute("select count(*) from entry_policy_audit where sid is not null and sid <> '' and (signal_id is null or execution_plan_id is null)")
+        s.entry_policy_audit_missing_chain = int(cur.fetchone()[0])
+        cur.execute("select count(*) from decision_snapshot where sid is not null and sid <> '' and (signal_id is null or execution_plan_id is null)")
+        s.decision_snapshot_missing_chain = int(cur.fetchone()[0])
+    return s
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser(description='Check end-to-end execution audit chain consistency.')
+    parser.add_argument('--dsn', default=os.getenv('EXECUTION_JOURNAL_DSN', ''))
+    args = parser.parse_args()
+    if not args.dsn or psycopg is None:
+        raise RuntimeError('psycopg + EXECUTION_JOURNAL_DSN required')
+    with psycopg.connect(args.dsn) as conn:
+        summary = collect_summary(conn)
+    print(json.dumps(asdict(summary), ensure_ascii=False, indent=2))
+    return 0
+
+
+if __name__ == '__main__':  # pragma: no cover
+    raise SystemExit(main())
