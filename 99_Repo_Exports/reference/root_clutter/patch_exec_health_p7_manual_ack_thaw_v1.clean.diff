+++ b/services/orderflow/tests/test_exec_health_freeze_control_v1.py
@@ -0,0 +1,24 @@
+from __future__ import annotations
+
+from services.orderflow.exec_health_freeze_control import (
+    build_autoguard_latch_update,
+    build_manual_ack_thaw_update,
+    parse_exec_health_freeze_control,
+)
+
+
+def test_parse_control_latched_freeze_requires_manual_ack() -> None:
+    raw = build_autoguard_latch_update(prev={}, now_ms=10_000, reasons=["cross_scope_mode_mismatch"], freeze_until_ts_ms=11_000)
+    st = parse_exec_health_freeze_control(raw, now_ms=50_000)
+    assert st.effective_freeze_active is True
+    assert st.manual_ack_required is True
+    assert st.control_source == "autoguard"
+
+
+def test_parse_control_manual_thaw_override_clears_freeze() -> None:
+    raw = build_manual_ack_thaw_update(prev={}, now_ms=20_000, operator="alex", reason="checked", ticket="INC-1")
+    st = parse_exec_health_freeze_control(raw, now_ms=25_000)
+    assert st.effective_freeze_active is False
+    assert st.manual_ack_required is False
+    assert st.manual_override_action == "thaw"
+    assert st.manual_ack_operator == "alex"
