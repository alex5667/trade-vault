+    )
+    assert result['applied'] is True
+    assert 'orders:quarantine:state:sid-1' in r.kv
+    assert 'sid-1' in r.sets['orders:quarantine:state:sids']
+    payload = json.loads(r.kv['orders:quarantine:state:sid-1'])
