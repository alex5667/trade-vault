+from __future__ import annotations
+
+import importlib.util
+import json
+import sys
+from pathlib import Path
+
+SCRIPT = Path(__file__).resolve().parent.parent / 'scripts' / 'quarantine_inconsistent_sid.py'
+SPEC = importlib.util.spec_from_file_location('quarantine_inconsistent_sid', SCRIPT)
+mod = importlib.util.module_from_spec(SPEC)
+assert SPEC and SPEC.loader
+sys.modules[SPEC.name] = mod
+SPEC.loader.exec_module(mod)
+
+
+class _Pipe:
+    def __init__(self, redis_obj):
+        self.redis = redis_obj
+        self.ops = []
+
+    def set(self, key, value):
+        self.ops.append(('set', key, value))
+        return self
+
+    def sadd(self, key, value):
+        self.ops.append(('sadd', key, value))
+        return self
+
+    def xadd(self, key, fields, maxlen=None, approximate=None):
+        self.ops.append(('xadd', key, fields))
+        return self
+
+    def execute(self):
+        for op, key, value in self.ops:
+            if op == 'set':
+                self.redis.kv[key] = value
+            elif op == 'sadd':
+                self.redis.sets.setdefault(key, set()).add(value)
+            elif op == 'xadd':
+                self.redis.streams.setdefault(key, []).append(value)
+        return True
+
+
+class _Redis:
+    def __init__(self):
+        self.kv = {}
+        self.sets = {}
+        self.streams = {}
+
+    def get(self, key):
+        return self.kv.get(key)
+
+    def pipeline(self):
+        return _Pipe(self)
+
+
+def test_quarantine_sid_writes_copy_and_event():
