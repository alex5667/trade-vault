--- orderflow_services/tests/test_exec_health_slo_exporter_v1.py
+++ orderflow_services/tests/test_exec_health_slo_exporter_v1.py
@@ -0,0 +1,68 @@
+from __future__ import annotations
+
+from unittest.mock import patch, MagicMock
+
+from orderflow_services import exec_health_slo_exporter_v1 as exp
+
+
+def test_exec_health_slo_exporter_sets_gauges_from_summary() -> None:
+    mock_redis_mod = MagicMock()
+    mock_client = MagicMock()
