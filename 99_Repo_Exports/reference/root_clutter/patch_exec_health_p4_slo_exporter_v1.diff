+from __future__ import annotations
+
+from contextlib import contextmanager
+import os
+
+from services.orderflow.exec_health_rollups import ExecHealthDecision
+from services.orderflow.exec_health_slo_contract import (
+    record_exec_health_contract_state,
+    record_exec_health_contract_reader_error,
+    flush_exec_health_contract_state_sync,
+)
+
+
+class FakePipe:
+    def __init__(self, redis):
+        self.redis = redis
+        self.ops = []
+    def hset(self, key, mapping):
+        self.ops.append(("hset", key, dict(mapping)))
+        return self
+    def expire(self, key, ttl):
+        self.ops.append(("expire", key, int(ttl)))
+        return self
+    def execute(self):
+        for op, a, b in self.ops:
+            if op == "hset":
+                self.redis.hset(a, mapping=b)
+            elif op == "expire":
+                self.redis.expire(a, b)
+        self.ops = []
+        return True
+
+
+class FakeRedis:
+    def __init__(self):
+        self.hashes = {}
+        self.expires = {}
+    def pipeline(self, transaction=False):
+        return FakePipe(self)
+    def hset(self, key, mapping):
+        self.hashes.setdefault(key, {}).update({str(k): str(v) for k, v in mapping.items()})
+        return True
+    def expire(self, key, ttl):
+        self.expires[key] = int(ttl)
+        return True
+
+
+@contextmanager
+def _env(**kwargs):
+    old = {k: os.environ.get(k) for k in kwargs}
+    try:
+        for k, v in kwargs.items():
+            os.environ[k] = str(v)
+        yield
+    finally:
+        for k, v in old.items():
+            if v is None:
+                os.environ.pop(k, None)
+            else:
+                os.environ[k] = v
+
+
+def test_exec_health_slo_contract_flushes_scope_state_hash() -> None:
+    r = FakeRedis()
+    dec = ExecHealthDecision(apply=True, veto=True, mode="veto", flags=["is_p95_high"], reason_code="VETO_IMPL_SHORTFALL_P95")
+    with _env(
+        EXEC_HEALTH_INSTANCE_ID="inst-A",
+        EXEC_HEALTH_DEPLOY_ID="deploy-1",
+        EXEC_HEALTH_SERVICE_NAME="svc-A",
+        EXEC_HEALTH_STATE_FLUSH_INTERVAL_MS="1",
+    ):
+        record_exec_health_contract_state(scope="edge", profile="hard", symbol="BTCUSDT", decision=dec, now_ms=1000)
+        record_exec_health_contract_reader_error(scope="edge")
+        ok = flush_exec_health_contract_state_sync(redis_client=r, scope="edge", force=True)
+
+    assert ok is True
+    key = "metrics:exec_health:scope_state:edge:inst-A"
+    assert key in r.hashes
+    h = r.hashes[key]
+    assert h["schema_name"] == "exec_health_scope_state"
+    assert h["scope"] == "edge"
+    assert h["instance_id"] == "inst-A"
+    assert h["deploy_id"] == "deploy-1"
+    assert h["service_name"] == "svc-A"
+    assert h["last_mode"] == "veto"
+    assert h["last_reason_code"] == "VETO_IMPL_SHORTFALL_P95"
+    assert int(h["total_n"]) >= 1
+    assert int(h["veto_n"]) >= 1
+    assert int(h["reader_error_n"]) >= 1
+    assert key in r.expires
