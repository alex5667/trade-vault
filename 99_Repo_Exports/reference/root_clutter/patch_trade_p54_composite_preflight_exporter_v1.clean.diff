+groups:
+  - name: orchestration_composite_preflight_p54
+    rules:
+      - alert: TradeOrchestrationCompositePreflightBlockedCrit
+        expr: orchestration_composite_preflight_decision_status{status="block"} > 0
+        for: 10m
+        labels:
+          severity: crit
+          component: orchestration_composite_preflight
