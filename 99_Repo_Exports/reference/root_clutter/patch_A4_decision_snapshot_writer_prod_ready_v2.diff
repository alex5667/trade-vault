@@ -0,0 +1,143 @@
+import asyncio
+import json
+import sqlite3
+import sys
+import unittest
+from pathlib import Path
+
+ROOT = Path(__file__).resolve()
+PYWORKER = ROOT.parents[1]
+REPO = ROOT.parents[2]
+for p in (str(PYWORKER), str(REPO)):
+    if p not in sys.path:
+        sys.path.insert(0, p)
+
+from services.posttrade.decision_snapshot_db import SQLiteDecisionSnapshotDB
+from services.posttrade.decision_snapshot_writer import DecisionSnapshotWriterConfig, DecisionSnapshotStreamWorker
+
+
+class FakeRedisDLQ:
+    def __init__(self, stream: str, entries):
+        self.stream = stream
+        self.entries = entries[:]  # list of (id, fields)
+        self.acked = []
+        self.dlq = []  # list of (stream, fields)
+        self.created = False
+
+    async def xgroup_create(self, name, groupname, id, mkstream):
+        self.created = True
+        return True
+
+    async def xreadgroup(self, groupname, consumername, streams, count, block):
+        if not self.entries:
+            return []
+        batch = self.entries[:count]
+        self.entries = self.entries[count:]
+        return [(self.stream, batch)]
+
+    async def xack(self, stream, group, *ids):
+        self.acked.extend(list(ids))
+        return len(ids)
+
+    async def xadd(self, name, fields, maxlen=None):
+        self.dlq.append((name, dict(fields)))
+        return "1-0"
+
+
+class FakeRedisReclaim(FakeRedisDLQ):
+    def __init__(self, stream: str, entries, claimed):
+        super().__init__(stream, entries)
+        self._claimed = claimed[:]  # list of (id, fields)
+        self._cursor = "0-0"
+
+    async def xautoclaim(self, name, groupname, consumername, min_idle_time, start_id, count):
+        # one-shot claim
+        if self._claimed:
+            msgs = self._claimed
+            self._claimed = []
+            return ("0-0", msgs)
+        return ("0-0", [])
+
+
+class DecisionSnapshotWriterDLQReclaimTest(unittest.TestCase):
+    def test_bad_payload_goes_to_dlq_and_acked(self):
+        conn = sqlite3.connect(":memory:")
+        db = SQLiteDecisionSnapshotDB(conn=conn)
+        db.ensure_schema()
+
+        # invalid JSON
+        fields = {b"payload": b"{not-json"}
+        fake = FakeRedisDLQ("events:decision_snapshot", [("1-0", fields)])
+
+        cfg = DecisionSnapshotWriterConfig()
+        cfg.db_type = "sqlite"
+        cfg.dlq_enable = True
+        cfg.dlq_stream = "stream:decision_snapshot:dlq"
+
+        worker = DecisionSnapshotStreamWorker(cfg=cfg, redis=fake, db=db)
+
+        async def _run():
+            await worker.ensure_group()
+            await worker.run_once()
+
+        asyncio.run(_run())
+
+        self.assertIn("1-0", fake.acked)
+        self.assertEqual(len(fake.dlq), 1)
+        dlq_stream, dlq_fields = fake.dlq[0]
+        self.assertEqual(dlq_stream, "stream:decision_snapshot:dlq")
+        self.assertEqual(dlq_fields.get("reason"), "bad_payload_json")
+
+    def test_reclaim_processes_claimed_and_acks(self):
+        conn = sqlite3.connect(":memory:")
+        db = SQLiteDecisionSnapshotDB(conn=conn)
+        db.ensure_schema()
+
+        evt = {
+            "schema_version": 1,
+            "producer": "python-worker",
+            "sid": "S2",
+            "symbol": "BTCUSDT",
+            "venue": "binance",
+            "session": "utc",
+            "tf": "1m",
+            "kind": "breakout",
+            "side": "LONG",
+            "direction": "LONG",
+            "decision_ts_ms": 1710000000001,
+            "decision_bid": 100.0,
+            "decision_ask": 100.1,
+            "decision_mid": 100.05,
+            "decision_spread_bps": 10.0,
+            "tca_ready": True,
+            "book_sanity_flags": [],
+        }
+        fields = {b"payload": json.dumps(evt).encode("utf-8")}
+        claimed = [("9-0", fields)]
+
+        fake = FakeRedisReclaim("events:decision_snapshot", [], claimed)
+
+        cfg = DecisionSnapshotWriterConfig()
+        cfg.db_type = "sqlite"
+        cfg.pel_enable = True
+        cfg.pel_max_iters = 1
+
+        worker = DecisionSnapshotStreamWorker(cfg=cfg, redis=fake, db=db)
+
+        async def _run():
+            await worker.ensure_group()
+            n = await worker.recover_pending_once()
+            return n
+
+        n = asyncio.run(_run())
+        self.assertEqual(n, 1)
+        self.assertIn("9-0", fake.acked)
+
+        # Ensure row exists
+        cur = conn.cursor()
+        cur.execute("SELECT COUNT(*) FROM decision_snapshot WHERE sid='S2'")
+        self.assertEqual(cur.fetchone()[0], 1)
+
+
+if __name__ == "__main__":
+    unittest.main()
