+"""services.orderflow.book_geometry
+
+Phase C (P2): Liquidity geometry metrics computed from a bounded L2 snapshot (top-5).
+
+Why bounded top-5?
+  - Hot-path safe: predictable CPU and memory.
+  - Deterministic: same inputs -> same outputs.
+  - Good enough for *relative* measures (slope / DWS) used as a risk overlay.
+
+Metrics implemented:
+  - Book slope (USD per bps): how much notional sits per 1 bps away from mid.
+  - Depth-weighted spread (DWS, bps): spread proxy that accounts for near-book depth.
+  - Notional within X bps (USD): cost-to-cross band proxy.
+
+All functions are fail-open and return 0.0 for missing/invalid inputs.
+"""
+
+from __future__ import annotations
+
+from typing import Any, Iterable, List, Sequence, Tuple
+
+
+Level = Tuple[float, float]  # (px, qty)
+
+
+def _f(x: Any, d: float = 0.0) -> float:
+    try:
+        return float(x)
+    except Exception:
+        return d
+
+
+def _safe_mid(best_bid: float, best_ask: float) -> float:
+    bb = float(best_bid or 0.0)
+    ba = float(best_ask or 0.0)
+    if bb > 0.0 and ba > 0.0 and ba >= bb:
+        return 0.5 * (bb + ba)
+    return 0.0
+
+
+def calc_cost_to_cross(levels: Sequence[Level], *, mid: float, xbps: float) -> float:
+    """Return notional (USD) available within X bps band from mid on the given side.
+
+    Note: for bids, distance is (mid - px); for asks, distance is (px - mid).
+    The caller should pass side-specific `levels`.
+    """
+    try:
+        mid = float(mid or 0.0)
+        if mid <= 0.0:
+            return 0.0
+        xbps = float(xbps or 0.0)
+        if xbps <= 0.0:
+            return 0.0
+        band = mid * (xbps / 10_000.0)
+        # floating tolerance to avoid boundary precision issues
+        band_eps = band + (1e-12 * max(mid, 1.0))
+        out = 0.0
+        for px, qty in levels:
+            px = float(px or 0.0)
+            qty = float(qty or 0.0)
+            if px <= 0.0 or qty <= 0.0:
+                continue
+            if abs(px - mid) <= band_eps:
+                out += px * qty
+        return float(out)
+    except Exception:
+        return 0.0
+
+
+def calc_book_slope(bids: Sequence[Level], asks: Sequence[Level], *, mid: float) -> Tuple[float, float]:
+    """Compute liquidity slope for bid and ask sides.
+
+    Definition (robust/simple):
+      slope_side = sum(notional_i / distance_bps_i) for levels within top-5.
+
+    Units: USD per bps (higher = better, more liquidity close to mid).
+    """
+    try:
+        mid = float(mid or 0.0)
+        if mid <= 0.0:
+            return 0.0, 0.0
+
+        def _side(levels: Sequence[Level], sign: int) -> float:
+            s = 0.0
+            for px, qty in levels:
+                px = float(px or 0.0)
+                qty = float(qty or 0.0)
+                if px <= 0.0 or qty <= 0.0:
+                    continue
+                # distance bps from mid
+                dist_bps = (abs(px - mid) / mid) * 10_000.0
+                if dist_bps <= 0.0:
+                    continue
+                notional = px * qty
+                s += notional / dist_bps
+            return float(s)
+
+        slope_bid = _side(bids, -1)
+        slope_ask = _side(asks, +1)
+        return slope_bid, slope_ask
+    except Exception:
+        return 0.0, 0.0
+
+
+def calc_depth_weighted_spread(bids: Sequence[Level], asks: Sequence[Level], *, mid: float, xbps: float = 5.0) -> float:
+    """Depth-weighted spread (DWS) proxy.
+
+    Approach:
+      - Compute VWAP of bids and asks within X bps band from mid.
+      - DWS = (vwap_ask - vwap_bid) / mid * 10_000
+
+    If we cannot compute VWAPs (no depth), returns 0.0.
+    """
+    try:
+        mid = float(mid or 0.0)
+        if mid <= 0.0:
+            return 0.0
+        xbps = float(xbps or 5.0)
+        if xbps <= 0.0:
+            return 0.0
+        band = mid * (xbps / 10_000.0)
+
+        def _vwap(levels: Sequence[Level]) -> Tuple[float, float]:
+            notional = 0.0
+            qty_sum = 0.0
+            for px, qty in levels:
+                px = float(px or 0.0)
+                qty = float(qty or 0.0)
+                if px <= 0.0 or qty <= 0.0:
+                    continue
+                if abs(px - mid) > band:
+                    continue
+                notional += px * qty
+                qty_sum += qty
+            if qty_sum <= 0.0:
+                return 0.0, 0.0
+            return float(notional / qty_sum), float(qty_sum)
+
+        vwap_bid, qb = _vwap(bids)
+        vwap_ask, qa = _vwap(asks)
+        if vwap_bid <= 0.0 or vwap_ask <= 0.0:
+            return 0.0
+        dws_bps = ((vwap_ask - vwap_bid) / mid) * 10_000.0
+        # Bound to sane values (avoid outliers from corrupt books)
+        if dws_bps < 0.0:
+            return 0.0
+        if dws_bps > 10_000.0:
+            return 10_000.0
+        return float(dws_bps)
+    except Exception:
+        return 0.0
+
+
+def extract_levels_from_runtime(runtime: Any) -> Tuple[List[Level], List[Level], float]:
+    """Best-effort extraction of (bids, asks, mid) from SymbolRuntime.
+
+    We prefer typed snapshot runtime.last_book (top5).
+    """
+    try:
+        snap = getattr(runtime, "last_book", None) or getattr(getattr(runtime, "book_state", None), "snap", None)
+        if snap is None:
+            return [], [], 0.0
+        bids = list(getattr(snap, "bids", []) or [])
+        asks = list(getattr(snap, "asks", []) or [])
+        bb = _f(getattr(snap, "best_bid_px", 0.0) or 0.0)
+        ba = _f(getattr(snap, "best_ask_px", 0.0) or 0.0)
+        mid = _safe_mid(bb, ba)
+        return bids, asks, float(mid)
+    except Exception:
+        return [], [], 0.0
