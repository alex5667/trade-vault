+"""services.orderflow.liquidity_resiliency
+
+Phase C (P2): Liquidity resiliency / recovery time tracker.
+
+Goal
+  Detect *fragile* market episodes where liquidity temporarily collapses and takes time
+  to recover, even if instantaneous spread/depth snapshots look acceptable.
+
+Design constraints
+  - Hot-path safe (O(1) update).
+  - Deterministic event-time: caller must pass `ts_ms` (epoch ms).
+  - Fail-open: never raises, returns 0/neutral values on missing inputs.
+
+State machine
+  Baselines:
+    - spread_ema_bps
+    - depth_ema_usd
+
+  Stress enters when:
+    spread_bps > spread_ema_bps * stress_spread_mult
+      OR
+    depth_usd < depth_ema_usd * (1 - stress_depth_drop_frac)
+
+  Stress exits when (must hold for `recover_hold_ms`):
+    spread_bps <= spread_ema_bps * recover_spread_mult
+      AND
+    depth_usd >= depth_ema_usd * (1 - recover_depth_drop_frac)
+
+Outputs
+  - liq_recovery_time_ms: duration since stress start while stressed else 0
+  - liq_fragility_score: [0..1] heuristic severity (spread_ratio + depth_ratio)
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+
+
+def _f(x, d: float = 0.0) -> float:
+    try:
+        return float(x)
+    except Exception:
+        return d
+
+
+def _i(x, d: int = 0) -> int:
+    try:
+        return int(x)
+    except Exception:
+        return d
+
+
+@dataclass
+class LiquidityResiliencyTracker:
+    """O(1) tracker for liquidity fragility and recovery time."""
+
+    ema_alpha: float = 0.02
+    stress_spread_mult: float = 1.75
+    stress_depth_drop_frac: float = 0.50
+    recover_spread_mult: float = 1.20
+    recover_depth_drop_frac: float = 0.20
+    recover_hold_ms: int = 1000
+
+    # state
+    spread_ema_bps: float = 0.0
+    depth_ema_usd: float = 0.0
+    stress_active: int = 0
+    stress_start_ts_ms: int = 0
+    recover_candidate_ts_ms: int = 0
+
+    def update(self, *, ts_ms: int, spread_bps: float, depth_usd: float) -> dict:
+        """Update state and return a dict suitable to merge into indicators."""
+        try:
+            ts = _i(ts_ms, 0)
+            spr = max(0.0, _f(spread_bps, 0.0))
+            dep = max(0.0, _f(depth_usd, 0.0))
+            a = float(self.ema_alpha or 0.02)
+            a = min(max(a, 0.001), 0.50)
+
+            # IMPORTANT: detect stress against the *previous* baseline.
+            # If we update EMA first, we may "chase" the spike and miss stress entry.
+            spr_base_pre = float(self.spread_ema_bps or 0.0)
+            dep_base_pre = float(self.depth_ema_usd or 0.0)
+            if spr_base_pre <= 0.0:
+                spr_base_pre = spr
+            if dep_base_pre <= 0.0:
+                dep_base_pre = dep
+
+            # Stress entry condition (against pre-update baseline)
+            stress = False
+            if spr_base_pre > 0.0 and spr > (spr_base_pre * float(self.stress_spread_mult or 1.75)):
+                stress = True
+            if dep_base_pre > 0.0:
+                min_dep = dep_base_pre * max(0.0, 1.0 - float(self.stress_depth_drop_frac or 0.50))
+                if dep < min_dep:
+                    stress = True
+            # EMA update (post detection)
+            if self.spread_ema_bps <= 0.0:
+                self.spread_ema_bps = spr
+            else:
+                self.spread_ema_bps = (1.0 - a) * self.spread_ema_bps + a * spr
+
+            if self.depth_ema_usd <= 0.0:
+                self.depth_ema_usd = dep
+            else:
+                self.depth_ema_usd = (1.0 - a) * self.depth_ema_usd + a * dep
+
+            # Ratios (bounded) (post-update for smoother telemetry)
+            spr_base = max(self.spread_ema_bps, 1e-9)
+            dep_base = max(self.depth_ema_usd, 1e-9)
+            spr_ratio = spr / spr_base
+            dep_ratio = dep / dep_base
+
+
+            if self.stress_active == 0 and stress and ts > 0:
+                self.stress_active = 1
+                self.stress_start_ts_ms = ts
+                self.recover_candidate_ts_ms = 0
+
+            # Stress exit requires hold duration
+            if self.stress_active == 1:
+                ok_spread = spr <= spr_base * float(self.recover_spread_mult or 1.20)
+                min_dep2 = dep_base * max(0.0, 1.0 - float(self.recover_depth_drop_frac or 0.20))
+                ok_depth = dep >= min_dep2
+                if ok_spread and ok_depth:
+                    if self.recover_candidate_ts_ms <= 0:
+                        self.recover_candidate_ts_ms = ts
+                    elif (ts - self.recover_candidate_ts_ms) >= int(self.recover_hold_ms or 1000):
+                        # recovered
+                        self.stress_active = 0
+                        self.stress_start_ts_ms = 0
+                        self.recover_candidate_ts_ms = 0
+                else:
+                    self.recover_candidate_ts_ms = 0
+
+            liq_recovery_time_ms = 0
+            if self.stress_active == 1 and self.stress_start_ts_ms > 0 and ts >= self.stress_start_ts_ms:
+                liq_recovery_time_ms = ts - self.stress_start_ts_ms
+
+            # Fragility score: combine spread expansion and depth contraction (bounded 0..1)
+            # Use simple transform to avoid heavy math.
+            spread_sev = max(0.0, min(1.0, (spr_ratio - 1.0) / max(float(self.stress_spread_mult or 1.75) - 1.0, 0.25)))
+            depth_sev = max(0.0, min(1.0, (1.0 - dep_ratio) / max(float(self.stress_depth_drop_frac or 0.50), 0.10)))
+            frag = max(spread_sev, depth_sev)
+
+            return {
+                "liq_stress_active": int(self.stress_active),
+                "liq_recovery_time_ms": int(liq_recovery_time_ms),
+                "liq_fragility_score": float(frag),
+                "liq_spread_ema": float(self.spread_ema_bps),
+                "liq_depth_ema_usd": float(self.depth_ema_usd),
+                "liq_spread_ratio": float(spr_ratio),
+                "liq_depth_ratio": float(dep_ratio),
+            }
+        except Exception:
+            return {
+                "liq_stress_active": 0,
+                "liq_recovery_time_ms": 0,
+                "liq_fragility_score": 0.0,
+            }
