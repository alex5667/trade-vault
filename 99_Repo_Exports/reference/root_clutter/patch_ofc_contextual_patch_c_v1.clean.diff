+                b"last_ok": b"1",
+                b"last_batch_rows": b"7",
+            },
+            ex.ops_key: {
+                b"last_run_ts_ms": b"1700003600000",
+                b"last_ok": b"1",
+                b"last_exit_code": b"0",
+                b"bundle_created_ts_ms": b"1700003600000",
+            },
+        }
+    )
+    ex.tick()
