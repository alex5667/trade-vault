+        "symbol": "BTCUSDT",
+        "direction": "long",
+        "pnl_bps_net": 1.2,
+        "realized_slippage_bps": 0.9,
+        "fill_delay_ms": 150,
+    }) + "\n", encoding="utf-8")
+    work_dir = tmp_path / "work"
+    rc = subprocess.run(
+        [
+            sys.executable,
+            str(root / "orderflow_services/nightly_ofc_contextual_ops_bundle_v1.py"),
