+                            tps[0] = float(new_tp1)
+                        if isinstance(new_sl, (int, float)) and float(new_sl) < float(entry):
+                            sl = float(new_sl)
+                    else:  # SHORT
+                        if isinstance(new_tp1, (int, float)) and float(new_tp1) < float(entry):
+                            tps[0] = float(new_tp1)
+                        if isinstance(new_sl, (int, float)) and float(new_sl) > float(entry):
+                            sl = float(new_sl)
         except Exception:
             # Fail-open: never block signal building due to overlay issues.
             pass
