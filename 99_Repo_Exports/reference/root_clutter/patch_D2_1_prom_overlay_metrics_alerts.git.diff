diff --git a/../repo_base/services/orderflow/metrics.py b/services/orderflow/metrics.py
index a588af4..86bf679 100644
--- a/../repo_base/services/orderflow/metrics.py
+++ b/services/orderflow/metrics.py
@@ -1800,3 +1800,63 @@ metrics_queue_dropped_total = _get_or_create_prom_counter(
 
 # pre_publish_veto_total → pre_publish_gate_veto_total
 pre_publish_veto_total = pre_publish_gate_veto_total  # noqa: F811
+
+# -----------------------------------------------------------------------------
+# D2.1: LiqMap levels overlay (TP/SL anchoring) — Prometheus metrics
+# -----------------------------------------------------------------------------
+# These metrics are emitted from TickProcessor._calculate_levels() overlay block.
+# They are intentionally low-cardinality: labels are (symbol, window, [reason]).
+# - overlay_enabled: gauge (1 when overlay enabled and code-path is executed)
+# - attempt_total: counter (how many times overlay logic ran)
+# - applied: gauge (last observed applied flag: 0/1)
+# - applied_total: counter (how many times overlay actually modified TP1/SL)
+# - cap_sl_widen_total: counter (how many times SL widening was capped)
+# - tp1/sl adj bps histograms: distribution of signed adjustments in bps
+# -----------------------------------------------------------------------------
+
+liqmap_levels_overlay_enabled_gauge = _get_or_create_prom_gauge(
+    "liqmap_levels_overlay_enabled",
+    "LiqMap TP/SL overlay enabled on tick path (1 when executed)",
+    ["symbol", "window"],
+)
+liqmap_levels_attempt_total = _get_or_create_prom_counter(
+    "liqmap_levels_attempt",
+    "Total attempts to apply LiqMap TP/SL overlay (executed code-path)",
+    ["symbol", "window"],
+)
+liqmap_levels_applied_gauge = _get_or_create_prom_gauge(
+    "liqmap_levels_applied_last",
+    "LiqMap TP/SL overlay applied flag (last observed 0/1)",
+    ["symbol", "window"],
+)
+liqmap_levels_applied_total = _get_or_create_prom_counter(
+    "liqmap_levels_applied",
+    "Total successful LiqMap TP/SL overlay applications (TP1/SL modified)",
+    ["symbol", "window", "reason"],
+)
+liqmap_levels_cap_sl_widen_total = _get_or_create_prom_counter(
+    "liqmap_levels_cap_sl_widen",
+    "Total times SL widening was capped by max_sl_widen_bps",
+    ["symbol", "window"],
+)
+
+# Signed bps histograms (include negative buckets for SHORT/LONG symmetry).
+# Keep buckets coarse to avoid memory bloat; values are typically in [-50..50] bps.
+_LIQMAP_ADJ_BPS_BUCKETS = [
+    -200.0, -100.0, -50.0, -30.0, -20.0, -10.0, -5.0, -2.0, -1.0,
+    0.0,
+    1.0, 2.0, 5.0, 10.0, 20.0, 30.0, 50.0, 100.0, 200.0,
+]
+
+liqmap_tp1_adj_bps_hist = _get_or_create_prom_histogram(
+    "liqmap_tp1_adj_bps",
+    "Distribution of TP1 adjustment from LiqMap overlay (signed bps)",
+    ["symbol", "window"],
+    buckets=_LIQMAP_ADJ_BPS_BUCKETS,
+)
+liqmap_sl_adj_bps_hist = _get_or_create_prom_histogram(
+    "liqmap_sl_adj_bps",
+    "Distribution of SL adjustment from LiqMap overlay (signed bps)",
+    ["symbol", "window"],
+    buckets=_LIQMAP_ADJ_BPS_BUCKETS,
+)
diff --git a/services/orderflow/tests/test_liqmap_levels_overlay_metrics_exports_d21.py b/services/orderflow/tests/test_liqmap_levels_overlay_metrics_exports_d21.py
new file mode 100644
index 0000000..98de76d
--- /dev/null
+++ b/services/orderflow/tests/test_liqmap_levels_overlay_metrics_exports_d21.py
@@ -0,0 +1,49 @@
+from __future__ import annotations
+
+import importlib.util
+from pathlib import Path
+
+
+def _load_module_from_path(mod_name: str, path: Path):
+    spec = importlib.util.spec_from_file_location(mod_name, str(path))
+    assert spec is not None
+    assert spec.loader is not None
+    m = importlib.util.module_from_spec(spec)
+    spec.loader.exec_module(m)  # type: ignore[attr-defined]
+    return m
+
+
+def test_liqmap_levels_overlay_metrics_exports_d21():
+    root = Path(__file__).resolve().parents[3]  # repo root
+
+    # Import only SoT metrics to avoid default-registry collisions from the mirror module.
+    sot = _load_module_from_path(
+        "tick_flow_full_sot_metrics_d21",
+        root / "tick_flow_full" / "services" / "orderflow" / "metrics.py",
+    )
+
+    expected = [
+        "liqmap_levels_overlay_enabled_gauge",
+        "liqmap_levels_attempt_total",
+        "liqmap_levels_applied_gauge",
+        "liqmap_levels_applied_total",
+        "liqmap_levels_cap_sl_widen_total",
+        "liqmap_tp1_adj_bps_hist",
+        "liqmap_sl_adj_bps_hist",
+    ]
+    for name in expected:
+        assert hasattr(sot, name), f"SoT metrics missing {name}"
+
+    # label contracts (low cardinality)
+    assert tuple(sot.liqmap_levels_overlay_enabled_gauge._labelnames) == ("symbol", "window")
+    assert tuple(sot.liqmap_levels_attempt_total._labelnames) == ("symbol", "window")
+    assert tuple(sot.liqmap_levels_applied_gauge._labelnames) == ("symbol", "window")
+    assert tuple(sot.liqmap_levels_applied_total._labelnames) == ("symbol", "window", "reason")
+    assert tuple(sot.liqmap_levels_cap_sl_widen_total._labelnames) == ("symbol", "window")
+    assert tuple(sot.liqmap_tp1_adj_bps_hist._labelnames) == ("symbol", "window")
+    assert tuple(sot.liqmap_sl_adj_bps_hist._labelnames) == ("symbol", "window")
+
+    # Mirror: static check (avoid registry collisions on import)
+    mir_text = (root / "services" / "orderflow" / "metrics.py").read_text("utf-8", errors="ignore")
+    for name in expected:
+        assert name in mir_text, f"Mirror metrics code missing {name}"
