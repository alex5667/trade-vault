diff -ruN p45/db/migrations/20260306_11_risk_decision_summary.sql p46/db/migrations/20260306_11_risk_decision_summary.sql
--- p45/db/migrations/20260306_11_risk_decision_summary.sql	1970-01-01 00:00:00.000000000 +0000
+++ p46/db/migrations/20260306_11_risk_decision_summary.sql	2026-03-07 07:24:22.779816530 +0000
@@ -0,0 +1,42 @@
+
+-- P4.6: materialized SQL summary for risk decision quality and SLOs.
+
+create materialized view if not exists risk_decision_summary_mv as
+with base as (
+  select
+    created_ts_ms,
+    to_timestamp(created_ts_ms / 1000.0) at time zone 'utc' as created_at_utc,
+    tier,
+    level,
+    symbol,
+    cluster,
+    allow_trade_publish,
+    clamp_ratio,
+    decision_latency_ms,
+    (case when reasons_jsonb::text ilike '%confidence_below_tier_floor%' then 1 else 0 end) as confidence_denial,
+    (case when clamp_ratio < 0.999 then 1 else 0 end) as clamp_flag
+  from risk_decision_audit
+), windows as (
+  select '1h'::text as window_name, ((extract(epoch from now()) * 1000)::bigint - 3600 * 1000)::bigint as cutoff_ts_ms
+  union all
+  select '24h'::text, ((extract(epoch from now()) * 1000)::bigint - 24 * 3600 * 1000)::bigint
+  union all
+  select '7d'::text, ((extract(epoch from now()) * 1000)::bigint - 7 * 24 * 3600 * 1000)::bigint
+)
+select
+  w.window_name,
+  b.tier,
+  b.level,
+  count(*)::bigint as decision_count,
+  coalesce(sum(case when b.allow_trade_publish then 1 else 0 end), 0)::bigint as allow_count,
+  coalesce(sum(case when not b.allow_trade_publish then 1 else 0 end), 0)::bigint as deny_count,
+  coalesce(sum(b.clamp_flag), 0)::bigint as clamp_count,
+  coalesce(sum(b.confidence_denial), 0)::bigint as confidence_denial_count,
+  coalesce(avg(b.clamp_ratio), 1.0)::double precision as avg_clamp_ratio,
+  coalesce(percentile_cont(0.95) within group (order by b.decision_latency_ms), 0)::double precision as decision_latency_p95_ms,
+  max(b.created_ts_ms)::bigint as latest_created_ts_ms,
+  ((extract(epoch from now()) * 1000)::bigint)::bigint as refreshed_ts_ms
+from windows w
+join base b on b.created_ts_ms >= w.cutoff_ts_ms
+group by w.window_name, b.tier, b.level
+with no data;
