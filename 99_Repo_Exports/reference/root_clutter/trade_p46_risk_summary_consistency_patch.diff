@@ -0,0 +1,76 @@
+#!/usr/bin/env python3
+from __future__ import annotations
+
+import argparse
+import json
+import os
+
+try:
+    import psycopg  # type: ignore
+except Exception:  # pragma: no cover
+    psycopg = None  # type: ignore
+
+
+def _eq_num(a, b, tol: float = 1e-6) -> bool:
+    try:
+        return abs(float(a) - float(b)) <= tol
+    except Exception:
+        return a == b
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser(description='Check consistency between signal payload persisted in risk_decision_audit and SQL risk_snapshot.')
+    parser.add_argument('--dsn', default=os.getenv('RISK_AUDIT_SQL_DSN', os.getenv('EXECUTION_JOURNAL_DSN', '')))
+    parser.add_argument('--limit', type=int, default=int(os.getenv('RISK_CONSISTENCY_LIMIT', '250')))
+    args = parser.parse_args()
+    if not args.dsn or psycopg is None:
+        raise RuntimeError('psycopg + DSN required')
+
+    mismatches = []
+    checked = 0
+    with psycopg.connect(args.dsn) as conn:
+        with conn.cursor() as cur:
+            cur.execute('''
+                select a.decision_id, a.symbol, a.sid, a.effective_execution_policy,
+                       a.adjusted_notional_usd, a.leverage_cap, a.clamp_ratio,
+                       a.signal_jsonb, s.snapshot_jsonb, s.tier, s.level,
+                       s.effective_execution_policy as snap_execution_policy,
+                       s.adjusted_notional_usd as snap_adjusted_notional_usd,
+                       s.leverage_cap as snap_leverage_cap,
+                       s.clamp_ratio as snap_clamp_ratio
+                from risk_decision_audit a
+                join risk_snapshot s using (decision_id)
+                order by a.created_ts_ms desc
+                limit %s
+            ''', (args.limit,))
+            for row in cur.fetchall():
+                checked += 1
+                decision_id, symbol, sid, exec_policy, adjusted_notional, leverage_cap, clamp_ratio, signal_jsonb, snapshot_jsonb, tier, level, snap_exec_policy, snap_adj, snap_lev, snap_clamp = row
+                signal = signal_jsonb or {}
+                snap = snapshot_jsonb or {}
+                reasons = []
+                if str(signal.get('execution_policy') or exec_policy) != str(snap_exec_policy or signal.get('execution_policy') or exec_policy):
+                    reasons.append('execution_policy')
+                if not _eq_num(signal.get('planned_notional_usd', adjusted_notional), snap_adj):
+                    reasons.append('planned_notional_usd')
+                if not _eq_num(signal.get('risk_leverage_cap', leverage_cap), snap_lev):
+                    reasons.append('risk_leverage_cap')
+                snap_ratio = snap.get('clamp_ratio') if isinstance(snap, dict) else None
+                if not _eq_num((snap_ratio if snap_ratio is not None else clamp_ratio), snap_clamp):
+                    reasons.append('clamp_ratio_snapshot')
+                if reasons:
+                    mismatches.append({
+                        'decision_id': decision_id,
+                        'sid': sid,
+                        'symbol': symbol,
+                        'tier': tier,
+                        'level': level,
+                        'mismatches': reasons,
+                    })
+    out = {'checked': checked, 'mismatch_count': len(mismatches), 'mismatches': mismatches}
+    print(json.dumps(out, ensure_ascii=False, indent=2))
+    return 0
+
+
+if __name__ == '__main__':  # pragma: no cover
+    raise SystemExit(main())
diff -ruN p45/scripts/refresh_risk_decision_summary.py p46/scripts/refresh_risk_decision_summary.py
--- p45/scripts/refresh_risk_decision_summary.py	1970-01-01 00:00:00.000000000 +0000
+++ p46/scripts/refresh_risk_decision_summary.py	2026-03-07 07:24:22.780355777 +0000
@@ -0,0 +1,46 @@
+#!/usr/bin/env python3
+from __future__ import annotations
+
+import argparse
+import json
+import os
+from pathlib import Path
+
+try:
+    import psycopg  # type: ignore
+except Exception:  # pragma: no cover
+    psycopg = None  # type: ignore
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser(description='Refresh materialized risk decision summary and emit JSON report.')
+    parser.add_argument('--dsn', default=os.getenv('RISK_AUDIT_SQL_DSN', os.getenv('EXECUTION_JOURNAL_DSN', '')))
+    parser.add_argument('--out', default=os.getenv('RISK_DECISION_SUMMARY_REPORT_PATH', '/var/lib/trade-runbook/reports/latest_risk_decision_summary.json'))
+    args = parser.parse_args()
+    if not args.dsn or psycopg is None:
+        raise RuntimeError('psycopg + DSN required')
+
+    report = {'rows': []}
+    with psycopg.connect(args.dsn) as conn:
+        with conn.cursor() as cur:
+            cur.execute('refresh materialized view risk_decision_summary_mv')
+            cur.execute('''
+                select window_name, tier, level, decision_count, allow_count, deny_count,
+                       clamp_count, confidence_denial_count, avg_clamp_ratio,
+                       decision_latency_p95_ms, latest_created_ts_ms, refreshed_ts_ms
+                from risk_decision_summary_mv
+                order by window_name, tier, level
+            ''')
+            cols = [d.name for d in cur.description]
+            for row in cur.fetchall():
+                report['rows'].append({k: row[i] for i, k in enumerate(cols)})
+        conn.commit()
+    out = Path(args.out)
+    out.parent.mkdir(parents=True, exist_ok=True)
+    out.write_text(json.dumps(report, ensure_ascii=False, indent=2), encoding='utf-8')
+    print(json.dumps({'rows': len(report['rows']), 'out': str(out)}, ensure_ascii=False))
+    return 0
+
+
+if __name__ == '__main__':  # pragma: no cover
+    raise SystemExit(main())
