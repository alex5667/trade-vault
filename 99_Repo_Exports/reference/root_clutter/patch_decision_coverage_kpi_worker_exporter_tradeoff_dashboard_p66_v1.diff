+groups:
+  - name: tradeoff-p66
+    rules:
+      - alert: DecisionFinalStaleSLO
+        expr: (time() - (decision_last_ts_ms / 1000)) > 1800
+        for: 5m
+        labels:
+          severity: critical
+          team: trade
+          component: decision_coverage
+        annotations:
+          summary: "decisions:final is stale (>30m)"
+          description: "No new decisions observed for >30m. Check crypto-orderflow-service, Redis, consumer-group lag."
+          runbook_path: "/tradeoff_p66.md"
+          dashboard_path: "/d/tradeoff_p66/tradeoff-coverage-vs-quality?orgId=1"
+
+      - alert: DecisionRegimeUnknownShareHighSLO
+        expr: decision_regime_share_24h{regime="unknown"} > 0.05 and decision_n_24h > 200
+        for: 30m
+        labels:
+          severity: warning
+          team: trade
+          component: decision_coverage
+        annotations:
+          summary: "Unknown regime share high (>5%)"
+          description: "Too many decisions have unknown dq/drift regime. Likely missing dq_state/drift_state in payload or parser mismatch."
+          runbook_path: "/tradeoff_p66.md"
+          dashboard_path: "/d/tradeoff_p66/tradeoff-coverage-vs-quality?orgId=1"
+
+      - alert: DecisionRegimeBlockShareHighSLO
+        expr: decision_regime_share_24h{regime="block"} > 0.15 and decision_n_24h > 200
+        for: 30m
+        labels:
+          severity: warning
+          team: trade
+          component: decision_coverage
+        annotations:
+          summary: "Block regime share high (>15%)"
+          description: "A large share of decisions are in block regime. Check DQ/Drift gates and market conditions; consider shadow mode for ML rollout."
+          runbook_path: "/tradeoff_p66.md"
+          dashboard_path: "/d/tradeoff_p66/tradeoff-coverage-vs-quality?orgId=1"
