+++ b/orderflow_services/deploy/systemd/trade-strategy-research-guard-exporter.service
@@ -0,0 +1,15 @@
+[Unit]
+Description=Trade strategy research guard exporter
+After=network-online.target
+Wants=network-online.target
+
+[Service]
+Type=simple
+EnvironmentFile=/etc/default/trade-latency-sensitive-jobs-staging
+Environment=PYTHONUNBUFFERED=1
+ExecStart=/bin/bash -lc 'cd "${TRADE_REPO_ROOT:?}" && ./orderflow_services/deploy/systemd/run_trade_strategy_research_guard_exporter_v1.sh'
+Restart=always
+RestartSec=5
+
+[Install]
+WantedBy=multi-user.target
diff --git a/orderflow_services/integrations/metrics-proxy.strategy-research-guard-exporter-v1.conf b/orderflow_services/integrations/metrics-proxy.strategy-research-guard-exporter-v1.conf
--- a/orderflow_services/integrations/metrics-proxy.strategy-research-guard-exporter-v1.conf
+++ b/orderflow_services/integrations/metrics-proxy.strategy-research-guard-exporter-v1.conf
@@ -0,0 +1,8 @@
+# Include into metrics-proxy nginx/conf.d to expose the exporter through a stable route.
+location /m/strategy-research-guard-exporter {
+    proxy_pass http://strategy-research-guard-exporter:${STRATEGY_RESEARCH_GUARD_EXPORTER_PORT:-9836}/metrics;
+    proxy_http_version 1.1;
+    proxy_set_header Host $host;
+    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
+    proxy_set_header X-Forwarded-Proto $scheme;
+}
