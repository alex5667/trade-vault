@@ -0,0 +1,20 @@
+services:
+  strategy-research-guard-exporter:
+    image: ${TRADE_ORDERFLOW_IMAGE:?}
+    working_dir: /app
+    environment:
+      PYTHONPATH: /app
+      REDIS_URL: ${REDIS_URL:?}
+      STRATEGY_RESEARCH_GUARD_SUMMARY_KEY: ${STRATEGY_RESEARCH_GUARD_SUMMARY_KEY:-metrics:strategy_research_guard:last}
+      STRATEGY_RESEARCH_GUARD_BLOCKER_KEY: ${STRATEGY_RESEARCH_GUARD_BLOCKER_KEY:-cfg:research_guard:blocker:v1}
+      STRATEGY_RESEARCH_GUARD_EXPORTER_PORT: ${STRATEGY_RESEARCH_GUARD_EXPORTER_PORT:-9836}
+      STRATEGY_RESEARCH_GUARD_EXPORTER_INTERVAL_S: ${STRATEGY_RESEARCH_GUARD_EXPORTER_INTERVAL_S:-15}
+    volumes:
+      - ${TRADE_REPO_ROOT:?}:/app:ro
+    expose:
+      - "${STRATEGY_RESEARCH_GUARD_EXPORTER_PORT:-9836}"
+    command:
+      - bash
+      - -lc
+      - >-
+        python3 -m orderflow_services.strategy_research_guard_state_exporter_v1
