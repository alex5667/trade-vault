+# -*- coding: utf-8 -*-
+"""P86: Contract test for v_exec_slippage_eval SQL view.
+
+Several P80/P86 tools query v_exec_slippage_eval with columns:
+  - slippage_residual_bps
+  - edge_minus_expected_bps
+
+This test ensures the SQL source files in both trees include these columns.
+"""
+
+from __future__ import annotations
+
+from pathlib import Path
+
+
+def _read(p: Path) -> str:
+    return p.read_text(encoding="utf-8", errors="replace")
+
+
+def test_exec_slippage_eval_view_sql_contains_p86_columns() -> None:
+    repo = Path(__file__).resolve().parents[2]  # repo root (python-worker/)
+    paths = [
+        repo / "services" / "archivers" / "sql" / "20260223_exec_slippage_eval_view.sql",
+        repo / "tick_flow_full" / "services" / "archivers" / "sql" / "20260223_exec_slippage_eval_view.sql",
+    ]
+    for p in paths:
+        assert p.exists(), f"missing SQL file: {p}"
+        s = _read(p)
+        assert "CREATE OR REPLACE VIEW v_exec_slippage_eval" in s, f"view DDL missing in {p}"
+        assert "slippage_residual_bps" in s, f"slippage_residual_bps missing in {p}"
+        assert "edge_minus_expected_bps" in s, f"edge_minus_expected_bps missing in {p}"
