+        side="LONG",
+        cum_notional=(0.4 * 100.02) + (0.6 * 100.04),
+        cum_qty=1.0,
+        cum_fee_usd=0.0,
+    )
+    assert v is not None
+    assert 3.19 <= float(v) <= 3.21
+
