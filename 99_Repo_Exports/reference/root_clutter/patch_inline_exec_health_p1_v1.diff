+            max_samples=32,
+        )
+        assert s1["count"] == 1
+        assert 1.9 <= s1["p95_bps"] <= 2.1
+
+        # Same sid partial fill must overwrite/update one sample, not create count=2.
+        s2 = await update_inline_exec_from_fill(
+            redis=ar,
