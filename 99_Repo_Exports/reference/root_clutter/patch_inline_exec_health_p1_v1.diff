+def test_update_inline_exec_from_fill_overwrites_same_sid_sample_and_sync_read():
+    async def _run():
+        store = MemStore()
+        ar = AsyncRedis(store)
+        dims = InlineExecDims(symbol="BTCUSDT", side="LONG", session="eu", kind="breakout", tf="1m")
+
+        s1 = await update_inline_exec_from_fill(
+            redis=ar,
+            sid="sid-1",
