+class AsyncRedis:
+    def __init__(self, store: MemStore):
+        self.s = store
+
+    async def hgetall(self, key):
+        return dict(self.s.hashes.get(key, {}))
+
+    async def hset(self, key, mapping=None):
+        self.s.hashes.setdefault(key, {})
+        for k, v in (mapping or {}).items():
+            self.s.hashes[key][k] = v
+        return 1
+
+    async def expire(self, key, ttl):
+        return True
+
+    async def zadd(self, key, mapping):
+        self.s.zsets.setdefault(key, {})
+        self.s.zsets[key].update(mapping)
+        return 1
+
+    async def zcard(self, key):
+        return len(self.s.zsets.get(key, {}))
+
+    async def zrange(self, key, start, stop):
+        items = sorted(self.s.zsets.get(key, {}).items(), key=lambda kv: (kv[1], kv[0]))
+        if stop == -1:
+            sliced = items[start:]
+        else:
+            sliced = items[start : stop + 1]
+        return [k for k, _ in sliced]
+
+    async def zrem(self, key, *members):
+        z = self.s.zsets.get(key, {})
+        for m in members:
+            z.pop(m, None)
+        return 1
+
+    async def hdel(self, key, *members):
+        h = self.s.hashes.get(key, {})
+        for m in members:
+            h.pop(m, None)
+        return 1
+
+    async def hget(self, key, member):
+        return self.s.hashes.get(key, {}).get(member)
+
+
+class SyncRedis:
+    def __init__(self, store: MemStore):
+        self.s = store
+
+    def hgetall(self, key):
+        return dict(self.s.hashes.get(key, {}))
+
