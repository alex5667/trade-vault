@@ -0,0 +1,90 @@
+package hyperliquid
+
+import (
+	"context"
+	"log"
+	"os"
+	"sort"
+	"testing"
+
+	"github.com/stretchr/testify/assert"
+	"github.com/stretchr/testify/require"
+)
+
+// noopPublisher satisfies internalredis.Publisher interface for testing.
+type noopPublisher struct {
+	ticks []string
+	books []string
+}
+
+func (p *noopPublisher) PublishTick(_ context.Context, symbol string, _ map[string]any) error {
+	p.ticks = append(p.ticks, symbol)
+	return nil
+}
+
+func (p *noopPublisher) PublishBook(_ context.Context, symbol string, _ map[string]any) error {
+	p.books = append(p.books, symbol)
+	return nil
+}
+
+func newTestController() *FuturesStreamController {
+	logger := log.New(os.Stdout, "[test-hl] ", 0)
+	return &FuturesStreamController{
+		publisher: &noopPublisher{},
+		logger:    logger,
+		symbolMap: map[string]string{},
+		// default suffix (not relevant for reconcile tests)
+		symbolSuffix:  "USDT",
+		maxBookLevels: 20,
+	}
+}
+
+func sortedStrings(ss []string) []string {
+	out := make([]string, len(ss))
+	copy(out, ss)
+	sort.Strings(out)
+	return out
+}
+
+func TestReconcile_NoOpOnSameCoins(t *testing.T) {
+	c := newTestController()
+	c.currentCoins = []string{"BTC", "ETH"}
+
+	ctx, cancel := context.WithCancel(context.Background())
+	defer cancel()
+
+	c.reconcile(ctx, []string{"BTC", "ETH"})
+	assert.Nil(t, c.activeManager, "no manager should be created for no-op reconcile")
+}
+
+func TestReconcile_NewCoinsTriggersReconnect(t *testing.T) {
+	c := newTestController()
+	c.currentCoins = []string{}
+
+	ctx, cancel := context.WithCancel(context.Background())
+	defer cancel()
+
+	coins := []string{"BTC", "ETH", "SOL"}
+	c.reconcile(ctx, coins)
+	require.Equal(t, 3, len(c.currentCoins))
+
+	got := sortedStrings(c.currentCoins)
+	want := []string{"BTC", "ETH", "SOL"}
+	for i := range want {
+		assert.Equal(t, want[i], got[i])
+	}
+
+	cancel()
+}
+
+func TestUpdateSubscriptions_NoConn(t *testing.T) {
+	m := NewHyperliquidFuturesManager([]string{"BTC"}, log.New(os.Stdout, "", 0))
+	err := m.UpdateSubscriptions([]string{"ETH"}, nil)
+	assert.Error(t, err)
+	assert.Contains(t, err.Error(), "no active connection")
+}
+
+func TestLoadBaseCoins_FromSymbols(t *testing.T) {
+	coins := LoadBaseCoins([]string{"BTCUSDT", "ETHUSDT", "1000PEPEUSDT"})
+	require.Equal(t, []string{"1000PEPE", "BTC", "ETH"}, coins)
+}

