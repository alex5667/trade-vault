+from pathlib import Path
+import importlib.util
+import sys
+
+root = Path(__file__).resolve().parents[2]
+if str(root) not in sys.path:
+    sys.path.insert(0, str(root))
+
+
+def _load(name: str, rel: str):
+    mod_path = root / rel
+    spec = importlib.util.spec_from_file_location(name, mod_path)
+    mod = importlib.util.module_from_spec(spec)
+    sys.modules[spec.name] = mod
+    assert spec.loader is not None
+    spec.loader.exec_module(mod)
+    return mod
+
+
+store_mod = _load('services.active_symbol_guard_store_p7_integration', 'services/active_symbol_guard_store.py')
+proj_mod = _load('services.execution_projection_worker_p7_integration', 'services/execution_projection_worker.py')
+exec_mod = _load('services.binance_executor_p7_integration', 'services/binance_executor.py')
+repair_mod = _load('services.binance_guard_repair_p7_integration', 'services/binance_active_symbol_guard_repair_worker.py')
+
+
+class FakeRedis:
+    def __init__(self):
+        self.kv = {}
+        self.streams = {}
+        self._seq = 0
+
+    def get(self, key):
+        return self.kv.get(key)
+
+    def set(self, key, value, ex=None, nx=False, px=None):
+        if nx and key in self.kv:
+            return False
+        self.kv[key] = value
+        return True
+
+    def delete(self, *keys):
+        n = 0
+        for key in keys:
+            if key in self.kv:
+                del self.kv[key]
+                n += 1
+        return n
+
+    def scan_iter(self, match=None):
+        prefix = str(match or '').rstrip('*')
+        for key in list(self.kv.keys()):
+            if key.startswith(prefix):
+                yield key
+
+    def xadd(self, key, fields, maxlen=None, approximate=None):
+        self._seq += 1
+        sid = f"{1700000000000 + self._seq}-0"
+        self.streams.setdefault(key, []).append((sid, dict(fields)))
+        return sid
+
+    def xrange(self, key, start='-', end='+', count=None):
+        rows = list(self.streams.get(key, []))
+        if count is not None:
+            rows = rows[: int(count)]
+        return rows
+
+
+def _mk_executor(redis_obj):
+    ex = exec_mod.BinanceExecutor.__new__(exec_mod.BinanceExecutor)
+    ex.r = redis_obj
+    ex.state_key_prefix = 'orders:state:'
+    ex.state_ttl = 86400
+    ex.exec_single_active_position_per_symbol = True
+    ex.exec_single_active_position_release_on_terminal = True
+    ex.exec_single_active_position_exchange_truth_release = True
+    ex.active_symbol_key_prefix = 'orders:active_symbol_sid:'
+    ex.active_symbol_guard_tombstone_ttl_sec = 120
+    ex.execution_journal = None
+    ex.exec_journal_primary = False
+    ex.exec_state_derived_view = True
+    ex.exec_inline_state_projection = True
+    return ex
+
+
+def _mk_repair(redis_obj):
+    w = repair_mod.BinanceActiveSymbolGuardRepairWorker.__new__(repair_mod.BinanceActiveSymbolGuardRepairWorker)
+    w.r = redis_obj
+    w.active_symbol_key_prefix = 'orders:active_symbol_sid:'
+    w.state_key_prefix = 'orders:state:'
+    w.state_ttl_sec = 86400
+    w.active_symbol_guard_tombstone_ttl_sec = 120
+    w.dry_run = False
+    return w
+
+
+def test_projection_late_same_sid_event_cannot_resurrect_after_repair_release():
+    r = FakeRedis()
+    worker = proj_mod.ExecutionProjectionWorker(r, exchange_truth_release=True, state_ttl_sec=86400)
+    repair = _mk_repair(r)
+    store = store_mod.ActiveSymbolGuardStore(r, key_prefix='orders:active_symbol_sid:', active_ttl_sec=86400, tombstone_ttl_sec=120)
+
+    worker._persist_active_symbol_state({'symbol': 'BTCUSDT', 'sid': 'sid-A', 'fsm_state': 'ENTRY_FILLED', 'updated_at_ms': 100})
+    released = repair._clear_guard('BTCUSDT', expected_sid='sid-A')
+    assert released is True
+    assert store.load_active('BTCUSDT') == {}
+
+    worker._persist_active_symbol_state({'symbol': 'BTCUSDT', 'sid': 'sid-A', 'fsm_state': 'ENTRY_FILLED', 'updated_at_ms': 200})
+    assert store.load_active('BTCUSDT') == {}
+    assert store.load_raw('BTCUSDT').get('guard_status') == 'released'
+
+
+def test_executor_new_sid_can_acquire_after_released_tombstone():
+    r = FakeRedis()
+    worker = proj_mod.ExecutionProjectionWorker(r, exchange_truth_release=True, state_ttl_sec=86400)
+    repair = _mk_repair(r)
+    executor = _mk_executor(r)
+    store = store_mod.ActiveSymbolGuardStore(r, key_prefix='orders:active_symbol_sid:', active_ttl_sec=86400, tombstone_ttl_sec=120)
+
+    worker._persist_active_symbol_state({'symbol': 'BTCUSDT', 'sid': 'sid-A', 'fsm_state': 'ENTRY_FILLED', 'updated_at_ms': 100})
+    assert repair._clear_guard('BTCUSDT', expected_sid='sid-A') is True
+    executor._persist_materialized_state_cache('sid-B', {'symbol': 'BTCUSDT', 'sid': 'sid-B', 'fsm_state': 'ENTRY_FILLED', 'status': 'open', 'updated_at_ms': 300})
+
+    active = store.load_active('BTCUSDT')
+    assert active.get('sid') == 'sid-B'
+    assert active.get('guard_status') == 'active'
