+from pathlib import Path
+import importlib.util
+import json
+import sys
+
+root = Path(__file__).resolve().parents[2]
+if str(root) not in sys.path:
+    sys.path.insert(0, str(root))
+
+mod_path = root / 'services' / 'active_symbol_guard_store.py'
+spec = importlib.util.spec_from_file_location('services.active_symbol_guard_store_p7', mod_path)
+mod = importlib.util.module_from_spec(spec)
+sys.modules[spec.name] = mod
+assert spec.loader is not None
+spec.loader.exec_module(mod)
+
+
+class FakeRedis:
+    def __init__(self):
+        self.kv = {}
+
+    def get(self, key):
+        return self.kv.get(key)
+
+    def set(self, key, value, ex=None):
+        self.kv[key] = value
+        return True
+
+    def delete(self, key):
+        self.kv.pop(key, None)
+        return 1
+
+    def scan_iter(self, match=None):
+        prefix = str(match or '').rstrip('*')
+        for key in list(self.kv.keys()):
+            if key.startswith(prefix):
+                yield key
+
+
+ActiveSymbolGuardStore = mod.ActiveSymbolGuardStore
+
+
+def test_released_tombstone_blocks_same_sid_resurrection():
+    r = FakeRedis()
+    store = ActiveSymbolGuardStore(r, key_prefix='orders:active_symbol_sid:', active_ttl_sec=86400, tombstone_ttl_sec=120)
+
+    first = store.acquire_or_refresh(symbol='BTCUSDT', sid='sid-A', payload_patch={'fsm_state': 'OPEN'}, writer='projection')
+    assert first['applied'] is True
+
+    released = store.mark_released(symbol='BTCUSDT', expected_sid='sid-A', release_reason='flat', writer='guard_repair')
+    assert released['applied'] is True
+    assert released['doc']['guard_status'] == 'released'
+
+    late_same_sid = store.acquire_or_refresh(symbol='BTCUSDT', sid='sid-A', payload_patch={'fsm_state': 'OPEN_LATE'}, writer='projection')
+    assert late_same_sid['applied'] is False
+    assert late_same_sid['reason'] == 'released_tombstone_same_sid'
+    assert store.load_active('BTCUSDT') == {}
+    assert store.load_raw('BTCUSDT').get('guard_status') == 'released'
+
+
+def test_different_sid_can_take_over_after_release_tombstone():
+    r = FakeRedis()
+    store = ActiveSymbolGuardStore(r, key_prefix='orders:active_symbol_sid:', active_ttl_sec=86400, tombstone_ttl_sec=120)
+
+    first = store.acquire_or_refresh(symbol='BTCUSDT', sid='sid-A', payload_patch={'fsm_state': 'OPEN'}, writer='projection')
+    release = store.mark_released(symbol='BTCUSDT', expected_sid='sid-A', release_reason='flat', writer='guard_repair')
+    second = store.acquire_or_refresh(symbol='BTCUSDT', sid='sid-B', payload_patch={'fsm_state': 'OPEN'}, writer='executor')
+
+    assert first['doc']['guard_version'] == 1
+    assert release['doc']['guard_version'] == 2
+    assert second['applied'] is True
+    assert second['doc']['guard_version'] == 3
+    assert second['doc']['sid'] == 'sid-B'
+    assert second['doc']['guard_status'] == 'active'
+    assert store.load_active('BTCUSDT').get('sid') == 'sid-B'
+
+
+def test_stale_release_cas_cannot_delete_newer_refresh():
+    r = FakeRedis()
+    store = ActiveSymbolGuardStore(r, key_prefix='orders:active_symbol_sid:', active_ttl_sec=86400, tombstone_ttl_sec=120)
+
+    created = store.acquire_or_refresh(symbol='BTCUSDT', sid='sid-A', payload_patch={'fsm_state': 'OPEN', 'updated_at_ms': 100}, writer='projection')
+    stale = dict(created['doc'])
+    refreshed = store.acquire_or_refresh(symbol='BTCUSDT', sid='sid-A', payload_patch={'fsm_state': 'OPEN', 'updated_at_ms': 200}, writer='executor')
+    assert refreshed['doc']['guard_version'] == 2
+
+    stale_release_doc = dict(stale)
+    stale_release_doc.update({'guard_status': 'released', 'release_reason': 'stale_release', 'guard_writer': 'guard_repair'})
+    rejected = store._cas_set(
+        symbol='BTCUSDT',
+        payload_doc=stale_release_doc,
+        expected_version=int(stale['guard_version']),
+        expected_sid='sid-A',
+        expected_lease_token=str(stale.get('guard_lease_token') or ''),
+        ttl_sec=120,
+    )
+    assert rejected['applied'] is False
+    assert rejected['reason'] == 'version_mismatch'
+    assert store.load_active('BTCUSDT').get('guard_version') == 2
