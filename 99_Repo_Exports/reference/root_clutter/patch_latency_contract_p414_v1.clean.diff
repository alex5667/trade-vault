@@ -0,0 +1,109 @@
+from orderflow_services import latency_contract_deploy_lint_silence_v1 as mod
+
+
+class FakeRedis:
+    def __init__(self):
+        self.h = {}
+        self.exp = {}
+        self.stream = []
+        self.kv = {}
+    def hgetall(self, k):
+        return dict(self.h.get(k, {}))
+    def hset(self, k, mapping=None, **kwargs):
+        cur = self.h.setdefault(k, {})
+        cur.update(mapping or kwargs)
+    def expire(self, k, ttl):
+        self.exp[k] = ttl
+    def xadd(self, stream, fields, maxlen=None, approximate=None):
+        self.stream.append((stream, dict(fields)))
+        return f"{len(self.stream)}-0"
+    def get(self, k):
+        return self.kv.get(k)
+    def set(self, k, v, ex=None):
+        self.kv[k] = v
+        if ex is not None:
+            self.exp[k] = ex
+
+
+def _cfg(*, warn_csv: str = '', crit_csv: str = '', page_csv: str = '') -> mod.Cfg:
+    return mod.Cfg(
+        redis_url='redis://unused',
+        state_prefix='metrics:latency_contract:deploy_lint:last',
+        silence_prefix='cfg:orderflow:latency_contract:deploy_lint:silence',
+        approval_prefix='cfg:orderflow:latency_contract:deploy_lint:silence_approval',
+        ops_stream='ops:latency_contract:events:v1',
+        silence_ttl_s=3600,
+        approval_ttl_s=3600,
+        approval_prepared_freshness_s=60,
+        approval_approved_freshness_s=60,
+        default_minutes=60,
+        policy_window_s=168 * 3600,
+        policy_max_budget_minutes=60,
+        policy_max_acks=1,
+        policy_denied_exit_code=27,
+        dual_control_minutes=45,
+        notify_warn_codes_warn_csv=warn_csv,
+        notify_warn_codes_crit_csv=crit_csv,
+        notify_warn_codes_page_csv=page_csv,
+    )
+
+
+def test_ack_invalidates_when_warning_policy_changes_without_core_drift_change() -> None:
+    r = FakeRedis()
+    key = 'metrics:latency_contract:deploy_lint:last:meta_cov_rollout_controller'
+    r.h[key] = {
+        'gate_active': '1',
+        'gate_reason_code': 'persistent_config_drift',
+        'error_codes': 'compose_wrong_service',
+        'errors_count': '1',
+        'warning_codes': 'unexpected_environmentfile',
+        'warnings_count': '1',
+        'compose_file': '/tmp/a.yml',
+        'wrapper_file': '/tmp/b.sh',
+        'unit_file': '/tmp/c.service',
+        'env_file': '/tmp/d.env',
+        'missing_runtime_env': 'none',
+        'missing_env_file_vars': 'none',
+    }
+    cfg_prepare = _cfg(warn_csv='unexpected_environmentfile')
+    cfg_ack = _cfg(page_csv='unexpected_environmentfile')
+    mod.cmd_ack(r, cfg_prepare, purpose='meta_cov_rollout_controller', operator='alex', ticket='INC-1', reason='known drift', minutes=30, now_ms=1000)
+    prep = mod.cmd_prepare_override(
+        r, cfg_prepare, purpose='meta_cov_rollout_controller', operator='alex', ticket='INC-1',
+        escalation_ticket='SEV-1', reason='need long silence', minutes=45, now_ms=2000,
+    )
+    req_id = prep['request_id']
+    mod.cmd_approve_override(r, cfg_prepare, request_id=req_id, operator='bob', reason='approved', now_ms=3000)
+    out = mod.cmd_ack(
+        r, cfg_ack, purpose='meta_cov_rollout_controller', operator='alex', ticket='INC-1',
+        escalation_ticket='SEV-1', approval_request_id=req_id, reason='final ack', minutes=45, now_ms=4000,
+    )
+    assert out['ok'] is False
+    assert 'warning_severity_policy' in out['policy']['denied_reason']
+    assert 'notifier_route_class' in out['policy']['denied_reason']
+    approval_key = f'cfg:orderflow:latency_contract:deploy_lint:silence_approval:req:{req_id}'
+    assert r.h[approval_key]['status'] == 'invalidated'
+
+
+def test_status_exposes_warning_policy_binding_fields() -> None:
+    r = FakeRedis()
+    key = 'metrics:latency_contract:deploy_lint:last:meta_cov_rollout_controller'
+    r.h[key] = {
+        'gate_active': '1',
+        'gate_reason_code': 'persistent_config_drift',
+        'error_codes': 'compose_wrong_service',
+        'errors_count': '1',
+        'warning_codes': 'unexpected_environmentfile',
+        'warnings_count': '1',
+    }
+    cfg = _cfg(warn_csv='unexpected_environmentfile')
+    prep = mod.cmd_prepare_override(
+        r, cfg, purpose='meta_cov_rollout_controller', operator='alex', ticket='INC-1',
+        escalation_ticket='SEV-1', reason='need long silence', minutes=45, now_ms=2000,
+    )
+    mod.cmd_approve_override(r, cfg, request_id=prep['request_id'], operator='bob', reason='approved', now_ms=3000)
+    row = mod.cmd_status(r, cfg, purpose='meta_cov_rollout_controller', now_ms=3500)['rows'][0]
+    assert row['latest_approval_bound_warning_severity_policy'] == 'warn'
+    assert row['latest_approval_bound_notifier_route_class'] == 'notify'
+    assert row['latest_approval_current_warning_severity_policy'] == 'warn'
+    assert row['latest_approval_current_notifier_route_class'] == 'notify'
