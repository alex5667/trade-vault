+from orderflow_services import latency_contract_deploy_lint_notifier_v1 as mod
+
+
+def test_page_warning_policy_routes_to_page_stream() -> None:
+    cfg = mod.Cfg(
+        redis_url='redis://unused',
+        state_prefix='metrics:latency_contract:deploy_lint:last',
+        notifier_state_key='metrics:latency_contract:deploy_lint:notifier:last',
+        silence_prefix='cfg:orderflow:latency_contract:deploy_lint:silence',
+        silence_ttl_s=3600,
+        ops_stream='ops:latency_contract:events:v1',
+        notify_stream='notify:telegram',
+        notify_page_stream='notify:telegram:page',
+        notify_enable=True,
+        reminder_s=60,
+        escalated_reminder_s=60,
+        state_ttl_s=3600,
+        warn_codes_warn_csv='unexpected_environmentfile',
+        warn_codes_crit_csv='',
+        warn_codes_page_csv='unexpected_environmentfile',
+    )
+    details = {'meta_cov_rollout_controller': {'warning_codes': 'unexpected_environmentfile'}}
+    policy = mod._warning_policy_for_active(cfg, details, ['meta_cov_rollout_controller'])
+    assert policy == 'page'
+    assert mod._route_class_for_event('latency_deploy_lint_persistent_drift', policy) == 'page'
+    assert mod._notify_stream_for_event(cfg, 'latency_deploy_lint_persistent_drift', policy) == 'notify:telegram:page'
