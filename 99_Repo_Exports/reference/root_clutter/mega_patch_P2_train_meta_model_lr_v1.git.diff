+import hashlib
+from typing import Any, Dict, List, Optional, Tuple
+
+from core.meta_features_v7 import (
+    META_FEAT_V7_COLS,
+    META_FEAT_V7_HASH,
+    META_FEAT_V7_NAME,
+    META_FEAT_V7_TRANSFORMS,
+    META_FEAT_V7_VERSION,
+    build_meta_features_v7,
+)
+
+# ---------------------------------------------------------------------
+# META-FEATURE SCHEMA V8
+#
+# Goal (P2/F): Add *strict DQ / stream integrity* features that are:
+# - Cheap to compute
+# - Deterministic
+# - Low-cardinality for observability
+#
+# These features are populated in runtime.indicators by the processors.
+# ---------------------------------------------------------------------
+
+META_FEAT_V8_NAME = "meta_feat_v8"
+META_FEAT_V8_VERSION = 8
+
+META_FEAT_V8_NEW_COLS: List[str] = [
+    # Stream integrity
+    "dq_tick_gap_p95_ms",
+    "dq_tick_missing_seq_ema",
+    "dq_book_missing_seq_ema",
+
+    # Gate behavior (EWMA)
+    "dq_hard_veto_rate",
+]
+
+META_FEAT_V8_COLS: List[str] = list(META_FEAT_V7_COLS) + list(META_FEAT_V8_NEW_COLS)
+META_FEAT_V8_HASH: str = hashlib.sha1(",".join(META_FEAT_V8_COLS).encode("utf-8")
+).hexdigest()
+
+# Transform specs are applied by core.feature_engineering.apply_transform.
+META_FEAT_V8_TRANSFORMS: Dict[str, Dict[str, Any]] = {
+    **META_FEAT_V7_TRANSFORMS,
+
+    # Tick gap can be heavy-tailed
+    "dq_tick_gap_p95_ms": {"type": "log1p"},
+
+    # Missing seq EMA should be near 0; clip to reduce effect of resync bursts
+    "dq_tick_missing_seq_ema": {"type": "clip", "lo": 0.0, "hi": 50.0},
+    "dq_book_missing_seq_ema": {"type": "clip", "lo": 0.0, "hi": 50.0},
+
+    # Rate in [0,1]
+    "dq_hard_veto_rate": {"type": "clip", "lo": 0.0, "hi": 1.0},
+}
+
+
+def _try_get_float(x: Any) -> Optional[float]:
+    try:
+        if x is None:
+            return None
+        return float(x)
+    except Exception:
+        return None
+
+
+def build_meta_features_v8(
+    evidence: Dict[str, Any],
+    indicators: Dict[str, Any],
+    runtime_snap: Optional[Any] = None,
+    runtime_prev_snap: Optional[Any] = None,
+    indicators_with_v4: Optional[Dict[str, Any]] = None,
+    legs: Optional[Dict[str, Any]] = None,
+    have: int = 0,
+    need: int = 0,
+    ok_soft: int = 0,
+    rule_score: float = 0.0,
+    exec_risk_norm: float = 0.0,
+    exec_risk_bps: float = 0.0,
+    ml_scenario: str = "",
+	) -> Tuple[Dict[str, float], List[str]]:
+    """Build meta_feat_v8 = v7 + strict DQ features."""
+
+    feat, missing = build_meta_features_v7(
+        evidence=evidence,
+        indicators=indicators,
+        runtime_snap=runtime_snap,
+        runtime_prev_snap=runtime_prev_snap,
+        indicators_with_v4=indicators_with_v4,
+        legs=legs,
+        have=have,
+        need=need,
+        ok_soft=ok_soft,
+        rule_score=rule_score,
+        exec_risk_norm=exec_risk_norm,
+        exec_risk_bps=exec_risk_bps,
+        ml_scenario=ml_scenario,
+    )
+
+    nested_ind = evidence.get("indicators") if isinstance(evidence, dict) else None
+    if not isinstance(nested_ind, dict):
+        nested_ind = {}
+
+    for k in META_FEAT_V8_NEW_COLS:
+        v = None
+
+        # Prefer explicit DQ-prefixed indicators
+        if k in indicators:
+            v = _try_get_float(indicators.get(k))
+        elif k in nested_ind:
+            v = _try_get_float(nested_ind.get(k))
+        elif k == "dq_hard_veto_rate":
+            # Compatibility: allow runtime to store this under dq_hard_veto_rate_ema
+            v = _try_get_float(indicators.get("dq_hard_veto_rate_ema"))
+
+        if v is None:
+            feat[k] = 0.0
+            missing.append(k)
+        else:
+            feat[k] = float(v)
+
+    return feat, missing
