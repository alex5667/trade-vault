+import os
+from types import SimpleNamespace
+
+import pytest
+
+from services.binance_futures_client import BinanceFuturesClient
+from services.binance_executor import AlgoOrderRef, BinanceExecutor, PlainOrderRef
+
+
+class DummyClient(BinanceFuturesClient):
+    def __init__(self):
+        super().__init__(api_key='k', api_secret='s')
+        self.calls = []
+
+    def _request(self, method, path, *, params=None, signed=False):
+        self.calls.append((method, path, dict(params or {}), signed))
+        if path == '/fapi/v1/algoOrder' and method == 'GET':
+            return {'algoId': 77, 'status': 'NEW'}
+        if path == '/fapi/v1/algoOrder' and method == 'DELETE':
+            return {'status': 'CANCELED'}
+        if path == '/fapi/v1/algoOrder' and method == 'POST':
+            return {'algoId': 88, 'clientAlgoId': params.get('clientAlgoId')}
+        if path == '/fapi/v1/order' and method == 'POST':
+            return {'orderId': 99, 'clientOrderId': params.get('newClientOrderId')}
+        return {}
+
+
+def test_algo_validator_rejects_close_position_with_quantity(monkeypatch):
+    monkeypatch.setenv('BINANCE_POSITION_MODE', 'oneway')
+    client = DummyClient()
+    with pytest.raises(ValueError, match='algo_closePosition_incompatible_with_quantity'):
+        client.post_algo_order({
+            'symbol': 'BTCUSDT',
+            'side': 'SELL',
+            'type': 'STOP_MARKET',
+            'triggerPrice': '100000',
+            'closePosition': 'true',
+            'quantity': '0.01',
+            'clientAlgoId': 'x',
+        })
+
+
+def test_algo_validator_rejects_bad_activate_price(monkeypatch):
+    monkeypatch.setenv('BINANCE_POSITION_MODE', 'oneway')
+    client = DummyClient()
+    with pytest.raises(ValueError, match='activatePrice_must_be_positive'):
+        client.post_algo_order({
+            'symbol': 'BTCUSDT',
+            'side': 'SELL',
+            'type': 'TRAILING_STOP_MARKET',
+            'callbackRate': '0.5',
+            'activatePrice': '0',
+            'quantity': '0.01',
+            'clientAlgoId': 'trail-1',
+        })
+
+
+def test_plain_validator_requires_position_side_in_hedge(monkeypatch):
+    monkeypatch.setenv('BINANCE_POSITION_MODE', 'hedge')
+    client = DummyClient()
+    with pytest.raises(ValueError, match='positionSide_required_in_hedge'):
+        client.post_plain_order({
+            'symbol': 'BTCUSDT',
+            'side': 'BUY',
+            'type': 'MARKET',
+            'quantity': '0.01',
+            'newClientOrderId': 'entry-1',
+        })
+
+
+def test_replace_untriggered_algo_order_cancel_then_post(monkeypatch):
+    monkeypatch.setenv('BINANCE_POSITION_MODE', 'oneway')
+    client = DummyClient()
