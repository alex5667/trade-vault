+def _resolve_mode(*, profile: str, scope: str) -> str:
+    env_name = _SCOPE_TO_ENV.get(str(scope or "").strip().lower())
+    raw = str(os.getenv(env_name, os.getenv("EXEC_HEALTH_MODE", "auto")) or "auto").strip().lower() if env_name else str(os.getenv("EXEC_HEALTH_MODE", "auto") or "auto").strip().lower()
