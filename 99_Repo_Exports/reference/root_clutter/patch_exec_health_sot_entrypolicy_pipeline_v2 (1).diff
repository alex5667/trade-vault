+            elif hit_adverse:
+                reason_code = "VETO_EXEC_ADVERSE_SELECTION"
+            else:
+                reason_code = "VETO_EXEC_HEALTH"
+
+    return ExecHealthDecision(
+        apply=True,
+        veto=bool(veto),
+        mode=mode,
+        flags=flags,
+        reason_code=str(reason_code),
+        tighten_add_bps=float(tighten_add_bps),
+        tighten_k_mult=float(tighten_k_mult),
+        scope=str(scope),
+        rollups={k: float(v) for k, v in dict(rollups or {}).items() if isinstance(v, (int, float)) and math.isfinite(float(v))},
+    )
