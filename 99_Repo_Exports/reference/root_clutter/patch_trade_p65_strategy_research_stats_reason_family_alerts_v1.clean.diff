--- a/orderflow_services/tests/test_orchestration_composite_preflight_strategy_research_stats_p65_alerts_yaml_v1.py
+++ b/orderflow_services/tests/test_orchestration_composite_preflight_strategy_research_stats_p65_alerts_yaml_v1.py
@@ -0,0 +1,41 @@
+from __future__ import annotations
+
+import os
+import yaml
+import pytest
+
+
+def _alerts_path(tick_flow_full: bool = False) -> str:
+    base = os.path.dirname(__file__)
+    root = os.path.abspath(os.path.join(base, '..'))
+    if tick_flow_full:
+        return os.path.abspath(
+            os.path.join(base, '..', '..', 'tick_flow_full', 'orderflow_services', 'prometheus_alerts_orchestration_composite_preflight_strategy_research_stats_p65.yml')
+        )
+    return os.path.join(root, 'prometheus_alerts_orchestration_composite_preflight_strategy_research_stats_p65.yml')
+
+
+@pytest.mark.parametrize('tick_flow_full', [False, True])
+def test_strategy_research_stats_p65_alerts_yaml_parses(tick_flow_full: bool) -> None:
+    path = _alerts_path(tick_flow_full)
+    with open(path, 'r', encoding='utf-8') as f:
+        doc = yaml.safe_load(f)
+    assert 'groups' in doc and doc['groups']
+    rules = doc['groups'][0].get('rules', [])
+    names = {r.get('alert') for r in rules}
+    assert 'TradeStrategyResearchStatsPboHighSustained24h' in names
+    assert 'TradeStrategyResearchStatsReportStaleRecurring7d' in names
+    assert 'TradeStrategyResearchStatsPsrDsrLowShareRising24hVs7d' in names
+
+
+@pytest.mark.parametrize('tick_flow_full', [False, True])
+def test_strategy_research_stats_p65_alert_exprs_reference_history_metrics(tick_flow_full: bool) -> None:
+    path = _alerts_path(tick_flow_full)
+    with open(path, 'r', encoding='utf-8') as f:
+        doc = yaml.safe_load(f)
+    exprs = '\n'.join(str(rule.get('expr') or '') for rule in doc['groups'][0].get('rules', []))
+    assert 'orchestration_composite_preflight_history_strategy_research_stats_reason_family_total' in exprs
+    assert 'orchestration_composite_preflight_history_events_total' in exprs
+    assert 'family="pbo_high"' in exprs
+    assert 'family="report_stale"' in exprs
+    assert 'family=~"psr_low|dsr_low"' in exprs
