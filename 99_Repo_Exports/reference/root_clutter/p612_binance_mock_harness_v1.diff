+@dataclass
+class ScriptedOrder:
+    order_id: int
+    client_order_id: str
+    symbol: str
+    side: str
+    order_type: str
+    quantity: float
+    reduce_only: bool = False
+    status: str = "NEW"
+    avg_price: float = 0.0
+    executed_qty: float = 0.0
+    script: List[Dict[str, Any]] = field(default_factory=list)
+    query_index: int = 0
+    applied_qty: float = 0.0
+
+
+@dataclass
+class ScriptedAlgoOrder:
+    algo_id: int
