+        self.next_order_id = 1000
+        self.next_algo_id = 5000
+        self.request_log: List[Dict[str, Any]] = []
+        self.user_stream_events: Deque[str] = deque()
+        self.plain_orders: Dict[int, ScriptedOrder] = {}
