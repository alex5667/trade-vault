      "id": 6,
      "type": "timeseries",
      "title": "Public: probe_duration_seconds",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 10
      },
      "targets": [
        {
          "expr": "probe_duration_seconds{job=\"blackbox_public\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
