# =============================================================================
# Stream Archiver Configuration
# =============================================================================
# Конфигурация для надежного архивирования Redis Streams в PostgreSQL и NDJSON.gz
# 
# Компоненты:
# 1. stream_archiver.py - PostgreSQL archiver (consumer group)
# 2. stream_exporter.py - NDJSON.gz exporter (XRANGE)
# =============================================================================

# =============================================================================
# Redis Connection
# =============================================================================
REDIS_URL=redis://redis-worker-1:6379/0

# =============================================================================
# PostgreSQL Connection (precedence order)
# =============================================================================
# 1. TRADES_DB_DSN (analytics/trades DB - preferred)
TRADES_DB_DSN=postgresql://trading:trading_password@postgres:5432/scanner_analytics

# 2. DATABASE_URL (fallback)
DATABASE_URL=postgresql://trading:trading_password@postgres:5432/scanner_analytics

# 3. PG_DSN (final fallback)
PG_DSN=postgresql://trading:trading_password@postgres:5432/trade

# =============================================================================
# Stream Names
# =============================================================================
TRADE_ENTRY_AUDIT_STREAM=stream:trade:entry_audit
TRADE_EVENTS_STREAM=events:trades

# =============================================================================
# Stream Maxlen (важно координировать с producer)
# =============================================================================
# Entry audit stream maxlen (smt_entry_policy_service.py)
TRADE_ENTRY_AUDIT_MAXLEN=200000

# Events stream maxlen (trade_events_logger.py)
TRADE_EVENTS_MAXLEN=200000

# Entry stream maxlen (smt_entry_policy_service.py)
TRADE_ENTRY_MAXLEN=20000

# =============================================================================
# Entry Audit Archiver (stream:trade:entry_audit -> entry_policy_audit)
# =============================================================================
ENTRY_AUDIT_ARCHIVE_ENABLED=1
ENTRY_AUDIT_CG=entry_audit_archiver
ENTRY_AUDIT_CONSUMER=archiver_1
ENTRY_AUDIT_BATCH=500
ENTRY_AUDIT_BLOCK_MS=2000
ENTRY_AUDIT_MIN_IDLE_MS=60000
ENTRY_AUDIT_DLQ_STREAM=stream:dlq:entry_audit

# =============================================================================
# Position Events Archiver (events:trades -> position_events)
# =============================================================================
POSITION_EVENTS_ARCHIVE_ENABLED=1
POSITION_EVENTS_CG=position_events_archiver
POSITION_EVENTS_CONSUMER=archiver_1
POSITION_EVENTS_BATCH=500
POSITION_EVENTS_BLOCK_MS=2000
POSITION_EVENTS_MIN_IDLE_MS=60000
POSITION_EVENTS_DLQ_STREAM=stream:dlq:position_events

# Event types to archive (пустая строка = все события)
# Recommendation: архивировать все для полного timeline
POSITION_EVENTS_TYPES=TP_HIT,TP1_HIT,TP2_HIT,TP3_HIT,TRAILING_MOVE,TRAILING_STARTED,SL_HIT,SL_ADJUST,POSITION_OPENED,POSITION_CLOSED

# =============================================================================
# NDJSON.gz Exporter (fail-safe disk archive)
# =============================================================================
STREAM_EXPORT_ENABLED=1
STREAM_EXPORT_DIR=/var/log/trade/exports
STREAM_EXPORT_KEEP_DAYS=90
STREAM_EXPORT_INTERVAL_SEC=300

# Host directory для volume mount (docker-compose)
STREAM_EXPORT_HOST_DIR=./exports

# =============================================================================
# Observability / Metrics (рекомендуемые запросы)
# =============================================================================
# 
# 1. Проверка lag consumer group:
#    redis-cli XINFO GROUPS stream:trade:entry_audit
#    redis-cli XINFO GROUPS events:trades
#
# 2. Проверка pending messages:
#    redis-cli XPENDING stream:trade:entry_audit entry_audit_archiver
#    redis-cli XPENDING events:trades position_events_archiver
#
# 3. DLQ monitoring:
#    redis-cli XLEN stream:dlq:entry_audit
#    redis-cli XLEN stream:dlq:position_events
#
# 4. PostgreSQL row count:
#    SELECT count(*) FROM entry_policy_audit;
#    SELECT count(*) FROM position_events;
#
# 5. Recent events:
#    SELECT symbol, decision, ts FROM entry_policy_audit ORDER BY ts DESC LIMIT 10;
#    SELECT position_id, event_type, ts FROM position_events ORDER BY ts DESC LIMIT 10;
#
# =============================================================================

# =============================================================================
# Rollout Strategy
# =============================================================================
# 
# Phase 1: Enable exporter only (safest layer)
#   STREAM_EXPORT_ENABLED=1
#   ENTRY_AUDIT_ARCHIVE_ENABLED=0
#   POSITION_EVENTS_ARCHIVE_ENABLED=0
#
# Phase 2: Enable PostgreSQL archiver
#   Apply migrations (026_entry_policy_audit.sql, 027_position_events.sql)
#   ENTRY_AUDIT_ARCHIVE_ENABLED=1
#   POSITION_EVENTS_ARCHIVE_ENABLED=1
#
# Phase 3: Monitor metrics
#   Check lag, pending, DLQ, row counts
#
# Rollback:
#   Set *_ARCHIVE_ENABLED=0 to disable archiver
#   Exporter can stay running (no side effects)
#
# =============================================================================
