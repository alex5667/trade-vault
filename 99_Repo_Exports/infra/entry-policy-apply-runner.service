[Unit]
Description=Entry Policy Apply Runner V2 (cfg:suggestions -> cfg:entry_policy)
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/alex/front/trade/scanner_infra/python-worker
Environment=PYTHONPATH=.:..
Environment=REDIS_URL=redis://redis-worker-1:6379/0
Environment=AB_APPLY_POLL_MS=2000
ExecStart=/usr/bin/python -m services.entry_policy_apply_runner_v2
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
