--- a/services/tests/test_shadow_calib_meta_v1.py	1970-01-01 00:00:00.000000000 +0000
+++ b/services/tests/test_shadow_calib_meta_v1.py	2026-04-04 18:35:07.158383875 +0000
@@ -0,0 +1,37 @@
+from services.shadow_calib_meta import extract_shadow_calib_meta
+
+
+def test_extract_shadow_calib_meta_priority_and_filtering() -> None:
+    primary = {
+        "calib": 1,
+        "calib_kind": "cont_ctx_window",
+        "candidate_window_ms": 180000,
+        "entry_reason": "rescued_cont_ctx_window",
+        "paper_only": 1,
+        "shadow_only": 1,
+        "parent_signal_id": "sig-1",
+    }
+    secondary = {
+        "calib": 0,
+        "candidate_window_ms": 150000,
+        "baseline_window_ms": 120000,
+        "cont_ctx_age_ms": 133000,
+        "entry_reason": "",
+    }
+
+    out = extract_shadow_calib_meta(primary, secondary)
+
+    assert out["calib"] == 1
+    assert out["candidate_window_ms"] == 180000
+    assert out["baseline_window_ms"] == 120000
+    assert out["cont_ctx_age_ms"] == 133000
+    assert out["entry_reason"] == "rescued_cont_ctx_window"
+
+
+def test_extract_shadow_calib_meta_ignores_none_and_empty_strings() -> None:
+    out = extract_shadow_calib_meta({
+        "calib": None,
+        "calib_kind": "",
+        "paper_only": 1,
+    })
+    assert out == {"paper_only": 1}
