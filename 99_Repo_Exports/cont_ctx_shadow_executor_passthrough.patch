+from __future__ import annotations
+
+from typing import Any, Dict, Mapping
+
+# Metadata that must survive shadow/paper open -> resize -> close lifecycle
+# so calibrators can join trades:closed back to the candidate window.
+CALIB_PASSTHROUGH_KEYS = (
+    "paper_only",
+    "shadow_only",
+    "is_virtual",
+    "virtual",
+    "calib",
+    "calib_kind",
+    "calib_run_id",
+    "candidate_window_ms",
+    "baseline_window_ms",
+    "cont_ctx_age_ms",
+    "entry_reason",
+    "parent_signal_id",
+)
+
+
+def extract_shadow_calib_meta(*sources: Mapping[str, Any]) -> Dict[str, Any]:
+    """Extract shadow/calibration metadata from payload-like mappings.
+
+    Priority: earlier sources win. Empty strings / None are ignored.
+    Keys are intentionally flat to minimize hidden dependencies between
+    signal-pipeline, execution-router and binance-executor.
+    """
+    out: Dict[str, Any] = {}
+    for src in sources:
+        if not isinstance(src, Mapping):
+            continue
+        for key in CALIB_PASSTHROUGH_KEYS:
+            if key in out:
+                continue
+            try:
+                value = src.get(key)  # type: ignore[attr-defined]
+            except Exception:
+                value = None
+            if value is None:
+                continue
+            if isinstance(value, str) and value == "":
+                continue
+            out[key] = value
+    return out
