# ===========================================================================
# Execution Safe Defaults — P0 closure (copy to .env.execution_safe and load)
# ===========================================================================

# ── Execution policy ────────────────────────────────────────────────────────
# Default is SAFETY_FIRST (market fills). Use MAKER_FIRST only for large caps
# with explicit maker-allowed-symbols override.
EXEC_POLICY_DEFAULT=SAFETY_FIRST
EXEC_POLICY_MAKER_ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT
EXEC_POLICY_TIER_C_FORCE_SAFETY_FIRST=true

# ── Trigger semantics ────────────────────────────────────────────────────────
SL_WORKING_TYPE=MARK_PRICE
TP_MARKET_WORKING_TYPE=MARK_PRICE
TP_LIMIT_TRIGGER_WORKING_TYPE=MARK_PRICE
TRAIL_WORKING_TYPE=MARK_PRICE

# ── Position mode ────────────────────────────────────────────────────────────
BINANCE_POSITION_MODE=oneway

# ── Leverage tiers (safe reduced defaults) ──────────────────────────────────
BINANCE_DEFAULT_LEVERAGE=20
BINANCE_LEVERAGE_TIER_A=20
BINANCE_LEVERAGE_TIER_B=10
BINANCE_LEVERAGE_TIER_C=5
# Per-symbol overrides (examples):
# BINANCE_LEVERAGE_BTCUSDT=15
# BINANCE_LEVERAGE_ETHUSDT=10

# ── Protection / watchdog timeouts ──────────────────────────────────────────
PROTECTION_ARM_TIMEOUT_MS=2500
PROTECTION_FEE_BUFFER_BPS=8.0
PROTECTION_SLIPPAGE_BUFFER_BPS=15.0
ACCOUNT_AVAILABLE_FLOOR_USD=25.0

# ── Trailing arm policy ──────────────────────────────────────────────────────
TRAIL_ARM_ONLY_AFTER_TP1=true
FORCE_TRAIL_AFTER_TP1=false
BINANCE_TRAIL_CALLBACK_MIN=0.1
BINANCE_TRAIL_CALLBACK_MAX=5.0
BINANCE_TRAIL_CALLBACK_DEFAULT=0.3

# ── Reconcile / 503 ambiguous path ──────────────────────────────────────────
EXEC_RECONCILE_ENABLE=true
EXEC_RECONCILE_ON_503_UNKNOWN=true
EXEC_RECONCILE_PREFER_USER_STREAM=true

# ── Binance timing ────────────────────────────────────────────────────────────
BINANCE_RECV_WINDOW_MS=60000
BINANCE_TIME_SYNC_INTERVAL_MS=30000
MAX_CLOCK_DRIFT_MS=250
BINANCE_FILL_TIMEOUT_S=8.0
BINANCE_FILL_POLL_S=0.25
BINANCE_MAX_RETRY=3

# ── Risk settings ─────────────────────────────────────────────────────────────
ACCOUNT_LEVERAGE=20
RISK_PERCENT=0.5

# ── Dynamic balance provider ───────────────────────────────────────────────────
# BALANCE_PROVIDER_MODE: redis_first (default) | direct | static
#   redis_first → читает account:snapshot:binance_usdtm из Redis (fast)
#                 при устаревании (> BALANCE_MAX_STALENESS_S) → сваливается на REST
#   direct      → всегда вызывает GET /fapi/v2/account напрямую
#   static      → только ACCOUNT_DEPOSIT_USD (старый режим)
BALANCE_PROVIDER_MODE=redis_first
BALANCE_MAX_STALENESS_S=3600   # Redis snapshot не старше N секунд (= интервалу binance_account_reporter)
BALANCE_CACHE_TTL_S=30         # in-process cache TTL (не долбить Redis на каждый ордер)
ACCOUNT_DEPOSIT_USD=1000       # static fallback (используется если Redis + REST недоступны)
ACCOUNT_SNAPSHOT_KEY=account:snapshot:binance_usdtm

# ── Outbox contract versioning ────────────────────────────────────────────────
OUTBOX_SCHEMA_VER=execution_intent:v1
OUTBOX_CONTRACT_VER=execution_contract:v1

# ── Virtual / Demo mirror ──────────────────────────────────────────────────────
# BINANCE_VIRTUAL_MIRROR_ALL=1   → mirror ALL confirmed signals to demo account
#   signals go to ORDERS_QUEUE_BINANCE_MIRROR (orders:queue:binance:mirror)
#   consumed by binance-executor-demo Docker service (BINANCE_CLIENT_MODE=dem# Virtual Mirroring
# BINANCE_VIRTUAL_MIRROR_ALL: send ALL signals to orders:queue:binance:mirror
BINANCE_VIRTUAL_MIRROR_ALL=0

# BINANCE_VIRTUAL_ORDERS_ENABLED: proxy failed/rejected signals -> orders:queue:binance (demo)
BINANCE_VIRTUAL_ORDERS_ENABLED=0
ORDERS_QUEUE_BINANCE_MIRROR=orders:queue:binance:mirror
EXEC_STREAM_DEMO=orders:exec:demo

# Demo executor credentials (testnet) — required when BINANCE_VIRTUAL_MIRROR_ALL=1
BINANCE_DEMO_API_KEY=
BINANCE_DEMO_API_SECRET=
BINANCE_DEMO_FUTURES_BASE_URL=https://testnet.binancefuture.com
# Demo-specific risk (safe testnet defaults)
BINANCE_DEMO_DEFAULT_LEVERAGE=5
BINANCE_DEMO_RISK_PERCENT=1.0
BINANCE_DEMO_DEPOSIT_USD=10000
