EXEC_POLICY_DEFAULT=SAFETY_FIRST
EXEC_POLICY_MAKER_ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
EXEC_REQUIRE_USER_STREAM_LIVE=1
PARTIAL_FILL_POLICY=CANCEL_REMAINDER_AND_PROTECT_FILLED
PROTECTION_ARM_TIMEOUT_MS=2500
SL_WORKING_TYPE=MARK_PRICE
TP_MARKET_WORKING_TYPE=MARK_PRICE
TP_LIMIT_TRIGGER_WORKING_TYPE=MARK_PRICE
TRAIL_WORKING_TYPE=MARK_PRICE
TP_LIMIT_WATCHDOG_ENABLE=1
TP_LIMIT_WATCHDOG_TIMEOUT_MS=4000
TP_LIMIT_WATCHDOG_MARKET_FALLBACK=1
BINANCE_RECV_WINDOW_MS=3000
BINANCE_TIME_SYNC_INTERVAL_MS=30000
MAX_CLOCK_DRIFT_MS=250
RISK_MAX_DAILY_LOSS_PCT=2.0
RISK_TARGET_VOLATILITY_BPS=45
RISK_MAX_NET_BETA_LONG_RATIO=1.5
RISK_MAX_NET_BETA_SHORT_RATIO=1.5
RISK_LEADER_OVERRIDE_ENABLE=1
RISK_LEADER_OVERRIDE_DRAWDOWN_BPS=250
RISK_NEWS_BLACKOUT_FORCE_DENY=1
STRATEGY_SHADOW_ONLY=0

# P1.2.1 – Journal-primary projection knobs
# EXEC_INLINE_STATE_PROJECTION=0  → executor writes only to orders:exec; projection worker writes cache
# EXEC_JOURNAL_PRIMARY=1          → orders:exec is the SoT; orders:state:{sid} is derived view
EXEC_INLINE_STATE_PROJECTION=0
EXEC_JOURNAL_PRIMARY=1
EXEC_STATE_DERIVED_VIEW=1
EXEC_PROJECTION_CURSOR_KEY=orders:exec:projection:cursor
EXEC_PROJECTION_BATCH_SIZE=500
EXEC_PROJECTION_IDLE_SLEEP_MS=500
EXEC_PROJECTION_LEASE_KEY=orders:exec:projection:leader
EXEC_PROJECTION_FENCING_KEY=orders:exec:projection:fencing
EXEC_PROJECTION_LEASE_TTL_MS=10000
EXEC_PROJECTION_HEALTH_MAX_LAG_MS=15000
EXEC_PROJECTION_HEALTH_MAX_CURSOR_AGE_MS=60000

# P1.2.3 – Execution bootstrap gate knobs
# EXEC_BOOTSTRAP_REQUIRE_READY=1  → executor will not start until both dependencies are healthy
# Rollback: set EXEC_BOOTSTRAP_REQUIRE_READY=0 to bypass the gate without code change
EXEC_BOOTSTRAP_REQUIRE_READY=1
EXEC_BOOTSTRAP_REQUIRE_PROJECTION_READY=1
EXEC_BOOTSTRAP_REQUIRE_USER_STREAM_READY=1
EXEC_BOOTSTRAP_TIMEOUT_MS=120000
EXEC_BOOTSTRAP_POLL_MS=500
EXEC_BOOTSTRAP_USER_STREAM_GRACE_MS=45000
EXEC_BOOTSTRAP_HEALTH_PORT=8787
# P1.2.4: persisted bootstrap block state (incident + runbook API)
EXEC_BOOTSTRAP_STATUS_KEY=orders:execution:bootstrap:status
EXEC_BOOTSTRAP_LAST_BLOCK_KEY=orders:execution:bootstrap:last_block
EXEC_BOOTSTRAP_BLOCK_TTL_SEC=86400
