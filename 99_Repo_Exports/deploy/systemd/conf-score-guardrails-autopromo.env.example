# --- AUTOPROMO controller config ---

# State file written by autopromo controller (exporter reads this)
CONF_SCORE_GUARD_AUTOPROMO_STATE_PATH=/var/lib/trade/conf_score_guard_autopromo_state.json

# Observe window after canary-only promote before deciding full promote/rollback
CONF_SCORE_GUARD_CANARY_OBSERVE_SEC=900

# Regression margins vs baseline snapshot
CONF_SCORE_GUARD_MAX_DELTA_ECE=0.005
CONF_SCORE_GUARD_MAX_DELTA_BRIER=0.005

# Require at least N samples if health state includes 'n'
CONF_SCORE_GUARD_MIN_N=200

# If your health-state JSON doesn't include ece_cal/brier_cal, set to 1 (not recommended)
CONF_SCORE_GUARD_ALLOW_MISSING=0

# Safety toggles
CONF_SCORE_GUARD_AUTOPROMO_APPLY=1
CONF_SCORE_GUARD_AUTOPROMO_CLEAR_STAGED=1
CONF_SCORE_GUARD_AUTOPROMO_PROMOTE_POINTER=1
CONF_SCORE_GUARD_AUTOPROMO_ROLLBACK_ON_FAIL=1
