# Postgres connection string
TRADES_DB_DSN=postgresql://user:pass@127.0.0.1:5432/trade

# P5.6 checker params
EXEC_AUDIT_LOOKBACK_HOURS=24
EXEC_AUDIT_LIMIT=1000
EXEC_AUDIT_REPORT_JSON=/var/lib/trade/runbooks/latest_execution_audit_chain.json
EXEC_AUDIT_REPORT_PROM=/var/lib/node_exporter/textfile_collector/latest_execution_audit_chain.prom
EXEC_AUDIT_REPORT_STALE_SECONDS=900

# Optional table overrides (leave commented out to use defaults)
# EXEC_AUDIT_TBL_EXECUTION_ORDERS=execution_orders
# EXEC_AUDIT_TBL_SIGNALS=signals
# EXEC_AUDIT_TBL_SIGNAL_EXECUTION_PLAN=signal_execution_plan
# EXEC_AUDIT_TBL_TRADES_CLOSED=trades_closed
# EXEC_AUDIT_TBL_POSITION_EVENTS=position_events
# EXEC_AUDIT_TBL_ENTRY_POLICY_AUDIT=entry_policy_audit
# EXEC_AUDIT_TBL_DECISION_SNAPSHOT=decision_snapshot

# Runbook server
RUNBOOK_SERVER_BIND=0.0.0.0
RUNBOOK_SERVER_PORT=8777
