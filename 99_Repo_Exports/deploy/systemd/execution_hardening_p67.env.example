# Execution policy
EXEC_POLICY_DEFAULT=SAFETY_FIRST
EXEC_POLICY_MAKER_ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
EXEC_POLICY_TIER_C_FORCE_SAFETY_FIRST=1

# Trigger semantics
SL_WORKING_TYPE=MARK_PRICE
TP_MARKET_WORKING_TYPE=MARK_PRICE
TP_LIMIT_TRIGGER_WORKING_TYPE=MARK_PRICE
TRAIL_WORKING_TYPE=MARK_PRICE

# Protection
PROTECTION_ARM_TIMEOUT_MS=2500
TRAIL_ARM_ONLY_AFTER_TP1=1

# Watchdog
TP_LIMIT_WATCHDOG_ENABLE=1
TP_LIMIT_WATCHDOG_TIMEOUT_MS=4000
TP_LIMIT_WATCHDOG_MARKET_FALLBACK=1

# Binance timing
BINANCE_RECV_WINDOW_MS=3000
BINANCE_TIME_SYNC_INTERVAL_MS=30000
MAX_CLOCK_DRIFT_MS=250

# Reconcile
EXEC_RECONCILE_ON_503_UNKNOWN=1
EXEC_RECONCILE_PREFER_USER_STREAM=1

# Risk
RISK_ENGINE_V2_ENABLE=1
RISK_MAX_DAILY_LOSS_PCT=2.0
RISK_TIER_A_MAX_LEVERAGE=10
RISK_TIER_B_MAX_LEVERAGE=5
RISK_TIER_C_MAX_LEVERAGE=3

# Optional fee model for maker policy telemetry
EXEC_FEE_MAKER_BPS=2.0
EXEC_FEE_TAKER_BPS=5.0
