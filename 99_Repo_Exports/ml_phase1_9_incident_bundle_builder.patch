diff -urN empty_clean/orderflow_services/runbook_ml_phase1_9_v1.md phase19_clean/orderflow_services/runbook_ml_phase1_9_v1.md
--- empty_clean/orderflow_services/runbook_ml_phase1_9_v1.md	1970-01-01 00:00:00.000000000 +0000
+++ phase19_clean/orderflow_services/runbook_ml_phase1_9_v1.md	2026-04-05 14:05:25.378816728 +0000
@@ -0,0 +1,36 @@
+# Phase 1.9 — Incident Bundle Builder (scanner_infra)
+
+## Purpose
+Build a compact forensic bundle per `recommendation_id` for operator review.
+
+## Inputs
+- `stream:ml:incident_bundle_requests`
+- `stream:ml:recommendation_audit`
+- `stream:ml:recommendation_apply_results`
+- `stream:ml:recommendation_rollback_results`
+- `stream:ml:recommendation_rollback_verification_results`
+- `stream:ml:recommendation_escalations`
+- `metrics:ml:model_snapshot_before:<recommendation_id>`
+- `metrics:ml:model_snapshot:<model_id>`
+
+## Outputs
+- `stream:ml:incident_bundle_results`
+- `metrics:ml:incident_bundle:last`
+- `metrics:ml:incident_bundle:<recommendation_id>`
+- `llm_incident_bundles`
+
+## Smoke checks
+```bash
+redis-cli XADD stream:ml:incident_bundle_requests '*' recommendation_id rec-1 ts_ms $(python - <<'PY'
+import time
+print(int(time.time()*1000))
+PY
+)
+redis-cli XREVRANGE stream:ml:incident_bundle_results + - COUNT 3
+redis-cli HGETALL metrics:ml:incident_bundle:last
+curl -s localhost:9867/metrics | grep '^ml_incident_bundle_'
+```
+
+## Rollback
+- stop `scanner-ml-incident-bundle-builder-v1`
+- keep SQL and streams in place
diff -urN empty_clean/orderflow_services/sql/ml_phase1_9_v1.sql phase19_clean/orderflow_services/sql/ml_phase1_9_v1.sql
--- empty_clean/orderflow_services/sql/ml_phase1_9_v1.sql	1970-01-01 00:00:00.000000000 +0000
+++ phase19_clean/orderflow_services/sql/ml_phase1_9_v1.sql	2026-04-05 14:05:25.336000969 +0000
@@ -0,0 +1,16 @@
+CREATE TABLE IF NOT EXISTS llm_incident_bundles (
+  bundle_id               text PRIMARY KEY,
+  recommendation_id       text NOT NULL,
+  ts_ms                   bigint NOT NULL,
+  severity                text NOT NULL,
+  model_id                text NOT NULL,
+  bundle_json             jsonb NOT NULL,
+  snapshot_diff_json      jsonb,
+  created_at              timestamptz NOT NULL DEFAULT now()
+);
+
+CREATE INDEX IF NOT EXISTS idx_llm_incident_bundles_rec_ts
+  ON llm_incident_bundles (recommendation_id, ts_ms DESC);
+
+CREATE INDEX IF NOT EXISTS idx_llm_incident_bundles_model_ts
+  ON llm_incident_bundles (model_id, ts_ms DESC);
diff -urN empty_clean/orderflow_services/tests/test_incident_bundle_builder_v1.py phase19_clean/orderflow_services/tests/test_incident_bundle_builder_v1.py
--- empty_clean/orderflow_services/tests/test_incident_bundle_builder_v1.py	1970-01-01 00:00:00.000000000 +0000
+++ phase19_clean/orderflow_services/tests/test_incident_bundle_builder_v1.py	2026-04-05 14:05:25.320188228 +0000
@@ -0,0 +1,36 @@
+from orderflow_services.incident_bundle_builder_v1 import build_incident_bundle, compute_snapshot_diff, summarize_reason_codes
+
+
+def test_compute_snapshot_diff_numeric_and_status_changes():
+    before = {'latency_p95_max_ms': 2.0, 'error_rate_max': 0.01, 'status': 'ok'}
