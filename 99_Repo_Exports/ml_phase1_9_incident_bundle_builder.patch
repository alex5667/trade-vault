+groups:
+  - name: ml_phase1_9_incident_bundle_builder
+    rules:
+      - alert: MLIncidentBundleBuilderStale
+        expr: (time() - ml_incident_bundle_last_run_ts_seconds) > 1800
+        for: 10m
+        labels:
+          severity: warning
+        annotations:
+          summary: "ML incident bundle builder stale"
+
+      - alert: MLIncidentBundleQueueLagHigh
+        expr: ml_incident_bundle_queue_lag_ms > 300000
