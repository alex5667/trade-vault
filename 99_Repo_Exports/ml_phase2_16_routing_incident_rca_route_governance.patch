+from __future__ import annotations
+
+import json
+import os
+import statistics
+import time
+from typing import Any, Dict, List, Tuple
+
+try:  # pragma: no cover
+    import redis.asyncio as redis
+except Exception:  # pragma: no cover
+    redis = None
+
+try:  # pragma: no cover
+    import psycopg
+except Exception:  # pragma: no cover
+    psycopg = None
+
+try:  # pragma: no cover
+    from prometheus_client import Counter, Gauge, Histogram, start_http_server
+except Exception:  # pragma: no cover
+    Counter = Gauge = Histogram = None
+    def start_http_server(*args: Any, **kwargs: Any) -> None:
+        return None
+
+
+APP_NAME = "operator_routing_incident_rca_route_slo_analytics_v2_16"
+VERIFY_RESULTS_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTING_VERIFY_RESULTS_STREAM",
+    "stream:ml:operator_routing_incident_rca_routing_verify_results",
+)
+ROLLBACK_RESULTS_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTING_ROLLBACK_RESULTS_STREAM",
+    "stream:ml:operator_routing_incident_rca_routing_rollback_results",
+)
+OUTPUT_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_SLO_ROLLUPS_STREAM",
+    "stream:ml:operator_routing_incident_rca_route_slo_rollups",
+)
+LAST_HASH = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_SLO_LAST_HASH",
+    "metrics:ml:operator_routing_incident_rca_route_slo:last",
+)
+AUDIT_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTING_APPLY_AUDIT_STREAM",
+    "stream:ml:operator_routing_incident_rca_routing_apply_audit",
+)
+PORT = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_SLO_PORT", "9896"))
+MAXLEN = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_SLO_MAXLEN", "20000"))
+WINDOW_MIN = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_SLO_WINDOW_MIN", "1440"))
+MTTR_SLO_SEC = float(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_MTTR_SLO_SEC", "900"))
+SUCCESS_RATE_MIN = float(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_SUCCESS_RATE_MIN", "0.85"))
+RUN_EVERY_SEC = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_SLO_RUN_EVERY_SEC", "300"))
+
+
+def _counter(name: str, doc: str, labels: Tuple[str, ...] = ()) -> Any:
+    return Counter(name, doc, labels) if Counter else None
+
+
+def _gauge(name: str, doc: str, labels: Tuple[str, ...] = ()) -> Any:
+    return Gauge(name, doc, labels) if Gauge else None
+
+
+def _hist(name: str, doc: str, labels: Tuple[str, ...] = ()) -> Any:
+    return Histogram(name, doc, labels) if Histogram else None
+
+
+RUNS = _counter(
+    "ml_operator_routing_incident_rca_route_slo_runs_total",
+    "Route SLO analytics runs",
+    ("status",),
+)
+LAT = _hist(
+    "ml_operator_routing_incident_rca_route_slo_latency_seconds",
+    "Route SLO analytics latency seconds",
+)
+UP = _gauge(
+    "ml_operator_routing_incident_rca_route_slo_up",
+    "Route SLO analytics up",
+)
+LAST_RUN_TS = _gauge(
+    "ml_operator_routing_incident_rca_route_slo_last_run_ts_seconds",
+    "Route SLO analytics last run timestamp",
+)
+SUCCESS_RATE = _gauge(
+    "ml_operator_routing_incident_rca_route_success_rate",
+    "Route safety-loop success rate",
+)
+MTTR_P95 = _gauge(
+    "ml_operator_routing_incident_rca_route_mttr_p95_seconds",
+    "Route safety-loop MTTR p95 seconds",
+)
+
+
+def now_ms() -> int:
+    return int(time.time() * 1000)
+
+
+def as_dict(fields: Dict[Any, Any]) -> Dict[str, Any]:
+    out: Dict[str, Any] = {}
+    for k, v in fields.items():
+        kk = k.decode() if isinstance(k, (bytes, bytearray)) else str(k)
+        if isinstance(v, (bytes, bytearray)):
+            try:
+                out[kk] = v.decode()
+            except Exception:
+                out[kk] = v.hex()
+        else:
+            out[kk] = v
+    return out
+
+
+def safe_int(value: Any, default: int = 0) -> int:
+    try:
+        return int(float(value))
+    except Exception:
+        return default
+
+
+def stable_json(obj: Any) -> str:
+    return json.dumps(obj, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
+
+
+async def xr_recent(client: Any, stream_key: str, count: int) -> List[Dict[str, Any]]:
+    try:
+        rows = await client.xrevrange(stream_key, count=count)
+    except Exception:
+        return []
+    out: List[Dict[str, Any]] = []
+    for entry_id, payload in rows:
+        row = as_dict(payload)
+        row["_stream_id"] = entry_id.decode() if isinstance(entry_id, (bytes, bytearray)) else str(entry_id)
+        out.append(row)
+    return out
+
+
+def percentile(values: List[float], q: float) -> float:
+    if not values:
+        return 0.0
+    if len(values) == 1:
+        return float(values[0])
+    k = max(0, min(len(values) - 1, int(round((len(values) - 1) * q))))
+    values_sorted = sorted(values)
+    return float(values_sorted[k])
+
+
+def compute_rollup(verify_rows: List[Dict[str, Any]], rollback_rows: List[Dict[str, Any]]) -> Dict[str, Any]:
+    now = now_ms()
+    window_start = now - WINDOW_MIN * 60 * 1000
+
+    verify_rows = [r for r in verify_rows if safe_int(r.get("ts_ms"), 0) >= window_start]
+    rollback_rows = [r for r in rollback_rows if safe_int(r.get("ts_ms"), 0) >= window_start]
+
+    total = len(verify_rows)
+    success = sum(1 for r in verify_rows if r.get("verification_status") == "PASS")
+    failed = sum(1 for r in verify_rows if r.get("verification_status") == "ROLLBACK_REQUIRED")
+    inconclusive = sum(1 for r in verify_rows if r.get("verification_status") == "INCONCLUSIVE")
+
+    mttr_values: List[float] = []
+    rollback_by_exp: Dict[str, Dict[str, Any]] = {}
+    for r in rollback_rows:
+        exp = r.get("experiment_id", "")
+        if exp and exp not in rollback_by_exp:
+            rollback_by_exp[exp] = r
+
+    for r in verify_rows:
+        if r.get("verification_status") != "ROLLBACK_REQUIRED":
+            continue
+        exp = r.get("experiment_id", "")
+        rb = rollback_by_exp.get(exp)
+        if not rb:
+            continue
+        dt = max(0, safe_int(rb.get("ts_ms"), 0) - safe_int(r.get("ts_ms"), 0))
+        mttr_values.append(dt / 1000.0)
+
+    success_rate = (success / total) if total > 0 else 1.0
+    mttr_p50 = percentile(mttr_values, 0.50)
+    mttr_p95 = percentile(mttr_values, 0.95)
+    breach_n = sum(1 for x in mttr_values if x > MTTR_SLO_SEC)
+
+    reason_codes = []
+    if success_rate < SUCCESS_RATE_MIN:
+        reason_codes.append("ROUTE_SUCCESS_RATE_LOW")
+    if mttr_p95 > MTTR_SLO_SEC:
+        reason_codes.append("ROUTE_MTTR_P95_HIGH")
+        reason_codes.append("ROUTE_MTTR_SLO_BREACH")
+
+    return {
+        "window_min": WINDOW_MIN,
+        "total": total,
+        "success": success,
+        "failed": failed,
+        "inconclusive": inconclusive,
+        "success_rate": round(success_rate, 6),
+        "mttr_p50_sec": round(mttr_p50, 6),
+        "mttr_p95_sec": round(mttr_p95, 6),
+        "breach_n": breach_n,
+        "reason_codes": reason_codes,
+    }
+
+
+async def persist_if_configured(db_url: str, rollup: Dict[str, Any]) -> None:
+    if not db_url or psycopg is None:
+        return
+    with psycopg.connect(db_url) as conn:  # pragma: no cover
+        with conn.cursor() as cur:
+            cur.execute(
+                """
+                INSERT INTO llm_operator_routing_incident_rca_route_slo_rollups (
+                    ts_ms,
+                    window_min,
+                    total,
+                    success,
+                    failed,
+                    inconclusive,
+                    success_rate,
+                    mttr_p50_sec,
+                    mttr_p95_sec,
+                    breach_n,
+                    reason_codes_json
+                ) VALUES (
+                    %(ts_ms)s,
+                    %(window_min)s,
+                    %(total)s,
+                    %(success)s,
+                    %(failed)s,
+                    %(inconclusive)s,
+                    %(success_rate)s,
+                    %(mttr_p50_sec)s,
+                    %(mttr_p95_sec)s,
+                    %(breach_n)s,
+                    %(reason_codes_json)s
+                )
+                """,
+                {
+                    "ts_ms": now_ms(),
+                    "window_min": rollup["window_min"],
+                    "total": rollup["total"],
+                    "success": rollup["success"],
+                    "failed": rollup["failed"],
+                    "inconclusive": rollup["inconclusive"],
+                    "success_rate": rollup["success_rate"],
+                    "mttr_p50_sec": rollup["mttr_p50_sec"],
+                    "mttr_p95_sec": rollup["mttr_p95_sec"],
+                    "breach_n": rollup["breach_n"],
+                    "reason_codes_json": json.dumps(rollup["reason_codes"]),
+                },
+            )
+            conn.commit()
+
+
+async def main() -> None:  # pragma: no cover
+    if redis is None:
+        raise RuntimeError("redis.asyncio is required")
+    start_http_server(PORT)
+    if UP:
+        UP.set(1)
+    r = redis.from_url(os.getenv("REDIS_URL", "redis://localhost:6379/0"))
+    db_url = os.getenv("DATABASE_URL", "")
+    lookback = max(300, WINDOW_MIN * 10)
+
+    while True:
+        started = time.perf_counter()
+        status = "ok"
+        try:
+            verify_rows = await xr_recent(r, VERIFY_RESULTS_STREAM, lookback)
+            rollback_rows = await xr_recent(r, ROLLBACK_RESULTS_STREAM, lookback)
+            rollup = compute_rollup(verify_rows, rollback_rows)
+            await persist_if_configured(db_url, rollup)
+            await r.xadd(
+                OUTPUT_STREAM,
+                {
+                    "schema_version": 1,
+                    "payload_json": stable_json(rollup),
+                    "reason_codes_json": stable_json(rollup["reason_codes"]),
+                    "ts_ms": str(now_ms()),
+                },
+                maxlen=MAXLEN,
+                approximate=True,
+            )
+            await r.hset(
+                LAST_HASH,
+                mapping={
+                    "success_rate": str(rollup["success_rate"]),
+                    "mttr_p50_sec": str(rollup["mttr_p50_sec"]),
+                    "mttr_p95_sec": str(rollup["mttr_p95_sec"]),
+                    "breach_n": str(rollup["breach_n"]),
+                    "reason_codes_json": stable_json(rollup["reason_codes"]),
+                    "ts_ms": str(now_ms()),
+                },
+            )
+            if SUCCESS_RATE:
+                SUCCESS_RATE.set(rollup["success_rate"])
+            if MTTR_P95:
+                MTTR_P95.set(rollup["mttr_p95_sec"])
+            if LAST_RUN_TS:
+                LAST_RUN_TS.set(time.time())
+        except Exception as exc:
+            status = "error"
+            await r.xadd(
+                AUDIT_STREAM,
+                {
+                    "event_type": "ROUTING_INCIDENT_RCA_ROUTE_SLO_FAILED",
+                    "error": str(exc),
+                    "ts_ms": str(now_ms()),
+                },
+                maxlen=MAXLEN,
+                approximate=True,
+            )
+        finally:
+            if RUNS:
+                RUNS.labels(status=status).inc()
+            if LAT:
+                LAT.observe(max(time.perf_counter() - started, 0.0))
+            time.sleep(max(RUN_EVERY_SEC, 5))
+
+
+if __name__ == "__main__":  # pragma: no cover
+    main()
