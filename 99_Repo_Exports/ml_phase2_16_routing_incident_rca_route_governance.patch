+BEGIN;
+
+CREATE TABLE IF NOT EXISTS llm_operator_routing_incident_rca_route_slo_rollups (
+    id               bigserial PRIMARY KEY,
+    ts_ms            bigint NOT NULL,
+    window_min       integer NOT NULL,
+    total            integer NOT NULL,
+    success          integer NOT NULL,
+    failed           integer NOT NULL,
+    inconclusive     integer NOT NULL,
+    success_rate     double precision NOT NULL,
+    mttr_p50_sec     double precision NOT NULL,
+    mttr_p95_sec     double precision NOT NULL,
+    breach_n         integer NOT NULL,
+    reason_codes_json jsonb NOT NULL
+);
+
+CREATE TABLE IF NOT EXISTS llm_operator_routing_incident_rca_route_retry_events (
+    id                       bigserial PRIMARY KEY,
+    experiment_id            text NOT NULL,
+    ts_ms                    bigint NOT NULL,
+    verification_reason_code text NOT NULL,
+    decision                 text NOT NULL,
+    attempts                 integer NOT NULL,
+    backoff_sec              integer NOT NULL,
+    event_json               jsonb NOT NULL
+);
+
+CREATE TABLE IF NOT EXISTS llm_operator_routing_incident_rca_route_escalations (
+    id            bigserial PRIMARY KEY,
+    ts_ms         bigint NOT NULL,
+    severity      text NOT NULL,
+    summary_json  jsonb NOT NULL
+);
+
+CREATE INDEX IF NOT EXISTS idx_llm_operator_routing_incident_rca_route_slo_rollups_ts
+    ON llm_operator_routing_incident_rca_route_slo_rollups(ts_ms DESC);
+
+CREATE INDEX IF NOT EXISTS idx_llm_operator_routing_incident_rca_route_retry_events_exp_ts
+    ON llm_operator_routing_incident_rca_route_retry_events(experiment_id, ts_ms DESC);
+
+CREATE INDEX IF NOT EXISTS idx_llm_operator_routing_incident_rca_route_escalations_ts
+    ON llm_operator_routing_incident_rca_route_escalations(ts_ms DESC);
+
+COMMIT;
