@@ -0,0 +1,47 @@
+# Phase 2.16 — Routing Incident RCA Route SLO/MTTR + Retry/Escalation
+
+## Цель
+Замкнуть полный governance contour для `routing incident RCA` route-safety loop:
+- SLO / MTTR analytics
+- bounded retry
+- auto-escalation summaries
+
+## Потоки
+- SLO rollups: `stream:ml:operator_routing_incident_rca_route_slo_rollups`
+- retry requests: `stream:ml:operator_routing_incident_rca_route_retry_requests`
+- escalations: `stream:ml:operator_routing_incident_rca_route_escalations`
+
+## Safe start
+```bash
+export ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_MTTR_SLO_SEC=900
+export ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_SUCCESS_RATE_MIN=0.85
+export ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_RETRY_MAX_ATTEMPTS=3
+export ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_RETRY_BASE_BACKOFF_SEC=300
+```
+
+## Smoke checks
+```bash
+curl -s localhost:9896/metrics | grep '^ml_operator_routing_incident_rca_route_slo_'
+curl -s localhost:9897/metrics | grep '^ml_operator_routing_incident_rca_route_retry_'
+curl -s localhost:9898/metrics | grep '^ml_operator_routing_incident_rca_route_escalations_'
+redis-cli HGETALL metrics:ml:operator_routing_incident_rca_route_slo:last
+redis-cli XREVRANGE stream:ml:operator_routing_incident_rca_route_retry_requests + - COUNT 5
+redis-cli XREVRANGE stream:ml:operator_routing_incident_rca_route_escalations + - COUNT 5
+```
+
+## Notes
+- scope только `scanner_infra`
+- hot path не затронут
+- retry bounded
+- escalation advisory-only
diff --git a/orderflow_services/tests/test_operator_routing_incident_rca_route_governance_v2_16.py b/orderflow_services/tests/test_operator_routing_incident_rca_route_governance_v2_16.py
new file mode 100644
index 0000000..8888888
--- /dev/null
+++ b/orderflow_services/tests/test_operator_routing_incident_rca_route_governance_v2_16.py
@@ -0,0 +1,60 @@
+from orderflow_services.operator_routing_incident_rca_route_slo_analytics_v2_16 import (
+    compute_rollup,
+)
+from orderflow_services.operator_routing_incident_rca_route_retry_controller_v2_16 import (
+    evaluate_retry,
+)
+from orderflow_services.operator_routing_incident_rca_route_auto_escalation_summarizer_v2_16 import (
+    severity_and_summary,
+)
+
+
+def test_compute_rollup_detects_success_rate_issue():
+    verify_rows = [
+        {"ts_ms": "9999999999999", "experiment_id": "e1", "verification_status": "PASS"},
+        {"ts_ms": "9999999999999", "experiment_id": "e2", "verification_status": "ROLLBACK_REQUIRED"},
+        {"ts_ms": "9999999999999", "experiment_id": "e3", "verification_status": "ROLLBACK_REQUIRED"},
+    ]
+    rollback_rows = []
+    rollup = compute_rollup(verify_rows, rollback_rows)
+    assert rollup["failed"] == 2
+    assert "ROUTE_SUCCESS_RATE_LOW" in rollup["reason_codes"]
+
+
+def test_evaluate_retry_respects_retryable_and_hard_stop():
+    row = {"verification_reason_code": "LOW_EXPOSURE", "retry_attempt": "0"}
+    out = evaluate_retry(row)
+    assert out["decision"] == "RETRY"
+    row2 = {"verification_reason_code": "ROUTING_POLICY_CORRUPTED", "retry_attempt": "0"}
+    out2 = evaluate_retry(row2)
+    assert out2["decision"] == "NO_RETRY"
+    assert out2["reason_code"] == "HARD_STOP"
+
+
+def test_severity_and_summary_critical_on_breach():
+    slo_last = {"reason_codes_json": '["ROUTE_MTTR_SLO_BREACH"]'}
+    verify_rows = [{"verification_status": "ROLLBACK_REQUIRED"}]
+    rollback_rows = [{"status": "FAILED"}, {"status": "FAILED"}, {"status": "FAILED"}]
+    summary = severity_and_summary(slo_last, verify_rows, rollback_rows)
+    assert summary["severity"] == "critical"
+