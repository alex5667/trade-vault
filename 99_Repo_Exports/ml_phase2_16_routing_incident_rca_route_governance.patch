+from __future__ import annotations
+
+import json
+import os
+import time
+from typing import Any, Dict, Tuple
+
+try:  # pragma: no cover
+    import redis.asyncio as redis
+except Exception:  # pragma: no cover
+    redis = None
+
+try:  # pragma: no cover
+    import psycopg
+except Exception:  # pragma: no cover
+    psycopg = None
+
+try:  # pragma: no cover
+    from prometheus_client import Counter, Gauge, Histogram, start_http_server
+except Exception:  # pragma: no cover
+    Counter = Gauge = Histogram = None
+    def start_http_server(*args: Any, **kwargs: Any) -> None:
+        return None
+
+
+APP_NAME = "operator_routing_incident_rca_route_retry_controller_v2_16"
+VERIFY_RESULTS_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTING_VERIFY_RESULTS_STREAM",
+    "stream:ml:operator_routing_incident_rca_routing_verify_results",
+)
+RETRY_REQUESTS_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_RETRY_REQUESTS_STREAM",
+    "stream:ml:operator_routing_incident_rca_route_retry_requests",
+)
+AUDIT_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTING_APPLY_AUDIT_STREAM",
+    "stream:ml:operator_routing_incident_rca_routing_apply_audit",
+)
+LAST_HASH = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_RETRY_LAST_HASH",
+    "metrics:ml:operator_routing_incident_rca_route_retry:last",
+)
+GROUP = os.getenv("ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_RETRY_GROUP", APP_NAME)
+CONSUMER = os.getenv("HOSTNAME", APP_NAME)
+PORT = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_RETRY_PORT", "9897"))
+MAXLEN = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_RETRY_MAXLEN", "20000"))
+MAX_ATTEMPTS = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_RETRY_MAX_ATTEMPTS", "3"))
+BASE_BACKOFF_SEC = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_RETRY_BASE_BACKOFF_SEC", "300"))
+MAX_BACKOFF_SEC = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_RETRY_MAX_BACKOFF_SEC", "3600"))
+
+RETRYABLE = {
+    "LOW_EXPOSURE",
+    "FEEDBACK_STALE",
+    "ROUTE_MISMATCH",
+}
+HARD_STOP = {
+    "BASELINE_ROUTE_MISSING",
+    "ROUTING_POLICY_CORRUPTED",
+}
+
+
+def _counter(name: str, doc: str, labels: Tuple[str, ...] = ()) -> Any:
+    return Counter(name, doc, labels) if Counter else None
+
+
+def _gauge(name: str, doc: str, labels: Tuple[str, ...] = ()) -> Any:
+    return Gauge(name, doc, labels) if Gauge else None
+
+
+def _hist(name: str, doc: str, labels: Tuple[str, ...] = ()) -> Any:
+    return Histogram(name, doc, labels) if Histogram else None
+
+
+RUNS = _counter(
+    "ml_operator_routing_incident_rca_route_retry_runs_total",
+    "Route retry controller runs",
+    ("status", "decision"),
+)
+LAT = _hist(
+    "ml_operator_routing_incident_rca_route_retry_latency_seconds",
+    "Route retry controller latency seconds",
+)
+UP = _gauge(
+    "ml_operator_routing_incident_rca_route_retry_up",
+    "Route retry controller up",
+)
+LAST_RUN_TS = _gauge(
+    "ml_operator_routing_incident_rca_route_retry_last_run_ts_seconds",
+    "Route retry controller last run timestamp",
+)
+
+
+def now_ms() -> int:
+    return int(time.time() * 1000)
+
+
+def as_dict(fields: Dict[Any, Any]) -> Dict[str, Any]:
+    out: Dict[str, Any] = {}
+    for k, v in fields.items():
+        kk = k.decode() if isinstance(k, (bytes, bytearray)) else str(k)
+        if isinstance(v, (bytes, bytearray)):
+            try:
+                out[kk] = v.decode()
+            except Exception:
+                out[kk] = v.hex()
+        else:
+            out[kk] = v
+    return out
+
+
+def safe_int(value: Any, default: int = 0) -> int:
+    try:
+        return int(float(value))
+    except Exception:
+        return default
+
+
+def stable_json(obj: Any) -> str:
+    return json.dumps(obj, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
+
+
+async def ensure_group(client: Any, stream_key: str, group: str) -> None:
+    try:
+        await client.xgroup_create(stream_key, group, id="$", mkstream=True)
+    except Exception:
+        return
+
+
+def evaluate_retry(row: Dict[str, Any]) -> Dict[str, Any]:
+    reason = str(row.get("verification_reason_code", ""))
+    attempts = safe_int(row.get("retry_attempt"), 0)
+    if reason in HARD_STOP:
+        return {"decision": "NO_RETRY", "reason_code": "HARD_STOP", "attempts": attempts}
+    if reason not in RETRYABLE:
+        return {"decision": "NO_RETRY", "reason_code": "NOT_RETRYABLE", "attempts": attempts}
+    if attempts >= MAX_ATTEMPTS:
+        return {"decision": "NO_RETRY", "reason_code": "MAX_ATTEMPTS_REACHED", "attempts": attempts}
+    backoff = min(MAX_BACKOFF_SEC, BASE_BACKOFF_SEC * max(1, 2 ** attempts))
+    return {
+        "decision": "RETRY",
+        "reason_code": "RETRY_SCHEDULED",
+        "attempts": attempts + 1,
+        "backoff_sec": backoff,
+    }
+
+
+async def persist_if_configured(db_url: str, row: Dict[str, Any], evaluation: Dict[str, Any]) -> None:
+    if not db_url or psycopg is None:
+        return
+    with psycopg.connect(db_url) as conn:  # pragma: no cover
+        with conn.cursor() as cur:
+            cur.execute(
+                """
+                INSERT INTO llm_operator_routing_incident_rca_route_retry_events (
+                    experiment_id,
+                    ts_ms,
+                    verification_reason_code,
+                    decision,
+                    attempts,
+                    backoff_sec,
+                    event_json
+                ) VALUES (
+                    %(experiment_id)s,
+                    %(ts_ms)s,
+                    %(verification_reason_code)s,
+                    %(decision)s,
+                    %(attempts)s,
+                    %(backoff_sec)s,
+                    %(event_json)s
+                )
+                """,
+                {
+                    "experiment_id": row.get("experiment_id", ""),
+                    "ts_ms": now_ms(),
+                    "verification_reason_code": row.get("verification_reason_code", ""),
+                    "decision": evaluation["decision"],
+                    "attempts": evaluation["attempts"],
+                    "backoff_sec": evaluation.get("backoff_sec", 0),
+                    "event_json": json.dumps({"row": row, "evaluation": evaluation}),
+                },
+            )
+            conn.commit()
+
+
+async def main() -> None:  # pragma: no cover
+    if redis is None:
+        raise RuntimeError("redis.asyncio is required")
+    start_http_server(PORT)
+    if UP:
+        UP.set(1)
+    r = redis.from_url(os.getenv("REDIS_URL", "redis://localhost:6379/0"))
+    await ensure_group(r, VERIFY_RESULTS_STREAM, GROUP)
+    db_url = os.getenv("DATABASE_URL", "")
+
+    while True:
+        rows = await r.xreadgroup(GROUP, CONSUMER, {VERIFY_RESULTS_STREAM: ">"}, count=32, block=5000)
+        if not rows:
+            continue
+        for _stream, messages in rows:
+            for msg_id, payload in messages:
+                started = time.perf_counter()
+                status = "ok"
+                decision_label = "NO_RETRY"
+                try:
+                    row = as_dict(payload)
+                    evaluation = evaluate_retry(row)
+                    decision_label = evaluation["decision"]
+                    await persist_if_configured(db_url, row, evaluation)
+                    if evaluation["decision"] == "RETRY":
+                        retry_payload = {
+                            "schema_version": 1,
+                            "experiment_id": row.get("experiment_id", ""),
+                            "retry_attempt": str(evaluation["attempts"]),
+                            "verification_reason_code": row.get("verification_reason_code", ""),
+                            "retry_after_ts_ms": str(now_ms() + evaluation["backoff_sec"] * 1000),
+                            "baseline_route_json": row.get("baseline_route_json", "{}"),
+                            "target_route_json": row.get("target_route_json", "{}"),
+                            "ts_ms": str(now_ms()),
+                        }
+                        await r.xadd(RETRY_REQUESTS_STREAM, retry_payload, maxlen=MAXLEN, approximate=True)
+                    await r.xadd(
+                        AUDIT_STREAM,
+                        {
+                            "event_type": "ROUTING_INCIDENT_RCA_ROUTE_RETRY_EVALUATED",
+                            "experiment_id": row.get("experiment_id", ""),
+                            "decision": evaluation["decision"],
+                            "reason_code": evaluation["reason_code"],
+                            "attempts": str(evaluation["attempts"]),
+                            "ts_ms": str(now_ms()),
+                        },
+                        maxlen=MAXLEN,
+                        approximate=True,
+                    )
+                    await r.hset(
+                        LAST_HASH,
+                        mapping={
+                            "decision": evaluation["decision"],
+                            "reason_code": evaluation["reason_code"],
+                            "attempts": str(evaluation["attempts"]),
+                            "ts_ms": str(now_ms()),
+                        },
+                    )
+                    await r.xack(VERIFY_RESULTS_STREAM, GROUP, msg_id)
+                    if LAST_RUN_TS:
+                        LAST_RUN_TS.set(time.time())
+                except Exception as exc:
+                    status = "error"
+                    await r.xadd(
+                        AUDIT_STREAM,
+                        {
+                            "event_type": "ROUTING_INCIDENT_RCA_ROUTE_RETRY_FAILED",
+                            "error": str(exc),
+                            "ts_ms": str(now_ms()),
+                        },
+                        maxlen=MAXLEN,
+                        approximate=True,
+                    )
+                    await r.xack(VERIFY_RESULTS_STREAM, GROUP, msg_id)
+                finally:
+                    if RUNS:
+                        RUNS.labels(status=status, decision=decision_label).inc()
+                    if LAT:
+                        LAT.observe(max(time.perf_counter() - started, 0.0))
+
+
+if __name__ == "__main__":  # pragma: no cover
+    import asyncio
+    asyncio.run(main())
diff --git a/orderflow_services/operator_routing_incident_rca_route_auto_escalation_summarizer_v2_16.py b/orderflow_services/operator_routing_incident_rca_route_auto_escalation_summarizer_v2_16.py
new file mode 100644
index 0000000..3333333
--- /dev/null
+++ b/orderflow_services/operator_routing_incident_rca_route_auto_escalation_summarizer_v2_16.py
@@ -0,0 +1,323 @@
+from __future__ import annotations
+
+import json
+import os
+import time
+from typing import Any, Dict, List, Tuple
+
+try:  # pragma: no cover
+    import redis.asyncio as redis
+except Exception:  # pragma: no cover
+    redis = None
+
+try:  # pragma: no cover
+    import psycopg
+except Exception:  # pragma: no cover
+    psycopg = None
+
+try:  # pragma: no cover
+    from prometheus_client import Counter, Gauge, Histogram, start_http_server
+except Exception:  # pragma: no cover
+    Counter = Gauge = Histogram = None
+    def start_http_server(*args: Any, **kwargs: Any) -> None:
+        return None
+
+
+APP_NAME = "operator_routing_incident_rca_route_auto_escalation_summarizer_v2_16"
+SLO_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_SLO_ROLLUPS_STREAM",
+    "stream:ml:operator_routing_incident_rca_route_slo_rollups",
+)
+VERIFY_RESULTS_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTING_VERIFY_RESULTS_STREAM",
+    "stream:ml:operator_routing_incident_rca_routing_verify_results",
+)
+ROLLBACK_RESULTS_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTING_ROLLBACK_RESULTS_STREAM",
+    "stream:ml:operator_routing_incident_rca_routing_rollback_results",
+)
+OUTPUT_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_ESCALATIONS_STREAM",
+    "stream:ml:operator_routing_incident_rca_route_escalations",
+)
+LAST_HASH = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_ESCALATIONS_LAST_HASH",
+    "metrics:ml:operator_routing_incident_rca_route_escalations:last",
+)
+AUDIT_STREAM = os.getenv(
+    "ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTING_APPLY_AUDIT_STREAM",
+    "stream:ml:operator_routing_incident_rca_routing_apply_audit",
+)
+PORT = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_ESCALATIONS_PORT", "9898"))
+MAXLEN = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_ESCALATIONS_MAXLEN", "20000"))
+RUN_EVERY_SEC = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_ESCALATIONS_RUN_EVERY_SEC", "300"))
+ESCALATION_FAILED_MIN = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_ESCALATION_FAILED_MIN", "3"))
+ESCALATION_MANUAL_MIN = int(os.getenv("ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_ESCALATION_MANUAL_MIN", "2"))
+
+
+def _counter(name: str, doc: str, labels: Tuple[str, ...] = ()) -> Any:
+    return Counter(name, doc, labels) if Counter else None
+
+
+def _gauge(name: str, doc: str, labels: Tuple[str, ...] = ()) -> Any:
+    return Gauge(name, doc, labels) if Gauge else None
+
+
+def _hist(name: str, doc: str, labels: Tuple[str, ...] = ()) -> Any:
+    return Histogram(name, doc, labels) if Histogram else None
+
+
+RUNS = _counter(
+    "ml_operator_routing_incident_rca_route_escalations_runs_total",
+    "Route escalation summarizer runs",
+    ("status", "severity"),
+)
+LAT = _hist(
+    "ml_operator_routing_incident_rca_route_escalations_latency_seconds",
+    "Route escalation summarizer latency seconds",
+)
+UP = _gauge(
+    "ml_operator_routing_incident_rca_route_escalations_up",
+    "Route escalation summarizer up",
+)
+LAST_RUN_TS = _gauge(
+    "ml_operator_routing_incident_rca_route_escalations_last_run_ts_seconds",
+    "Route escalation summarizer last run timestamp",
+)
+
+
+def now_ms() -> int:
+    return int(time.time() * 1000)
+
+
+def as_dict(fields: Dict[Any, Any]) -> Dict[str, Any]:
+    out: Dict[str, Any] = {}
+    for k, v in fields.items():
+        kk = k.decode() if isinstance(k, (bytes, bytearray)) else str(k)
+        if isinstance(v, (bytes, bytearray)):
+            try:
+                out[kk] = v.decode()
+            except Exception:
+                out[kk] = v.hex()
+        else:
+            out[kk] = v
+    return out
+
+
+def safe_int(value: Any, default: int = 0) -> int:
+    try:
+        return int(float(value))
+    except Exception:
+        return default
+
+
+def stable_json(obj: Any) -> str:
+    return json.dumps(obj, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
+
+
+async def xr_recent(client: Any, stream_key: str, count: int) -> List[Dict[str, Any]]:
+    try:
+        rows = await client.xrevrange(stream_key, count=count)
+    except Exception:
+        return []
+    out: List[Dict[str, Any]] = []
+    for entry_id, payload in rows:
+        row = as_dict(payload)
+        row["_stream_id"] = entry_id.decode() if isinstance(entry_id, (bytes, bytearray)) else str(entry_id)
+        out.append(row)
+    return out
+
+
+def severity_and_summary(slo_last: Dict[str, Any], verify_rows: List[Dict[str, Any]], rollback_rows: List[Dict[str, Any]]) -> Dict[str, Any]:
+    reason_codes = json.loads(slo_last.get("reason_codes_json", "[]") or "[]")
+    rollback_required_n = sum(1 for r in verify_rows if r.get("verification_status") == "ROLLBACK_REQUIRED")
+    inconclusive_n = sum(1 for r in verify_rows if r.get("verification_status") == "INCONCLUSIVE")
+    rolled_back_n = sum(1 for r in rollback_rows if r.get("status") == "ROLLED_BACK")
+    failed_n = sum(1 for r in rollback_rows if r.get("status") not in {"ROLLED_BACK", "INCONCLUSIVE"})
+
+    severity = "info"
+    if failed_n >= ESCALATION_FAILED_MIN or "ROUTE_MTTR_SLO_BREACH" in reason_codes:
+        severity = "critical"
+    elif inconclusive_n >= ESCALATION_MANUAL_MIN or "ROUTE_SUCCESS_RATE_LOW" in reason_codes:
+        severity = "warning"
+
+    summary = {
+        "severity": severity,
+        "rollback_required_n": rollback_required_n,
+        "inconclusive_n": inconclusive_n,
+        "rolled_back_n": rolled_back_n,
+        "failed_n": failed_n,
+        "slo_reason_codes": reason_codes,
+    }
+    return summary
+
+
+async def persist_if_configured(db_url: str, summary: Dict[str, Any]) -> None:
+    if not db_url or psycopg is None:
+        return
+    with psycopg.connect(db_url) as conn:  # pragma: no cover
+        with conn.cursor() as cur:
+            cur.execute(
+                """
+                INSERT INTO llm_operator_routing_incident_rca_route_escalations (
+                    ts_ms,
+                    severity,
+                    summary_json
+                ) VALUES (
+                    %(ts_ms)s,
+                    %(severity)s,
+                    %(summary_json)s
+                )
+                """,
+                {
+                    "ts_ms": now_ms(),
+                    "severity": summary["severity"],
+                    "summary_json": json.dumps(summary),
+                },
+            )
+            conn.commit()
+
+
+async def main() -> None:  # pragma: no cover
+    if redis is None:
+        raise RuntimeError("redis.asyncio is required")
+    start_http_server(PORT)
+    if UP:
+        UP.set(1)
+    r = redis.from_url(os.getenv("REDIS_URL", "redis://localhost:6379/0"))
+    db_url = os.getenv("DATABASE_URL", "")
+
+    while True:
+        started = time.perf_counter()
+        status = "ok"
+        severity = "info"
+        try:
+            slo_last_raw = await r.hgetall(os.getenv(
+                "ML_OPERATOR_ROUTING_INCIDENT_RCA_ROUTE_SLO_LAST_HASH",
+                "metrics:ml:operator_routing_incident_rca_route_slo:last",
+            ))
+            slo_last = as_dict(slo_last_raw)
+            verify_rows = await xr_recent(r, VERIFY_RESULTS_STREAM, 200)
+            rollback_rows = await xr_recent(r, ROLLBACK_RESULTS_STREAM, 200)
+            summary = severity_and_summary(slo_last, verify_rows, rollback_rows)
+            severity = summary["severity"]
+            await persist_if_configured(db_url, summary)
+            await r.xadd(
+                OUTPUT_STREAM,
+                {
+                    "schema_version": 1,
+                    "severity": severity,
+                    "summary_json": stable_json(summary),
+                    "ts_ms": str(now_ms()),
+                },
+                maxlen=MAXLEN,
+                approximate=True,
+            )
+            await r.hset(
+                LAST_HASH,
+                mapping={
+                    "severity": severity,
+                    "summary_json": stable_json(summary),
+                    "ts_ms": str(now_ms()),
+                },
+            )
+            await r.xadd(
+                AUDIT_STREAM,
+                {
+                    "event_type": "ROUTING_INCIDENT_RCA_ROUTE_ESCALATION_SUMMARY",
+                    "severity": severity,
+                    "ts_ms": str(now_ms()),
+                },
+                maxlen=MAXLEN,
+                approximate=True,
+            )
+            if LAST_RUN_TS:
+                LAST_RUN_TS.set(time.time())
+        except Exception as exc:
+            status = "error"
+            await r.xadd(
+                AUDIT_STREAM,
+                {
+                    "event_type": "ROUTING_INCIDENT_RCA_ROUTE_ESCALATION_FAILED",
+                    "error": str(exc),
+                    "ts_ms": str(now_ms()),
+                },
+                maxlen=MAXLEN,
+                approximate=True,
+            )
+        finally:
+            if RUNS:
+                RUNS.labels(status=status, severity=severity).inc()
+            if LAT:
+                LAT.observe(max(time.perf_counter() - started, 0.0))
+            time.sleep(max(RUN_EVERY_SEC, 5))
+
+
+if __name__ == "__main__":  # pragma: no cover
+    main()
