++def _z_ts(hist: Deque[float], x: float) -> float:
++    xs = list(hist)
++    if len(xs) < 30:
++        return 0.0
++    mu = sum(xs) / float(len(xs))
++    var = sum((v - mu) * (v - mu) for v in xs) / float(max(1, len(xs) - 1))
++    sd = math.sqrt(var) if var > 1e-12 else 0.0
++    if sd <= 0:
++        return 0.0
++    return float((x - mu) / sd)
