+from __future__ import annotations
+
+import json
+import math
+from dataclasses import dataclass
+from typing import Any, Dict, Optional, Tuple
+
+
+@dataclass
+class NewsBlock:
+    blocked: bool
+    reason: str
+    until_ts_ms: int
+    meta: Dict[str, Any]
+
+
+def _i(x: Any, d: int = 0) -> int:
+    try:
+        return int(x)
+    except Exception:
+        return d
+
+
+def _f(x: Any, d: float = 0.0) -> float:
+    try:
+        v = float(x)
+        return v if math.isfinite(v) else d
+    except Exception:
+        return d
+
+
+class NewsGate:
+    """
+    Redis-based high-impact news gate.
+
+    Sources (in order):
+      1) Manual JSON key with TTL:
+         news:hi:active -> {"active":1, "until_ts_ms":..., "reason":"CPI", "symbols":[...]}
+      2) Calendar aggregated hash:
+         calendar:agg:<asset_class> -> fields:
+           event_grade_id, event_tminus_sec, event_ts_ms, title/event_id
+
+    Determinism:
+      - caller must pass now_ts_ms (event time), not wall-time.
+    """
+
+    def __init__(
+        self,
+        *,
+        redis_client: Any,
+        asset_class: str = "crypto",
+        window_sec: int = 300,
+        grade_min: int = 4,
+        manual_key: str = "news:hi:active",
+        cal_agg_prefix: str = "calendar:agg:",
+    ) -> None:
+        self.redis = redis_client
+        self.asset_class = str(asset_class)
+        self.window_sec = int(window_sec)
+        self.grade_min = int(grade_min)
+        self.manual_key = str(manual_key)
+        self.cal_key = f"{str(cal_agg_prefix)}{self.asset_class}"
+
+    def _manual(self, now_ts_ms: int, symbols: Optional[Tuple[str, ...]] = None) -> Optional[NewsBlock]:
+        try:
+            raw = self.redis.get(self.manual_key)
+            if not raw:
+                return None
+            d = json.loads(raw)
+            active = int(d.get("active", 0) or 0)
+            if active != 1:
+                return None
+            until_ts_ms = _i(d.get("until_ts_ms", 0), 0)
+            if until_ts_ms <= 0 or now_ts_ms <= 0:
+                return None
+            if now_ts_ms >= until_ts_ms:
+                return None
+            if symbols:
+                allow = d.get("symbols")
+                if isinstance(allow, list) and allow:
+                    allow_u = {str(x).upper() for x in allow}
+                    if not any(str(s).upper() in allow_u for s in symbols):
+                        return None
+            reason = str(d.get("reason", "manual_hi_impact") or "manual_hi_impact")
+            meta = {"src": "manual", "reason": reason}
+            return NewsBlock(blocked=True, reason=reason, until_ts_ms=until_ts_ms, meta=meta)
+        except Exception:
+            return None
+
+    def _calendar(self, now_ts_ms: int) -> Optional[NewsBlock]:
+        try:
+            d = self.redis.hgetall(self.cal_key) or {}
+            if not isinstance(d, dict) or not d:
+                return None
+            grade = _i(d.get("event_grade_id", 0), 0)
+            if grade < self.grade_min:
+                return None
+            tminus = _f(d.get("event_tminus_sec", 1e9), 1e9)
+            if abs(tminus) > float(self.window_sec):
+                return None
+            event_ts_ms = _i(d.get("event_ts_ms", 0), 0)
+            if event_ts_ms <= 0:
+                event_ts_ms = int(now_ts_ms + tminus * 1000.0)
+            until_ts_ms = int(event_ts_ms + self.window_sec * 1000)
+            if now_ts_ms >= until_ts_ms:
+                return None
+            title = str(d.get("title", "") or d.get("event_title", "") or "")
+            ev_id = str(d.get("event_id", "") or "")
+            meta = {"src": "calendar:agg", "grade": grade, "tminus_sec": float(tminus), "title": title, "event_id": ev_id}
+            return NewsBlock(blocked=True, reason="calendar_hi_impact", until_ts_ms=until_ts_ms, meta=meta)
+        except Exception:
+            return None
+
+    def check(self, *, now_ts_ms: int, symbols: Optional[Tuple[str, ...]] = None) -> NewsBlock:
+        if now_ts_ms <= 0:
+            return NewsBlock(blocked=False, reason="no_ts", until_ts_ms=0, meta={})
+        m = self._manual(now_ts_ms, symbols=symbols)
+        if m is not None:
+            return m
+        c = self._calendar(now_ts_ms)
+        if c is not None:
+            return c
+        return NewsBlock(blocked=False, reason="ok", until_ts_ms=0, meta={})
