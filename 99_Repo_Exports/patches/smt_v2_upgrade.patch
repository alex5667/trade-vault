+import redis.asyncio as aioredis
+
+
+def _now_ms() -> int:
+    return int(time.time() * 1000)
+
+
+def _i(x: Any, d: int = 0) -> int:
+    try:
+        return int(x)
+    except Exception:
+        return d
+
+
+def _b(x: Any) -> bool:
+    try:
+        return int(x) == 1
+    except Exception:
+        return False
+
+
+@dataclass
+class Setup:
+    bundle: str
+    kind: str
+    leader: str
+    pick: str
+    trend_dir: str
+    ts_ms: int
+    ttl_ms: int
+
+
+class SmtEntryCandidateService:
+    """
+    Reads stream:smt:setup and emits stream:trade:entry_candidate only after proxy retest+of_confirm:
+      of_strong == 1 AND (zone_ok OR near_zone OR abs_lvl_ok)
+    Tighten later by adding real retest FSM if you expose zone_dist/zone_id in smt:snap.
+    """
+
+    def __init__(self) -> None:
+        self.redis_url = os.getenv("REDIS_URL", "redis://redis-worker-1:6379/0")
+        self.r: aioredis.Redis = aioredis.from_url(self.redis_url, decode_responses=True)
+        self.in_stream = os.getenv("SMT_SETUP_STREAM", "stream:smt:setup")
+        self.out_stream = os.getenv("SMT_ENTRY_STREAM", "stream:trade:entry_candidate")
+        self.group = os.getenv("SMT_ENTRY_GROUP", "smt-entry")
+        self.consumer = os.getenv("SMT_ENTRY_CONSUMER", "c1")
+        self.snap_prefix = os.getenv("SMT_SNAP_PREFIX", "smt:snap:")
+        self.setup_ttl_ms = int(os.getenv("SMT_SETUP_TTL_MS", "120000"))
+        self.poll_ms = int(os.getenv("SMT_ENTRY_POLL_MS", "250"))
+
+    async def _ensure_group(self) -> None:
+        try:
+            await self.r.xgroup_create(self.in_stream, self.group, id="0", mkstream=True)
+        except Exception:
+            pass
+
+    def _parse_setup(self, payload: Dict[str, Any]) -> Optional[Setup]:
+        try:
+            p_raw = payload.get("payload")
+            if not p_raw:
+                return None
+            p = json.loads(p_raw) if isinstance(p_raw, str) else (p_raw if isinstance(p_raw, dict) else {})
+            kind = str(p.get("kind", "") or "")
+            pick = str(p.get("pick", "") or "")
+            if kind not in ("continuation", "reversal") or not pick:
+                return None
+            return Setup(
+                bundle=str(payload.get("bundle", "") or ""),
+                kind=kind,
+                leader=str(p.get("leader", "") or ""),
+                pick=pick,
+                trend_dir=str(p.get("trend_dir", "") or ""),
+                ts_ms=_i(p.get("ts_ms", 0), 0),
+                ttl_ms=self.setup_ttl_ms,
+            )
+        except Exception:
+            return None
+
+    async def _latest_snap(self, sym: str) -> Dict[str, Any]:
+        try:
+            raw = await self.r.get(f"{self.snap_prefix}{sym}")
+            if not raw:
+                return {}
+            return json.loads(raw)
+        except Exception:
+            return {}
+
+    async def run_forever(self) -> None:
+        await self._ensure_group()
+        while True:
+            try:
+                msgs = await self.r.xreadgroup(self.group, self.consumer, streams={self.in_stream: ">"}, count=50, block=1000)
+            except Exception:
+                await asyncio.sleep(0.5)
+                continue
+            if not msgs:
+                await asyncio.sleep(self.poll_ms / 1000.0)
+                continue
+            for _stream, entries in msgs:
+                for msg_id, fields in entries:
+                    setup = self._parse_setup(fields)
+                    try:
+                        if setup is None:
+                            await self.r.xack(self.in_stream, self.group, msg_id)
+                            continue
+                        now = _now_ms()
+                        if setup.ts_ms <= 0 or now - setup.ts_ms > setup.ttl_ms:
+                            await self.r.xack(self.in_stream, self.group, msg_id)
+                            continue
+                        snap = await self._latest_snap(setup.pick)
+                        of_strong = _b(snap.get("of_strong", 0))
+                        zone_ok = _b(snap.get("zone_ok", 0)) or _b(snap.get("near_zone", 0)) or _b(snap.get("abs_lvl_ok", 0))
+                        if of_strong and zone_ok:
+                            out = {
+                                "type": "entry_candidate",
+                                "ts_ms": str(now),
+                                "symbol": setup.pick,
+                                "setup_kind": setup.kind,
+                                "bundle": setup.bundle,
+                                "leader": setup.leader,
+                                "setup_ts_ms": str(setup.ts_ms),
+                                "payload": json.dumps({"setup": setup.__dict__, "snap": snap}, ensure_ascii=False, separators=(",", ":")),
+                            }
+                            await self.r.xadd(self.out_stream, out, maxlen=20000, approximate=True)
+                        await self.r.xack(self.in_stream, self.group, msg_id)
+                    except Exception:
+                        try:
+                            await self.r.xack(self.in_stream, self.group, msg_id)
+                        except Exception:
+                            pass
+
+
+async def _amain() -> None:
+    svc = SmtEntryCandidateService()
+    await svc.run_forever()
+
+
+if __name__ == "__main__":
+    asyncio.run(_amain())
