ly comes from tick side or aggression.":[53,53],"#Adding side to tick":[54,70],"#Adding side to tick#{1}":[55,70],"#1) Validation":[71,76],"#1) Validation#{1}":[72,76],"#2) Tick time policy (must be first: protects downstream detectors)":[77,84],"#2) Tick time policy (must be first: protects downstream detectors)#{1}":[78,84],"#3) Parse remaining tick fields":[85,93],"#3) Parse remaining tick fields#{1}":[86,93],"#4) Context update":[94,98],"#4) Context update#{1}":[95,98],"#P68: build effective cfg (static + dynamic) and apply circuit breaker overrides early.":[99,106],"#P68: build effective cfg (static + dynamic) and apply circuit breaker overrides early.#{1}":[100,106],"#------------------------------------------------------------------":[107,107],"#P68: Determine policy regime. Prefer local indicator states, fallback to dynamic cfg.":[108,108],"#------------------------------------------------------------------[2]":[109,114],"#------------------------------------------------------------------[2]#{1}":[110,114],"#1. Raw mode calculation (P68)":[115,117],"#1. Raw mode calculation (P68)#{1}":[116,117],"#2. Hysteresis check (P69)":[118,118],"#FORCE string to avoid \"Invalid input of type\" error in Redis":[119,121],"#FORCE string to avoid \"Invalid input of type\" error in Redis#{1}":[120,121],"#Need to await? Yes, update is async due to Redis state fetch":[122,124],"#Need to await? Yes, update is async due to Redis state fetch#{1}":[123,124],"#3. Construct EFFECTIVE decision object":[125,127],"#3. Construct EFFECTIVE decision object#{1}":[126,127],"#4. Apply overrides based on EFFECTIVE mode":[128,130],"#4. Apply overrides based on EFFECTIVE mode#{1}":[129,130],"#Apply overrides into effective cfg used by downstream logic":[131,133],"#Apply overrides into effective cfg used by downstream logic#{1}":[132,133],"#Record policy fields for decision record / auditing":[134,136],"#Record policy fields for decision record / auditing#{1}":[135,136],"#P69 enrichment":[137,144],"#P69 enrichment#{1}":[138,144],"#fail-open: do not break tick processing":[145,147],"#fail-open: do not break tick processing#{1}":[146,147],"#--- Delta Detection ---":[148,155],"#--- Delta Detection ---#{1}":[149,155],"#Usually means no significant delta spike":[156,156],"#We return None early unless we are in a mode that processes every tick for continuous metrics":[157,157],"#But the strategy logic relies on delta_event being present for signal generation.":[158,158],"#We check if we should continue anyway (e.g. for pure metrics update?)":[159,159],"#No, standard strategy returns None if no delta spike.":[160,162],"#No, standard strategy returns None if no delta spike.#{1}":[161,162],"#------------------------------------------------------------------[3]":[163,163],"#Authoritative DeltaNotional Tier Gating":[164,164],"#------------------------------------------------------------------[4]":[165,221],"#------------------------------------------------------------------[4]#{1}":[166,221]},"outlinks":[],"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"99_Repo_Exports/test_output.txt"},
