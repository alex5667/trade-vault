ower perf at N<500)":[49,52],"#Without cupy: automatic CPU numpy fallback (no errors, lower perf at N<500)#{1}":[50,52],"#GPU-accelerated ML training (Tier-3 nightly train speedup: 10-100x over sklearn)":[53,53],"#xgboost auto-detects CUDA via device='cuda'; CPU fallback if no GPU":[54,55],"#xgboost auto-detects CUDA via device='cuda'; CPU fallback if no GPU#{1}":[55,55],"#LightGBM for ML Scorer V2 (train_ml_scorer.py) — CPU-only, GBDT regressor":[56,57],"#LightGBM for ML Scorer V2 (train_ml_scorer.py) — CPU-only, GBDT regressor#{1}":[57,57],"#cuML (RAPIDS) for GPU Ridge/Scaler — install separately via conda/pip for CUDA env:":[58,58],"#pip install cuml-cu12 --extra-index-url=https://pypi.anaconda.org/rapidsai-nightly/simple":[59,62],"#pip install cuml-cu12 --extra-index-url=https://pypi.anaconda.org/rapidsai-nightly/simple#{1}":[61,62]},"outlinks":[],"task_lines":[],"tasks":{},"codeblock_ranges":[],"key":"99_Repo_Exports/python-worker/requirements.txt"},
